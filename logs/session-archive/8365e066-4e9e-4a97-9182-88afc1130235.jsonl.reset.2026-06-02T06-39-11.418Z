 \"actions\": []\n  },\n  {\n    \"id\": \"INC-024\",\n    \"title\": \"Rate limit exhaustion \\u2014 29 429 errors in gateway log\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-22T03:03:50.000Z\",\n    \"lastActivity\": \"2026-05-22T03:03:50.000Z\",\n    \"summary\": \"Gateway log shows 29 rate limit (429) errors. Free model pool may be exhausted.\",\n    \"tags\": [\n      \"rate-limit\",\n      \"429\",\n      \"models\",\n      \"rate-monitor\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-22T03:03:50.000Z\",\n        \"message\": \"Auto-detected by rate-monitor\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-023\",\n    \"title\": \"Rate limit exhaustion \\u2014 28 429 errors in gateway log\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-22T01:33:43.000Z\",\n    \"lastActivity\": \"2026-05-22T01:33:43.000Z\",\n    \"summary\": \"Gateway log shows 28 rate limit (429) errors. Free model pool may be exhausted.\",\n    \"tags\": [\n      \"rate-limit\",\n      \"429\",\n      \"models\",\n      \"rate-monitor\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-22T01:33:43.000Z\",\n        \"message\": \"Auto-detected by rate-monitor\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-022\",\n    \"title\": \"Rate limit exhaustion \\u2014 25 429 errors in gateway log\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-22T01:03:41.000Z\",\n    \"lastActivity\": \"2026-05-22T01:03:41.000Z\",\n    \"summary\": \"Gateway log shows 25 rate limit (429) errors. Free model pool may be exhausted.\",\n    \"tags\": [\n      \"rate-limit\",\n      \"429\",\n      \"models\",\n      \"rate-monitor\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-22T01:03:41.000Z\",\n        \"message\": \"Auto-detected by rate-monitor\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-021\",\n    \"title\": \"Rate limit exhaustion \\u2014 16 429 errors in gateway log\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-22T00:45:20.000Z\",\n    \"lastActivity\": \"2026-05-22T00:45:20.000Z\",\n    \"summary\": \"Gateway log shows 16 rate limit (429) errors. Free model pool may be exhausted.\",\n    \"tags\": [\n      \"rate-limit\",\n      \"429\",\n      \"models\",\n      \"rate-monitor\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-22T00:45:20.000Z\",\n        \"message\": \"Auto-detected by rate-monitor\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-020\",\n    \"title\": \"Gateway session errors \\u2014 2 session(s) with EmbeddedAttemptSessionTakeoverError\",\n    \"severity\": \"P1\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-22T00:45:20.000Z\",\n    \"lastActivity\": \"2026-05-22T00:45:20.000Z\",\n    \"summary\": \"Detected 2 session files with takeover errors in the last hour. Gateway may be in a crash loop.\",\n    \"tags\": [\n      \"gateway\",\n      \"crash-loop\",\n      \"session-takeover\",\n      \"gateway-monitor\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-22T00:45:20.000Z\",\n        \"message\": \"Auto-detected by gateway-monitor\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-019\",\n    \"title\": \"Cron job failures \\u2014 8 active errors detected\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-22T00:45:19.000Z\",\n    \"lastActivity\": \"2026-05-22T00:45:19.000Z\",\n    \"summary\": \"cron-errors.json shows 8 active error entries. Multiple cron jobs are failing.\",\n    \"tags\": [\n      \"cron\",\n      \"failures\",\n      \"cron-monitor\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-22T00:45:19.000Z\",\n        \"message\": \"Auto-detected by cron-monitor\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-018\",\n    \"title\": \"Operational consolidation \\u2014 cron jobs replaced with LaunchAgent maintenance script\",\n    \"severity\": \"P3\",\n    \"status\": \"RESOLVED\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-21T20:00:00.000Z\",\n    \"lastActivity\": \"2026-05-21T19:14:21.000Z\",\n    \"summary\": \"Replaced three high-frequency cron jobs (435 sessions/day) with single LaunchAgent running maintenance.sh every 30 minutes. All operational checks (MC health, error watchdog, task dispatcher, incident detection, session cleanup, backups) now run as shell-only with zero AI session overhead. Estimated savings: ~1.3M tokens/day.\",\n    \"tags\": [\n      \"optimization\",\n      \"launchagent\",\n      \"maintenance\",\n      \"cost-saving\",\n      \"backfill-2026-05-21\",\n      \"backfill\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-21T20:00:00.000Z\",\n        \"message\": \"Backfilled \\u2014 event occurred on 2026-05-21\",\n        \"actor\": \"system\"\n      },\n      {\n        \"ts\": \"2026-05-21T19:14:21.000Z\",\n        \"message\": \"Logged during incident backfill audit (May 21)\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-017\",\n    \"title\": \"WD MyCloud mount path changed \\u2014 /Volumes/Public-1 regenerated after purge\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-21T16:00:00.000Z\",\n    \"lastActivity\": \"2026-05-21T19:14:21.000Z\",\n    \"summary\": \"After gateway session purge, WD MyCloud mount appeared as /Volumes/Public-1 instead of /Volumes/Public. Scripts referencing the original path failed. mount-check and backup scripts need to handle both paths or prefer mount label over path.\",\n    \"tags\": [\n      \"wd-mycloud\",\n      \"mount\",\n      \"path-change\",\n      \"backup\",\n      \"backfill-2026-05-21\",\n      \"backfill\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-21T16:00:00.000Z\",\n        \"message\": \"Backfilled \\u2014 event occurred on 2026-05-21\",\n        \"actor\": \"system\"\n      },\n      {\n        \"ts\": \"2026-05-21T19:14:21.000Z\",\n        \"message\": \"Logged during incident backfill audit (May 21)\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-016\",\n    \"title\": \"Rate limit exhaustion (2nd wave) \\u2014 free model pool depleted by session explosion\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-21T15:35:00.000Z\",\n    \"lastActivity\": \"2026-05-21T19:14:21.000Z\",\n    \"summary\": \"Session explosion from runaway cron jobs created dozens of simultaneous session contexts, each consuming free-model rate limit quota. All free models returned 429. Resolved when cron jobs were terminated and sessions purged.\",\n    \"tags\": [\n      \"rate-limit\",\n      \"429\",\n      \"tokens\",\n      \"free-models\",\n      \"sessions\",\n      \"backfill-2026-05-21\",\n      \"backfill\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-21T15:35:00.000Z\",\n        \"message\": \"Backfilled \\u2014 event occurred on 2026-05-21\",\n        \"actor\": \"system\"\n      },\n      {\n        \"ts\": \"2026-05-21T19:14:21.000Z\",\n        \"message\": \"Logged during incident backfill audit (May 21)\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-015\",\n    \"title\": \"Session explosion \\u2014 22 to 87 sessions from runaway cron jobs\",\n    \"severity\": \"P1\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-21T15:30:00.000Z\",\n    \"lastActivity\": \"2026-05-21T19:14:21.000Z\",\n    \"summary\": \"Three cron jobs (Error Spike Watchdog every 5min, MC Health Check every 15min, Task Dispatcher every 30min) each created isolated sessions on every run. Combined rate of ~435 sessions/day with no session cleanup. Burned through token limits within hours. Fixed by deleting all three cron jobs and replacing with single LaunchAgent maintenance script (shell-only, zero sessions).\",\n    \"tags\": [\n      \"sessions\",\n      \"cron\",\n      \"explosion\",\n      \"tokens\",\n      \"outage\",\n      \"backfill-2026-05-21\",\n      \"backfill\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-21T15:30:00.000Z\",\n        \"message\": \"Backfilled \\u2014 event occurred on 2026-05-21\",\n        \"actor\": \"system\"\n      },\n      {\n        \"ts\": \"2026-05-21T19:14:21.000Z\",\n        \"message\": \"Logged during incident backfill audit (May 21)\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-014\",\n    \"title\": \"Gateway crash loop \\u2014 EmbeddedAttemptSessionTakeoverError across all sessions\",\n    \"severity\": \"P1\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-21T15:15:00.000Z\",\n    \"lastActivity\": \"2026-05-21T19:14:21.000Z\",\n    \"summary\": \"All active sessions hit EmbeddedAttemptSessionTakeoverError simultaneously around 15:15 UTC May 21. Gateway was in a crash loop where session files were being modified during embedded prompt lock release. Required gateway restart and session purge.\",\n    \"tags\": [\n      \"gateway\",\n      \"crash-loop\",\n      \"session-takeover\",\n      \"outage\",\n      \"backfill-2026-05-21\",\n      \"backfill\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-21T15:15:00.000Z\",\n        \"message\": \"Backfilled \\u2014 event occurred on 2026-05-21\",\n        \"actor\": \"system\"\n      },\n      {\n        \"ts\": \"2026-05-21T19:14:21.000Z\",\n        \"message\": \"Logged during incident backfill audit (May 21)\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-013\",\n    \"title\": \"Gateway update failure \\u2014 missing modules after partial update to v2026.5.19\",\n    \"severity\": \"P1\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-21T14:58:00.000Z\",\n    \"lastActivity\": \"2026-05-21T19:14:21.000Z\",\n    \"summary\": \"Partial gateway update to v2026.5.19 left missing module dependencies. Gateway failed to start after update. Required manual intervention to restore.\",\n    \"tags\": [\n      \"gateway\",\n      \"update\",\n      \"modules\",\n      \"v2026.5.19\",\n      \"outage\",\n      \"backfill-2026-05-21\",\n      \"backfill\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-21T14:58:00.000Z\",\n        \"message\": \"Backfilled \\u2014 event occurred on 2026-05-21\",\n        \"actor\": \"system\"\n      },\n      {\n        \"ts\": \"2026-05-21T19:14:21.000Z\",\n        \"message\": \"Logged during incident backfill audit (May 21)\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-012\",\n    \"title\": \"Mission Control down \\u2014 LaunchAgent pointing to deleted Wrangler binary\",\n    \"severity\": \"P1\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"The LaunchAgent com.openclaw.mission-control was pointing to a Wrangler binary in ~/Downloads/agent-control-station-main which no longer exists. Exit code 78 (EX_CONFIG) accumulated 9,473 restart attempts. The current Vite process was an unmanaged orphan.\",\n    \"tags\": [\n      \"wrangler\",\n      \"mission-control\",\n      \"launchagent\",\n      \"outage\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-011\",\n    \"title\": \"Rate limit exhaustion \\u2014 all models returned 429 starting May 15 19:42\",\n    \"severity\": \"P1\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"Starting 2026-05-15 19:42, owl-alpha began failing with all_keys_exhausted errors. The watcher log shows continuous rotation failures every ~16 minutes through 2026-05-16 00:49 (17+ failures). All API keys were exhausted, leaving the agent unable to process requests for several hours.\",\n    \"tags\": [\n      \"all-keys-exhausted\",\n      \"rate-limit\",\n      \"models\",\n      \"429\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-010\",\n    \"title\": \"Cron job failures \\u2014 Git Auto-Commit timeout and Activity Summary failing\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"Multiple cron jobs have been failing: Git Auto-Commit timeout, Activity Summary fail. The cron-errors.json shows 6 active error entries. Daily station check at 23:00 has been impacted.\",\n    \"tags\": [\n      \"failures\",\n      \"git\",\n      \"cron\",\n      \"activity-summary\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-009\",\n    \"title\": \"WD MyCloud mount failing \\u2014 /Volumes/Public-1 not found (persistent since May 16 06:18)\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"The mount-check.log shows continuous /Volumes/Public-1 not found errors every 30 minutes since at least 2026-05-16 06:18 (20+ errors). Backup scripts depending on this mount path are failing silently.\",\n    \"tags\": [\n      \"wd-mycloud\",\n      \"backup\",\n      \"mount\",\n      \"storage\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-008\",\n    \"title\": \"Tasks stuck In Progress \\u2014 3 tasks with no assignee or recent activity\",\n    \"severity\": \"P3\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"monkey\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"Three tasks (Error Feed behaviour review, Task Completion summary, Agent Office Overall) have been in In Progress state with no assigned owner. No activity updates visible. Tasks may be orphaned from agent assignments.\",\n    \"tags\": [\n      \"tasks\",\n      \"orphaned\",\n      \"in-progress\",\n      \"stale\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-007\",\n    \"title\": \"Build error \\u2014 AnimatePresence SSR failure in Dashboard component\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"ReferenceError: AnimatePresence is not defined at StationChatter in Dashboard.tsx. The awaitingReviewCount variable was defined inside QuickActionsPanel but referenced in the parent Dashboard component \\u2014 a scoping bug causing SSR crash on the /visual page.\",\n    \"tags\": [\n      \"ssr\",\n      \"animation\",\n      \"build\",\n      \"dashboard\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-006\",\n    \"title\": \"Port conflict \\u2014 Mission Control dev server jumping between 3000 and 3001\",\n    \"severity\": \"P3\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"When the LaunchAgent restarts the dev server, it sometimes finds port 3000 still occupied by the previous process and falls back to 3001. This causes confusion about which port is serving the live app and can result in stale builds being served.\",\n    \"tags\": [\n      \"dev-server\",\n      \"launchagent\",\n      \"conflict\",\n      \"port\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-005\",\n    \"title\": \"Disk space warning \\u2014 Data volume at 85% (175 Gi / 228 Gi)\",\n    \"severity\": \"P3\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"lifesupport\",\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"opened\": \"2026-05-16T14:36:26.000Z\",\n    \"lastActivity\": \"2026-05-16T14:36:26.000Z\",\n    \"summary\": \"Health log from 2026-05-15 12:03 shows /System/Volumes/Data at 85% usage (175 Gi / 228 Gi). Swap/compressor usage notable at ~21.9 GB. Approaching threshold where system performance may degrade.\",\n    \"tags\": [\n      \"swap\",\n      \"disk\",\n      \"warning\",\n      \"storage\",\n      \"backfill-2026-05-16\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"2026-05-16T14:36:26.000Z\",\n        \"message\": \"Backfilled from logs by backfill-2026-05-16\",\n        \"actor\": \"system\"\n      }\n    ],\n    \"actions\": []\n  },\n  {\n    \"id\": \"INC-004\",\n    \"title\": \"Memory index corruption after session restart\",\n    \"severity\": \"P1\",\n    \"status\": \"MITIGATING\",\n    \"owner\": \"archivist\",\n    \"opened\": \"2026-05-12 09:14\",\n    \"summary\": \"After an unplanned session restart, the SQLite memory index became partially corrupted. Daily log entries from 2026-05-11 onwards were not searchable. The raw .md files are intact \\u2014 only the index needs rebuilding.\",\n    \"tags\": [\n      \"memory\",\n      \"corruption\",\n      \"indexing\",\n      \"urgent\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"09:14\",\n        \"message\": \"Incident auto-detected: memory search returning stale results\",\n        \"actor\": \"lifesupport\"\n      },\n      {\n        \"ts\": \"09:22\",\n        \"message\": \"Confirmed SQLite index mismatch \\u2014 14 entries missing from index\",\n        \"actor\": \"archivist\"\n      },\n      {\n        \"ts\": \"09:31\",\n        \"message\": \"Status escalated to MITIGATING, assigned to Archivist\",\n        \"actor\": \"monkey\"\n      },\n      {\n        \"ts\": \"09:45\",\n        \"message\": \"Raw .md files verified intact, index rebuild initiated\",\n        \"actor\": \"archivist\"\n      },\n      {\n        \"ts\": \"10:02\",\n        \"message\": \"Index rebuild 40% complete, ETA ~5 minutes\",\n        \"actor\": \"archivist\"\n      }\n    ],\n    \"actions\": [],\n    \"acknowledged\": true,\n    \"escalated\": true,\n    \"lastActivity\": \"2026-05-12 09:14\"\n  },\n  {\n    \"id\": \"INC-003\",\n    \"title\": \"WD MyCloud SMB mount permissions broke backups\",\n    \"severity\": \"P2\",\n    \"status\": \"RESOLVED\",\n    \"owner\": \"lifesupport\",\n    \"opened\": \"2026-05-11 14:30\",\n    \"resolved\": \"2026-05-12 08:22\",\n    \"summary\": \"The WD MyCloud SMB share was mounted as read-only for the openclaw-agent account, preventing all backup scripts from running. The backup folder structure existed on the share but was completely empty.\",\n    \"tags\": [\n      \"backup\",\n      \"wd-mycloud\",\n      \"permissions\",\n      \"smb\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"14:30\",\n        \"message\": \"Backup script failed: permission denied writing to /Volumes/WD-MyCloud/OpenClaw/logs/\",\n        \"actor\": \"lifesupport\"\n      },\n      {\n        \"ts\": \"14:35\",\n        \"message\": \"Investigated mount permissions \\u2014 volume owned by root:wheel, read-only for agent\",\n        \"actor\": \"engineer\"\n      },\n      {\n        \"ts\": \"15:00\",\n        \"message\": \"Incident opened, assigned to Life Support for resolution tracking\",\n        \"actor\": \"monkey\"\n      },\n      {\n        \"ts\": \"2026-05-12 08:10\",\n        \"message\": \"New SMB share mounted at /Volumes/OpenClaw-WD with full read/write access\",\n        \"actor\": \"monkey\"\n      },\n      {\n        \"ts\": \"2026-05-12 08:22\",\n        \"message\": \"First successful backup completed to new mount path\",\n        \"actor\": \"lifesupport\"\n      }\n    ],\n    \"actions\": [\n      {\n        \"label\": \"Remount share with write access\",\n        \"description\": \"Mount the WD MyCloud SMB share with user credentials for r/w\",\n        \"status\": \"completed\",\n        \"completedAt\": \"08:10\",\n        \"completedBy\": \"monkey\"\n      },\n      {\n        \"label\": \"Run first backup\",\n        \"description\": \"Execute full backup to verify write access works end-to-end\",\n        \"status\": \"completed\",\n        \"completedAt\": \"08:22\",\n        \"completedBy\": \"lifesupport\"\n      },\n      {\n        \"label\": \"Set up automated daily backups\",\n        \"description\": \"Configure cron job for daily 3am backup runs\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-15 20:02:14\",\n        \"completedBy\": \"Space Monkey\"\n      },\n      {\n        \"label\": \"Decommission old mount path\",\n        \"description\": \"Remove references to /Volumes/WD-MyCloud/OpenClaw from scripts\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-15 20:02:16\",\n        \"completedBy\": \"Space Monkey\"\n      }\n    ],\n    \"acknowledged\": true,\n    \"escalated\": false,\n    \"lastActivity\": \"2026-05-11 14:30\"\n  },\n  {\n    \"id\": \"INC-002\",\n    \"title\": \"Mission Control dashboard can't read zip from Desktop\",\n    \"severity\": \"P2\",\n    \"status\": \"TRIAGE\",\n    \"owner\": \"engineer\",\n    \"opened\": \"2026-05-12 11:45\",\n    \"summary\": \"macOS security permissions prevent Terminal/Node from reading mission-control.zip on the Desktop. System shows a security prompt asking for Desktop folder access, but TTY-based processes can't interact with the GUI prompt.\",\n    \"tags\": [\n      \"macos\",\n      \"permissions\",\n      \"desktop\",\n      \"mission-control\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"11:45\",\n        \"message\": \"First attempt to unzip mission-control.zip failed with EACCES\",\n        \"actor\": \"engineer\"\n      },\n      {\n        \"ts\": \"11:52\",\n        \"message\": \"macOS TCC prompt appeared but can't be accepted by TTY process\",\n        \"actor\": \"engineer\"\n      },\n      {\n        \"ts\": \"12:00\",\n        \"message\": \"Incident opened \\u2014 needs human to either move file or grant Full Disk Access\",\n        \"actor\": \"monkey\"\n      }\n    ],\n    \"actions\": [\n      {\n        \"label\": \"Move zip to ~/Downloads/\",\n        \"description\": \"Human moves mission-control.zip to Downloads folder where Node has access\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-14 13:56:38\",\n        \"completedBy\": \"Space Monkey\"\n      },\n      {\n        \"label\": \"Grant Full Disk Access\",\n        \"description\": \"Add Terminal.app to System Settings \\u2192 Privacy & Security \\u2192 Full Disk Access\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-14 13:56:37\",\n        \"completedBy\": \"Space Monkey\"\n      },\n      {\n        \"label\": \"Alternative: use open dialog\",\n        \"description\": \"Use macOS native file picker to grant one-time access to the zip\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-14 13:56:43\",\n        \"completedBy\": \"Space Monkey\"\n      }\n    ],\n    \"acknowledged\": false,\n    \"escalated\": false,\n    \"lastActivity\": \"2026-05-12 11:45\"\n  },\n  {\n    \"id\": \"INC-001\",\n    \"title\": \"Cron job drift \\u2014 daily heartbeat running 3 hours late\",\n    \"severity\": \"P3\",\n    \"status\": \"MITIGATING\",\n    \"owner\": \"lifesupport\",\n    \"opened\": \"2026-05-12 06:00\",\n    \"summary\": \"The daily heartbeat cron job was scheduled for 03:00 but is consistently firing around 06:00. The gateway sleep/wake cycle is shifting the effective trigger time. This causes checks to run during active hours instead of quiet hours.\",\n    \"tags\": [\n      \"cron\",\n      \"scheduling\",\n      \"heartbeat\",\n      \"drift\"\n    ],\n    \"timeline\": [\n      {\n        \"ts\": \"06:00\",\n        \"message\": \"Daily heartbeat fired three hours late \\u2014 gap analysis initiated\",\n        \"actor\": \"lifesupport\"\n      },\n      {\n        \"ts\": \"06:10\",\n        \"message\": \"Root cause: gateway sleep shifts cron anchorMs forward on each resume\",\n        \"actor\": \"engineer\"\n      },\n      {\n        \"ts\": \"06:30\",\n        \"message\": \"Proposed fix: switch to cron expr with tz instead of everyMs\",\n        \"actor\": \"engineer\"\n      }\n    ],\n    \"actions\": [\n      {\n        \"label\": \"Switch to cron expression\",\n        \"description\": \"Replace everyMs schedule with cron '0 3 * * *' in Europe/London tz\",\n        \"status\": \"in_progress\",\n        \"completedAt\": \"2026-05-14 14:16:40\",\n        \"completedBy\": \"Space Monkey\"\n      },\n      {\n        \"label\": \"Add stagger tolerance\",\n        \"description\": \"Set staggerMs to 60000 to prevent exact-time clustering\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-14 14:16:33\",\n        \"completedBy\": \"Space Monkey\"\n      },\n      {\n        \"label\": \"Monitor for 48h\",\n        \"description\": \"Verify the fix holds over two sleep/wake cycles\",\n        \"status\": \"skipped\",\n        \"completedAt\": \"2026-05-14 13:57:08\",\n        \"completedBy\": \"Space Monkey\"\n      }\n    ],\n    \"acknowledged\": true,\n    \"escalated\": false,\n    \"lastActivity\": \"2026-05-12 06:00\"\n  }\n]"}],"isError":false,"timestamp":1780295832070}}
