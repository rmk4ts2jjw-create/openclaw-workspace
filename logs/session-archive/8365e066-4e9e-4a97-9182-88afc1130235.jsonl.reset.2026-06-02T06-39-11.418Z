ogress(t) : 0);\n\n  // Detect stall: no activity for STALE_WARNING_MINUTES\n  const now = new Date();\n  const lastActivityTime = t.lastActivity ? new Date(t.lastActivity) : (t.startedAt ? new Date(t.startedAt) : null);\n  const minutesSinceActivity = lastActivityTime ? Math.floor((now.getTime() - lastActivityTime.getTime()) / 60000) : 0;\n  const isStalled = isInProgress && minutesSinceActivity >= STALE_WARNING_MINUTES;\n  const stallDuration = isStalled ? minutesSinceActivity : 0;\n\n  // Progress bar color: grey (no activity), green (working), amber (stalled)\n  const progressColor = isDone\n    ? \"bg-[oklch(0.88_0.18_145)]\"\n    : isStalled\n    ? \"bg-amber\"\n    : \"bg-gradient-to-r from-violet/60 to-violet\";\n\n  // Current step display\n  const currentStep = t.currentStep || (isInProgress ? \"Working...\" : undefined);"}]},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/tasks.tsx\", \"edits\": [{\"oldText\": \"function TaskCard({\\n  t,\\n  onDragStart,\\n  dragging,\\n  onClick,\\n}: {\\n  t: Task;\\n  onDragStart: (id: string) => void;\\n  dragging: boolean;\\n  onClick: () => void;\\n}) {\\n  const a = getCrew(t.assignee);\\n  const isInProgress = t.status === \\\"in_progress\\\";\\n  const isAwaitingReview = t.status === \\\"awaiting_review\\\";\\n  const isDone = t.status === \\\"done\\\";\\n  const isBacklog = t.status === \\\"backlog\\\";\\n\\n  // Calculate time in current status\\n  const timeInStatus = t.lastUpdated\\n    ? getTimeAgo(t.lastUpdated)\\n    : t.ts;\\n\\n  // Progress percentage (simulated based on time in progress)\\n  const progressPct = t.progress ?? (isDone ? 100 : isInProgress ? calculateProgress(t) : 0);\", \"newText\": \"function TaskCard({\\n  t,\\n  onDragStart,\\n  dragging,\\n  onClick,\\n  onUpdate,\\n}: {\\n  t: Task;\\n  onDragStart: (id: string) => void;\\n  dragging: boolean;\\n  onClick: () => void;\\n  onUpdate: (updated: Task) => void;\\n}) {\\n  const a =