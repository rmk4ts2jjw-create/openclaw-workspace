o not call any models.","timeoutSeconds":120},"delivery":{"mode":"announce","channel":"last","to":"7507878944"},"state":{"lastRunAtMs":1780265550303,"lastRunStatus":"error","lastStatus":"error","lastDurationMs":120080,"lastDeliveryStatus":"unknown","consecutiveErrors":4,"consecutiveSkipped":0,"lastFailureNotificationDeliveryStatus":"unknown","nextRunAtMs":1780351200000,"lastDiagnostics":{"summary":"cron: job execution timed out (last phase: model-call-started)","entries":[{"ts":1780265670383,"source":"cron-setup","severity":"error","message":"cron: job execution timed out (last phase: model-call-started)"}]},"lastDiagnosticSummary":"cron: job execution timed out (last phase: model-call-started)","lastErrorReason":"timeout","lastError":"cron: job execution timed out (last phase: model-call-started)"},"updatedAtMs":1780265670383},{"id":"6f823429-453b-4db5-a5c9-51472f1693b3","agentId":"main","sessionKey":"agent:main:main","name":"Sessions Cleanup","enabled":true,"createdAtMs":1779373498843,"schedule":{"kind":"cron","expr":"0 2 * * *","tz":"UTC"},"sessionTarget":"main","wakeMode":"now","payload":{"kind":"systemEvent","text":"openclaw sessions cleanup"},"state":{"nextRunAtMs":1780365600000,"lastRunAtMs":1780279200008,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":15,"lastDeliveryStatus":"not-requested","lastFailureNotificationDeliveryStatus":"not-requested","consecutiveErrors":0,"consecutiveSkipped":0},"updatedAtMs":1780279200023},{"id":"c52ff1a0-0936-48f9-8247-3711020824ca","agentId":"main","sessionKey":"agent:main:main","name":"Session Auto‑Expiry","enabled":true,"createdAtMs":1779373821493,"schedule":{"kind":"cron","expr":"0 4 * * *","tz":"UTC"},"sessionTarget":"main","wakeMode":"now","payload":{"kind":"systemEvent","text":"/Users/spacemonkey/.openclaw/workspace/scripts/session-expiry.sh"},"state":{"nextRunAtMs":1780372800000,"lastRunAtMs":1780286400004,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":5,"lastDeliveryStatus":"not-requested","lastFailure