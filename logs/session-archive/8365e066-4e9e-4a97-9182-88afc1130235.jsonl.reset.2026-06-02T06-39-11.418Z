{"type":"message","id":"3bc3cc27","parentId":"6220ac8d","timestamp":"2026-06-01T07:17:33.969Z","message":{"role":"toolResult","toolCallId":"b3450eec-b0d2-48db-a887-e2e3276e3e79","toolName":"read","content":[{"type":"text","text":" rect(10, bY+4, 5, 10, c(PA.r1)); rect(26, bY+4, 5, 10, c(PA.r1));\n rect(14, bY+14, 12, 8, c(PA.bk0)); rect(15, bY+15, 10, 6, c(PA.bkP));\n line(16, bY+17, 8, c(PA.am0));\n }\n\n // ── ROBE LOWER ──\n if (seated) {\n rect(11, bY+20, 18, 14, c(PA.r2)); rect(12, bY+21, 16, 12, c(PA.r1));\n rect(12, bY+22, 16, 12, c(PA.r3));\n line(11, bY+20, 18, c(PA.am1)); line(11, bY+33, 18, c(PA.am1));\n rect(15, bY+31, 4, 4, c(PA.r1)); rect(21, bY+31, 4, 4, c(PA.r1));\n } else if (pose === \"walk\") {\n rect(11, bY+20, 18, 16, PA.r2); rect(12, bY+21, 16, 14, PA.r1);\n rect(12, bY+22, 16, 14, PA.r3); line(11, bY+35, 18, PA.am1);\n rect(14, bY+33, 4, 4, PA.r1); rect(20, bY+31, 4, 4, PA.r1);\n } else {\n rect(11, bY+20, 18, 16, PA.r2); rect(12, bY+21, 16, 14, PA.r1);\n rect(12, bY+22, 16, 14, PA.r3); line(11, bY+35, 18, PA.am1);\n rect(14, bY+33, 4, 4, PA.r1); rect(20, bY+33, 4, 4, PA.r1);\n }\n\n // ── HEAD ──\n rect(15, hY, 10, 12, c(PA.sk));\n rect(14, hY+1, 12, 10, c(PA.sk));\n rect(15, hY-1, 10, 14, c(PA.sk));\n // Hair wisps\n rect(15, hY-1, 10, 3, c(PA.r1)); rect(16, hY-2, 8, 3, c(PA.r2));\n rect(17, hY-3, 6, 2, c(PA.rLt));\n // Eyes\n if (sl) {\n line(15, hY+5, 4, c(PA.skD)); px(16, hY+6, c(PA.skD));\n line(21, hY+5, 4, c(PA.skD)); px(22, hY+6, c(PA.skD));\n } else {\n rect(15, hY+4, 4, 4, c(PA.eW)); rect(21, hY+4, 4, 4, c(PA.eW));\n rect(16, hY+5, 2, 2, c(PA.e)); rect(22, hY+5, 2, 2, c(PA.e));\n if (pose===\"thinking\") { rect(16, hY+4, 2, 2, c(PA.e)); rect(22, hY+4, 2, 2, c(PA.e)); } // look up\n glow(15, hY+4, 4, 2, c(glassGlow)+\"66\"); glow(21, hY+4, 4, 2, c(glassGlow)+\"66\");\n }\n px(18, hY+8, c(PA.skD)); px(19, hY+8, c(PA.skD)); // nose\n if (!sl) { line(16, hY+10, 7, c(PA.skD)); px(16, hY+11, c(PA.skD)); px(22, hY+11, c(PA.skD)); }\n\n // ── ROUND GLASSES ──\n // Left lens frame\n line(14, hY+3, 6, c(PA.gl0)); line(14, hY+7, 6, c(PA.gl1));\n line(14, hY+3, 1, c(PA.gl0), true); line(19, hY+3, 1, c(PA.gl1), true);\n // Right lens frame\n line(21, hY+3, 6, c(PA.gl0)); line(21, hY+7, 6, c(PA.gl1));\n line(21, hY+3, 1, c(PA.gl0), true); line(26, hY+3, 1, c(PA.gl1), true);\n // Bridge\n px(20, hY+5, c(PA.gl0));\n // Temples\n px(13, hY+5, c(PA.glL)); px(27, hY+5, c(PA.glL));\n // Askew if sleeping\n if (sl) { px(15, hY+3, c(PA.gl0)); px(16, hY+2, c(PA.gl0)); }\n // Glow in lenses\n if ((pose===\"working\"||pose===\"collab\") && !sl) {\n glow(15, hY+4, 4, 3, \"rgba(200,144,32,0.5)\");\n glow(22, hY+4, 4, 3, \"rgba(200,144,32,0.5)\");\n }\n\n // ZZZ\n if (sl) {\n px(23, hY-4, c(PA.zz)); line(24, hY-7, 3, c(PA.zz)); px(24, hY-6, c(PA.zz)); px(26, hY-6, c(PA.zz));\n rect(27, hY-10, 4, 2, c(PA.zz)); px(27, hY-9, c(PA.zz)); px(30, hY-9, c(PA.zz));\n }\n}\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// CHARACTER REGISTRY + APP\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nconst CHARS = [\n { id:\"monkey\", emoji:\"🐒\", label:\"Space Monkey\", sub:\"Mission Director\", accent:\"#9B6FE8\", fn:drawMonkey },\n { id:\"ninja\", emoji:\"🥷\", label:\"Life Support Officer\", sub:\"Infrastructure Controller\", accent:\"#FF40B0\", fn:drawNinja },\n { id:\"engineer\", emoji:\"🔧\", label:\"Systems Engineer\", sub:\"Coder / Builder\", accent:\"#20D0E8\", fn:drawEngineer },\n { id:\"archivist\", emoji:\"📚\", label:\"Station Archivist\", sub:\"Memory & Knowledge\", accent:\"#E0A030\", fn:drawArchivist },\n];\nconst POSES = [\"IDLE\",\"THINK\",\"WORK\",\"SLEEP\",\"WALK\",\"COLLAB\"];\nconst POSE_KEYS = [\"idle\",\"thinking\",\"working\",\"sleep\",\"walk\",\"collab\"];\n\nexport default function App() {\n const [tick, setTick] = useState(0);\n const [activeChar, setActiveChar] = useState(0);\n const [hoveredPose, setHoveredPose] = useState(0);\n const [exporting, setExporting] = useState(null);\n const tRef = useRef(0);\n\n const sheetCanvases = CHARS.map(() => useRef(null));\n const displayCanvases = CHARS.map(() => useRef(null));\n const previewRef = useRef(null);\n\n useEffect(() => {\n let live = true;\n function loop() {\n if (!live) return;\n tRef.current++;\n setTick(n => n + 1);\n requestAnimationFrame(loop);\n }\n requestAnimationFrame(loop);\n return () => { live = false; };\n }, []);\n\n useEffect(() => {\n CHARS.forEach((ch, ci) => {\n const cvs = sheetCanvases[ci].current;\n if (!cvs) return;\n const ctx = cvs.getContext(\"2d\");\n ctx.clearRect(0, 0, 1920, 240);\n POSE_KEYS.forEach((pose, pi) => ch.fn(ctx, pose, pi * FRAME_W, 0, tRef.current));\n // Scale to display canvas\n const disp = displayCanvases[ci].current;\n if (disp) {\n const dctx = disp.getContext(\"2d\");\n dctx.clearRect(0, 0, disp.width, disp.height);\n dctx.imageSmoothingEnabled = false;\n dctx.drawImage(cvs, 0, 0, disp.width, disp.height);\n }\n });\n }, [tick]);\n\n useEffect(() => {\n const cvs = previewRef.current;\n if (!cvs) return;\n const ctx = cvs.getContext(\"2d\");\n ctx.clearRect(0, 0, FRAME_W, FRAME_H);\n CHARS[activeChar].fn(ctx, POSE_KEYS[hoveredPose], 0, 0, tRef.current);\n }, [tick, activeChar, hoveredPose]);\n\n function exportPNG(ci) {\n setExporting(ci);\n setTimeout(() => {\n const cvs = sheetCanvases[ci].current;\n if (!cvs) { setExporting(null); return; }\n const a = document.createElement(\"a\");\n a.download = `${CHARS[ci].id}-spritesheet-1920x240.png`;\n a.href = cvs.toDataURL(\"image/png\");\n a.click();\n setExporting(null);\n }, 80);\n }\n\n const acc = CHARS[activeChar].accent;\n\n return (\n <div style={{ minHeight:\"100vh\", background:\"#12182A\", color:\"#D0C8F0\", fontFamily:\"'Courier New', monospace\", padding:\"18px 14px 40px\", boxSizing:\"border-box\" }}>\n {CHARS.map((_,ci) => <canvas key={ci} ref={sheetCanvases[ci]} width={1920} height={240} style={{display:\"none\"}} />)}\n\n {/* Header */}\n <div style={{textAlign:\"center\",marginBottom:22}}>\n <div style={{fontSize:9,letterSpacing:6,color:\"#3A3468\",textTransform:\"uppercase\",marginBottom:3}}>Deep Space Station · Crew Registry</div>\n <h1 style={{margin:0,fontSize:18,fontWeight:900,letterSpacing:3,color:\"#F0ECF8\"}}>SPRITE SHEET GENERATOR</h1>\n <div style={{fontSize:9,color:\"#2C2848\",marginTop:3,letterSpacing:4}}>16-BIT PIXEL ART · 6 POSES · TRUE TRANSPARENCY · 1920×240</div>\n </div>\n\n {/* Character tabs */}\n <div style={{display:\"flex\",gap:5,justifyContent:\"center\",marginBottom:18,flexWrap:\"wrap\"}}>\n {CHARS.map((ch,i) => (\n <button key={ch.id} onClick={() => setActiveChar(i)} style={{\n background: activeChar===i ? ch.accent+\"18\" : \"transparent\",\n border:`1.5px solid ${activeChar===i ? ch.accent : \"#1A183A\"}`,\n color: activeChar===i ? ch.accent : \"#504888\",\n padding:\"6px 13px\", borderRadius:4, cursor:\"pointer\",\n fontFamily:\"inherit\", fontSize:11, letterSpacing:1.5, transition:\"all 0.15s\",\n }}>{ch.emoji} {ch.id.toUpperCase()}</button>\n ))}\n </div>\n\n {/* Preview + pose picker */}\n <div style={{display:\"flex\",gap:14,justifyContent:\"center\",marginBottom:22,flexWrap:\"wrap\",alignItems:\"flex-start\"}}>\n <div>\n <div style={{fontSize:8,color:\"#2C2848\",letterSpacing:4,marginBottom:5,textAlign:\"center\"}}>LIVE PREVIEW · {POSES[hoveredPose]}</div>\n <div style={{border:`1px solid ${acc}2A`,borderRadius:7,overflow:\"hidden\",background:\"#080C18\",lineHeight:0}}>\n <canvas ref={previewRef} width={320} height={240} style={{display:\"block\",imageRendering:\"pixelated\"}} />\n </div>\n <div style={{textAlign:\"center\",marginTop:6,fontSize:10,color:acc,letterSpacing:1}}>{CHARS[activeChar].emoji} {CHARS[activeChar].label}</div>\n <div style={{textAlign:\"center\",fontSize:8,color:\"#383460\",letterSpacing:1}}>{CHARS[activeChar].sub}</div>\n </div>\n <div style={{display:\"flex\",flexDirection:\"column\",gap:7}}>\n <div style={{fontSize:8,color:\"#2C2848\",letterSpacing:4,marginBottom:1}}>SELECT POSE</div>\n <div style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr\",gap:4}}>\n {POSES.map((p,pi) => (\n <button key={p} onMouseEnter={() => setHoveredPose(pi)} onClick={() => setHoveredPose(pi)} style={{\n padding:\"7px 11px\", background: hoveredPose===pi ? acc+\"12\" : \"transparent\",\n border:`1px solid ${hoveredPose===pi ? acc : \"#16143A\"}`,\n color: hoveredPose===pi ? acc : \"#484870\",\n borderRadius:3, cursor:\"pointer\", fontFamily:\"inherit\", fontSize:10, letterSpacing:1.5, transition:\"all 0.1s\", textAlign:\"left\",\n }}><span style={{opacity:0.4,fontSize:8}}>0{pi+1} </span>{p}</button>\n ))}\n </div>\n <button onClick={() => exportPNG(activeChar)} disabled={exporting!==null} style={{\n marginTop:2,padding:\"9px 14px\",background:acc+\"14\",\n border:`1.5px solid ${acc}`,color:acc,borderRadius:4,\n cursor:\"pointer\",fontFamily:\"inherit\",fontSize:10,letterSpacing:2,transition:\"all 0.14s\",\n }}>{exporting===activeChar ? \"EXPORTING…\" : \"↓ EXPORT 1920×240 PNG\"}</button>\n <div style={{fontSize:8,color:\"#1E1C38\",letterSpacing:1,textAlign:\"center\"}}>transparent · anti-aliased for #12182A</div>\n </div>\n </div>\n\n {/* All 4 strips */}\n <div style={{fontSize:8,color:\"#1E1C38\",letterSpacing:4,marginBottom:12,textAlign:\"center\"}}>ALL SPRITE SHEETS — EXPORT FOR FULL 1920px</div>\n <div style={{display:\"flex\",flexDirection:\"column\",gap:14}}>\n {CHARS.map((ch,ci) => (\n <div key={ch.id}>\n <div style={{display:\"flex\",alignItems:\"center\",gap:8,marginBottom:3}}>\n <span style={{fontSize:10,color:ch.accent,letterSpacing:1.5}}>{ch.emoji} {ch.label.toUpperCase()}</span>\n <span style={{fontSize:8,color:\"#2C2848\"}}>— {ch.sub}</span>\n <button onClick={() => exportPNG(ci)} disabled={exporting!==null} style={{\n marginLeft:\"auto\",padding:\"2px 9px\",background:\"transparent\",\n border:`1px solid ${ch.accent}44`,color:ch.accent,borderRadius:3,\n cursor:\"pointer\",fontFamily:\"inherit\",fontSize:9,letterSpacing:1,\n }}>↓ PNG</button>\n </div>\n <div style={{display:\"flex\",marginBottom:2}}>\n {POSES.map(p => <div key={p} style={{flex:\"0 0 96px\",minWidth:96,fontSize:7,color:\"#1E1C38\",letterSpacing:2,textAlign:\"center\"}}>{p}</div>))}\n </div>\n <div style={{overflowX:\"auto\",borderRadius:3,border:`1px solid ${ch.accent}1A`}}>\n <div"}],"isError":false,"timestamp":1780298253968}}
