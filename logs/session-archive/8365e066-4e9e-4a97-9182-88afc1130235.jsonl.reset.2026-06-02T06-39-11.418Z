{"type":"message","id":"96fbd2e1","parentId":"51f309a2","timestamp":"2026-06-01T07:17:17.697Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"9600fae9-a8ae-4baf-98de-d244286bb07d","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/components/sprites/SpriteSheetGenerator.tsx","content":"import { useEffect, useRef, useState } from \"react\";\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// PIXEL ART ENGINE\n// Sprites drawn on 40×56 pixel grid, scaled to fill 320×240 frame\n// Each \"pixel\" = PW wide × PH tall → 200×224px centered in 320×240\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\nconst PW = 5, PH = 4;\nconst GW = 40, GH = 56;\nconst SPRITE_W = GW * PW; // 200\nconst SPRITE_H = GH * PH; // 224\nconst FRAME_W = 320, FRAME_H = 240;\nconst OX = Math.floor((FRAME_W - SPRITE_W) / 2); // 60\nconst OY = Math.floor((FRAME_H - SPRITE_H) / 2); // 8\n\nfunction makeDraw(ctx, fox, foy) {\n const px = (c, r, color, cw = 1, ch = 1) => {\n if (!color || color === \".\") return;\n ctx.fillStyle = color;\n ctx.fillRect(fox + OX + c * PW, foy + OY + r * PH, cw * PW, ch * PH);\n };\n const line = (c, r, len, color, vert = false) => {\n for (let i = 0; i < len; i++) vert ? px(c, r + i, color) : px(c + i, r, color);\n };\n const rect = (c, r, w, h, color) => {\n if (!color) return;\n for (let row = 0; row < h; row++) line(c, r + row, w, color);\n };\n const glow = (c, r, w, h, color) => {\n ctx.fillStyle = color;\n ctx.fillRect(fox + OX + c * PW, foy + OY + r * PH, w * PW, h * PH);\n };\n return { px, line, rect, glow };\n}\n\n// Dim a hex color for sleep state\nfunction dimHex(col, f) {\n if (!col || col[0] !== \"#\" || col.length < 7) return col;\n const r = parseInt(col.slice(1,3),16), g = parseInt(col.slice(3,5),16), b = parseInt(col.slice(5,7),16);\n return `rgb(${Math.round(r*f)},${Math.round(g*f)},${Math.round(b*f)})`;\n}\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// PALETTES\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nconst PM = {\n fur0:\"#5C3A1E\", fur1:\"#8B5E3C\", fur2:\"#A0724A\", fur3:\"#C4956A\",\n s0:\"#2A1260\", s1:\"#4C2A8A\", s2:\"#6B3FBF\", s3:\"#9B6FE8\", sLt:\"#C4A0FF\",\n g0:\"#7A5810\", g1:\"#B08020\", g2:\"#D4A830\", g3:\"#FFD060\", gLt:\"#FFE898\",\n e:\"#0A0408\", eW:\"#F0E8E0\", eH:\"#FFD4B0\",\n sk:\"#D4A87A\", skD:\"#A87850\",\n h0:\"#1A0C48\", h1:\"#3A2880\", hm:\"#60CC60\",\n ch0:\"#12102A\", ch1:\"#20183C\", ch2:\"#2C2250\",\n kb0:\"#221880\", kb1:\"#4040B0\", kbG:\"#8090FF\",\n t0:\"#3C1C0C\", t1:\"#5C2C10\", t2:\"#7C3C18\",\n p0:\"#7A2828\", p1:\"#A83A3A\", pG:\"#CC7020\",\n tab0:\"#141E30\", tab1:\"#1E3048\", tabG:\"#4080CC\",\n con0:\"#0E0C20\", con1:\"#1A1638\", conG:\"#6050D0\",\n zz:\"#8080C0\",\n};\nconst PN = {\n s0:\"#080410\", s1:\"#100820\", s2:\"#1C1030\", s3:\"#2C1848\",\n tp0:\"#2A1440\", tp1:\"#3C2060\",\n pk0:\"#660044\", pk1:\"#AA1077\", pk2:\"#EE20AA\", pk3:\"#FF80D0\", pkLt:\"#FFB8E8\",\n sk:\"#C49060\", skD:\"#8C6030\",\n e:\"#0A0408\", eW:\"#E8E0F0\",\n v0:\"#440022\", v1:\"#880044\", v2:\"#CC1166\", v3:\"#FF3399\",\n sc0:\"#8070A0\", sc1:\"#C0B0D8\", sc2:\"#E8E0F8\",\n bt0:\"#080410\", bt1:\"#140C24\",\n con0:\"#080414\", con1:\"#100820\", conP:\"#EE20AA\",\n hl0:\"#1A0028\", hl1:\"#EE20AA\", hl2:\"#FF80D0\",\n zz:\"#906090\",\n bl0:\"#0C0818\", bl1:\"#180C28\", blP:\"#AA1077\",\n};\nconst PE = {\n c0:\"#0E1A20\", c1:\"#1C2C38\", c2:\"#2A4050\", c3:\"#3A5868\",\n cy0:\"#005060\", cy1:\"#008090\", cy2:\"#00B8C8\", cy3:\"#30E0F0\", cyLt:\"#90FFFF\",\n og0:\"#602C08\", og1:\"#904010\", og2:\"#C86020\", og3:\"#F09840\", ogG:\"#FFD090\",\n sk:\"#D0906A\", skD:\"#A06840\",\n e:\"#0A0408\", eW:\"#F0E8E0\",\n bt0:\"#101818\", bt1:\"#202828\",\n cr0:\"#1E2816\", cr1:\"#2E3C22\", cr2:\"#3E5030\", crL:\"#506040\",\n mg0:\"#3C2418\", mg1:\"#5C3820\", mgH:\"#B06030\",\n bh0:\"#181E1C\", bh1:\"#283030\",\n wr0:\"#484840\", wr1:\"#686860\", wrH:\"#9090A0\",\n sp0:\"#FF6000\", sp1:\"#FFAA00\", sp2:\"#FFFFFF\",\n bl0:\"#101418\", bl1:\"#182028\", blG:\"#00B8C8\",\n rl0:\"#3C2C1C\", rl1:\"#5C4428\",\n gr:\"#1C2428\",\n hl0:\"#001018\", hl1:\"#00B8C8\", hl2:\"#80F0FF\",\n zz:\"#5080A0\",\n tb0:\"#0E1828\", tb1:\"#162238\", tbG:\"#30D8F0\",\n blt:\"#281C08\", blt2:\"#403010\", pch:\"#362210\",\n};\nconst PA = {\n r0:\"#180C04\", r1:\"#2C1808\", r2:\"#4A2C10\", r3:\"#6A4018\", rLt:\"#8A5820\",\n am0:\"#5C3808\", am1:\"#8A5810\", am2:\"#C08020\", am3:\"#E8AA30\", amLt:\"#FFD060\",\n cr0:\"#F0E4C0\", cr1:\"#F8F0DC\",\n sk:\"#D4B896\", skD:\"#A48060\",\n e:\"#0A0408\", eW:\"#F0ECD8\",\n gl0:\"#4A2C0C\", gl1:\"#7A4C18\", glL:\"#C09040\",\n bk0:\"#100808\", bk1:\"#201010\", bkP:\"#F0E8D0\", bkT:\"#C0A060\",\n ch0:\"#100804\", ch1:\"#1C1008\", ch2:\"#281808\",\n cx0:\"#E09020\", cx1:\"#FFB830\", cx2:\"#FFF0A0\",\n cxB:\"#FF6010\", cxC:\"#60A0FF\",\n dt0:\"#C08020\", dt1:\"#E8A820\", dtG:\"#FFF080\",\n tm0:\"#100804\", tm1:\"#201008\", tmG:\"#C08020\",\n zz:\"#C0A050\",\n tc:\"#FFB830\",\n hl0:\"#180C00\", hl1:\"#C08020\", hl2:\"#FFD060\",\n};\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// 🐒 SPACE MONKEY DRAWER\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nfunction drawMonkey(ctx, pose, fox, foy, t) {\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\n const sl = pose === \"sleep\";\n const f = sl ? 0.45 : 1;\n const c = (col) => sl ? dimHex(col, f) : col;\n const bob = pose === \"idle\" ? Math.round(Math.sin(t * 0.08) * 0.8) : 0;\n\n // Seated context\n const seated = pose === \"idle\" || pose === \"sleep\" || pose === \"working\";\n const bY = seated ? 26 + bob : 22; // body top Y\n const hY = seated ? 13 + bob : 9; // head top Y\n\n // ── CHAIR ──\n if (seated) {\n rect(4, hY+14, 5, 28, c(PM.ch1)); rect(5, hY+15, 3, 26, c(PM.ch0));\n rect(31, hY+14, 5, 28, c(PM.ch1)); rect(32, hY+15, 3, 26, c(PM.ch0));\n line(4, hY+14, 32, c(PM.ch2));\n rect(4, 40+bob, 32, 5, c(PM.ch1)); rect(6, 41+bob, 28, 3, c(PM.ch0));\n rect(6, 44+bob, 3, 10, c(PM.ch1)); rect(31, 44+bob, 3, 10, c(PM.ch1));\n // Console wings\n rect(0, 35+bob, 10, 4, c(PM.con1)); rect(1, 33+bob, 8, 4, c(PM.con0));\n rect(30, 35+bob, 10, 4, c(PM.con1)); rect(31, 33+bob, 8, 4, c(PM.con0));\n if (!sl) { line(1, 32+bob, 6, PM.conG); line(33, 32+bob, 6, PM.conG); }\n }\n\n // ── TAIL ──\n if (pose === \"idle\") {\n for (let i=0;i<5;i++) { px(34+i, 33+i+bob, c(PM.t2)); px(35+i, 33+i+bob, c(PM.t1)); }\n rect(35, 38+bob, 3, 3, c(PM.t0));\n } else if (pose === \"thinking\") {\n // Question mark shape\n line(27, 17, 6, PM.t2); px(27, 18, PM.t1); px(26, 19, PM.t2); px(26, 20, PM.t1);\n px(27, 21, PM.t2); px(28, 21, PM.t1); px(29, 20, PM.t2); px(30, 19, PM.t1);\n px(31, 18, PM.t2); px(31, 17, PM.t1); px(30, 16, PM.t2);\n rect(28, 23, 2, 2, PM.t0);\n } else if (pose === \"working\") {\n px(33, 28+bob, c(PM.t2)); px(34, 30+bob, c(PM.t1)); px(35, 31+bob, c(PM.t2));\n px(36, 30+bob, c(PM.t1)); px(37, 28+bob, c(PM.t2)); px(38, 26+bob, c(PM.t1));\n px(38, 24+bob, c(PM.t2));\n } else if (pose === \"sleep\") {\n for (let i=0;i<6;i++) px(33+Math.round(i*0.5), 34+i, c(PM.t1));\n px(34, 40, c(PM.t0));\n } else if (pose === \"walk\") {\n px(32,28,PM.t2); px(33,27,PM.t1); px(34,26,PM.t2); px(35,25,PM.t1);\n px(36,24,PM.t2); px(37,23,PM.t1); px(38,22,PM.t0);\n } else { // collab\n px(31,24,PM.t2); px(32,23,PM.t1); px(33,22,PM.t2); px(34,21,PM.t1);\n px(35,20,PM.t2); px(36,19,PM.t1); px(37,18,PM.t0);\n }\n\n // ── SUIT BODY ──\n rect(14, bY, 12, 14, c(PM.s1)); rect(15, bY+1, 10, 12, c(PM.s0));\n line(14, bY, 12, c(PM.s2)); // highlight top\n line(15, bY+1, 3, c(PM.s3)); // shine\n // Gold collar trim\n line(14, bY, 12, c(PM.g2));\n // Gold waist trim\n line(14, bY+13, 12, c(PM.g1)); line(15, bY+14, 10, c(PM.g2));\n // Mission patch\n rect(16, bY+3, 4, 4, c(PM.p0)); rect(17, bY+4, 2, 2, c(PM.pG));\n // Chest stripe\n rect(23, bY+3, 3, 4, c(PM.s2));\n\n // ── ARMS ──\n if (pose === \"idle\") {\n rect(10, bY+2, 5, 9, c(PM.s1)); rect(11, bY+3, 3, 7, c(PM.s0));\n rect(10, bY+10, 4, 4, c(PM.fur2)); // hand on console\n rect(25, bY+2, 5, 8, c(PM.s1)); rect(26, bY+3, 3, 6, c(PM.s0));\n rect(25, bY+9, 4, 4, c(PM.fur2));\n } else if (pose === \"thinking\") {\n rect(10, bY+2, 5, 11, PM.s1); rect(11, bY+3, 3, 9, PM.s0);\n rect(10, bY+12, 5, 4, PM.fur2); // hand on chin\n rect(25, bY+2, 5, 8, PM.s1); rect(26, bY+3, 3, 6, PM.s0);\n rect(25, bY+9, 4, 4, PM.fur2);\n } else if (pose === \"working\") {\n rect(9, bY+4, 6, 9, c(PM.s1)); rect(10, bY+5, 4, 7, c(PM.s0));\n rect(9, bY+12, 5, 4, c(PM.fur2));\n rect(25, bY+4, 6, 9, c(PM.s1)); rect(26, bY+5, 4, 7, c(PM.s0));\n rect(25, bY+12, 5, 4, c(PM.fur2));\n } else if (pose === \"sleep\") {\n rect(9, bY+3, 6, 12, c(PM.s1)); rect(25, bY+3, 6, 12, c(PM.s1));\n } else if (pose === \"walk\") {\n rect(9, bY+2, 5, 10, PM.s1); rect(10, bY+3, 3, 8, PM.s0);\n rect(9, bY+11, 4, 4, PM.fur2);\n rect(4, bY+4, 6, 8, PM.tab0); rect(5, bY+5, 4, 6, PM.tab1);\n line(5, bY+6, 4, PM.tabG); line(5, bY+8, 4, PM.tabG);\n rect(25, bY+4, 5, 9, PM.s1); rect(26, bY+5, 3, 7, PM.s0);\n rect(25, bY+12, 4, 4, PM.fur2);\n } else { // collab\n rect(8, bY+2, 5, 8, PM.s1);\n line(5, bY+8, 6, PM.s1); rect(4, bY+7, 4, 4, PM.fur2); // pointing\n rect(25, bY+2, 5, 9, PM.s1); rect(26, bY+3, 3, 7, PM.s0);\n rect(25, bY+10, 4, 4, PM.fur2);\n }\n\n // ── LEGS ──\n if (seated) {\n rect(15, bY+15, 4, 5, c(PM.s1)); rect(16, bY+16, 2, 3, c(PM.s0));\n rect(21, bY+15, 4, 5, c(PM.s1)); rect(22, bY+16, 2, 3, c(PM.s0));\n rect(15, bY+19, 4, 4, c(PM.s0)); line(15, bY+22, 4, c(PM.g1));\n rect(21, bY+19, 4, 4, c(PM.s0)); line(21, bY+22, 4, c(PM.g1));\n } else if (pose === \"walk\") {\n rect(15, bY+15, 4, 12, PM.s1); rect(16, bY+16, 2, 10, PM.s0);\n rect(15, bY+26, 5, 4, PM.s0); line(15, bY+29, 5, PM.g1);\n rect(21, bY+15, 4, 10, PM.s1); rect(22, bY+16, 2, 8, PM.s0);\n rect(21, bY+24, 5, 4, PM.s0); line(21, bY+27, 5, PM.g1);\n } else {\n rect(15, bY+15, 4, 13, PM.s1); rect(16, bY+16, 2, 11, PM.s0);\n rect(21, bY+15, 4, 13, PM.s1); rect(22, bY+16, 2, 11, PM.s0);\n rect(15, bY+27, 5, 4, PM.s0); line(15, bY+30, 5, PM.g1);\n rect(21, bY+27, 5, 4, PM.s0); line(21, bY+30, 5, PM.g1);\n }\n\n // ── KEYBOARD / MONITOR (working) ──\n if (pose === \"working\") {\n rect(8, bY+16, 24, 4, c(PM.kb0)); rect(9, bY+15, 22, 4, c(PM.kb1));\n for (let i=0;i<7;i++) { px(10+i*3, bY+15, c(PM.kbG)); }\n glow(14, bY, 12, 7, \"rgba(120,80,255,0.22)\");\n glow(15, bY-3, 10, 4, \"rgba(120,80,255,0.16)\");\n px(12, bY-2, c(PM.hm)); // mic active light\n }\n\n // ── SHARED DISPLAY (collab) ──\n if (pose === \"collab\") {\n rect(0, 14, 9, 18, PM.con1); rect(1, 15, 7, 16, PM.con0);\n for (let i=0;i<3;i++) line(2, 16+i*5, 5, PM.conG);\n px(4, 28, PM.g2); px(3, 30, PM.g1); px(5, 30, PM.g1);\n rect(0, 31, 9, 2, PM.ch2);\n }\n\n // ── HEAD ──\n rect(14, hY, 12, 12, c(PM.fur2));\n rect(13, hY+1, 14, 10, c(PM.fur2));\n rect(14, hY-1, 12, 2, c(PM.fur1));\n rect(15, hY+3, 10, 6, c(PM.fur3)); // face lighter\n // Ears\n rect(12, hY+3, 3, 5, c(PM.fur2)); px(13, hY+4, c(PM.fur3)); px(13, hY+5, c(PM.fur3));\n rect(25, hY+3, 3, 5, c(PM.fur2)); px(26, hY+4, c(PM.fur3)); px(26, hY+5, c(PM.fur3));\n // Eyes\n if (sl) {\n line(15, hY+5, 4, c(PM.fur0)); px(16, hY+6, c(PM.fur0));\n line(21, hY+5, 4, c(PM.fur0)); px(22, hY+6, c(PM.fur0));\n } else {\n rect(15, hY+4, 4, 4, c(PM.eW)); rect(21, hY+4, 4, 4, c(PM.eW));\n const pOff = pose===\"thinking\" ? 1 : 0;\n rect(16+pOff, hY+5, 2, 2, c(PM.e)); rect(22+pOff, hY+5, 2, 2, c(PM.e));\n px(16+pOff, hY+5, c(PM.eH));\n // Brows\n line(15, hY+3, 4, c(PM.fur0)); line(21, hY+3, 4, c(PM.fur0));\n if (pose===\"thinking\") { px(18, hY+3, c(PM.fur0)); px(24, hY+3, c(PM.fur0)); }\n }\n // Muzzle\n rect(16, hY+8, 8, 4, c(PM.fur3)); rect(17, hY+9, 6, 3, c(PM.sk));\n px(18, hY+8, c(PM.fur0)); px(19, hY+8, c(PM.fur0)); // nostrils\n if (pose===\"collab\") {\n rect(17, hY+11, 6, 2, c(PM.fur0)); rect(18, hY+11, 4, 2, c(PM.e));\n } else if (!sl) {\n line(17, hY+11, 6, c(PM.fur0));\n }\n\n // ── HEADSET ──\n line(14, hY, 12, c(PM.h0)); // band\n rect(12, hY+2, 3, 4, c(PM.h0)); rect(25, hY+2, 3, 4, c(PM.h0)); // earcups\n rect(13, hY+3, 2, 3, c(PM.h1)); rect(26, hY+3, 2, 3, c(PM.h1));\n rect(11, hY+5, 2, 4, c(PM.h0)); // mic arm\n rect(10, hY+8, 3, 2, c(PM.h0)); // mic\n if (!sl) px(10, hY+9, PM.hm); // mic green light\n // Data visor (right eye)\n glow(26, hY+3, 3, 4, \"rgba(160,120,255,0.55)\");\n glow(26, hY+3, 3, 2, \"rgba(190,160,255,0.35)\");\n\n // ZZZ\n if (sl) {\n px(22, hY-3, c(PM.zz)); line(23, hY-5, 3, c(PM.zz)); px(23, hY-4, c(PM.zz)); px(25, hY-4, c(PM.zz));\n rect(26, hY-8, 4, 2, c(PM.zz)); px(26, hY-7, c(PM.zz)); px(29, hY-7, c(PM.zz));\n }\n}\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// 🥷 LIFE SUPPORT NINJA DRAWER\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nfunction drawNinja(ctx, pose, fox, foy, t) {\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\n const sl = pose === \"sleep\";\n const f = sl ? 0.45 : 1;\n const c = (col) => sl ? dimHex(col, f) : col;\n const bob = pose === \"idle\" ? Math.round(Math.sin(t * 0.07) * 0.6) : 0;\n const visorOn = !sl && (pose !== \"idle\");\n const visorCol = sl ? PN.v0 : visorOn ? PN.v3 : PN.v1;\n const bY = 22;\n const hY = 11;\n\n // ── WALL CONSOLE (idle) ──\n if (pose === \"idle\") {\n rect(1, 10+bob, 6, 30, c(PN.bl1)); rect(2, 11+bob, 4, 28, c(PN.bl0));\n for (let i=0;i<4;i++) line(2, 13+bob+i*6, 4, c(PN.blP));\n if (!sl) glow(1, 12+bob, 4, 20, \"rgba(200,20,100,0.12)\");\n }\n\n // ── SCARF ──\n const sf = pose === \"walk\" ? Math.round(Math.sin(t*0.1)*1.5) : 0;\n if (pose === \"idle\" || pose === \"sleep\") {\n rect(20, 20+bob, 4, 16, c(PN.sc2)); rect(21, 21+bob, 2, 14, c(PN.sc1)); rect(19, 22+bob, 2, 10, c(PN.sc1));\n } else if (pose === \"walk\") {\n rect(22, 18, 3, 8, PN.sc2); rect(23, 19+sf, 4, 6, PN.sc1); rect(25, 17-sf, 5, 5, PN.sc0);\n } else if (pose === \"working\") {\n rect(21, 18, 3, 10, c(PN.sc2)); rect(22, 19, 2, 8, c(PN.sc1));\n rect(18, 22, 3, 6, c(PN.sc0));\n } else {\n rect(21, 18, 4, 10, PN.sc2); rect(22, 19, 2, 8, PN.sc1);\n }\n\n // ── BODY TORSO ──\n rect(14, bY, 12, 18, c(PN.s2)); rect(15, bY+1, 10, 16, c(PN.s1));\n line(15, bY+2, 10, c(PN.pk1)); // chest accent\n rect(16, bY+5, 8, 2, c(PN.pk0));\n rect(19, bY+1, 2, 14, c(PN.tp1)); // center seam\n\n // ── ARMS ──\n if (pose === \"idle\") {\n rect(10, bY+4, 5, 8, c(PN.s2)); rect(25, bY+4, 5, 8, c(PN.s2));\n rect(11, bY+10, 14, 4, c(PN.s1)); rect(12, bY+11, 12, 2, c(PN.tp0));\n rect(10, bY+11, 4, 4, c(PN.s1)); rect(25, bY+11, 4, 4, c(PN.s1)); // gloves\n } else if (pose === \"thinking\") {\n // Left arm raised with forearm readout\n rect(9, bY+2, 5, 14, PN.s2); rect(10, bY+3, 3, 12, PN.s1);\n rect(9, bY+15, 5, 4, PN.s1);\n // Holographic forearm readout\n rect(0, bY+2, 9, 13, PN.hl0);\n glow(0, bY+2, 9, 13, \"rgba(200,20,100,0.18)\");\n line(1, bY+7, 7, PN.hl2); // heartbeat\n px(2, bY+6, PN.hl1); px(4, bY+5, PN.hl1); px(5, bY+7, PN.hl1);\n line(1, bY+12, 7, PN.hl1); px(4, bY+11, PN.pk3);\n rect(25, bY+4, 5, 12, PN.s2); rect(26, bY+5, 3, 10, PN.s1); rect(25, bY+15, 4, 4, PN.s1);\n } else if (pose === \"working\") {\n rect(8, bY+6, 6, 10, c(PN.s2)); rect(9, bY+7, 4, 8, c(PN.s1)); rect(8, bY+15, 5, 4, c(PN.s1));\n rect(26, bY+6, 6, 10, c(PN.s2)); rect(27, bY+7, 4, 8, c(PN.s1)); rect(26, bY+15, 5, 4, c(PN.s1));\n } else if (pose === \"walk\") {\n rect(9, bY+2, 5, 12, PN.s2); rect(10, bY+3, 3, 10, PN.s1); rect(9, bY+13, 4, 4, PN.s1);\n rect(25, bY+4, 5, 10, PN.s2); rect(26, bY+5, 3, 8, PN.s1); rect(25, bY+13, 4, 4, PN.s1);\n } else if (pose === \"collab\") {\n line(6, bY+8, 8, PN.s2); rect(4, bY+7, 5, 4, PN.s1); // arm+hand pointing\n rect(25, bY+4, 5, 10, PN.s2); rect(26, bY+5, 3, 8, PN.s1); rect(25, bY+13, 4, 4, PN.s1);\n } else { // sleep\n rect(10, bY+4, 5, 8, c(PN.s2)); rect(25, bY+4, 5, 8, c(PN.s2));\n rect(11, bY+10, 14, 4, c(PN.s1));\n rect(10, bY+11, 4, 4, c(PN.s1)); rect(25, bY+11, 4, 4, c(PN.s1));\n }\n\n // ── BELT ──\n rect(14, bY+18, 12, 3, c(PN.bl0)); line(15, bY+19, 10, c(PN.bl1));\n rect(15, bY+18, 3, 5, c(PN.tp0)); px(16, bY+19, c(PN.tp1));\n rect(22, bY+18, 3, 5, c(PN.tp0)); px(23, bY+19, c(PN.tp1));\n\n // ── LEGS ──\n if (pose === \"walk\") {\n rect(15, bY+21, 4, 13, PN.s2); rect(16, bY+22, 2, 11, PN.s1);\n rect(15, bY+33, 5, 4, PN.bt0); line(15, bY+36, 5, PN.bt1);\n rect(21, bY+21, 4, 10, PN.s2); rect(22, bY+22, 2, 8, PN.s1);\n rect(21, bY+30, 5, 4, PN.bt0); line(21, bY+33, 5, PN.bt1);\n } else {\n rect(15, bY+21, 4, 14, c(PN.s2)); rect(16, bY+22, 2, 12, c(PN.s1));\n rect(21, bY+21, 4, 14, c(PN.s2)); rect(22, bY+22, 2, 12, c(PN.s1));\n rect(15, bY+34, 5, 4, c(PN.bt0)); rect(21, bY+34, 5, 4, c(PN.bt0));\n }\n\n // ── WORKING CONSOLE ──\n if (pose === \"working\") {\n rect(7, bY+20, 26, 5, c(PN.bl0)); rect(8, bY+18, 24, 5, c(PN.bl1));\n for (let i=0;i<6;i++) { px(9+i*4, bY+17, c(PN.pk2)); rect(10+i*4, bY+18, 2, 2, c(PN.pk0)); }\n if (!sl) {\n glow(14, bY+13, 12, 6, \"rgba(220,30,120,0.2)\");\n glow(15, bY+7, 10, 8, \"rgba(200,20,100,0.12)\");\n }\n }\n\n // ── SHARED DISPLAY (collab) ──\n if (pose === \"collab\") {\n rect(0, 12, 10, 24, PN.bl1); rect(1, 13, 8, 22, PN.bl0);\n for (let i=0;i<5;i++) line(2, 14+i*4, 6, PN.blP);\n rect(0, 35, 10, 3, PN.bt0);\n }\n\n // ── HEAD ──\n rect(14, hY, 12, 11, c(PN.sk));\n rect(13, hY+1, 14, 9, c(PN.sk));\n rect(14, hY-1, 12, 2, c(PN.sk));\n // Hood\n rect(13, hY-1, 14, 7, c(PN.s1)); rect(14, hY-2, 12, 7, c(PN.s2));\n rect(15, hY-3, 10, 6, c(PN.s1)); rect(16, hY-4, 8, 5, c(PN.tp0));\n rect(12, hY+4, 3, 7, c(PN.s1)); rect(25, hY+4, 3, 7, c(PN.s1));\n // Visor line\n rect(14, hY+4, 12, 3, c(visorCol));\n line(15, hY+4, 10, c(sl ? PN.v0 : visorOn ? PN.pk3 : PN.v2));\n if (visorOn) glow(13, hY+3, 14, 5, \"rgba(220,30,120,0.22)\");\n // Visor walk pulse\n if (pose === \"walk\") glow(13, hY+3, 14, 5, `rgba(220,30,120,${0.12+0.1*Math.sin(t*0.15)})`);\n // Eyes\n if (sl) {\n line(16, hY+3, 4, c(PN.s0)); line(21, hY+3, 4, c(PN.s0));\n } else {\n rect(16, hY+2, 4, 3, c(PN.eW)); rect(21, hY+2, 4, 3, c(PN.eW));\n rect(17, hY+3, 2, 2, c(PN.e)); rect(22, hY+3, 2, 2, c(PN.e));\n line(16, hY+2, 4, c(PN.s0)); line(21, hY+2, 4, c(PN.s0)); // eyelid\n }\n // Lower mask\n rect(14, hY+7, 12, 5, c(PN.s2)); rect(15, hY+8, 10, 3, c(PN.s1));\n line(16, hY+9, 8, c(PN.tp0));\n\n // ZZZ\n if (sl) {\n px(22, hY-4, c(PN.zz)); line(23, hY-6, 3, c(PN.zz)); px(23, hY-5, c(PN.zz)); px(25, hY-5, c(PN.zz));\n rect(26, hY-9, 4, 2, c(PN.zz)); px(26, hY-8, c(PN.zz)); px(29, hY-8, c(PN.zz));\n }\n}\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// 🔧 SYSTEMS ENGINEER DRAWER\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nfunction drawEngineer(ctx, pose, fox, foy, t) {\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\n const sl = pose === \"sleep\";\n const f = sl ? 0.45 : 1;\n const c = (col) => sl ? dimHex(col, f) : col;\n const gogDown = pose === \"working\";\n const seated = pose === \"idle\" || pose === \"sleep\";\n const bY = seated ? 29 : 22;\n const hY = seated ? 16 : 9;\n\n // ── CRATE (idle, sleep) ──\n if (seated) {\n rect(9, 38, 22, 13, c(PE.cr1)); rect(10, 39, 20, 11, c(PE.cr0));\n line(10, 45, 20, c(PE.cr2)); px(19, 45, c(PE.crL));\n line(9, 38, 22, c(PE.cr1));\n px(11, 40, c(PE.crL)); px(28, 40, c(PE.crL)); px(11, 49, c(PE.crL)); px(28, 49, c(PE.crL));\n }\n\n // ── WORKBENCH (working) ──\n if (pose === \"working\") {\n rect(2, 39, 36, 5, c(PE.bh1)); rect(3, 37, 34, 5, c(PE.bh0));\n if (!sl) glow(3, 36, 34, 3, \"rgba(0,184,200,0.2)\");\n rect(25, 34, 5, 4, c(PE.mg0)); rect(26, 33, 3, 2, c(PE.mg1)); rect(29, 36, 2, 2, c(PE.mg0));\n }\n\n // ── SLEEP BENCH ──\n if (sl) {\n rect(3, 39, 34, 5, c(PE.bh1)); rect(4, 37, 32, 5, c(PE.bh0));\n rect(26, 36, 4, 3, c(PE.mg0)); rect(27, 35, 2, 2, c(PE.mg1));\n glow(22, 39, 8, 2, \"rgba(100,60,30,0.35)\");\n }\n\n // ── BODY ──\n rect(13, bY, 14, 16, c(PE.c2)); rect(14, bY+1, 12, 14, c(PE.c1));\n line(14, bY, 12, c(PE.c3));\n line(14, bY+1, 4, c(PE.cy2)); // shine\n rect(12, bY+3, 2, 4, c(PE.c3)); rect(26, bY+3, 2, 4, c(PE.c3)); // rolled sleeves\n line(14, bY+2, 12, c(PE.cy1));\n // Grease stains\n px(17, bY+6, c(PE.gr)); px(21, bY+4, c(PE.gr)); px(23, bY+9, c(PE.gr));\n\n // ── ARMS ──\n if (pose === \"idle\") {\n rect(9, bY+2, 5, 9, c(PE.c2)); rect(10, bY+3, 3, 7, c(PE.c1));\n rect(9, bY+10, 5, 4, c(PE.sk));\n rect(5, bY+12, 5, 3, c(PE.rl0)); rect(6, bY+13, 3, 2, c(PE.rl1)); // rag\n rect(26, bY+2, 5, 9, c(PE.c2)); rect(27, bY+3, 3, 7, c(PE.c1)); rect(26, bY+10, 5, 4, c(PE.sk));\n rect(30, bY+8, 4, 6, c(PE.mg0)); rect(31, bY+7, 2, 2, c(PE.mg1)); rect(33, bY+10, 2, 3, c(PE.mg0));\n if (!sl) { px(31, bY+5, \"rgba(200,200,200,0.5)\"); px(33, bY+4, \"rgba(200,200,200,0.4)\"); }\n } else if (pose === \"thinking\") {\n rect(9, bY+2, 5, 11, PE.c2); rect(10, bY+3, 3, 9, PE.c1);\n rect(9, bY+12, 5, 4, PE.sk); // hand on chin\n rect(26, bY+2, 5, 8, PE.c2); rect(27, bY+3, 3, 6, PE.c1); rect(26, bY+9, 4, 4, PE.sk);\n // Holo blueprints\n rect(0, bY-6, 12, 18, PE.hl0);\n glow(0, bY-6, 12, 18, \"rgba(0,184,200,0.14)\");\n for (let i=0;i<4;i++) line(1, bY-4+i*4, 10, PE.hl2);\n rect(1, bY-4, 5, 4, \"rgba(0,184,200,0.35)\"); rect(6, bY+4, 4, 4, \"rgba(0,184,200,0.35)\");\n glow(14, bY-6, 12, 8, \"rgba(0,184,200,0.14)\");\n } else if (pose === \"working\") {\n rect(8, bY+4, 6, 10, c(PE.c2)); rect(9, bY+5, 4, 8, c(PE.c1)); rect(8, bY+13, 5, 4, c(PE.sk));\n rect(26, bY+4, 6, 10, c(PE.c2)); rect(27, bY+5, 4, 8, c(PE.c1)); rect(26, bY+13, 5, 4, c(PE.sk));\n // Sparks\n for (let i=0;i<7;i++) {\n const sx = 14+Math.round(Math.sin(t*0.25+i*0.9)*5);\n const sy = bY+14+Math.round(Math.cos(t*0.3+i)*2);\n px(sx, sy, c([PE.sp0,PE.sp1,PE.sp2][i%3]));\n }\n glow(14, bY, 12, 7, \"rgba(0,184,200,0.18)\");\n } else if (pose === \"walk\") {\n rect(9, bY+2, 5, 10, PE.c2); rect(10, bY+3, 3, 8, PE.c1); rect(9, bY+11, 4, 4, PE.sk);\n rect(4, bY+5, 3, 14, PE.wr1); rect(3, bY+5, 5, 4, PE.wrH); rect(3, bY+6, 2, 2, PE.c1);\n rect(26, bY+4, 5, 9, PE.c2); rect(27, bY+5, 3, 7, PE.c1); rect(26, bY+12, 4, 4, PE.sk);\n rect(30, bY+7, 6, 8, PE.tb0); rect(31, bY+8, 4, 6, PE.tb1); line(31, bY+10, 4, PE.tbG);\n } else if (pose === \"collab\") {\n rect(8, bY+2, 5, 8, PE.c2);\n line(3, bY+8, 7, PE.c2); rect(2, bY+7, 4, 4, PE.sk);\n rect(0, bY+2, 3, 14, PE.wr1); rect(0, bY+2, 5, 4, PE.wrH);\n rect(26, bY+2, 5, 9, PE.c2); rect(27, bY+3, 3, 7, PE.c1); rect(26, bY+10, 4, 4, PE.sk);\n } else { // sleep\n rect(9, bY+4, 6, 10, c(PE.c2)); rect(26, bY+4, 6, 10, c(PE.c2));\n rect(9, bY+13, 20, 5, c(PE.c2)); // arms on bench\n }\n\n // ── BELT ──\n rect(13, bY+16, 14, 3, c(PE.blt)); line(14, bY+17, 12, c(PE.blt2));\n for (let i=0;i<4;i++) { rect(14+i*3, bY+15, 2, 5, c(PE.pch)); px(15+i*3, bY+16, c(PE.cy0)); }\n rect(23, bY+15, 2, 5, c(PE.wr1)); rect(23, bY+14, 2, 2, c(PE.wr0));\n\n // ── LEGS ──\n if (seated) {\n rect(15, bY+19, 4, 7, c(PE.c2)); rect(16, bY+20, 2, 5, c(PE.c1));\n rect(21, bY+19, 4, 7, c(PE.c2)); rect(22, bY+20, 2, 5, c(PE.c1));\n rect(15, bY+25, 5, 4, c(PE.bt0)); rect(21, bY+25, 5, 4, c(PE.bt0));\n } else if (pose === \"walk\") {\n rect(15, bY+19, 4, 13, PE.c2); rect(16, bY+20, 2, 11, PE.c1);\n rect(15, bY+31, 5, 4, PE.bt0);\n rect(21, bY+19, 4, 10, PE.c2); rect(22, bY+20, 2, 8, PE.c1);\n rect(21, bY+28, 5, 4, PE.bt0);\n } else {\n rect(15, bY+19, 4, 13, PE.c2); rect(16, bY+20, 2, 11, PE.c1);\n rect(21, bY+19, 4, 13, PE.c2); rect(22, bY+20, 2, 11, PE.c1);\n rect(15, bY+31, 5, 4, PE.bt0); rect(21, bY+31, 5, 4, PE.bt0);\n }\n\n // ── HEAD ──\n rect(13, hY, 14, 12, c(PE.sk)); rect(14, hY-1, 12, 14, c(PE.sk));\n rect(15, hY-2, 10, 16, c(PE.sk));\n // Hair stubble\n rect(14, hY-2, 12, 3, c(PE.c1)); rect(15, hY-3, 10, 3, c(PE.c2)); px(13, hY-1, c(PE.c1));\n // Eyes\n if (sl) {\n line(15, hY+5, 5, c(PE.skD)); px(16, hY+6, c(PE.skD));\n line(22, hY+5, 5, c(PE.skD)); px(23, hY+6, c(PE.skD));\n } else {\n rect(15, hY+4, 5, 4, c(PE.eW)); rect(22, hY+4, 5, 4, c(PE.eW));\n rect(16, hY+5, 2, 2, c(PE.e)); rect(23, hY+5, 2, 2, c(PE.e));\n px(16, hY+5, c(PE.og3));\n if (pose===\"working\") { line(15, hY+4, 5, c(PE.skD)); line(22, hY+4, 5, c(PE.skD)); }\n }\n px(18, hY+8, c(PE.skD)); px(19, hY+8, c(PE.skD)); // nose\n if (pose===\"collab\") { line(16, hY+10, 7, c(PE.skD)); px(17, hY+11, c(PE.skD)); px(21, hY+11, c(PE.skD)); }\n else if (!sl) line(17, hY+10, 5, c(PE.skD));\n\n // ── GOGGLES ──\n const gY = gogDown ? hY+4 : hY-1;\n line(12, gY, 17, c(PE.og0)); // band\n rect(14, gY, 5, 5, c(PE.og1)); rect(23, gY, 5, 5, c(PE.og1));\n rect(15, gY+1, 3, 3, c(PE.og3)); rect(24, gY+1, 3, 3, c(PE.og3));\n px(25, gY+1, c(PE.og0)); px(26, gY+2, c(PE.og0)); // crack right lens\n line(19, gY+2, 4, c(PE.og0)); // bridge\n if (gogDown && !sl) {\n glow(15, gY+1, 3, 3, \"rgba(0,184,200,0.55)\");\n glow(24, gY+1, 3, 3, \"rgba(0,184,200,0.5)\");\n glow(14, gY, 14, 6, \"rgba(0,184,200,0.15)\");\n }\n\n // ── BLUEPRINT (collab) ──\n if (pose === \"collab\") {\n rect(0, 8, 12, 22, PE.hl0);\n glow(0, 8, 12, 22, \"rgba(0,184,200,0.12)\");\n for (let i=0;i<5;i++) line(1, 9+i*4, 10, PE.hl2);\n rect(1, 9, 5, 4, \"rgba(0,184,200,0.35)\"); rect(6, 21, 4, 4, \"rgba(0,184,200,0.35)\");\n rect(0, 29, 12, 2, PE.bh1);\n }\n\n // ZZZ\n if (sl) {\n px(22, hY-4, c(PE.zz)); line(23, hY-7, 3, c(PE.zz)); px(23, hY-6, c(PE.zz)); px(25, hY-6, c(PE.zz));\n rect(26, hY-10, 4, 2, c(PE.zz)); px(26, hY-9, c(PE.zz)); px(29, hY-9, c(PE.zz));\n }\n}\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// 📚 STATION ARCHIVIST DRAWER\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nfunction drawArchivist(ctx, pose, fox, foy, t) {\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\n const sl = pose === \"sleep\";\n const f = sl ? 0.42 : 1;\n const c = (col) => sl ? dimHex(col, f) : col;\n const bob = pose === \"idle\" ? Math.round(Math.sin(t * 0.05) * 0.7) : 0;\n const seated = pose === \"idle\" || pose === \"sleep\";\n const bY = seated ? 24 + bob : (pose === \"working\" ? 20 : 20);\n const hY = seated ? 12 + bob : 8;\n const glassGlow = (pose===\"working\"||pose===\"collab\") ? PA.am3 : PA.cxC;\n\n // ── ORBITING DATA CRYSTALS ──\n function crystal(cx, cy, col, bright) {\n rect(cx, cy, 2, 2, c(col)); if (!sl) px(cx, cy, bright);\n }\n if (pose === \"idle\") {\n const a = t * 0.04;\n [[Math.cos(a)*8, Math.sin(a)*4],[Math.cos(a+1.57)*8, Math.sin(a+1.57)*4],\n [Math.cos(a+3.14)*8, Math.sin(a+3.14)*4],[Math.cos(a+4.71)*8, Math.sin(a+4.71)*4]\n ].forEach(([dx,dy],i) => {\n const col=[PA.cx0,PA.cx1,PA.cxB,PA.cxC][i];\n crystal(Math.round(20+dx), Math.round(22+dy+bob), col, PA.cx2);\n });\n } else if (pose === \"working\") {\n const a = t * 0.12;\n for (let i=0;i<5;i++) {\n const angle = a + i*1.26;\n crystal(Math.round(20+Math.cos(angle)*10), Math.round(20+Math.sin(angle)*5), PA.cx0, PA.cx2);\n }\n } else if (sl) {\n [[-7,1],[7,-2],[-4,6],[9,3]].forEach(([dx,dy],i) => {\n crystal(20+dx, 22+dy, [PA.cx0,PA.cx1,PA.cxB,PA.cxC][i], PA.cx2);\n });\n }\n\n // ── CHAIR (seated) ──\n if (seated) {\n rect(8, hY+12, 24, 40, c(PA.ch2)); rect(9, hY+13, 22, 38, c(PA.ch1));\n rect(10, hY+14, 20, 36, c(PA.r1));\n line(8, hY+12, 24, c(PA.am1)); line(8, hY+51, 24, c(PA.am1));\n rect(8, hY+13, 2, 38, c(PA.am0)); rect(30, hY+13, 2, 38, c(PA.am0));\n rect(10, hY+51, 3, 5, c(PA.ch2)); rect(27, hY+51, 3, 5, c(PA.ch2));\n }\n\n // ── ARCHIVE TERMINAL (working) ──\n if (pose === \"working\") {\n rect(1, 34, 38, 8, PA.tm1); rect(2, 32, 36, 6, PA.tm0);\n glow(3, 31, 34, 4, \"rgba(192,128,32,0.18)\");\n rect(4, 28, 32, 4, PA.hl0); line(4, 29, 32, PA.tmG);\n }\n\n // ── ROBE BODY ──\n rect(12, bY, 16, 20, c(PA.r2)); rect(13, bY+1, 14, 18, c(PA.r1));\n rect(14, bY+2, 12, 16, c(PA.r3));\n rect(12, bY+2, 2, 18, c(PA.am1)); rect(26, bY+2, 2, 18, c(PA.am1));\n rect(16, bY+3, 8, 2, c(PA.am2)); rect(17, bY+5, 6, 2, c(PA.am1)); px(19, bY+7, c(PA.amLt));\n rect(14, bY+4, 12, 12, c(PA.r3));\n rect(15, bY+5, 10, 10, c(PA.cr0));\n line(15, bY+6, 10, c(PA.am0)); line(15, bY+9, 10, c(PA.am0)); line(15, bY+12, 10, c(PA.am0));\n\n // ── ARMS ──\n if (pose === \"idle\") {\n rect(10, bY+2, 5, 13, c(PA.r1)); rect(11, bY+3, 3, 11, c(PA.r0)); rect(10, bY+14, 4, 4, c(PA.sk));\n rect(26, bY+2, 5, 12, c(PA.r1)); rect(27, bY+3, 3, 10, c(PA.r0)); rect(26, bY+13, 4, 4, c(PA.sk));\n // Floating holo book\n rect(28, bY-12+bob, 12, 14, c(PA.bk0)); rect(29, bY-11+bob, 10, 12, c(PA.bk1));\n rect(30, bY-10+bob, 8, 10, c(PA.bkP));\n for (let i=0;i<3;i++) line(31, bY-8+bob+i*3, 6, c(PA.am0));\n rect(28, bY-12+bob, 12, 14, c(\"rgba(192,128,32,0.12)\"));\n rect(28, bY-11+bob, 2, 12, c(PA.bkT));\n } else if (pose === \"thinking\") {\n rect(10, bY+2, 5, 12, PA.r1); rect(11, bY+3, 3, 10, PA.r0); rect(10, bY+13, 4, 4, PA.sk);\n rect(26, bY+2, 5, 8, PA.r1); rect(26, bY+9, 5, 5, PA.sk); // hand adj glasses\n // Crystals clustering\n [[-5,-5],[-3,-7],[1,-6],[3,-4],[-2,-3],[4,-7]].forEach(([dx,dy],i) => {\n rect(19+dx, bY-2+dy, 2, 2, [PA.cx0,PA.cx1,PA.cxB,PA.cx2,PA.cxC,PA.cx0][i]);\n });\n } else if (pose === \"working\") {\n rect(9, bY+4, 5, 11, PA.r1); rect(10, bY+5, 3, 9, PA.r0); rect(9, bY+14, 4, 4, PA.sk);\n rect(26, bY+4, 5, 11, PA.r1); rect(27, bY+5, 3, 9, PA.r0); rect(26, bY+14, 4, 4, PA.sk);\n // Golden data streams\n for (let i=0;i<6;i++) {\n const a = t*0.1+i*1.05;\n const dx = Math.round(Math.cos(a)*6), dy = Math.round(Math.sin(a)*3);\n px(20+dx, bY+6+dy, PA.dt0); px(20+dx+1, bY+7+dy, PA.dt1);\n }\n glow(13, bY, 14, 16, \"rgba(192,128,32,0.14)\");\n glow(14, bY-4, 12, 6, \"rgba(192,128,32,0.12)\");\n } else if (pose === \"walk\") {\n rect(10, bY+2, 5, 11, PA.r1); rect(11, bY+3, 3, 9, PA.r0); rect(10, bY+12, 4, 4, PA.sk);\n // Text crystals trailing\n const tr = Math.sin(t*0.08)*1.5;\n [[-6,-1],[-9,1],[-12,-2],[-15,0],[-18,-3]].forEach(([dx,dy],i) => {\n const cy = Math.round(bY+13+dy+tr*(i+1)*0.3);\n rect(20+dx, cy, 4, 3, PA.tc); rect(21+dx, cy+1, 2, 1, PA.amLt); px(20+dx, cy, PA.amLt);\n });\n rect(26, bY+2, 5, 11, PA.r1); rect(27, bY+3, 3, 9, PA.r0); rect(26, bY+12, 4, 4, PA.sk);\n } else if (pose === \"collab\") {\n rect(10, bY+2, 5, 10, PA.r1); rect(11, bY+3, 3, 8, PA.r0); rect(10, bY+11, 4, 4, PA.sk);\n // Large tome\n rect(26, bY-7, 14, 18, PA.bk0); rect(27, bY-6, 12, 16, PA.bk1);\n rect(28, bY-5, 10, 14, PA.bkP);\n for (let i=0;i<4;i++) line(29, bY-3+i*3, 8, PA.am0);\n rect(28, bY+4, 4, 3, PA.sk); px(32, bY+5, PA.sk); // pointing\n // Text fragments\n [[2,-2],[4,2],[-2,4]].forEach(([dx,dy]) => { rect(20+dx, bY+dy, 3, 2, PA.tc); px(20+dx, bY+dy, PA.amLt); });\n rect(26, bY+2, 5, 9, PA.r1); rect(27, bY+3, 3, 7, PA.r0); rect(26, bY+10, 4, 4, PA.sk);\n } else { // sleep\n rect(10, bY+4, 5, 10, c(PA.r1)); rect(26, bY+4, 5, 10, c(PA.r1));\n rect(14, bY+14, 12, 8, c(PA.bk0)); rect(15, bY+15, 10, 6, c(PA.bkP));\n line(16, bY+17, 8, c(PA.am0));\n }\n\n // ── ROBE LOWER ──\n if (seated) {\n rect(11, bY+20, 18, 14, c(PA.r2)); rect(12, bY+21, 16, 12, c(PA.r1));\n rect(12, bY+22, 16, 12, c(PA.r3));\n line(11, bY+20, 18, c(PA.am1)); line(11, bY+33, 18, c(PA.am1));\n rect(15, bY+31, 4, 4, c(PA.r1)); rect(21, bY+31, 4, 4, c(PA.r1));\n } else if (pose === \"walk\") {\n rect(11, bY+20, 18, 16, PA.r2); rect(12, bY+21, 16, 14, PA.r1);\n rect(12, bY+22, 16, 14, PA.r3); line(11, bY+35, 18, PA.am1);\n rect(14, bY+33, 4, 4, PA.r1); rect(20, bY+31, 4, 4, PA.r1);\n } else {\n rect(11, bY+20, 18, 16, PA.r2); rect(12, bY+21, 16, 14, PA.r1);\n rect(12, bY+22, 16, 14, PA.r3); line(11, bY+35, 18, PA.am1);\n rect(14, bY+33, 4, 4, PA.r1); rect(20, bY+33, 4, 4, PA.r1);\n }\n\n // ── HEAD ──\n rect(15, hY, 10, 12, c(PA.sk));\n rect(14, hY+1, 12, 10, c(PA.sk));\n rect(15, hY-1, 10, 14, c(PA.sk));\n // Hair wisps\n rect(15, hY-1, 10, 3, c(PA.r1)); rect(16, hY-2, 8, 3, c(PA.r2));\n rect(17, hY-3, 6, 2, c(PA.rLt));\n // Eyes\n if (sl) {\n line(15, hY+5, 4, c(PA.skD)); px(16, hY+6, c(PA.skD));\n line(21, hY+5, 4, c(PA.skD)); px(22, hY+6, c(PA.skD));\n } else {\n rect(15, hY+4, 4, 4, c(PA.eW)); rect(21, hY+4, 4, 4, c(PA.eW));\n rect(16, hY+5, 2, 2, c(PA.e)); rect(22, hY+5, 2, 2, c(PA.e));\n if (pose===\"thinking\") { rect(16, hY+4, 2, 2, c(PA.e)); rect(22, hY+4, 2, 2, c(PA.e)); } // look up\n glow(15, hY+4, 4, 2, c(glassGlow)+\"66\"); glow(21, hY+4, 4, 2, c(glassGlow)+\"66\");\n }\n px(18, hY+8, c(PA.skD)); px(19, hY+8, c(PA.skD)); // nose\n if (!sl) { line(16, hY+10, 7, c(PA.skD)); px(16, hY+11, c(PA.skD)); px(22, hY+11, c(PA.skD)); }\n\n // ── ROUND GLASSES ──\n // Left lens frame\n line(14, hY+3, 6, c(PA.gl0)); line(14, hY+7, 6, c(PA.gl1));\n line(14, hY+3, 1, c(PA.gl0), true); line(19, hY+3, 1, c(PA.gl1), true);\n // Right lens frame\n line(21, hY+3, 6, c(PA.gl0)); line(21, hY+7, 6, c(PA.gl1));\n line(21, hY+3, 1, c(PA.gl0), true); line(26, hY+3, 1, c(PA.gl1), true);\n // Bridge\n px(20, hY+5, c(PA.gl0));\n // Temples\n px(13, hY+5, c(PA.glL)); px(27, hY+5, c(PA.glL));\n // Askew if sleeping\n if (sl) { px(15, hY+3, c(PA.gl0)); px(16, hY+2, c(PA.gl0)); }\n // Glow in lenses\n if ((pose===\"working\"||pose===\"collab\") && !sl) {\n glow(15, hY+4, 4, 3, \"rgba(200,144,32,0.5)\");\n glow(22, hY+4, 4, 3, \"rgba(200,144,32,0.5)\");\n }\n\n // ZZZ\n if (sl) {\n px(23, hY-4, c(PA.zz)); line(24, hY-7, 3, c(PA.zz)); px(24, hY-6, c(PA.zz)); px(26, hY-6, c(PA.zz));\n rect(27, hY-10, 4, 2, c(PA.zz)); px(27, hY-9, c(PA.zz)); px(30, hY-9, c(PA.zz));\n }\n}\n\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n// CHARACTER REGISTRY + APP\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nconst CHARS = [\n { id:\"monkey\", emoji:\"🐒\", label:\"Space Monkey\", sub:\"Mission Director\", accent:\"#9B6FE8\", fn:drawMonkey },\n { id:\"ninja\", emoji:\"🥷\", label:\"Life Support Officer\", sub:\"Infrastructure Controller\", accent:\"#FF40B0\", fn:drawNinja },\n { id:\"engineer\", emoji:\"🔧\", label:\"Systems Engineer\", sub:\"Coder / Builder\", accent:\"#20D0E8\", fn:drawEngineer },\n { id:\"archivist\", emoji:\"📚\", label:\"Station Archivist\", sub:\"Memory & Knowledge\", accent:\"#E0A030\", fn:drawArchivist },\n];\nconst POSES = [\"IDLE\",\"THINK\",\"WORK\",\"SLEEP\",\"WALK\",\"COLLAB\"];\nconst POSE_KEYS = [\"idle\",\"thinking\",\"working\",\"sleep\",\"walk\",\"collab\"];\n\nexport default function App() {\n const [tick, setTick] = useState(0);\n const [activeChar, setActiveChar] = useState(0);\n const [hoveredPose, setHoveredPose] = useState(0);\n const [exporting, setExporting] = useState(null);\n const tRef = useRef(0);\n\n const sheetCanvases = CHARS.map(() => useRef(null));\n const displayCanvases = CHARS.map(() => useRef(null));\n const previewRef = useRef(null);\n\n useEffect(() => {\n let live = true;\n function loop() {\n if (!live) return;\n tRef.current++;\n setTick(n => n + 1);\n requestAnimationFrame(loop);\n }\n requestAnimationFrame(loop);\n return () => { live = false; };\n }, []);\n\n useEffect(() => {\n CHARS.forEach((ch, ci) => {\n const cvs = sheetCanvases[ci].current;\n if (!cvs) return;\n const ctx = cvs.getContext(\"2d\");\n ctx.clearRect(0, 0, 1920, 240);\n POSE_KEYS.forEach((pose, pi) => ch.fn(ctx, pose, pi * FRAME_W, 0, tRef.current));\n // Scale to display canvas\n const disp = displayCanvases[ci].current;\n if (disp) {\n const dctx = disp.getContext(\"2d\");\n dctx.clearRect(0, 0, disp.width, disp.height);\n dctx.imageSmoothingEnabled = false;\n dctx.drawImage(cvs, 0, 0, disp.width, disp.height);\n }\n });\n }, [tick]);\n\n useEffect(() => {\n const cvs = previewRef.current;\n if (!cvs) return;\n const ctx = cvs.getContext(\"2d\");\n ctx.clearRect(0, 0, FRAME_W, FRAME_H);\n CHARS[activeChar].fn(ctx, POSE_KEYS[hoveredPose], 0, 0, tRef.current);\n }, [tick, activeChar, hoveredPose]);\n\n function exportPNG(ci) {\n setExporting(ci);\n setTimeout(() => {\n const cvs = sheetCanvases[ci].current;\n if (!cvs) { setExporting(null); return; }\n const a = document.createElement(\"a\");\n a.download = `${CHARS[ci].id}-spritesheet-1920x240.png`;\n a.href = cvs.toDataURL(\"image/png\");\n a.click();\n setExporting(null);\n }, 80);\n }\n\n const acc = CHARS[activeChar].accent;\n\n return (\n <div style={{ minHeight:\"100vh\", background:\"#12182A\", color:\"#D0C8F0\", fontFamily:\"'Courier New', monospace\", padding:\"18px 14px 40px\", boxSizing:\"border-box\" }}>\n {CHARS.map((_,ci) => <canvas key={ci} ref={sheetCanvases[ci]} width={1920} height={240} style={{display:\"none\"}} />)}\n\n {/* Header */}\n <div style={{textAlign:\"center\",marginBottom:22}}>\n <div style={{fontSize:9,letterSpacing:6,color:\"#3A3468\",textTransform:\"uppercase\",marginBottom:3}}>Deep Space Station · Crew Registry</div>\n <h1 style={{margin:0,fontSize:18,fontWeight:900,letterSpacing:3,color:\"#F0ECF8\"}}>SPRITE SHEET GENERATOR</h1>\n <div style={{fontSize:9,color:\"#2C2848\",marginTop:3,letterSpacing:4}}>16-BIT PIXEL ART · 6 POSES · TRUE TRANSPARENCY · 1920×240</div>\n </div>\n\n {/* Character tabs */}\n <div style={{display:\"flex\",gap:5,justifyContent:\"center\",marginBottom:18,flexWrap:\"wrap\"}}>\n {CHARS.map((ch,i) => (\n <button key={ch.id} onClick={() => setActiveChar(i)} style={{\n background: activeChar===i ? ch.accent+\"18\" : \"transparent\",\n border:`1.5px solid ${activeChar===i ? ch.accent : \"#1A183A\"}`,\n color: activeChar===i ? ch.accent : \"#504888\",\n padding:\"6px 13px\", borderRadius:4, cursor:\"pointer\",\n fontFamily:\"inherit\", fontSize:11, letterSpacing:1.5, transition:\"all 0.15s\",\n }}>{ch.emoji} {ch.id.toUpperCase()}</button>\n ))}\n </div>\n\n {/* Preview + pose picker */}\n <div style={{display:\"flex\",gap:14,justifyContent:\"center\",marginBottom:22,flexWrap:\"wrap\",alignItems:\"flex-start\"}}>\n <div>\n <div style={{fontSize:8,color:\"#2C2848\",letterSpacing:4,marginBottom:5,textAlign:\"center\"}}>LIVE PREVIEW · {POSES[hoveredPose]}</div>\n <div style={{border:`1px solid ${acc}2A`,borderRadius:7,overflow:\"hidden\",background:\"#080C18\",lineHeight:0}}>\n <canvas ref={previewRef} width={320} height={240} style={{display:\"block\",imageRendering:\"pixelated\"}} />\n </div>\n <div style={{textAlign:\"center\",marginTop:6,fontSize:10,color:acc,letterSpacing:1}}>{CHARS[activeChar].emoji} {CHARS[activeChar].label}</div>\n <div style={{textAlign:\"center\",fontSize:8,color:\"#383460\",letterSpacing:1}}>{CHARS[activeChar].sub}</div>\n </div>\n <div style={{display:\"flex\",flexDirection:\"column\",gap:7}}>\n <div style={{fontSize:8,color:\"#2C2848\",letterSpacing:4,marginBottom:1}}>SELECT POSE</div>\n <div style={{display:\"grid\",gridTemplateColumns:\"1fr 1fr\",gap:4}}>\n {POSES.map((p,pi) => (\n <button key={p} onMouseEnter={() => setHoveredPose(pi)} onClick={() => setHoveredPose(pi)} style={{\n padding:\"7px 11px\", background: hoveredPose===pi ? acc+\"12\" : \"transparent\",\n border:`1px solid ${hoveredPose===pi ? acc : \"#16143A\"}`,\n color: hoveredPose===pi ? acc : \"#484870\",\n borderRadius:3, cursor:\"pointer\", fontFamily:\"inherit\", fontSize:10, letterSpacing:1.5, transition:\"all 0.1s\", textAlign:\"left\",\n }}><span style={{opacity:0.4,fontSize:8}}>0{pi+1} </span>{p}</button>\n ))}\n </div>\n <button onClick={() => exportPNG(activeChar)} disabled={exporting!==null} style={{\n marginTop:2,padding:\"9px 14px\",background:acc+\"14\",\n border:`1.5px solid ${acc}`,color:acc,borderRadius:4,\n cursor:\"pointer\",fontFamily:\"inherit\",fontSize:10,letterSpacing:2,transition:\"all 0.14s\",\n }}>{exporting===activeChar ? \"EXPORTING…\" : \"↓ EXPORT 1920×240 PNG\"}</button>\n <div style={{fontSize:8,color:\"#1E1C38\",letterSpacing:1,textAlign:\"center\"}}>transparent · anti-aliased for #12182A</div>\n </div>\n </div>\n\n {/* All 4 strips */}\n <div style={{fontSize:8,color:\"#1E1C38\",letterSpacing:4,marginBottom:12,textAlign:\"center\"}}>ALL SPRITE SHEETS — EXPORT FOR FULL 1920px</div>\n <div style={{display:\"flex\",flexDirection:\"column\",gap:14}}>\n {CHARS.map((ch,ci) => (\n <div key={ch.id}>\n <div style={{display:\"flex\",alignItems:\"center\",gap:8,marginBottom:3}}>\n <span style={{fontSize:10,color:ch.accent,letterSpacing:1.5}}>{ch.emoji} {ch.label.toUpperCase()}</span>\n <span style={{fontSize:8,color:\"#2C2848\"}}>— {ch.sub}</span>\n <button onClick={() => exportPNG(ci)} disabled={exporting!==null} style={{\n marginLeft:\"auto\",padding:\"2px 9px\",background:\"transparent\",\n border:`1px solid ${ch.accent}44`,color:ch.accent,borderRadius:3,\n cursor:\"pointer\",fontFamily:\"inherit\",fontSize:9,letterSpacing:1,\n }}>↓ PNG</button>\n </div>\n <div style={{display:\"flex\",marginBottom:2}}>\n {POSES.map(p => <div key={p} style={{flex:\"0 0 96px\",minWidth:96,fontSize:7,color:\"#1E1C38\",letterSpacing:2,textAlign:\"center\"}}>{p}</div>))}\n </div>\n <div style={{overflowX:\"auto\",borderRadius:3,border:`1px solid ${ch.accent}1A`}}>\n <div"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/components/sprites/SpriteSheetGenerator.tsx\", \"content\": \"import { useEffect, useRef, useState } from \\\"react\\\";\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// PIXEL ART ENGINE\\n// Sprites drawn on 40×56 pixel grid, scaled to fill 320×240 frame\\n// Each \\\"pixel\\\" = PW wide × PH tall → 200×224px centered in 320×240\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n\\nconst PW = 5, PH = 4;\\nconst GW = 40, GH = 56;\\nconst SPRITE_W = GW * PW; // 200\\nconst SPRITE_H = GH * PH; // 224\\nconst FRAME_W = 320, FRAME_H = 240;\\nconst OX = Math.floor((FRAME_W - SPRITE_W) / 2); // 60\\nconst OY = Math.floor((FRAME_H - SPRITE_H) / 2); // 8\\n\\nfunction makeDraw(ctx, fox, foy) {\\n const px = (c, r, color, cw = 1, ch = 1) => {\\n if (!color || color === \\\".\\\") return;\\n ctx.fillStyle = color;\\n ctx.fillRect(fox + OX + c * PW, foy + OY + r * PH, cw * PW, ch * PH);\\n };\\n const line = (c, r, len, color, vert = false) => {\\n for (let i = 0; i < len; i++) vert ? px(c, r + i, color) : px(c + i, r, color);\\n };\\n const rect = (c, r, w, h, color) => {\\n if (!color) return;\\n for (let row = 0; row < h; row++) line(c, r + row, w, color);\\n };\\n const glow = (c, r, w, h, color) => {\\n ctx.fillStyle = color;\\n ctx.fillRect(fox + OX + c * PW, foy + OY + r * PH, w * PW, h * PH);\\n };\\n return { px, line, rect, glow };\\n}\\n\\n// Dim a hex color for sleep state\\nfunction dimHex(col, f) {\\n if (!col || col[0] !== \\\"#\\\" || col.length < 7) return col;\\n const r = parseInt(col.slice(1,3),16), g = parseInt(col.slice(3,5),16), b = parseInt(col.slice(5,7),16);\\n return `rgb(${Math.round(r*f)},${Math.round(g*f)},${Math.round(b*f)})`;\\n}\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// PALETTES\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\nconst PM = {\\n fur0:\\\"#5C3A1E\\\", fur1:\\\"#8B5E3C\\\", fur2:\\\"#A0724A\\\", fur3:\\\"#C4956A\\\",\\n s0:\\\"#2A1260\\\", s1:\\\"#4C2A8A\\\", s2:\\\"#6B3FBF\\\", s3:\\\"#9B6FE8\\\", sLt:\\\"#C4A0FF\\\",\\n g0:\\\"#7A5810\\\", g1:\\\"#B08020\\\", g2:\\\"#D4A830\\\", g3:\\\"#FFD060\\\", gLt:\\\"#FFE898\\\",\\n e:\\\"#0A0408\\\", eW:\\\"#F0E8E0\\\", eH:\\\"#FFD4B0\\\",\\n sk:\\\"#D4A87A\\\", skD:\\\"#A87850\\\",\\n h0:\\\"#1A0C48\\\", h1:\\\"#3A2880\\\", hm:\\\"#60CC60\\\",\\n ch0:\\\"#12102A\\\", ch1:\\\"#20183C\\\", ch2:\\\"#2C2250\\\",\\n kb0:\\\"#221880\\\", kb1:\\\"#4040B0\\\", kbG:\\\"#8090FF\\\",\\n t0:\\\"#3C1C0C\\\", t1:\\\"#5C2C10\\\", t2:\\\"#7C3C18\\\",\\n p0:\\\"#7A2828\\\", p1:\\\"#A83A3A\\\", pG:\\\"#CC7020\\\",\\n tab0:\\\"#141E30\\\", tab1:\\\"#1E3048\\\", tabG:\\\"#4080CC\\\",\\n con0:\\\"#0E0C20\\\", con1:\\\"#1A1638\\\", conG:\\\"#6050D0\\\",\\n zz:\\\"#8080C0\\\",\\n};\\nconst PN = {\\n s0:\\\"#080410\\\", s1:\\\"#100820\\\", s2:\\\"#1C1030\\\", s3:\\\"#2C1848\\\",\\n tp0:\\\"#2A1440\\\", tp1:\\\"#3C2060\\\",\\n pk0:\\\"#660044\\\", pk1:\\\"#AA1077\\\", pk2:\\\"#EE20AA\\\", pk3:\\\"#FF80D0\\\", pkLt:\\\"#FFB8E8\\\",\\n sk:\\\"#C49060\\\", skD:\\\"#8C6030\\\",\\n e:\\\"#0A0408\\\", eW:\\\"#E8E0F0\\\",\\n v0:\\\"#440022\\\", v1:\\\"#880044\\\", v2:\\\"#CC1166\\\", v3:\\\"#FF3399\\\",\\n sc0:\\\"#8070A0\\\", sc1:\\\"#C0B0D8\\\", sc2:\\\"#E8E0F8\\\",\\n bt0:\\\"#080410\\\", bt1:\\\"#140C24\\\",\\n con0:\\\"#080414\\\", con1:\\\"#100820\\\", conP:\\\"#EE20AA\\\",\\n hl0:\\\"#1A0028\\\", hl1:\\\"#EE20AA\\\", hl2:\\\"#FF80D0\\\",\\n zz:\\\"#906090\\\",\\n bl0:\\\"#0C0818\\\", bl1:\\\"#180C28\\\", blP:\\\"#AA1077\\\",\\n};\\nconst PE = {\\n c0:\\\"#0E1A20\\\", c1:\\\"#1C2C38\\\", c2:\\\"#2A4050\\\", c3:\\\"#3A5868\\\",\\n cy0:\\\"#005060\\\", cy1:\\\"#008090\\\", cy2:\\\"#00B8C8\\\", cy3:\\\"#30E0F0\\\", cyLt:\\\"#90FFFF\\\",\\n og0:\\\"#602C08\\\", og1:\\\"#904010\\\", og2:\\\"#C86020\\\", og3:\\\"#F09840\\\", ogG:\\\"#FFD090\\\",\\n sk:\\\"#D0906A\\\", skD:\\\"#A06840\\\",\\n e:\\\"#0A0408\\\", eW:\\\"#F0E8E0\\\",\\n bt0:\\\"#101818\\\", bt1:\\\"#202828\\\",\\n cr0:\\\"#1E2816\\\", cr1:\\\"#2E3C22\\\", cr2:\\\"#3E5030\\\", crL:\\\"#506040\\\",\\n mg0:\\\"#3C2418\\\", mg1:\\\"#5C3820\\\", mgH:\\\"#B06030\\\",\\n bh0:\\\"#181E1C\\\", bh1:\\\"#283030\\\",\\n wr0:\\\"#484840\\\", wr1:\\\"#686860\\\", wrH:\\\"#9090A0\\\",\\n sp0:\\\"#FF6000\\\", sp1:\\\"#FFAA00\\\", sp2:\\\"#FFFFFF\\\",\\n bl0:\\\"#101418\\\", bl1:\\\"#182028\\\", blG:\\\"#00B8C8\\\",\\n rl0:\\\"#3C2C1C\\\", rl1:\\\"#5C4428\\\",\\n gr:\\\"#1C2428\\\",\\n hl0:\\\"#001018\\\", hl1:\\\"#00B8C8\\\", hl2:\\\"#80F0FF\\\",\\n zz:\\\"#5080A0\\\",\\n tb0:\\\"#0E1828\\\", tb1:\\\"#162238\\\", tbG:\\\"#30D8F0\\\",\\n blt:\\\"#281C08\\\", blt2:\\\"#403010\\\", pch:\\\"#362210\\\",\\n};\\nconst PA = {\\n r0:\\\"#180C04\\\", r1:\\\"#2C1808\\\", r2:\\\"#4A2C10\\\", r3:\\\"#6A4018\\\", rLt:\\\"#8A5820\\\",\\n am0:\\\"#5C3808\\\", am1:\\\"#8A5810\\\", am2:\\\"#C08020\\\", am3:\\\"#E8AA30\\\", amLt:\\\"#FFD060\\\",\\n cr0:\\\"#F0E4C0\\\", cr1:\\\"#F8F0DC\\\",\\n sk:\\\"#D4B896\\\", skD:\\\"#A48060\\\",\\n e:\\\"#0A0408\\\", eW:\\\"#F0ECD8\\\",\\n gl0:\\\"#4A2C0C\\\", gl1:\\\"#7A4C18\\\", glL:\\\"#C09040\\\",\\n bk0:\\\"#100808\\\", bk1:\\\"#201010\\\", bkP:\\\"#F0E8D0\\\", bkT:\\\"#C0A060\\\",\\n ch0:\\\"#100804\\\", ch1:\\\"#1C1008\\\", ch2:\\\"#281808\\\",\\n cx0:\\\"#E09020\\\", cx1:\\\"#FFB830\\\", cx2:\\\"#FFF0A0\\\",\\n cxB:\\\"#FF6010\\\", cxC:\\\"#60A0FF\\\",\\n dt0:\\\"#C08020\\\", dt1:\\\"#E8A820\\\", dtG:\\\"#FFF080\\\",\\n tm0:\\\"#100804\\\", tm1:\\\"#201008\\\", tmG:\\\"#C08020\\\",\\n zz:\\\"#C0A050\\\",\\n tc:\\\"#FFB830\\\",\\n hl0:\\\"#180C00\\\", hl1:\\\"#C08020\\\", hl2:\\\"#FFD060\\\",\\n};\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// 🐒 SPACE MONKEY DRAWER\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\nfunction drawMonkey(ctx, pose, fox, foy, t) {\\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\\n const sl = pose === \\\"sleep\\\";\\n const f = sl ? 0.45 : 1;\\n const c = (col) => sl ? dimHex(col, f) : col;\\n const bob = pose === \\\"idle\\\" ? Math.round(Math.sin(t * 0.08) * 0.8) : 0;\\n\\n // Seated context\\n const seated = pose === \\\"idle\\\" || pose === \\\"sleep\\\" || pose === \\\"working\\\";\\n const bY = seated ? 26 + bob : 22; // body top Y\\n const hY = seated ? 13 + bob : 9; // head top Y\\n\\n // ── CHAIR ──\\n if (seated) {\\n rect(4, hY+14, 5, 28, c(PM.ch1)); rect(5, hY+15, 3, 26, c(PM.ch0));\\n rect(31, hY+14, 5, 28, c(PM.ch1)); rect(32, hY+15, 3, 26, c(PM.ch0));\\n line(4, hY+14, 32, c(PM.ch2));\\n rect(4, 40+bob, 32, 5, c(PM.ch1)); rect(6, 41+bob, 28, 3, c(PM.ch0));\\n rect(6, 44+bob, 3, 10, c(PM.ch1)); rect(31, 44+bob, 3, 10, c(PM.ch1));\\n // Console wings\\n rect(0, 35+bob, 10, 4, c(PM.con1)); rect(1, 33+bob, 8, 4, c(PM.con0));\\n rect(30, 35+bob, 10, 4, c(PM.con1)); rect(31, 33+bob, 8, 4, c(PM.con0));\\n if (!sl) { line(1, 32+bob, 6, PM.conG); line(33, 32+bob, 6, PM.conG); }\\n }\\n\\n // ── TAIL ──\\n if (pose === \\\"idle\\\") {\\n for (let i=0;i<5;i++) { px(34+i, 33+i+bob, c(PM.t2)); px(35+i, 33+i+bob, c(PM.t1)); }\\n rect(35, 38+bob, 3, 3, c(PM.t0));\\n } else if (pose === \\\"thinking\\\") {\\n // Question mark shape\\n line(27, 17, 6, PM.t2); px(27, 18, PM.t1); px(26, 19, PM.t2); px(26, 20, PM.t1);\\n px(27, 21, PM.t2); px(28, 21, PM.t1); px(29, 20, PM.t2); px(30, 19, PM.t1);\\n px(31, 18, PM.t2); px(31, 17, PM.t1); px(30, 16, PM.t2);\\n rect(28, 23, 2, 2, PM.t0);\\n } else if (pose === \\\"working\\\") {\\n px(33, 28+bob, c(PM.t2)); px(34, 30+bob, c(PM.t1)); px(35, 31+bob, c(PM.t2));\\n px(36, 30+bob, c(PM.t1)); px(37, 28+bob, c(PM.t2)); px(38, 26+bob, c(PM.t1));\\n px(38, 24+bob, c(PM.t2));\\n } else if (pose === \\\"sleep\\\") {\\n for (let i=0;i<6;i++) px(33+Math.round(i*0.5), 34+i, c(PM.t1));\\n px(34, 40, c(PM.t0));\\n } else if (pose === \\\"walk\\\") {\\n px(32,28,PM.t2); px(33,27,PM.t1); px(34,26,PM.t2); px(35,25,PM.t1);\\n px(36,24,PM.t2); px(37,23,PM.t1); px(38,22,PM.t0);\\n } else { // collab\\n px(31,24,PM.t2); px(32,23,PM.t1); px(33,22,PM.t2); px(34,21,PM.t1);\\n px(35,20,PM.t2); px(36,19,PM.t1); px(37,18,PM.t0);\\n }\\n\\n // ── SUIT BODY ──\\n rect(14, bY, 12, 14, c(PM.s1)); rect(15, bY+1, 10, 12, c(PM.s0));\\n line(14, bY, 12, c(PM.s2)); // highlight top\\n line(15, bY+1, 3, c(PM.s3)); // shine\\n // Gold collar trim\\n line(14, bY, 12, c(PM.g2));\\n // Gold waist trim\\n line(14, bY+13, 12, c(PM.g1)); line(15, bY+14, 10, c(PM.g2));\\n // Mission patch\\n rect(16, bY+3, 4, 4, c(PM.p0)); rect(17, bY+4, 2, 2, c(PM.pG));\\n // Chest stripe\\n rect(23, bY+3, 3, 4, c(PM.s2));\\n\\n // ── ARMS ──\\n if (pose === \\\"idle\\\") {\\n rect(10, bY+2, 5, 9, c(PM.s1)); rect(11, bY+3, 3, 7, c(PM.s0));\\n rect(10, bY+10, 4, 4, c(PM.fur2)); // hand on console\\n rect(25, bY+2, 5, 8, c(PM.s1)); rect(26, bY+3, 3, 6, c(PM.s0));\\n rect(25, bY+9, 4, 4, c(PM.fur2));\\n } else if (pose === \\\"thinking\\\") {\\n rect(10, bY+2, 5, 11, PM.s1); rect(11, bY+3, 3, 9, PM.s0);\\n rect(10, bY+12, 5, 4, PM.fur2); // hand on chin\\n rect(25, bY+2, 5, 8, PM.s1); rect(26, bY+3, 3, 6, PM.s0);\\n rect(25, bY+9, 4, 4, PM.fur2);\\n } else if (pose === \\\"working\\\") {\\n rect(9, bY+4, 6, 9, c(PM.s1)); rect(10, bY+5, 4, 7, c(PM.s0));\\n rect(9, bY+12, 5, 4, c(PM.fur2));\\n rect(25, bY+4, 6, 9, c(PM.s1)); rect(26, bY+5, 4, 7, c(PM.s0));\\n rect(25, bY+12, 5, 4, c(PM.fur2));\\n } else if (pose === \\\"sleep\\\") {\\n rect(9, bY+3, 6, 12, c(PM.s1)); rect(25, bY+3, 6, 12, c(PM.s1));\\n } else if (pose === \\\"walk\\\") {\\n rect(9, bY+2, 5, 10, PM.s1); rect(10, bY+3, 3, 8, PM.s0);\\n rect(9, bY+11, 4, 4, PM.fur2);\\n rect(4, bY+4, 6, 8, PM.tab0); rect(5, bY+5, 4, 6, PM.tab1);\\n line(5, bY+6, 4, PM.tabG); line(5, bY+8, 4, PM.tabG);\\n rect(25, bY+4, 5, 9, PM.s1); rect(26, bY+5, 3, 7, PM.s0);\\n rect(25, bY+12, 4, 4, PM.fur2);\\n } else { // collab\\n rect(8, bY+2, 5, 8, PM.s1);\\n line(5, bY+8, 6, PM.s1); rect(4, bY+7, 4, 4, PM.fur2); // pointing\\n rect(25, bY+2, 5, 9, PM.s1); rect(26, bY+3, 3, 7, PM.s0);\\n rect(25, bY+10, 4, 4, PM.fur2);\\n }\\n\\n // ── LEGS ──\\n if (seated) {\\n rect(15, bY+15, 4, 5, c(PM.s1)); rect(16, bY+16, 2, 3, c(PM.s0));\\n rect(21, bY+15, 4, 5, c(PM.s1)); rect(22, bY+16, 2, 3, c(PM.s0));\\n rect(15, bY+19, 4, 4, c(PM.s0)); line(15, bY+22, 4, c(PM.g1));\\n rect(21, bY+19, 4, 4, c(PM.s0)); line(21, bY+22, 4, c(PM.g1));\\n } else if (pose === \\\"walk\\\") {\\n rect(15, bY+15, 4, 12, PM.s1); rect(16, bY+16, 2, 10, PM.s0);\\n rect(15, bY+26, 5, 4, PM.s0); line(15, bY+29, 5, PM.g1);\\n rect(21, bY+15, 4, 10, PM.s1); rect(22, bY+16, 2, 8, PM.s0);\\n rect(21, bY+24, 5, 4, PM.s0); line(21, bY+27, 5, PM.g1);\\n } else {\\n rect(15, bY+15, 4, 13, PM.s1); rect(16, bY+16, 2, 11, PM.s0);\\n rect(21, bY+15, 4, 13, PM.s1); rect(22, bY+16, 2, 11, PM.s0);\\n rect(15, bY+27, 5, 4, PM.s0); line(15, bY+30, 5, PM.g1);\\n rect(21, bY+27, 5, 4, PM.s0); line(21, bY+30, 5, PM.g1);\\n }\\n\\n // ── KEYBOARD / MONITOR (working) ──\\n if (pose === \\\"working\\\") {\\n rect(8, bY+16, 24, 4, c(PM.kb0)); rect(9, bY+15, 22, 4, c(PM.kb1));\\n for (let i=0;i<7;i++) { px(10+i*3, bY+15, c(PM.kbG)); }\\n glow(14, bY, 12, 7, \\\"rgba(120,80,255,0.22)\\\");\\n glow(15, bY-3, 10, 4, \\\"rgba(120,80,255,0.16)\\\");\\n px(12, bY-2, c(PM.hm)); // mic active light\\n }\\n\\n // ── SHARED DISPLAY (collab) ──\\n if (pose === \\\"collab\\\") {\\n rect(0, 14, 9, 18, PM.con1); rect(1, 15, 7, 16, PM.con0);\\n for (let i=0;i<3;i++) line(2, 16+i*5, 5, PM.conG);\\n px(4, 28, PM.g2); px(3, 30, PM.g1); px(5, 30, PM.g1);\\n rect(0, 31, 9, 2, PM.ch2);\\n }\\n\\n // ── HEAD ──\\n rect(14, hY, 12, 12, c(PM.fur2));\\n rect(13, hY+1, 14, 10, c(PM.fur2));\\n rect(14, hY-1, 12, 2, c(PM.fur1));\\n rect(15, hY+3, 10, 6, c(PM.fur3)); // face lighter\\n // Ears\\n rect(12, hY+3, 3, 5, c(PM.fur2)); px(13, hY+4, c(PM.fur3)); px(13, hY+5, c(PM.fur3));\\n rect(25, hY+3, 3, 5, c(PM.fur2)); px(26, hY+4, c(PM.fur3)); px(26, hY+5, c(PM.fur3));\\n // Eyes\\n if (sl) {\\n line(15, hY+5, 4, c(PM.fur0)); px(16, hY+6, c(PM.fur0));\\n line(21, hY+5, 4, c(PM.fur0)); px(22, hY+6, c(PM.fur0));\\n } else {\\n rect(15, hY+4, 4, 4, c(PM.eW)); rect(21, hY+4, 4, 4, c(PM.eW));\\n const pOff = pose===\\\"thinking\\\" ? 1 : 0;\\n rect(16+pOff, hY+5, 2, 2, c(PM.e)); rect(22+pOff, hY+5, 2, 2, c(PM.e));\\n px(16+pOff, hY+5, c(PM.eH));\\n // Brows\\n line(15, hY+3, 4, c(PM.fur0)); line(21, hY+3, 4, c(PM.fur0));\\n if (pose===\\\"thinking\\\") { px(18, hY+3, c(PM.fur0)); px(24, hY+3, c(PM.fur0)); }\\n }\\n // Muzzle\\n rect(16, hY+8, 8, 4, c(PM.fur3)); rect(17, hY+9, 6, 3, c(PM.sk));\\n px(18, hY+8, c(PM.fur0)); px(19, hY+8, c(PM.fur0)); // nostrils\\n if (pose===\\\"collab\\\") {\\n rect(17, hY+11, 6, 2, c(PM.fur0)); rect(18, hY+11, 4, 2, c(PM.e));\\n } else if (!sl) {\\n line(17, hY+11, 6, c(PM.fur0));\\n }\\n\\n // ── HEADSET ──\\n line(14, hY, 12, c(PM.h0)); // band\\n rect(12, hY+2, 3, 4, c(PM.h0)); rect(25, hY+2, 3, 4, c(PM.h0)); // earcups\\n rect(13, hY+3, 2, 3, c(PM.h1)); rect(26, hY+3, 2, 3, c(PM.h1));\\n rect(11, hY+5, 2, 4, c(PM.h0)); // mic arm\\n rect(10, hY+8, 3, 2, c(PM.h0)); // mic\\n if (!sl) px(10, hY+9, PM.hm); // mic green light\\n // Data visor (right eye)\\n glow(26, hY+3, 3, 4, \\\"rgba(160,120,255,0.55)\\\");\\n glow(26, hY+3, 3, 2, \\\"rgba(190,160,255,0.35)\\\");\\n\\n // ZZZ\\n if (sl) {\\n px(22, hY-3, c(PM.zz)); line(23, hY-5, 3, c(PM.zz)); px(23, hY-4, c(PM.zz)); px(25, hY-4, c(PM.zz));\\n rect(26, hY-8, 4, 2, c(PM.zz)); px(26, hY-7, c(PM.zz)); px(29, hY-7, c(PM.zz));\\n }\\n}\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// 🥷 LIFE SUPPORT NINJA DRAWER\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\nfunction drawNinja(ctx, pose, fox, foy, t) {\\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\\n const sl = pose === \\\"sleep\\\";\\n const f = sl ? 0.45 : 1;\\n const c = (col) => sl ? dimHex(col, f) : col;\\n const bob = pose === \\\"idle\\\" ? Math.round(Math.sin(t * 0.07) * 0.6) : 0;\\n const visorOn = !sl && (pose !== \\\"idle\\\");\\n const visorCol = sl ? PN.v0 : visorOn ? PN.v3 : PN.v1;\\n const bY = 22;\\n const hY = 11;\\n\\n // ── WALL CONSOLE (idle) ──\\n if (pose === \\\"idle\\\") {\\n rect(1, 10+bob, 6, 30, c(PN.bl1)); rect(2, 11+bob, 4, 28, c(PN.bl0));\\n for (let i=0;i<4;i++) line(2, 13+bob+i*6, 4, c(PN.blP));\\n if (!sl) glow(1, 12+bob, 4, 20, \\\"rgba(200,20,100,0.12)\\\");\\n }\\n\\n // ── SCARF ──\\n const sf = pose === \\\"walk\\\" ? Math.round(Math.sin(t*0.1)*1.5) : 0;\\n if (pose === \\\"idle\\\" || pose === \\\"sleep\\\") {\\n rect(20, 20+bob, 4, 16, c(PN.sc2)); rect(21, 21+bob, 2, 14, c(PN.sc1)); rect(19, 22+bob, 2, 10, c(PN.sc1));\\n } else if (pose === \\\"walk\\\") {\\n rect(22, 18, 3, 8, PN.sc2); rect(23, 19+sf, 4, 6, PN.sc1); rect(25, 17-sf, 5, 5, PN.sc0);\\n } else if (pose === \\\"working\\\") {\\n rect(21, 18, 3, 10, c(PN.sc2)); rect(22, 19, 2, 8, c(PN.sc1));\\n rect(18, 22, 3, 6, c(PN.sc0));\\n } else {\\n rect(21, 18, 4, 10, PN.sc2); rect(22, 19, 2, 8, PN.sc1);\\n }\\n\\n // ── BODY TORSO ──\\n rect(14, bY, 12, 18, c(PN.s2)); rect(15, bY+1, 10, 16, c(PN.s1));\\n line(15, bY+2, 10, c(PN.pk1)); // chest accent\\n rect(16, bY+5, 8, 2, c(PN.pk0));\\n rect(19, bY+1, 2, 14, c(PN.tp1)); // center seam\\n\\n // ── ARMS ──\\n if (pose === \\\"idle\\\") {\\n rect(10, bY+4, 5, 8, c(PN.s2)); rect(25, bY+4, 5, 8, c(PN.s2));\\n rect(11, bY+10, 14, 4, c(PN.s1)); rect(12, bY+11, 12, 2, c(PN.tp0));\\n rect(10, bY+11, 4, 4, c(PN.s1)); rect(25, bY+11, 4, 4, c(PN.s1)); // gloves\\n } else if (pose === \\\"thinking\\\") {\\n // Left arm raised with forearm readout\\n rect(9, bY+2, 5, 14, PN.s2); rect(10, bY+3, 3, 12, PN.s1);\\n rect(9, bY+15, 5, 4, PN.s1);\\n // Holographic forearm readout\\n rect(0, bY+2, 9, 13, PN.hl0);\\n glow(0, bY+2, 9, 13, \\\"rgba(200,20,100,0.18)\\\");\\n line(1, bY+7, 7, PN.hl2); // heartbeat\\n px(2, bY+6, PN.hl1); px(4, bY+5, PN.hl1); px(5, bY+7, PN.hl1);\\n line(1, bY+12, 7, PN.hl1); px(4, bY+11, PN.pk3);\\n rect(25, bY+4, 5, 12, PN.s2); rect(26, bY+5, 3, 10, PN.s1); rect(25, bY+15, 4, 4, PN.s1);\\n } else if (pose === \\\"working\\\") {\\n rect(8, bY+6, 6, 10, c(PN.s2)); rect(9, bY+7, 4, 8, c(PN.s1)); rect(8, bY+15, 5, 4, c(PN.s1));\\n rect(26, bY+6, 6, 10, c(PN.s2)); rect(27, bY+7, 4, 8, c(PN.s1)); rect(26, bY+15, 5, 4, c(PN.s1));\\n } else if (pose === \\\"walk\\\") {\\n rect(9, bY+2, 5, 12, PN.s2); rect(10, bY+3, 3, 10, PN.s1); rect(9, bY+13, 4, 4, PN.s1);\\n rect(25, bY+4, 5, 10, PN.s2); rect(26, bY+5, 3, 8, PN.s1); rect(25, bY+13, 4, 4, PN.s1);\\n } else if (pose === \\\"collab\\\") {\\n line(6, bY+8, 8, PN.s2); rect(4, bY+7, 5, 4, PN.s1); // arm+hand pointing\\n rect(25, bY+4, 5, 10, PN.s2); rect(26, bY+5, 3, 8, PN.s1); rect(25, bY+13, 4, 4, PN.s1);\\n } else { // sleep\\n rect(10, bY+4, 5, 8, c(PN.s2)); rect(25, bY+4, 5, 8, c(PN.s2));\\n rect(11, bY+10, 14, 4, c(PN.s1));\\n rect(10, bY+11, 4, 4, c(PN.s1)); rect(25, bY+11, 4, 4, c(PN.s1));\\n }\\n\\n // ── BELT ──\\n rect(14, bY+18, 12, 3, c(PN.bl0)); line(15, bY+19, 10, c(PN.bl1));\\n rect(15, bY+18, 3, 5, c(PN.tp0)); px(16, bY+19, c(PN.tp1));\\n rect(22, bY+18, 3, 5, c(PN.tp0)); px(23, bY+19, c(PN.tp1));\\n\\n // ── LEGS ──\\n if (pose === \\\"walk\\\") {\\n rect(15, bY+21, 4, 13, PN.s2); rect(16, bY+22, 2, 11, PN.s1);\\n rect(15, bY+33, 5, 4, PN.bt0); line(15, bY+36, 5, PN.bt1);\\n rect(21, bY+21, 4, 10, PN.s2); rect(22, bY+22, 2, 8, PN.s1);\\n rect(21, bY+30, 5, 4, PN.bt0); line(21, bY+33, 5, PN.bt1);\\n } else {\\n rect(15, bY+21, 4, 14, c(PN.s2)); rect(16, bY+22, 2, 12, c(PN.s1));\\n rect(21, bY+21, 4, 14, c(PN.s2)); rect(22, bY+22, 2, 12, c(PN.s1));\\n rect(15, bY+34, 5, 4, c(PN.bt0)); rect(21, bY+34, 5, 4, c(PN.bt0));\\n }\\n\\n // ── WORKING CONSOLE ──\\n if (pose === \\\"working\\\") {\\n rect(7, bY+20, 26, 5, c(PN.bl0)); rect(8, bY+18, 24, 5, c(PN.bl1));\\n for (let i=0;i<6;i++) { px(9+i*4, bY+17, c(PN.pk2)); rect(10+i*4, bY+18, 2, 2, c(PN.pk0)); }\\n if (!sl) {\\n glow(14, bY+13, 12, 6, \\\"rgba(220,30,120,0.2)\\\");\\n glow(15, bY+7, 10, 8, \\\"rgba(200,20,100,0.12)\\\");\\n }\\n }\\n\\n // ── SHARED DISPLAY (collab) ──\\n if (pose === \\\"collab\\\") {\\n rect(0, 12, 10, 24, PN.bl1); rect(1, 13, 8, 22, PN.bl0);\\n for (let i=0;i<5;i++) line(2, 14+i*4, 6, PN.blP);\\n rect(0, 35, 10, 3, PN.bt0);\\n }\\n\\n // ── HEAD ──\\n rect(14, hY, 12, 11, c(PN.sk));\\n rect(13, hY+1, 14, 9, c(PN.sk));\\n rect(14, hY-1, 12, 2, c(PN.sk));\\n // Hood\\n rect(13, hY-1, 14, 7, c(PN.s1)); rect(14, hY-2, 12, 7, c(PN.s2));\\n rect(15, hY-3, 10, 6, c(PN.s1)); rect(16, hY-4, 8, 5, c(PN.tp0));\\n rect(12, hY+4, 3, 7, c(PN.s1)); rect(25, hY+4, 3, 7, c(PN.s1));\\n // Visor line\\n rect(14, hY+4, 12, 3, c(visorCol));\\n line(15, hY+4, 10, c(sl ? PN.v0 : visorOn ? PN.pk3 : PN.v2));\\n if (visorOn) glow(13, hY+3, 14, 5, \\\"rgba(220,30,120,0.22)\\\");\\n // Visor walk pulse\\n if (pose === \\\"walk\\\") glow(13, hY+3, 14, 5, `rgba(220,30,120,${0.12+0.1*Math.sin(t*0.15)})`);\\n // Eyes\\n if (sl) {\\n line(16, hY+3, 4, c(PN.s0)); line(21, hY+3, 4, c(PN.s0));\\n } else {\\n rect(16, hY+2, 4, 3, c(PN.eW)); rect(21, hY+2, 4, 3, c(PN.eW));\\n rect(17, hY+3, 2, 2, c(PN.e)); rect(22, hY+3, 2, 2, c(PN.e));\\n line(16, hY+2, 4, c(PN.s0)); line(21, hY+2, 4, c(PN.s0)); // eyelid\\n }\\n // Lower mask\\n rect(14, hY+7, 12, 5, c(PN.s2)); rect(15, hY+8, 10, 3, c(PN.s1));\\n line(16, hY+9, 8, c(PN.tp0));\\n\\n // ZZZ\\n if (sl) {\\n px(22, hY-4, c(PN.zz)); line(23, hY-6, 3, c(PN.zz)); px(23, hY-5, c(PN.zz)); px(25, hY-5, c(PN.zz));\\n rect(26, hY-9, 4, 2, c(PN.zz)); px(26, hY-8, c(PN.zz)); px(29, hY-8, c(PN.zz));\\n }\\n}\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// 🔧 SYSTEMS ENGINEER DRAWER\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\nfunction drawEngineer(ctx, pose, fox, foy, t) {\\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\\n const sl = pose === \\\"sleep\\\";\\n const f = sl ? 0.45 : 1;\\n const c = (col) => sl ? dimHex(col, f) : col;\\n const gogDown = pose === \\\"working\\\";\\n const seated = pose === \\\"idle\\\" || pose === \\\"sleep\\\";\\n const bY = seated ? 29 : 22;\\n const hY = seated ? 16 : 9;\\n\\n // ── CRATE (idle, sleep) ──\\n if (seated) {\\n rect(9, 38, 22, 13, c(PE.cr1)); rect(10, 39, 20, 11, c(PE.cr0));\\n line(10, 45, 20, c(PE.cr2)); px(19, 45, c(PE.crL));\\n line(9, 38, 22, c(PE.cr1));\\n px(11, 40, c(PE.crL)); px(28, 40, c(PE.crL)); px(11, 49, c(PE.crL)); px(28, 49, c(PE.crL));\\n }\\n\\n // ── WORKBENCH (working) ──\\n if (pose === \\\"working\\\") {\\n rect(2, 39, 36, 5, c(PE.bh1)); rect(3, 37, 34, 5, c(PE.bh0));\\n if (!sl) glow(3, 36, 34, 3, \\\"rgba(0,184,200,0.2)\\\");\\n rect(25, 34, 5, 4, c(PE.mg0)); rect(26, 33, 3, 2, c(PE.mg1)); rect(29, 36, 2, 2, c(PE.mg0));\\n }\\n\\n // ── SLEEP BENCH ──\\n if (sl) {\\n rect(3, 39, 34, 5, c(PE.bh1)); rect(4, 37, 32, 5, c(PE.bh0));\\n rect(26, 36, 4, 3, c(PE.mg0)); rect(27, 35, 2, 2, c(PE.mg1));\\n glow(22, 39, 8, 2, \\\"rgba(100,60,30,0.35)\\\");\\n }\\n\\n // ── BODY ──\\n rect(13, bY, 14, 16, c(PE.c2)); rect(14, bY+1, 12, 14, c(PE.c1));\\n line(14, bY, 12, c(PE.c3));\\n line(14, bY+1, 4, c(PE.cy2)); // shine\\n rect(12, bY+3, 2, 4, c(PE.c3)); rect(26, bY+3, 2, 4, c(PE.c3)); // rolled sleeves\\n line(14, bY+2, 12, c(PE.cy1));\\n // Grease stains\\n px(17, bY+6, c(PE.gr)); px(21, bY+4, c(PE.gr)); px(23, bY+9, c(PE.gr));\\n\\n // ── ARMS ──\\n if (pose === \\\"idle\\\") {\\n rect(9, bY+2, 5, 9, c(PE.c2)); rect(10, bY+3, 3, 7, c(PE.c1));\\n rect(9, bY+10, 5, 4, c(PE.sk));\\n rect(5, bY+12, 5, 3, c(PE.rl0)); rect(6, bY+13, 3, 2, c(PE.rl1)); // rag\\n rect(26, bY+2, 5, 9, c(PE.c2)); rect(27, bY+3, 3, 7, c(PE.c1)); rect(26, bY+10, 5, 4, c(PE.sk));\\n rect(30, bY+8, 4, 6, c(PE.mg0)); rect(31, bY+7, 2, 2, c(PE.mg1)); rect(33, bY+10, 2, 3, c(PE.mg0));\\n if (!sl) { px(31, bY+5, \\\"rgba(200,200,200,0.5)\\\"); px(33, bY+4, \\\"rgba(200,200,200,0.4)\\\"); }\\n } else if (pose === \\\"thinking\\\") {\\n rect(9, bY+2, 5, 11, PE.c2); rect(10, bY+3, 3, 9, PE.c1);\\n rect(9, bY+12, 5, 4, PE.sk); // hand on chin\\n rect(26, bY+2, 5, 8, PE.c2); rect(27, bY+3, 3, 6, PE.c1); rect(26, bY+9, 4, 4, PE.sk);\\n // Holo blueprints\\n rect(0, bY-6, 12, 18, PE.hl0);\\n glow(0, bY-6, 12, 18, \\\"rgba(0,184,200,0.14)\\\");\\n for (let i=0;i<4;i++) line(1, bY-4+i*4, 10, PE.hl2);\\n rect(1, bY-4, 5, 4, \\\"rgba(0,184,200,0.35)\\\"); rect(6, bY+4, 4, 4, \\\"rgba(0,184,200,0.35)\\\");\\n glow(14, bY-6, 12, 8, \\\"rgba(0,184,200,0.14)\\\");\\n } else if (pose === \\\"working\\\") {\\n rect(8, bY+4, 6, 10, c(PE.c2)); rect(9, bY+5, 4, 8, c(PE.c1)); rect(8, bY+13, 5, 4, c(PE.sk));\\n rect(26, bY+4, 6, 10, c(PE.c2)); rect(27, bY+5, 4, 8, c(PE.c1)); rect(26, bY+13, 5, 4, c(PE.sk));\\n // Sparks\\n for (let i=0;i<7;i++) {\\n const sx = 14+Math.round(Math.sin(t*0.25+i*0.9)*5);\\n const sy = bY+14+Math.round(Math.cos(t*0.3+i)*2);\\n px(sx, sy, c([PE.sp0,PE.sp1,PE.sp2][i%3]));\\n }\\n glow(14, bY, 12, 7, \\\"rgba(0,184,200,0.18)\\\");\\n } else if (pose === \\\"walk\\\") {\\n rect(9, bY+2, 5, 10, PE.c2); rect(10, bY+3, 3, 8, PE.c1); rect(9, bY+11, 4, 4, PE.sk);\\n rect(4, bY+5, 3, 14, PE.wr1); rect(3, bY+5, 5, 4, PE.wrH); rect(3, bY+6, 2, 2, PE.c1);\\n rect(26, bY+4, 5, 9, PE.c2); rect(27, bY+5, 3, 7, PE.c1); rect(26, bY+12, 4, 4, PE.sk);\\n rect(30, bY+7, 6, 8, PE.tb0); rect(31, bY+8, 4, 6, PE.tb1); line(31, bY+10, 4, PE.tbG);\\n } else if (pose === \\\"collab\\\") {\\n rect(8, bY+2, 5, 8, PE.c2);\\n line(3, bY+8, 7, PE.c2); rect(2, bY+7, 4, 4, PE.sk);\\n rect(0, bY+2, 3, 14, PE.wr1); rect(0, bY+2, 5, 4, PE.wrH);\\n rect(26, bY+2, 5, 9, PE.c2); rect(27, bY+3, 3, 7, PE.c1); rect(26, bY+10, 4, 4, PE.sk);\\n } else { // sleep\\n rect(9, bY+4, 6, 10, c(PE.c2)); rect(26, bY+4, 6, 10, c(PE.c2));\\n rect(9, bY+13, 20, 5, c(PE.c2)); // arms on bench\\n }\\n\\n // ── BELT ──\\n rect(13, bY+16, 14, 3, c(PE.blt)); line(14, bY+17, 12, c(PE.blt2));\\n for (let i=0;i<4;i++) { rect(14+i*3, bY+15, 2, 5, c(PE.pch)); px(15+i*3, bY+16, c(PE.cy0)); }\\n rect(23, bY+15, 2, 5, c(PE.wr1)); rect(23, bY+14, 2, 2, c(PE.wr0));\\n\\n // ── LEGS ──\\n if (seated) {\\n rect(15, bY+19, 4, 7, c(PE.c2)); rect(16, bY+20, 2, 5, c(PE.c1));\\n rect(21, bY+19, 4, 7, c(PE.c2)); rect(22, bY+20, 2, 5, c(PE.c1));\\n rect(15, bY+25, 5, 4, c(PE.bt0)); rect(21, bY+25, 5, 4, c(PE.bt0));\\n } else if (pose === \\\"walk\\\") {\\n rect(15, bY+19, 4, 13, PE.c2); rect(16, bY+20, 2, 11, PE.c1);\\n rect(15, bY+31, 5, 4, PE.bt0);\\n rect(21, bY+19, 4, 10, PE.c2); rect(22, bY+20, 2, 8, PE.c1);\\n rect(21, bY+28, 5, 4, PE.bt0);\\n } else {\\n rect(15, bY+19, 4, 13, PE.c2); rect(16, bY+20, 2, 11, PE.c1);\\n rect(21, bY+19, 4, 13, PE.c2); rect(22, bY+20, 2, 11, PE.c1);\\n rect(15, bY+31, 5, 4, PE.bt0); rect(21, bY+31, 5, 4, PE.bt0);\\n }\\n\\n // ── HEAD ──\\n rect(13, hY, 14, 12, c(PE.sk)); rect(14, hY-1, 12, 14, c(PE.sk));\\n rect(15, hY-2, 10, 16, c(PE.sk));\\n // Hair stubble\\n rect(14, hY-2, 12, 3, c(PE.c1)); rect(15, hY-3, 10, 3, c(PE.c2)); px(13, hY-1, c(PE.c1));\\n // Eyes\\n if (sl) {\\n line(15, hY+5, 5, c(PE.skD)); px(16, hY+6, c(PE.skD));\\n line(22, hY+5, 5, c(PE.skD)); px(23, hY+6, c(PE.skD));\\n } else {\\n rect(15, hY+4, 5, 4, c(PE.eW)); rect(22, hY+4, 5, 4, c(PE.eW));\\n rect(16, hY+5, 2, 2, c(PE.e)); rect(23, hY+5, 2, 2, c(PE.e));\\n px(16, hY+5, c(PE.og3));\\n if (pose===\\\"working\\\") { line(15, hY+4, 5, c(PE.skD)); line(22, hY+4, 5, c(PE.skD)); }\\n }\\n px(18, hY+8, c(PE.skD)); px(19, hY+8, c(PE.skD)); // nose\\n if (pose===\\\"collab\\\") { line(16, hY+10, 7, c(PE.skD)); px(17, hY+11, c(PE.skD)); px(21, hY+11, c(PE.skD)); }\\n else if (!sl) line(17, hY+10, 5, c(PE.skD));\\n\\n // ── GOGGLES ──\\n const gY = gogDown ? hY+4 : hY-1;\\n line(12, gY, 17, c(PE.og0)); // band\\n rect(14, gY, 5, 5, c(PE.og1)); rect(23, gY, 5, 5, c(PE.og1));\\n rect(15, gY+1, 3, 3, c(PE.og3)); rect(24, gY+1, 3, 3, c(PE.og3));\\n px(25, gY+1, c(PE.og0)); px(26, gY+2, c(PE.og0)); // crack right lens\\n line(19, gY+2, 4, c(PE.og0)); // bridge\\n if (gogDown && !sl) {\\n glow(15, gY+1, 3, 3, \\\"rgba(0,184,200,0.55)\\\");\\n glow(24, gY+1, 3, 3, \\\"rgba(0,184,200,0.5)\\\");\\n glow(14, gY, 14, 6, \\\"rgba(0,184,200,0.15)\\\");\\n }\\n\\n // ── BLUEPRINT (collab) ──\\n if (pose === \\\"collab\\\") {\\n rect(0, 8, 12, 22, PE.hl0);\\n glow(0, 8, 12, 22, \\\"rgba(0,184,200,0.12)\\\");\\n for (let i=0;i<5;i++) line(1, 9+i*4, 10, PE.hl2);\\n rect(1, 9, 5, 4, \\\"rgba(0,184,200,0.35)\\\"); rect(6, 21, 4, 4, \\\"rgba(0,184,200,0.35)\\\");\\n rect(0, 29, 12, 2, PE.bh1);\\n }\\n\\n // ZZZ\\n if (sl) {\\n px(22, hY-4, c(PE.zz)); line(23, hY-7, 3, c(PE.zz)); px(23, hY-6, c(PE.zz)); px(25, hY-6, c(PE.zz));\\n rect(26, hY-10, 4, 2, c(PE.zz)); px(26, hY-9, c(PE.zz)); px(29, hY-9, c(PE.zz));\\n }\\n}\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// 📚 STATION ARCHIVIST DRAWER\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\nfunction drawArchivist(ctx, pose, fox, foy, t) {\\n const { px, line, rect, glow } = makeDraw(ctx, fox, foy);\\n const sl = pose === \\\"sleep\\\";\\n const f = sl ? 0.42 : 1;\\n const c = (col) => sl ? dimHex(col, f) : col;\\n const bob = pose === \\\"idle\\\" ? Math.round(Math.sin(t * 0.05) * 0.7) : 0;\\n const seated = pose === \\\"idle\\\" || pose === \\\"sleep\\\";\\n const bY = seated ? 24 + bob : (pose === \\\"working\\\" ? 20 : 20);\\n const hY = seated ? 12 + bob : 8;\\n const glassGlow = (pose===\\\"working\\\"||pose===\\\"collab\\\") ? PA.am3 : PA.cxC;\\n\\n // ── ORBITING DATA CRYSTALS ──\\n function crystal(cx, cy, col, bright) {\\n rect(cx, cy, 2, 2, c(col)); if (!sl) px(cx, cy, bright);\\n }\\n if (pose === \\\"idle\\\") {\\n const a = t * 0.04;\\n [[Math.cos(a)*8, Math.sin(a)*4],[Math.cos(a+1.57)*8, Math.sin(a+1.57)*4],\\n [Math.cos(a+3.14)*8, Math.sin(a+3.14)*4],[Math.cos(a+4.71)*8, Math.sin(a+4.71)*4]\\n ].forEach(([dx,dy],i) => {\\n const col=[PA.cx0,PA.cx1,PA.cxB,PA.cxC][i];\\n crystal(Math.round(20+dx), Math.round(22+dy+bob), col, PA.cx2);\\n });\\n } else if (pose === \\\"working\\\") {\\n const a = t * 0.12;\\n for (let i=0;i<5;i++) {\\n const angle = a + i*1.26;\\n crystal(Math.round(20+Math.cos(angle)*10), Math.round(20+Math.sin(angle)*5), PA.cx0, PA.cx2);\\n }\\n } else if (sl) {\\n [[-7,1],[7,-2],[-4,6],[9,3]].forEach(([dx,dy],i) => {\\n crystal(20+dx, 22+dy, [PA.cx0,PA.cx1,PA.cxB,PA.cxC][i], PA.cx2);\\n });\\n }\\n\\n // ── CHAIR (seated) ──\\n if (seated) {\\n rect(8, hY+12, 24, 40, c(PA.ch2)); rect(9, hY+13, 22, 38, c(PA.ch1));\\n rect(10, hY+14, 20, 36, c(PA.r1));\\n line(8, hY+12, 24, c(PA.am1)); line(8, hY+51, 24, c(PA.am1));\\n rect(8, hY+13, 2, 38, c(PA.am0)); rect(30, hY+13, 2, 38, c(PA.am0));\\n rect(10, hY+51, 3, 5, c(PA.ch2)); rect(27, hY+51, 3, 5, c(PA.ch2));\\n }\\n\\n // ── ARCHIVE TERMINAL (working) ──\\n if (pose === \\\"working\\\") {\\n rect(1, 34, 38, 8, PA.tm1); rect(2, 32, 36, 6, PA.tm0);\\n glow(3, 31, 34, 4, \\\"rgba(192,128,32,0.18)\\\");\\n rect(4, 28, 32, 4, PA.hl0); line(4, 29, 32, PA.tmG);\\n }\\n\\n // ── ROBE BODY ──\\n rect(12, bY, 16, 20, c(PA.r2)); rect(13, bY+1, 14, 18, c(PA.r1));\\n rect(14, bY+2, 12, 16, c(PA.r3));\\n rect(12, bY+2, 2, 18, c(PA.am1)); rect(26, bY+2, 2, 18, c(PA.am1));\\n rect(16, bY+3, 8, 2, c(PA.am2)); rect(17, bY+5, 6, 2, c(PA.am1)); px(19, bY+7, c(PA.amLt));\\n rect(14, bY+4, 12, 12, c(PA.r3));\\n rect(15, bY+5, 10, 10, c(PA.cr0));\\n line(15, bY+6, 10, c(PA.am0)); line(15, bY+9, 10, c(PA.am0)); line(15, bY+12, 10, c(PA.am0));\\n\\n // ── ARMS ──\\n if (pose === \\\"idle\\\") {\\n rect(10, bY+2, 5, 13, c(PA.r1)); rect(11, bY+3, 3, 11, c(PA.r0)); rect(10, bY+14, 4, 4, c(PA.sk));\\n rect(26, bY+2, 5, 12, c(PA.r1)); rect(27, bY+3, 3, 10, c(PA.r0)); rect(26, bY+13, 4, 4, c(PA.sk));\\n // Floating holo book\\n rect(28, bY-12+bob, 12, 14, c(PA.bk0)); rect(29, bY-11+bob, 10, 12, c(PA.bk1));\\n rect(30, bY-10+bob, 8, 10, c(PA.bkP));\\n for (let i=0;i<3;i++) line(31, bY-8+bob+i*3, 6, c(PA.am0));\\n rect(28, bY-12+bob, 12, 14, c(\\\"rgba(192,128,32,0.12)\\\"));\\n rect(28, bY-11+bob, 2, 12, c(PA.bkT));\\n } else if (pose === \\\"thinking\\\") {\\n rect(10, bY+2, 5, 12, PA.r1); rect(11, bY+3, 3, 10, PA.r0); rect(10, bY+13, 4, 4, PA.sk);\\n rect(26, bY+2, 5, 8, PA.r1); rect(26, bY+9, 5, 5, PA.sk); // hand adj glasses\\n // Crystals clustering\\n [[-5,-5],[-3,-7],[1,-6],[3,-4],[-2,-3],[4,-7]].forEach(([dx,dy],i) => {\\n rect(19+dx, bY-2+dy, 2, 2, [PA.cx0,PA.cx1,PA.cxB,PA.cx2,PA.cxC,PA.cx0][i]);\\n });\\n } else if (pose === \\\"working\\\") {\\n rect(9, bY+4, 5, 11, PA.r1); rect(10, bY+5, 3, 9, PA.r0); rect(9, bY+14, 4, 4, PA.sk);\\n rect(26, bY+4, 5, 11, PA.r1); rect(27, bY+5, 3, 9, PA.r0); rect(26, bY+14, 4, 4, PA.sk);\\n // Golden data streams\\n for (let i=0;i<6;i++) {\\n const a = t*0.1+i*1.05;\\n const dx = Math.round(Math.cos(a)*6), dy = Math.round(Math.sin(a)*3);\\n px(20+dx, bY+6+dy, PA.dt0); px(20+dx+1, bY+7+dy, PA.dt1);\\n }\\n glow(13, bY, 14, 16, \\\"rgba(192,128,32,0.14)\\\");\\n glow(14, bY-4, 12, 6, \\\"rgba(192,128,32,0.12)\\\");\\n } else if (pose === \\\"walk\\\") {\\n rect(10, bY+2, 5, 11, PA.r1); rect(11, bY+3, 3, 9, PA.r0); rect(10, bY+12, 4, 4, PA.sk);\\n // Text crystals trailing\\n const tr = Math.sin(t*0.08)*1.5;\\n [[-6,-1],[-9,1],[-12,-2],[-15,0],[-18,-3]].forEach(([dx,dy],i) => {\\n const cy = Math.round(bY+13+dy+tr*(i+1)*0.3);\\n rect(20+dx, cy, 4, 3, PA.tc); rect(21+dx, cy+1, 2, 1, PA.amLt); px(20+dx, cy, PA.amLt);\\n });\\n rect(26, bY+2, 5, 11, PA.r1); rect(27, bY+3, 3, 9, PA.r0); rect(26, bY+12, 4, 4, PA.sk);\\n } else if (pose === \\\"collab\\\") {\\n rect(10, bY+2, 5, 10, PA.r1); rect(11, bY+3, 3, 8, PA.r0); rect(10, bY+11, 4, 4, PA.sk);\\n // Large tome\\n rect(26, bY-7, 14, 18, PA.bk0); rect(27, bY-6, 12, 16, PA.bk1);\\n rect(28, bY-5, 10, 14, PA.bkP);\\n for (let i=0;i<4;i++) line(29, bY-3+i*3, 8, PA.am0);\\n rect(28, bY+4, 4, 3, PA.sk); px(32, bY+5, PA.sk); // pointing\\n // Text fragments\\n [[2,-2],[4,2],[-2,4]].forEach(([dx,dy]) => { rect(20+dx, bY+dy, 3, 2, PA.tc); px(20+dx, bY+dy, PA.amLt); });\\n rect(26, bY+2, 5, 9, PA.r1); rect(27, bY+3, 3, 7, PA.r0); rect(26, bY+10, 4, 4, PA.sk);\\n } else { // sleep\\n rect(10, bY+4, 5, 10, c(PA.r1)); rect(26, bY+4, 5, 10, c(PA.r1));\\n rect(14, bY+14, 12, 8, c(PA.bk0)); rect(15, bY+15, 10, 6, c(PA.bkP));\\n line(16, bY+17, 8, c(PA.am0));\\n }\\n\\n // ── ROBE LOWER ──\\n if (seated) {\\n rect(11, bY+20, 18, 14, c(PA.r2)); rect(12, bY+21, 16, 12, c(PA.r1));\\n rect(12, bY+22, 16, 12, c(PA.r3));\\n line(11, bY+20, 18, c(PA.am1)); line(11, bY+33, 18, c(PA.am1));\\n rect(15, bY+31, 4, 4, c(PA.r1)); rect(21, bY+31, 4, 4, c(PA.r1));\\n } else if (pose === \\\"walk\\\") {\\n rect(11, bY+20, 18, 16, PA.r2); rect(12, bY+21, 16, 14, PA.r1);\\n rect(12, bY+22, 16, 14, PA.r3); line(11, bY+35, 18, PA.am1);\\n rect(14, bY+33, 4, 4, PA.r1); rect(20, bY+31, 4, 4, PA.r1);\\n } else {\\n rect(11, bY+20, 18, 16, PA.r2); rect(12, bY+21, 16, 14, PA.r1);\\n rect(12, bY+22, 16, 14, PA.r3); line(11, bY+35, 18, PA.am1);\\n rect(14, bY+33, 4, 4, PA.r1); rect(20, bY+33, 4, 4, PA.r1);\\n }\\n\\n // ── HEAD ──\\n rect(15, hY, 10, 12, c(PA.sk));\\n rect(14, hY+1, 12, 10, c(PA.sk));\\n rect(15, hY-1, 10, 14, c(PA.sk));\\n // Hair wisps\\n rect(15, hY-1, 10, 3, c(PA.r1)); rect(16, hY-2, 8, 3, c(PA.r2));\\n rect(17, hY-3, 6, 2, c(PA.rLt));\\n // Eyes\\n if (sl) {\\n line(15, hY+5, 4, c(PA.skD)); px(16, hY+6, c(PA.skD));\\n line(21, hY+5, 4, c(PA.skD)); px(22, hY+6, c(PA.skD));\\n } else {\\n rect(15, hY+4, 4, 4, c(PA.eW)); rect(21, hY+4, 4, 4, c(PA.eW));\\n rect(16, hY+5, 2, 2, c(PA.e)); rect(22, hY+5, 2, 2, c(PA.e));\\n if (pose===\\\"thinking\\\") { rect(16, hY+4, 2, 2, c(PA.e)); rect(22, hY+4, 2, 2, c(PA.e)); } // look up\\n glow(15, hY+4, 4, 2, c(glassGlow)+\\\"66\\\"); glow(21, hY+4, 4, 2, c(glassGlow)+\\\"66\\\");\\n }\\n px(18, hY+8, c(PA.skD)); px(19, hY+8, c(PA.skD)); // nose\\n if (!sl) { line(16, hY+10, 7, c(PA.skD)); px(16, hY+11, c(PA.skD)); px(22, hY+11, c(PA.skD)); }\\n\\n // ── ROUND GLASSES ──\\n // Left lens frame\\n line(14, hY+3, 6, c(PA.gl0)); line(14, hY+7, 6, c(PA.gl1));\\n line(14, hY+3, 1, c(PA.gl0), true); line(19, hY+3, 1, c(PA.gl1), true);\\n // Right lens frame\\n line(21, hY+3, 6, c(PA.gl0)); line(21, hY+7, 6, c(PA.gl1));\\n line(21, hY+3, 1, c(PA.gl0), true); line(26, hY+3, 1, c(PA.gl1), true);\\n // Bridge\\n px(20, hY+5, c(PA.gl0));\\n // Temples\\n px(13, hY+5, c(PA.glL)); px(27, hY+5, c(PA.glL));\\n // Askew if sleeping\\n if (sl) { px(15, hY+3, c(PA.gl0)); px(16, hY+2, c(PA.gl0)); }\\n // Glow in lenses\\n if ((pose===\\\"working\\\"||pose===\\\"collab\\\") && !sl) {\\n glow(15, hY+4, 4, 3, \\\"rgba(200,144,32,0.5)\\\");\\n glow(22, hY+4, 4, 3, \\\"rgba(200,144,32,0.5)\\\");\\n }\\n\\n // ZZZ\\n if (sl) {\\n px(23, hY-4, c(PA.zz)); line(24, hY-7, 3, c(PA.zz)); px(24, hY-6, c(PA.zz)); px(26, hY-6, c(PA.zz));\\n rect(27, hY-10, 4, 2, c(PA.zz)); px(27, hY-9, c(PA.zz)); px(30, hY-9, c(PA.zz));\\n }\\n}\\n\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n// CHARACTER REGISTRY + APP\\n// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\nconst CHARS = [\\n { id:\\\"monkey\\\", emoji:\\\"🐒\\\", label:\\\"Space Monkey\\\", sub:\\\"Mission Director\\\", accent:\\\"#9B6FE8\\\", fn:drawMonkey },\\n { id:\\\"ninja\\\", emoji:\\\"🥷\\\", label:\\\"Life Support Officer\\\", sub:\\\"Infrastructure Controller\\\", accent:\\\"#FF40B0\\\", fn:drawNinja },\\n { id:\\\"engineer\\\", emoji:\\\"🔧\\\", label:\\\"Systems Engineer\\\", sub:\\\"Coder / Builder\\\", accent:\\\"#20D0E8\\\", fn:drawEngineer },\\n { id:\\\"archivist\\\", emoji:\\\"📚\\\", label:\\\"Station Archivist\\\", sub:\\\"Memory & Knowledge\\\", accent:\\\"#E0A030\\\", fn:drawArchivist },\\n];\\nconst POSES = [\\\"IDLE\\\",\\\"THINK\\\",\\\"WORK\\\",\\\"SLEEP\\\",\\\"WALK\\\",\\\"COLLAB\\\"];\\nconst POSE_KEYS = [\\\"idle\\\",\\\"thinking\\\",\\\"working\\\",\\\"sleep\\\",\\\"walk\\\",\\\"collab\\\"];\\n\\nexport default function App() {\\n const [tick, setTick] = useState(0);\\n const [activeChar, setActiveChar] = useState(0);\\n const [hoveredPose, setHoveredPose] = useState(0);\\n const [exporting, setExporting] = useState(null);\\n const tRef = useRef(0);\\n\\n const sheetCanvases = CHARS.map(() => useRef(null));\\n const displayCanvases = CHARS.map(() => useRef(null));\\n const previewRef = useRef(null);\\n\\n useEffect(() => {\\n let live = true;\\n function loop() {\\n if (!live) return;\\n tRef.current++;\\n setTick(n => n + 1);\\n requestAnimationFrame(loop);\\n }\\n requestAnimationFrame(loop);\\n return () => { live = false; };\\n }, []);\\n\\n useEffect(() => {\\n CHARS.forEach((ch, ci) => {\\n const cvs = sheetCanvases[ci].current;\\n if (!cvs) return;\\n const ctx = cvs.getContext(\\\"2d\\\");\\n ctx.clearRect(0, 0, 1920, 240);\\n POSE_KEYS.forEach((pose, pi) => ch.fn(ctx, pose, pi * FRAME_W, 0, tRef.current));\\n // Scale to display canvas\\n const disp = displayCanvases[ci].current;\\n if (disp) {\\n const dctx = disp.getContext(\\\"2d\\\");\\n dctx.clearRect(0, 0, disp.width, disp.height);\\n dctx.imageSmoothingEnabled = false;\\n dctx.drawImage(cvs, 0, 0, disp.width, disp.height);\\n }\\n });\\n }, [tick]);\\n\\n useEffect(() => {\\n const cvs = previewRef.current;\\n if (!cvs) return;\\n const ctx = cvs.getContext(\\\"2d\\\");\\n ctx.clearRect(0, 0, FRAME_W, FRAME_H);\\n CHARS[activeChar].fn(ctx, POSE_KEYS[hoveredPose], 0, 0, tRef.current);\\n }, [tick, activeChar, hoveredPose]);\\n\\n function exportPNG(ci) {\\n setExporting(ci);\\n setTimeout(() => {\\n const cvs = sheetCanvases[ci].current;\\n if (!cvs) { setExporting(null); return; }\\n const a = document.createElement(\\\"a\\\");\\n a.download = `${CHARS[ci].id}-spritesheet-1920x240.png`;\\n a.href = cvs.toDataURL(\\\"image/png\\\");\\n a.click();\\n setExporting(null);\\n }, 80);\\n }\\n\\n const acc = CHARS[activeChar].accent;\\n\\n return (\\n <div style={{ minHeight:\\\"100vh\\\", background:\\\"#12182A\\\", color:\\\"#D0C8F0\\\", fontFamily:\\\"'Courier New', monospace\\\", padding:\\\"18px 14px 40px\\\", boxSizing:\\\"border-box\\\" }}>\\n {CHARS.map((_,ci) => <canvas key={ci} ref={sheetCanvases[ci]} width={1920} height={240} style={{display:\\\"none\\\"}} />)}\\n\\n {/* Header */}\\n <div style={{textAlign:\\\"center\\\",marginBottom:22}}>\\n <div style={{fontSize:9,letterSpacing:6,color:\\\"#3A3468\\\",textTransform:\\\"uppercase\\\",marginBottom:3}}>Deep Space Station · Crew Registry</div>\\n <h1 style={{margin:0,fontSize:18,fontWeight:900,letterSpacing:3,color:\\\"#F0ECF8\\\"}}>SPRITE SHEET GENERATOR</h1>\\n <div style={{fontSize:9,color:\\\"#2C2848\\\",marginTop:3,letterSpacing:4}}>16-BIT PIXEL ART · 6 POSES · TRUE TRANSPARENCY · 1920×240</div>\\n </div>\\n\\n {/* Character tabs */}\\n <div style={{display:\\\"flex\\\",gap:5,justifyContent:\\\"center\\\",marginBottom:18,flexWrap:\\\"wrap\\\"}}>\\n {CHARS.map((ch,i) => (\\n <button key={ch.id} onClick={() => setActiveChar(i)} style={{\\n background: activeChar===i ? ch.accent+\\\"18\\\" : \\\"transparent\\\",\\n border:`1.5px solid ${activeChar===i ? ch.accent : \\\"#1A183A\\\"}`,\\n color: activeChar===i ? ch.accent : \\\"#504888\\\",\\n padding:\\\"6px 13px\\\", borderRadius:4, cursor:\\\"pointer\\\",\\n fontFamily:\\\"inherit\\\", fontSize:11, letterSpacing:1.5, transition:\\\"all 0.15s\\\",\\n }}>{ch.emoji} {ch.id.toUpperCase()}</button>\\n ))}\\n </div>\\n\\n {/* Preview + pose picker */}\\n <div style={{display:\\\"flex\\\",gap:14,justifyContent:\\\"center\\\",marginBottom:22,flexWrap:\\\"wrap\\\",alignItems:\\\"flex-start\\\"}}>\\n <div>\\n <div style={{fontSize:8,color:\\\"#2C2848\\\",letterSpacing:4,marginBottom:5,textAlign:\\\"center\\\"}}>LIVE PREVIEW · {POSES[hoveredPose]}</div>\\n <div style={{border:`1px solid ${acc}2A`,borderRadius:7,overflow:\\\"hidden\\\",background:\\\"#080C18\\\",lineHeight:0}}>\\n <canvas ref={previewRef} width={320} height={240} style={{display:\\\"block\\\",imageRendering:\\\"pixelated\\\"}} />\\n </div>\\n <div style={{textAlign:\\\"center\\\",marginTop:6,fontSize:10,color:acc,letterSpacing:1}}>{CHARS[activeChar].emoji} {CHARS[activeChar].label}</div>\\n <div style={{textAlign:\\\"center\\\",fontSize:8,color:\\\"#383460\\\",letterSpacing:1}}>{CHARS[activeChar].sub}</div>\\n </div>\\n <div style={{display:\\\"flex\\\",flexDirection:\\\"column\\\",gap:7}}>\\n <div style={{fontSize:8,color:\\\"#2C2848\\\",letterSpacing:4,marginBottom:1}}>SELECT POSE</div>\\n <div style={{display:\\\"grid\\\",gridTemplateColumns:\\\"1fr 1fr\\\",gap:4}}>\\n {POSES.map((p,pi) => (\\n <button key={p} onMouseEnter={() => setHoveredPose(pi)} onClick={() => setHoveredPose(pi)} style={{\\n padding:\\\"7px 11px\\\", background: hoveredPose===pi ? acc+\\\"12\\\" : \\\"transparent\\\",\\n border:`1px solid ${hoveredPose===pi ? acc : \\\"#16143A\\\"}`,\\n color: hoveredPose===pi ? acc : \\\"#484870\\\",\\n borderRadius:3, cursor:\\\"pointer\\\", fontFamily:\\\"inherit\\\", fontSize:10, letterSpacing:1.5, transition:\\\"all 0.1s\\\", textAlign:\\\"left\\\",\\n }}><span style={{opacity:0.4,fontSize:8}}>0{pi+1} </span>{p}</button>\\n ))}\\n </div>\\n <button onClick={() => exportPNG(activeChar)} disabled={exporting!==null} style={{\\n marginTop:2,padding:\\\"9px 14px\\\",background:acc+\\\"14\\\",\\n border:`1.5px solid ${acc}`,color:acc,borderRadius:4,\\n cursor:\\\"pointer\\\",fontFamily:\\\"inherit\\\",fontSize:10,letterSpacing:2,transition:\\\"all 0.14s\\\",\\n }}>{exporting===activeChar ? \\\"EXPORTING…\\\" : \\\"↓ EXPORT 1920×240 PNG\\\"}</button>\\n <div style={{fontSize:8,color:\\\"#1E1C38\\\",letterSpacing:1,textAlign:\\\"center\\\"}}>transparent · anti-aliased for #12182A</div>\\n </div>\\n </div>\\n\\n {/* All 4 strips */}\\n <div style={{fontSize:8,color:\\\"#1E1C38\\\",letterSpacing:4,marginBottom:12,textAlign:\\\"center\\\"}}>ALL SPRITE SHEETS — EXPORT FOR FULL 1920px</div>\\n <div style={{display:\\\"flex\\\",flexDirection:\\\"column\\\",gap:14}}>\\n {CHARS.map((ch,ci) => (\\n <div key={ch.id}>\\n <div style={{display:\\\"flex\\\",alignItems:\\\"center\\\",gap:8,marginBottom:3}}>\\n <span style={{fontSize:10,color:ch.accent,letterSpacing:1.5}}>{ch.emoji} {ch.label.toUpperCase()}</span>\\n <span style={{fontSize:8,color:\\\"#2C2848\\\"}}>— {ch.sub}</span>\\n <button onClick={() => exportPNG(ci)} disabled={exporting!==null} style={{\\n marginLeft:\\\"auto\\\",padding:\\\"2px 9px\\\",background:\\\"transparent\\\",\\n border:`1px solid ${ch.accent}44`,color:ch.accent,borderRadius:3,\\n cursor:\\\"pointer\\\",fontFamily:\\\"inherit\\\",fontSize:9,letterSpacing:1,\\n }}>↓ PNG</button>\\n </div>\\n <div style={{display:\\\"flex\\\",marginBottom:2}}>\\n {POSES.map(p => <div key={p} style={{flex:\\\"0 0 96px\\\",minWidth:96,fontSize:7,color:\\\"#1E1C38\\\",letterSpacing:2,textAlign:\\\"center\\\"}}>{p}</div>))}\\n </div>\\n <div style={{overflowX:\\\"auto\\\",borderRadius:3,border:`1px solid ${ch.accent}1A`}}>\\n <div\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":180,"output":20480,"cacheRead":69760,"cacheWrite":0,"re