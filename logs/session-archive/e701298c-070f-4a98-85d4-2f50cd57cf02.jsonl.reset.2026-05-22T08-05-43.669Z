{"type":"message","id":"79d6a1b0","parentId":"05877d93","timestamp":"2026-05-21T18:54:07.347Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"2bc7f8b2-4dff-46cb-a13d-d7a0f433cd70","name":"read","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/scripts/session-expiry.sh"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/scripts/session-expiry.sh\"}"},{"type":"toolCall","id":"4a9313ca-a248-45a3-be4c-270fd53dee9b","name":"read","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/scripts/error-watchdog.sh"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/scripts/error-watchdog.sh\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":1884,"output":58,"cacheRead":20864,"cacheWrite":0,"totalTokens":22806,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779389636925,"responseId":"gen-1779389637-3sv6MyzK30cppJjbnQba"}}
{"type":"message","id":"dfe352b6","parentId":"79d6a1b0","timestamp":"2026-05-21T18:54:07.443Z","message":{"role":"toolResult","toolCallId":"2bc7f8b2-4dff-46cb-a13d-d7a0f433cd70","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# session-expiry.sh - Auto‑expire sessions idle >24h\n# This script runs daily to refuse stale sessions.\n\n# Grab the directory containing session JSONL files\nSESSION_DIR=\"${HOME}/.openclaw/agents/main/sessions\"\nTHRESHOLD=$((24*60*60))  # 24 hours in seconds\nNOW=$(date +%s)\n\n# Find sessions whose last modification time is older than threshold\nOLD=$(ls -1 \"$SESSION_DIR\"/*.jsonl 2>/dev/null | while read -r f; do\n  mtime=$(stat -f %m \"$f\")\n  if (( mtime < NOW - THRESHOLD )); then\n    echo \"$f\"\n  fi\ndone)\n\nif [ -z \"$OLD\" ]; then\n  echo \"$(date): No idle sessions older than 24h.\" >> \"$SESSION_DIR/expiry.log\"\n  exit 0\nfi\n\n# Delete old sessions and log\nfor f in $OLD; do\n  echo \"$(date): Expiring stale session $(basename $f)\" >> \"$SESSION_DIR/expiry.log\"\n  rm -f \"$f\"\n  # Also delete any associated lock files\n  lock=\"$SESSION_DIR/$(basename $f .jsonl).lock\"\n  [ -f \"$lock\" ] && rm -f \"$lock\"\ndone\n\nexit 0"}],"isError":false,"timestamp":1779389647443}}
{"type":"message","id":"f10dff7c","parentId":"dfe352b6","timestamp":"2026-05-21T18:54:07.444Z","message":{"role":"toolResult","toolCallId":"4a9313ca-a248-45a3-be4c-270fd53dee9b","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# error-watchdog.sh – Detect error spikes of identical messages within 10 min\n# If >=5 occurrences, write alert to mount-alert.txt (Telegram monitors this file)\n\nLOG_FILE=\"/tmp/openclaw/openclaw-$(date +%Y-%m-%d).log\"\nALERT_FILE=\"${HOME}/.openclaw/workspace/mount-alert.txt\"\nTHRESHOLD=5\nWINDOW=$((10*60)) # 10 minutes in seconds\nNOW=$(date +%s)\n\n# Function to parse ISO8601 to epoch (macOS compatible)\niso_to_epoch() {\n  local iso=\"${1%%+*}\"   # drop +01:00 part\n  local base=\"${iso%%.*}\" # drop milliseconds\n  date -j -f \"%Y-%m-%dT%H:%M:%S\" \"$base\" +%s 2>/dev/null\n}\n\n# Check if log file exists\nif [ ! -f \"$LOG_FILE\" ]; then\n  [ -f \"$ALERT_FILE\" ] && rm -f \"$ALERT_FILE\"\n  exit 0\nfi\n\n# Gather recent error messages and count with sort | uniq -c\n# (macOS bash 3.x compatible — no associative arrays)\nRECENT=$(while IFS= read -r line; do\n  ts=$(echo \"$line\" | sed -n 's/.*\"date\":\"\\([^\"]*\\)\".*/\\1/p')\n  [ -z \"$ts\" ] && continue\n  epoch=$(iso_to_epoch \"$ts\")\n  [ -z \"$epoch\" ] && continue\n  if (( epoch >= NOW - WINDOW )); then\n    msg=$(echo \"$line\" | sed -n 's/.*\"message\":\"\\([^\"]*\\)\".*/\\1/p')\n    [ -n \"$msg\" ] && echo \"$msg\"\n  fi\ndone < <(grep '\\[ERROR\\]' \"$LOG_FILE\") | sort | uniq -c | sort -rn)\n\n# Check if any message exceeds threshold\nALERTED=0\nwhile IFS= read -r entry; do\n  [ -z \"$entry\" ] && continue\n  count=$(echo \"$entry\" | awk '{print $1}')\n  msg=$(echo \"$entry\" | awk '{$1=\"\"; print substr($0,2)}')\n  if (( count >= THRESHOLD )); then\n    echo \"$(date): ALERT – $count occurrences of error: $msg\" > \"$ALERT_FILE\"\n    ALERTED=1\n    break\n  fi\ndone <<< \"$RECENT\"\n\n# Clean up stale alert if no trigger\nif (( ALERTED == 0 )); then\n  [ -f \"$ALERT_FILE\" ] && rm -f \"$ALERT_FILE\"\nfi\n\nexit 0\n"}],"isError":false,"timestamp":1779389647443}}
