 the station. Toggle jobs on or off.\n      </PageHeader>\n\n      {/* Tabs */}\n      <div className=\"flex items-center gap-1 mb-6 border-b border-border\">\n        <button","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779964729044}}
