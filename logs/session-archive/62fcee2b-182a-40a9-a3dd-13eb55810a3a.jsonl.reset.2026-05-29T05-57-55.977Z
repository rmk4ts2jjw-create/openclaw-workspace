{\n        const cronJobs = cronJobsData as OpenClawCronJob[];\n        setJobs(cronJobs);\n\n        const savedMap = new Map(\n          (savedErrors as Record<string, unknown>[]).map((e) => [e.id, e.status as CronError[\"status\"]])\n        );\n\n        // Extract errors from jobs, merge with saved statuses\n        const errorItems: CronError[] = cronJobs\n          .filter((j) => (j.consecutiveErrors ?? 0) > 0 || j.status === \"error\")\n          .map((j) => {\n            const id = `err-${j.id}`;\n            const savedStatus = savedMap.get(id);\n            // Determine the effective status:\n            // - If job is still failing AND was previously investigated → keep in_progress"}],"details":{"status":"completed","exitCode":0,"durationMs":18,"aggregated":"import { useState, useCallback, useEffect } from \"react\";\nimport { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader, Pill } from \"@/components/PageHeader\";\nimport type { OpenClawCronJob } from \"@/lib/server-data\";\nimport { Power, Clock, AlertTriangle, CheckCircle, Loader2, Play, SkipForward, CheckCircle2, RotateCcw } from \"lucide-react\";\n\nexport const Route = createFileRoute(\"/scheduler\")({\n  head: () => ({ meta: [{ title: \"Scheduler — Mission Control\" }] }),\n  component: SchedulerPage,\n});\n\n// ── Types ────────────────────────────────────────────────────────────────────\n\ninterface CronError {\n  id: string;\n  jobName: string;\n  jobId: string;\n  jobEnabled: boolean;\n  consecutiveErrors: number;\n  lastError: string;\n  lastErrorReason: string;\n  lastRunAt: string;\n  status: \"new\" | \"in_progress\" | \"completed\" | \"skipped\";\n  createdAt: string;\n}\n\n// ── Main Page ────────────────────────────────────────────────────────────────\n\ntype Tab = \"jobs\" | \"errors\";\n\nfunction SchedulerPage() {\n  const [activeTab, setActiveTab] = useState<Tab>(\"jobs\");\n  const [jobs, setJobs] = useState<OpenClawCronJob[]>([]);\n  const [errors, setErro