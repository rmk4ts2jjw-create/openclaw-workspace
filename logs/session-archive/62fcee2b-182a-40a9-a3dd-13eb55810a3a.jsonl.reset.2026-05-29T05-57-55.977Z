; }\n  catch (err) { return { ok: false, message: String(err) }; }\n});\n\nexport const pauseQueue = createServerFn({ method: \"POST\" }).handler(async () => {\n  try {\n    const { writeFileSync } = await import(\"node:fs\");\n    writeFileSync(join(WORKSPACE, \"data\", \"queue-paused.flag\"), \"\", \"utf-8\");\n    return { ok: true, message: \"Queue paused\" };\n  } catch (err) { return { ok: false, message: String(err) }; }\n});\n\nexport const resumeQueue = createServerFn({ method: \"POST\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try { execSync(`rm -f ${join(WORKSPACE, \"data\", \"queue-paused.flag\")}`, { encoding: \"utf-8\" }); return { ok: true, message: \"Queue resumed\" }; }\n  catch (err) { return { ok: false, message: String(err) }; }\n});\n\nexport const restartMissionControl = createServerFn({ method: \"POST\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    try { execSync(\"lsof -ti :3001 | xargs kill -9 2>/dev/null || true\", { encoding: \"utf-8\", timeout: 5000 }); } catch { /* */ }\n    const projectDir = join(WORKSPACE, \"mission-control-dashboard\");\n    execSync(`cd ${projectDir} && nohup npx vite dev --port 3001 > /tmp/mc-dev.log 2>&1 &`, { encoding: \"utf-8\", timeout: 5000 });\n    await new Promise((r) => setTimeout(r, 3000));\n    try { const pid = execSync(\"lsof -ti :3001\", { encoding: \"utf-8\" }).trim(); if (pid) return { ok: true, message: `Dev server restarted (PID ${pid})` }; } catch { /* */ }\n    return { ok: false, message: \"Dev server may not have started — check /tmp/mc-dev.log\" };\n  } catch (err) { return { ok: false, message: String(err) }; }\n});\n\nexport const getAwaitingReviewCount = createServerFn({ method: \"GET\" }).handler(async () => {\n  const tasks = (await import(\"./tasks\")).getTasks;\n  return { count: 0 }; // Placeholder — actual implementation reads tasks.json\n});\n\nexport const runBackup = createServerFn({ method: \"POST\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    const output = execSync(\"bash /Users/spacemonkey/.openclaw/workspace/scripts/openclaw-backup-quick.sh\", { timeout: 30000, encoding: \"utf-8\" });\n    const match = output.match(/([\\d.]+[KMGT]B)/);\n    return { ok: true, size: match ? match[1] : \"done\" };\n  } catch (err) { return { ok: false, size: \"failed\" }; }\n});\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/quick-actions.ts\", \"content\": \"// src/lib/server-data/quick-actions.ts\\n\\nimport { createServerFn } from \\\"@tanstack/react-start\\\";\\nimport { writeFileSync, join } from \\\"node:fs\\\";\\nimport { WORKSPACE, type ActionResult, type CronToggleResult, type AwaitingReviewResult, type OpenClawCronJob } from \\\"./types\\\";\\nimport { readJsonOrNull } from \\\"./helpers\\\";\\n\\nexport const restartGateway = createServerFn({ method: \\\"POST\\\" }).handler(async () => {\\n  const { execSync } = await import(\\\"node:child_process\\\");\\n  try { execSync(\\\"openclaw gateway restart\\\", { timeout: 15000, encoding: \\\"utf-8\\\" }); return { ok: true, message: \\\"Gateway restarted\\\" }; }\\n  catch (err) { return { ok: false, message: String(err) }; }\\n});\\n\\nexport const clearCache = createServerFn({ method: \\\"POST\\\" }).handler(async () => {\\n  const { execSync } = await import(\\\"node:child_process\\\");\\n  try { execSync(\\\"rm -rf /Users/spacemonkey/.openclaw/.freeride-cache.json\\\", { encoding: \\\"utf-8\\\" }); return { ok: true, message: \\\"Cache cleared\\\" }; }\\n  catch (err) { return { ok: false, message: String(err) }; }\\n});\\n\\nexport const runFreerideRefresh = createServerFn({ method: \\\"POST\\\" }).handler(async () => {\\n  const { execSync } = await import(\\\"node:child_process\\\");\\n  try { execSync(\\\"openclaw models refresh 2>/dev/null || echo 'refresh triggere