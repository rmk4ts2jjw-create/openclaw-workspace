{"type":"message","id":"aa8eff17","parentId":"9f6972d5","timestamp":"2026-05-28T11:42:20.946Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"299397b9-5b4a-427a-83f3-a92c2523fa5b","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/system.ts","content":"// src/lib/server-data/system.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { readFileSync, readdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { WORKSPACE, OPENCLAW_DIR, type SystemStats, type SystemHealth, type ActionResult } from \"./types\";\nimport { readJsonOrNull, formatBytes, parseSize } from \"./helpers\";\n\nexport const getSystemStats = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const agents = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = agents?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const crons = Array.isArray(cfg?.cron) ? cfg.cron as unknown[] : [];\n    const activeCrons = crons.filter((c: unknown) => (c as Record<string, unknown>).enabled !== false).length;\n\n    let workspaceFiles = 0;\n    try { workspaceFiles = readdirSync(WORKSPACE).length; } catch { /* ignore */ }\n\n    let cpuLoad = \"0\";\n    let diskUsed = \"—\"; let diskFree = \"—\"; let diskTotal = \"—\"; let diskPercent = 0;\n    let memoryUsed = \"—\"; let memoryTotal = \"—\"; let memoryPercent = 0;\n    let uptime = \"—\"; let gatewayStatus = \"unknown\"; let gatewayUptime = \"—\";\n    let wdDiskUsed = \"—\"; let wdDiskTotal = \"—\"; let wdDiskPercent = 0; let wdDiskMount = \"—\";\n\n    try {\n      const { execSync } = await import(\"node:child_process\");\n\n      try { cpuLoad = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim(); } catch { /* */ }\n\n      try {\n        const df = execSync(\"df -h / | tail -1 | awk '{print $2, $3, $4, $5}'\", { encoding: \"utf-8\" }).trim().split(\" \");\n        if (df.length >= 4) { diskTotal = df[0]; diskUsed = df[1]; diskFree = df[2]; diskPercent = parseInt(df[3].replace(\"%\", \"\")) || 0; }\n      } catch { /* */ }\n\n      try {\n        const mounts = execSync(\"df -h | grep -iE 'wd|mycloud|public' | awk '{print $2, $3, $4, $6}'\", { encoding: \"utf-8\" }).trim();\n        if (mounts) {\n          const parts = mounts.split(\" \");\n          if (parts.length >= 4) {\n            wdDiskTotal = parts[0]; wdDiskUsed = parts[1]; wdDiskMount = parts[3];\n            const usedNum = parseSize(parts[1]); const totalNum = parseSize(parts[0]);\n            if (totalNum > 0) wdDiskPercent = Math.round((usedNum / totalNum) * 100);\n          }\n        }\n      } catch { /* */ }\n\n      try {\n        const vmStat = execSync(\"vm_stat\", { encoding: \"utf-8\" });\n        const pageSize = 4096;\n        const parse = (key: string) => { const m = vmStat.match(new RegExp(`${key}:\\\\s+(\\\\d+)`)); return m ? parseInt(m[1]) : 0; };\n        const usedBytes = (parse(\"Pages active\") + parse(\"Pages wired down\") + parse(\"Pages speculative\")) * pageSize;\n        const totalBytes = parseInt(execSync(\"sysctl -n hw.memsize\", { encoding: \"utf-8\" }).trim()) || 0;\n        if (totalBytes > 0) {\n          memoryPercent = Math.round((usedBytes / totalBytes) * 100);\n          memoryUsed = formatBytes(usedBytes); memoryTotal = formatBytes(totalBytes);\n        }\n      } catch { /* */ }\n\n      try {\n        const upSec = execSync(\"sysctl -n kern.boottime | awk '{print $4}' | tr -d ','\", { encoding: \"utf-8\" }).trim();\n        const upMs = Date.now() - parseInt(upSec) * 1000;\n        const d = Math.floor(upMs / 86400000); const h = Math.floor((upMs % 86400000) / 3600000); const m = Math.floor((upMs % 3600000) / 60000);\n        uptime = d > 0 ? `${d}d ${h}h ${m}m` : `${h}h ${m}m`;\n      } catch { /* */ }\n\n      try {\n        const gw = execSync(\"openclaw gateway status 2>/dev/null\", { encoding: \"utf-8\" }).trim();\n        gatewayStatus = gw.toLowerCase().includes(\"running\") ? \"running\" : gw.toLowerCase().includes(\"stopped\") ? \"stopped\" : \"unknown\";\n        try {\n          const gwPid = execSync(\"pgrep -f 'openclaw' | head -1\", { encoding: \"utf-8\" }).trim();\n          if (gwPid) {\n            const gwStart = execSync(\"ps -o lstart= -p \" + gwPid, { encoding: \"utf-8\" }).trim();\n            if (gwStart) { const gwH = Math.floor((Date.now() - new Date(gwStart).getTime()) / 3600000); const gwM = Math.floor(((Date.now() - new Date(gwStart).getTime()) % 3600000) / 60000); gatewayUptime = `${gwH}h ${gwM}m`; }\n          }\n        } catch { /* */ }\n      } catch { gatewayStatus = \"unknown\"; }\n\n    } catch { /* ignore all */ }\n\n    return {\n      hostname: \"spacemonkey\", uptime, gatewayUptime,\n      diskUsed, diskFree, diskTotal, diskPercent,\n      wdDiskUsed, wdDiskTotal, wdDiskPercent, wdDiskMount,\n      memoryUsed, memoryTotal, memoryPercent, cpuLoad,\n      openclawVersion: String(cfg?.version || \"unknown\"),\n      model: String(modelConfig?.primary || \"unknown\"),\n      gatewayStatus, activeCrons, totalCrons: crons.length, workspaceFiles, lastBackup: \"—\",\n    } as SystemStats;\n  } catch (e) { console.error(\"[getSystemStats] ERROR:\", e); throw e; }\n});\n\nexport const getSystemHealth = createServerFn({ method: \"GET\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    const cpu = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim();\n    const mem = execSync(\"vm_stat | head -5\", { encoding: \"utf-8\" }).trim();\n    const disk = execSync(\"df -h / | tail -1 | awk '{print $3, $4, $5}'\", { encoding: \"utf-8\" }).trim();\n    const gateway = execSync(\"openclaw gateway status 2>/dev/null | head -1 || echo 'unknown'\", { encoding: \"utf-8\" }).trim();\n    return { cpu, mem, disk, gateway, timestamp: new Date().toISOString() };\n  } catch { return { cpu: \"—\", mem: \"—\", disk: \"—\", gateway: \"unknown\", timestamp: new Date().toISOString() }; }\n});\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/system.ts\", \"content\": \"// src/lib/server-data/system.ts\\n\\nimport { createServerFn } from \\\"@tanstack/react-start\\\";\\nimport { readFileSync, readdirSync } from \\\"node:fs\\\";\\nimport { join } from \\\"node:path\\\";\\nimport { WORKSPACE, OPENCLAW_DIR, type SystemStats, type SystemHealth, type ActionResult } from \\\"./types\\\";\\nimport { readJsonOrNull, formatBytes, parseSize } from \\\"./helpers\\\";\\n\\nexport const getSystemStats = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  try {\\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \\\"openclaw.json\\\"));\\n    const agents = cfg?.agents as Record<string, unknown> | undefined;\\n    const defaults = agents?.defaults as Record<string, unknown> | undefined;\\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\\n    const crons = Array.isArray(cfg?.cron) ? cfg.cron as unknown[] : [];\\n    const activeCrons = crons.filter((c: unknown) => (c as Record<string, unknown>).enabled !== false).length;\\n\\n    let workspaceFiles = 0;\\n    try { workspaceFiles = readdirSync(WORKSPACE).length; } catch { /* ignore */ }\\n\\n    let cpuLoad = \\\"0\\\";\\n    let diskUsed = \\\"—\\\"; let diskFree = \\\"—\\\"; let diskTotal = \\\"—\\\"; let diskPercent = 0;\\n    let memoryUsed = \\\"—\\\"; let memoryTotal = \\\"—\\\"; let memoryPercent = 0;\\n    let uptime = \\\"—\\\"; let gatewayStatus = \\\"unknown\\\"; let gatewayUptime = \\\"—\\\";\\n    let wdDiskUsed = \\\"—\\\"; let wdDiskTotal = \\\"—\\\"; let wdDiskPercent = 0; let wdDiskMount = \\\"—\\\";\\n\\n    try {\\n      const { execSync } = await import(\\\"node:child_process\\\");\\n\\n      try { cpuLoad = execSync(\\\"sysctl -n vm.loadavg | awk '{print $2}'\\\", { encoding: \\\"utf-8\\\" }).trim(); } catch { /* */ }\\n\\n      try {\\n        const df = execSync(\\\"df -h / | tail -1 | awk '{print $2, $3, $4, $5}'\\\", { encoding: \\\"utf-8\\\" }).trim().split(\\\" \\\");\\n        if (df.length >= 4) { diskTotal = df[0]; diskUsed = df[1]; diskFree = df[2]; diskPercent = parseInt(df[3].replace(\\\"%\\\", \\\"\\\")) || 0; }\\n      } catch { /* */ }\\n\\n      try {\\n        const mounts = execSync(\\\"df -h | grep -iE 'wd|mycloud|public' | awk '{print $2, $3, $4, $6}'\\\", { encoding: \\\"utf-8\\\" }).trim();\\n        if (mounts) {\\n          const parts = mounts.split(\\\" \\\");\\n          if (parts.length >= 4) {\\n            wdDiskTotal = parts[0]; wdDiskUsed = parts[1]; wdDiskMount = parts[3];\\n            const usedNum = parseSize(parts[1]); const totalNum = parseSize(parts[0]);\\n            if (totalNum > 0) wdDiskPercent = Math.round((usedNum / totalNum) * 100);\\n          }\\n        }\\n      } catch { /* */ }\\n\\n      try {\\n        const vmStat = execSync(\\\"vm_stat\\\", { encoding: \\\"utf-8\\\" });\\n        const pageSize = 4096;\\n        const parse = (key: string) => { const m = vmStat.match(new RegExp(`${key}:\\\\\\\\s+(\\\\\\\\d+)`)); return m ? parseInt(m[1]) : 0; };\\n        const usedBytes = (parse(\\\"Pages active\\\") + parse(\\\"Pages wired down\\\") + parse(\\\"Pages speculative\\\")) * pageSize;\\n        const totalBytes = parseInt(execSync(\\\"sysctl -n hw.memsize\\\", { encoding: \\\"utf-8\\\" }).trim()) || 0;\\n        if (totalBytes > 0) {\\n          memoryPercent = Math.round((usedBytes / totalBytes) * 100);\\n          memoryUsed = formatBytes(usedBytes); memoryTotal = formatBytes(totalBytes);\\n        }\\n      } catch { /* */ }\\n\\n      try {\\n        const upSec = execSync(\\\"sysctl -n kern.boottime | awk '{print $4}' | tr -d ','\\\", { encoding: \\\"utf-8\\\" }).trim();\\n        const upMs = Date.now() - parseInt(upSec) * 1000;\\n        const d = Math.floor(upMs / 86400000); const h = Math.floor((upMs % 86400000) / 3600000); const m = Math.floor((upMs % 3600000) / 60000);\\n        uptime = d > 0 ? `${d}d ${h}h ${m}m` : `${h}h ${m}m`;\\n      } catch { /* */ }\\n\\n      try {\\n        const gw = execSync(\\\"openclaw gateway status 2>/dev/null\\\", { encoding: \\\"utf-8\\\" }).trim();\\n        gatewayStatus = gw.toLowerCase().includes(\\\"running\\\") ? \\\"running\\\" : gw.toLowerCase().includes(\\\"stopped\\\") ? \\\"stopped\\\" : \\\"unknown\\\";\\n        try {\\n          const gwPid = execSync(\\\"pgrep -f 'openclaw' | head -1\\\", { encoding: \\\"utf-8\\\" }).trim();\\n          if (gwPid) {\\n            const gwStart = execSync(\\\"ps -o lstart= -p \\\" + gwPid, { encoding: \\\"utf-8\\\" }).trim();\\n            if (gwStart) { const gwH = Math.floor((Date.now() - new Date(gwStart).getTime()) / 3600000); const gwM = Math.floor(((Date.now() - new Date(gwStart).getTime()) % 3600000) / 60000); gatewayUptime = `${gwH}h ${gwM}m`; }\\n          }\\n        } catch { /* */ }\\n      } catch { gatewayStatus = \\\"unknown\\\"; }\\n\\n    } catch { /* ignore all */ }\\n\\n    return {\\n      hostname: \\\"spacemonkey\\\", uptime, gatewayUptime,\\n      diskUsed, diskFree, diskTotal, diskPercent,\\n      wdDiskUsed, wdDiskTotal, wdDiskPercent, wdDiskMount,\\n      memoryUsed, memoryTotal, memoryPercent, cpuLoad,\\n      openclawVersion: String(cfg?.version || \\\"unknown\\\"),\\n      model: String(modelConfig?.primary || \\\"unknown\\\"),\\n      gatewayStatus, activeCrons, totalCrons: crons.length, workspaceFiles, lastBackup: \\\"—\\\",\\n    } as SystemStats;\\n  } catch (e) { console.error(\\\"[getSystemStats] ERROR:\\\", e); throw e; }\\n});\\n\\nexport const getSystemHealth = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\