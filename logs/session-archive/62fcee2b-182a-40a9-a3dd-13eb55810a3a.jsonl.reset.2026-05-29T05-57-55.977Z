{"type":"message","id":"7daac12a","parentId":"2ce44b8a","timestamp":"2026-05-28T10:06:16.735Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"7bf7da7b-f8fc-405f-8882-1abeacd5ee00","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/openclaw-status.ts","content":"// src/lib/server-data/openclaw-status.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { join } from \"node:path\";\nimport { OPENCLAW_DIR, WORKSPACE, type OpenClawStatus, type OpenClawCronJob, type Task } from \"./types\";\nimport { readJsonOrNull } from \"./helpers\";\n\nexport const getOpenClawStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const models = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = models?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const channels = cfg?.channels as Record<string, unknown> | undefined;\n    const channelNames = channels ? Object.keys(channels).filter((k) => (channels[k] as Record<string, unknown>)?.enabled) : [];\n    const meta = cfg?.meta as Record<string, unknown> | undefined;\n    const skills = cfg?.skills as Record<string, unknown> | undefined;\n    const enabledSkills = skills ? Object.entries(skills).filter(([, v]) => (v as Record<string, unknown>)?.enabled).length : 0;\n\n    return {\n      gateway: \"running\",\n      version: String(meta?.lastTouchedVersion || \"unknown\"),\n      dashboard: \"http://127.0.0.1:18789/\",\n      channel: channelNames.join(\", \") || \"none\",\n      sessions: 4,\n      model: String(modelConfig?.primary || \"unknown\"),\n      ctx: \"1M\",\n      uptime: \"running\",\n      heartbeat: \"30m\",\n      tasksActive: 0,\n      tasksQueued: 0,\n      memoryPlugin: enabledSkills > 0 ? \"enabled\" : \"not checked\",\n    } as OpenClawStatus;\n  } catch (e) { console.error(\"[getOpenClawStatus] ERROR:\", e); throw e; }\n});\n\nexport const getOpenClawCrons = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const { execSync } = await import(\"node:child_process\");\n    const output = execSync(\"/opt/homebrew/bin/openclaw cron list --all --json\", { encoding: \"utf-8\", timeout: 10000 });\n    const data = JSON.parse(output);\n    const jobs = (data.jobs || []) as Record<string, unknown>[];\n    return jobs.map((j) => {\n      const state = (j.state || {}) as Record<string, unknown>;\n      const schedule = (j.schedule || {}) as Record<string, unknown>;\n      const payload = (j.payload || {}) as Record<string, unknown>;\n      return {\n        id: String(j.id || \"\"),\n        name: String(j.name || \"Unknown\"),\n        schedule: String(schedule.expr || \"\"),\n        enabled: j.enabled !== false,\n        status: String(state.lastRunStatus || \"never\"),\n        lastRun: state.lastRunAtMs ? new Date(Number(state.lastRunAtMs)).toISOString() : \"—\",\n        nextRun: state.nextRunAtMs ? new Date(Number(state.nextRunAtMs)).toISOString() : \"—\",\n        message: String(payload.message || \"\").slice(0, 150),\n      } as OpenClawCronJob;\n    });\n  } catch (err) { console.error(\"[getOpenClawCrons] Error:\", err); return []; }\n});\n\nexport const getAwaitingReviewCount = createServerFn({ method: \"GET\" }).handler(async () => {\n  const taskData = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  const count = taskData.filter((t) => t.status === \"awaiting_review\").length;\n  return { count };\n});\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/openclaw-status.ts\", \"content\": \"// src/lib/server-data/openclaw-status.ts\\n\\nimport { createServerFn } from \\\"@tanstack/react-start\\\";\\nimport { join } from \\\"node:path\\\";\\nimport { OPENCLAW_DIR, WORKSPACE, type OpenClawStatus, type OpenClawCronJob, type Task } from \\\"./types\\\";\\nimport { readJsonOrNull } from \\\"./helpers\\\";\\n\\nexport const getOpenClawStatus = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  try {\\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \\\"openclaw.json\\\"));\\n    const models = cfg?.agents as Record<string, unknown> | undefined;\\n    const defaults = models?.defaults as Record<string, unknown> | undefined;\\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\\n    const channels = cfg?.channels as Record<string, unknown> | undefined;\\n    const channelNames = channels ? Object.keys(channels).filter((k) => (channels[k] as Record<string, unknown>)?.enabled) : [];\\n    const meta = cfg?.meta as Record<string, unknown> | undefined;\\n    const skills = cfg?.skills as Record<string, unknown> | undefined;\\n    const enabledSkills = skills ? Object.entries(skills).filter(([, v]) => (v as Record<string, unknown>)?.enabled).length : 0;\\n\\n    return {\\n      gateway: \\\"running\\\",\\n      version: String(meta?.lastTouchedVersion || \\\"unknown\\\"),\\n      dashboard: \\\"http://127.0.0.1:18789/\\\",\\n      channel: channelNames.join(\\\", \\\") || \\\"none\\\",\\n      sessions: 4,\\n      model: String(modelConfig?.primary || \\\"unknown\\\"),\\n      ctx: \\\"1M\\\",\\n      uptime: \\\"running\\\",\\n      heartbeat: \\\"30m\\\",\\n      tasksActive: 0,\\n      tasksQueued: 0,\\n      memoryPlugin: enabledSkills > 0 ? \\\"enabled\\\" : \\\"not checked\\\",\\n    } as OpenClawStatus;\\n  } catch (e) { console.error(\\\"[getOpenClawStatus] ERROR:\\\", e); throw e; }\\n});\\n\\nexport const getOpenClawCrons = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  try {\\n    const { execSync } = await import(\\\"node:child_process\\\");\\n    const output = execSync(\\\"/opt/homebrew/bin/openclaw cron list --all --json\\\", { encoding: \\\"utf-8\\\", timeout: 10000 });\\n    const data = JSON.parse(output);\\n    const jobs = (data.jobs || []) as Record<string, unknown>[];\\n    return jobs.map((j) => {\\n      const state = (j.state || {}) as Record<string, unknown>;\\n      const schedule = (j.schedule || {}) as Record<string, unknown>;\\n      const payload = (j.payload || {}) as Record<string, unknown>;\\n      return {\\n        id: String(j.id || \\\"\\\"),\\n        name: String(j.name || \\\"Unknown\\\"),\\n        schedule: String(schedule.expr || \\\"\\\"),\\n        enabled: j.enabled !== false,\\n        status: String(state.lastRunStatus || \\\"never\\\"),\\n        lastRun: state.lastRunAtMs ? new Date(Number(state.lastRunAtMs)).toISOString() : \\\"—\\\",\\n        nextRun: state.nextRunAtMs ? new Date(Number(state.nextRunAtMs)).toISOString() : \\\"—\\\",\\n        message: String(payload.message || \\\"\\\").slice(0, 150),\\n      } as OpenClawCronJob;\\n    });\\n  } catch (err) { console.error(\\\"[getOpenClawCrons] Error:\\\", err); return []; }\\n});\\n\\nexport const getAwaitingReviewCount = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  const taskData = readJsonOrNull<Task[]>(join(WORKSPACE, \\\"data\\\", \\\"tasks.json\\\")) || [];\\n  const count = taskData.filter((t) => t.status === \\\"awaiting_review\\\").length;\\n  return { count };\\n});\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":321,"output":888,"cacheRead":132992,"cacheWrite":0,"totalTokens":134201,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779962742844,"responseId":"gen-1779962743-KIltj2m2DuarxJV1OnSi"}}
