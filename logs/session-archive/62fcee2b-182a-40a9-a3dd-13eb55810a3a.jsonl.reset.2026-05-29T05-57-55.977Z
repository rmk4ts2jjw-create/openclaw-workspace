{"type":"message","id":"716afd87","parentId":"03cbaf11","timestamp":"2026-05-28T11:42:20.946Z","message":{"role":"assistant","content":[{"type":"text","text":"Now the remaining modules — search, activity, system-stats, agent-status, quick-actions, openclaw-status. Let me do them in batches:"},{"type":"toolCall","id":"4044a373-663b-412a-95cf-969414321f80","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/mission-control-dashboard && cat src/lib/server-data/sections/Search.ts","timeout":5},"partialArgs":"{\"command\": \"cd ~/.openclaw/workspace/mission-control-dashboard && cat src/lib/server-data/sections/Search.ts\", \"timeout\": 5}"},{"type":"toolCall","id":"aeb2cc5c-fd95-406c-ab97-4289405681f1","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace/mission-control-dashboard && cat src/lib/server-data/sections/Activity-Feed.ts","timeout":5},"partialArgs":"{\"command\": \"cd ~/.openclaw/workspace/mission-control-dashboard && cat src/lib/server-data/sections/Activity-Feed.ts\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":788,"output":118,"cacheRead":120192,"cacheWrite":0,"totalTokens":121098,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779962440639,"responseId":"gen-1779962440-zk8FZS1CrBidBQbEqfka"}}
{"type":"message","id":"d01dd3b6","parentId":"716afd87","timestamp":"2026-05-28T11:42:20.946Z","message":{"role":"toolResult","toolCallId":"4044a373-663b-412a-95cf-969414321f80","toolName":"exec","content":[{"type":"text","text":"[... 3602 more characters truncat"}],"details":{"status":"completed","exitCode":0,"durationMs":8,"aggregated":"export interface SearchResult {\n  id: string;\n  title: string;\n  snippet: string;\n  type: \"task\" | \"doc\" | \"memory\" | \"project\" | \"incident\" | \"cron\";\n  url: string;\n  date?: string;\n}\n\nexport const search = createServerFn({ method: \"GET\" })\n  .inputValidator((d: unknown) => d as { query: string })\n  .handler(async ({ data }) => {\n    const query = data.query;\n    const q = query.toLowerCase().trim();\n    if (!q) return [] as SearchResult[];\n    const results: SearchResult[] = [];\n\n    // Search tasks\n    const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n    for (const t of tasks) {\n      if (t.title.toLowerCase().includes(q) || t.id.toLowerCase().includes(q) || (t.note && t.note.toLowerCase().includes(q))) {\n        results.push({ id: t.id, title: t.title, snippet: t.note || t.status, type: \"task\", url: \"/tasks\" });\n      }\n    }\n\n    // Search projects\n    const projects = readJsonOrNull<Project[]>(join(WORKSPACE, \"data\", \"projects.json\")) || [];\n    for (const p of projects) {\n      if (p.name.toLowerCase().includes(q) || p.description.toLowerCase().includes(q)) {\n        results.push({ id: p.id, title: p.name, snippet: p.description, type: \"project\", url: \"/projects\" });\n      }\n    }\n\n    // Search incidents\n    const incidents = readJsonOrNull<Incident[]>(join(WORKSPACE, \"data\", \"incidents.json\")) || [];\n    for (const inc of incidents) {\n      if (inc.title.toLowerCase().includes(q) || inc.summary.toLowerCase().includes(q)) {\n        results.push({ id: inc.id, title: inc.title, snippet: inc.summary, type: \"incident\", url: \"/incidents\" });\n      }\n    }\n\n    // Search memory\n    const memDir = join(WORKSPACE, \"memory\");\n    if (existsSync(memDir)) {\n      const memFiles = readdirSync(memDir).filter((f) => /^\\d{4}-\\d{2}-\\d{2}\\.md$/.test(f));\n      for (const file of memFiles) {\n        const body = readFileSync(join(memDir, file), \"utf-8\");\n        const title = extractTitle(body);\n        if (title.toLowerCase().includes(q) || body.toLowerCase().includes(q)) {\n          const snippet = body.split(\"\\n\").find((l) => l.toLowerCase().includes(q) && !l.startsWith(\"#\"))?.trim() || \"\";\n          results.push({ id: file, title, snippet: snippet.slice(0, 120), type: \"memory\", url: \"/memory\", date: file.replace(\".md\", \"\") });\n        }\n      }\n    }\n\n    // Search docs\n    const exclude = new Set([\"AGENTS.md\", \"SOUL.md\", \"IDENTITY.md\", \"USER.md\", \"TOOLS.md\", \"MEMORY.md\", \"HEARTBEAT.md\", \"BACKUP_GUIDE.md\", \"RECOVERY_GUIDE.md\"]);\n    const docFiles = readdirSync(WORKSPACE).filter((f) => f.endsWith(\".md\") && !exclude.has(f));\n    for (const file of docFiles) {\n      const body = readFileSync(join(WORKSPACE, file), \"utf-8\");\n      const title = extractTitle(body);\n      if (title.toLowerCase().includes(q) || body.toLowerCase().includes(q)) {\n        const snippet = body.split(\"\\n\").find((l) => l.toLowerCase().includes(q) && !l.startsWith(\"#\"))?.trim() || \"\";\n        results.push({ id: file, title, snippet: snippet.slice(0, 120), type: \"doc\", url: \"/docs\" });\n      }\n    }\n\n    // Search cron jobs\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    if (cfg && Array.isArray(cfg.cron)) {\n      for (const job of cfg.cron as Record<string, unknown>[]) {\n        const name = String(job.name || job.schedule || \"\");\n        if (name.toLowerCase().includes(q)) {\n          results.push({ id: String(job.id || \"\"), title: name, snippet: String(job.schedule || \"\"), type: \"cron\", url: \"/calendar\" });\n        }\n      }\n    }\n\n    return results.slice(0, 20) as SearchResult[];\n  });","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779962458170}}
{"type":"message","id":"e5cf1dc0","parentId":"d01dd3b6","timestamp":"2026-05-28T11:42:20.946Z","message":{"role":"toolResult","toolCallId":"aeb2cc5c-fd95-406c-ab97-4289405681f1","toolName":"exec","content":[{"type":"text","text":"[... 3312 more characters truncat"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"export interface ActivityEvent {\n  id: string;\n  ts: string;\n  message: string;\n  type: \"task\" | \"cron\" | \"system\" | \"memory\" | \"project\" | \"incident\";\n  actor?: string;\n}\n\nexport const runBackup = createServerFn({ method: \"POST\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    const output = execSync(\"bash /Users/spacemonkey/.openclaw/workspace/scripts/openclaw-backup-quick.sh\", {\n      timeout: 30000,\n      encoding: \"utf-8\",\n    });\n    const match = output.match(/([\\d.]+[KMGT]B)/);\n    return { ok: true, size: match ? match[1] : \"done\" };\n  } catch (err) {\n    return { ok: false, size: \"failed\" };\n  }\n});\n\nexport const getActivityFeed = createServerFn({ method: \"GET\" }).handler(async () => {\n    const limit = 30;\n    const events: ActivityEvent[] = [];\n\n    // 1. In-progress and recently completed tasks\n    const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n    for (const t of tasks.filter((t) => t.status === \"in_progress\").slice(0, 5)) {\n      events.push({\n        id: `task-active-${t.id}`,\n        ts: t.startedAt || t.ts,\n        message: `Working: ${t.title}`,\n        type: \"task\",\n        actor: t.assignee,\n      });\n    }\n    for (const t of tasks.filter((t) => t.status === \"done\" && t.completedAt).slice(-5).reverse()) {\n      events.push({\n        id: `task-done-${t.id}`,\n        ts: t.completedAt!,\n        message: `Completed: ${t.title}`,\n        type: \"task\",\n        actor: t.assignee,\n      });\n    }\n\n    // 2. Open incidents\n    const incidents = readJsonOrNull<Record<string, unknown>[]>(join(WORKSPACE, \"data\", \"incidents.json\")) || [];\n    for (const inc of incidents.filter((i) => i.status !== \"RESOLVED\").slice(0, 3)) {\n      events.push({\n        id: `inc-${inc.id}`,\n        ts: String(inc.updatedAt || inc.createdAt || new Date().toISOString()),\n        message: `Incident: ${inc.title || inc.id}`,\n        type: \"incident\",\n        actor: String(inc.assignee || \"system\"),\n      });\n    }\n\n    // 3. Cron errors\n    const cronErrors = readJsonOrNull<Record<string, unknown>[]>(join(WORKSPACE, \"data\", \"cron-errors.json\")) || [];\n    for (const ce of cronErrors.filter((e) => e.status !== \"completed\").slice(0, 3)) {\n      events.push({\n        id: `cron-err-${ce.id}`,\n        ts: String(ce.createdAt || new Date().toISOString()),\n        message: `Cron error: ${ce.jobName || ce.jobId} (${ce.consecutiveErrors}x)`,\n        type: \"cron\",\n        actor: \"system\",\n      });\n    }\n\n    // 4. Recent daily logs\n    const memDir = join(WORKSPACE, \"memory\");\n    if (existsSync(memDir)) {\n      const memFiles = readdirSync(memDir)\n        .filter((f) => /^\\d{4}-\\d{2}-\\d{2}\\.md$/.test(f))\n        .sort()\n        .reverse()\n        .slice(0, 3);\n      for (const file of memFiles) {\n        const stat = statSync(join(memDir, file));\n        events.push({\n          id: `mem-${file}`,\n          ts: stat.mtime.toISOString(),\n          message: `Log: ${extractTitle(readFileSync(join(memDir, file), \"utf-8\").slice(0, 80))}`,\n          type: \"memory\",\n          actor: \"Space Monkey\",\n        });\n      }\n    }\n\n    // Sort by time, most recent first\n    events.sort((a, b) => new Date(b.ts).getTime() - new Date(a.ts).getTime());\n    return events.slice(0, limit) as ActivityEvent[];\n  });","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779962458172}}
