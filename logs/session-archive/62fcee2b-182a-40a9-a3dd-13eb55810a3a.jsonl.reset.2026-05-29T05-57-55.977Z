{"type":"message","id":"58cab194","parentId":"0972f70a","timestamp":"2026-05-28T11:42:20.946Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"971ed24a-65b6-4ec3-a04f-8822fef15afd","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/incidents.ts","content":"// src/lib/server-data/incidents.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { writeFileSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { WORKSPACE, type Incident, type CreateIncidentInput } from \"./types\";\nimport { readJsonOrNull } from \"./helpers\";\n\nexport { type IncidentEvent, type IncidentAction } from \"./types\";\n\nexport const getIncidents = createServerFn({ method: \"GET\" }).handler(async () => {\n  const data = readJsonOrNull<Incident[]>(join(WORKSPACE, \"data\", \"incidents.json\"));\n  return data ?? [];\n});\n\n// ── Internal helpers (not exported as server fns) ─────────────────────────────\n\nfunction readIncidentsList(): Incident[] {\n  return readJsonOrNull<Incident[]>(join(WORKSPACE, \"data\", \"incidents.json\")) || [];\n}\n\nfunction writeIncidentsList(incs: Incident[]) {\n  writeFileSync(join(WORKSPACE, \"data\", \"incidents.json\"), JSON.stringify(incs, null, 2), \"utf-8\");\n}\n\nfunction nextIncidentId(incs: Incident[]): string {\n  const nums = incs.map(i => {\n    const m = i.id.match(/INC-(\\d+)/);\n    return m ? parseInt(m[1]) : 0;\n  });\n  return `INC-${String(Math.max(0, ...nums) + 1).padStart(3, \"0\")}`;\n}\n\nexport const createIncident = createServerFn({ method: \"POST\" })\n  .inputValidator((d: unknown) => d as CreateIncidentInput)\n  .handler(async ({ data }) => {\n    const incs = readIncidentsList();\n    const now = new Date().toISOString();\n    const dup = incs.find(i =>\n      i.status !== \"RESOLVED\" &&\n      i.title === data.title &&\n      i.tags?.includes(data.source)\n    );\n    if (dup) return { ok: true, id: dup.id, duplicate: true };\n    const incident: Incident = {\n      id: nextIncidentId(incs),\n      title: data.title,\n      severity: data.severity,\n      status: \"TRIAGE\",\n      owner: data.owner,\n      acknowledged: false,\n      escalated: false,\n      opened: now,\n      lastActivity: now,\n      summary: data.summary,\n      tags: [...data.tags, data.source],\n      timeline: [\n        { ts: now, message: `Auto-detected by ${data.source}`, actor: \"system\" },\n      ],\n      actions: [],\n    };\n    incs.unshift(incident);\n    writeIncidentsList(incs);\n    return { ok: true, id: incident.id };\n  });\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/incidents.ts\", \"content\": \"// src/lib/server-data/incidents.ts\\n\\nimport { createServerFn } from \\\"@tanstack/react-start\\\";\\nimport { writeFileSync } from \\\"node:fs\\\";\\nimport { join } from \\\"node:path\\\";\\nimport { WORKSPACE, type Incident, type CreateIncidentInput } from \\\"./types\\\";\\nimport { readJsonOrNull } from \\\"./helpers\\\";\\n\\nexport { type IncidentEvent, type IncidentAction } from \\\"./types\\\";\\n\\nexport const getIncidents = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  const data = readJsonOrNull<Incident[]>(join(WORKSPACE, \\\"data\\\", \\\"incidents.json\\\"));\\n  return data ?? [];\\n});\\n\\n// ── Internal helpers (not exported as server fns) ─────────────────────────────\\n\\nfunction readIncidentsList(): Incident[] {\\n  return readJsonOrNull<Incident[]>(join(WORKSPACE, \\\"data\\\", \\\"incidents.json\\\")) || [];\\n}\\n\\nfunction writeIncidentsList(incs: Incident[]) {\\n  writeFileSync(join(WORKSPACE, \\\"data\\\", \\\"incidents.json\\\"), JSON.stringify(incs, null, 2), \\\"utf-8\\\");\\n}\\n\\nfunction nextIncidentId(incs: Incident[]): string {\\n  const nums = incs.map(i => {\\n    const m = i.id.match(/INC-(\\\\d+)/);\\n    return m ? parseInt(m[1]) : 0;\\n  });\\n  return `INC-${String(Math.max(0, ...nums) + 1).padStart(3, \\\"0\\\")}`;\\n}\\n\\nexport const createIncident = createServerFn({ method: \\\"POST\\\" })\\n  .inputValidator((d: unknown) => d as CreateIncidentInput)\\n  .handler(async ({ data }) => {\\n    const incs = readIncidentsList();\\n    const now = new Date().toISOString();\\n    const dup = incs.find(i =>\\n      i.status !== \\\"RESOLVED\\\" &&\\n      i.title === data.title &&\\n      i.tags?.includes(data.source)\\n    );\\n    if (dup) return { ok: true, id: dup.id, duplicate: true };\\n    const incident: Incident = {\\n      id: nextIncidentId(incs),\\n      title: data.title,\\n      severity: data.severity,\\n      status: \\\"TRIAGE\\\",\\n      owner: data.owner,\\n      acknowledged: false,\\n      escalated: false,\\n      opened: now,\\n      lastActivity: now,\\n      summary: data.summary,\\n      tags: [...data.tags, data.source],\\n      timeline: [\\n        { ts: now, message: `Auto-detected by ${data.source}`, actor: \\\"system\\\" },\\n      ],\\n      actions: [],\\n    };\\n    incs.unshift(incident);\\n    writeIncidentsList(incs);\\n    return { ok: true, id: incident.id };\\n  });\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":377,"output":621,"cacheRead":119936,"cacheWrite":0,"totalTokens":120934,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779962410516,"responseId":"gen-1779962410-q56xPAIfXozUGGtWujP5"}}
