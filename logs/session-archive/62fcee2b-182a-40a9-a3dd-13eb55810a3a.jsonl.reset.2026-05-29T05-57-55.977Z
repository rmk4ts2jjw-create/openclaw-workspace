{"type":"message","id":"461fc8e0","parentId":"66eb1a36","timestamp":"2026-05-28T11:42:20.944Z","message":{"role":"toolResult","toolCallId":"10ac5683-aeb9-4951-b24f-cba10774b8f0","toolName":"exec","content":[{"type":"text","text":"[... 1793 more characters truncat"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"// src/lib/server-data.ts\n// Server-side data functions using TanStack Start createServerFn.\n// These run ONLY on the server and can safely access the filesystem.\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { readFileSync, existsSync, readdirSync, statSync } from \"node:fs\";\nimport { join } from \"node:path\";\n\nconst WORKSPACE = process.env.OPENCLAW_WORKSPACE || \"/Users/spacemonkey/.openclaw/workspace\";\nconst OPENCLAW_DIR = process.env.OPENCLAW_DIR || \"/Users/spacemonkey/.openclaw\";\n\nfunction readFileOrNull(path: string): string | null {\n  try {\n    if (!existsSync(path)) return null;\n    return readFileSync(path, \"utf-8\");\n  } catch {\n    return null;\n  }\n}\n\nfunction readJsonOrNull<T>(path: string): T | null {\n  const raw = readFileOrNull(path);\n  if (!raw) return null;\n  try {\n    return JSON.parse(raw) as T;\n  } catch {\n    return null;\n  }\n}\n\nfunction formatBytes(bytes: number): string {\n  if (bytes === 0) return \"0 B\";\n  const k = 1024;\n  const sizes = [\"B\", \"KB\", \"MB\", \"GB\", \"TB\"];\n  const i = Math.floor(Math.log(bytes) / Math.log(k));\n  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + \" \" + sizes[i];\n}\n\nfunction extractTitle(md: string): string {\n  const h1 = md.match(/^#\\s+(.+)/m);\n  if (h1) return h1[1].replace(/<!--.*?>/g, \"\").trim();\n  const h2 = md.match(/^##\\s+(.+)/m);\n  if (h2) return h2[1].replace(/<!--.*?>/g, \"\").trim();\n  return \"Untitled\";\n}\n\n// ── Tasks ──────────────────────────────────────────────────────────────────────\n\nexport interface Task {\n  id: string;\n  title: string;\n  assignee: string;\n  status: \"backlog\" | \"in_progress\" | \"awaiting_review\" | \"done\";\n  priority: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  ts: string;\n  note?: string;\n  lastUpdated?: string;\n  startedAt?: string;\n  completedAt?: string;\n  progress?: number;","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779961083595}}
{"type":"message","id":"e64bf2c8","parentId":"461fc8e0","timestamp":"2026-05-28T11:42:20.944Z","message":{"role":"toolResult","toolCallId":"0b1f68e2-2d8d-4a93-9c8c-b518bfb1c703","toolName":"exec","content":[{"type":"text","text":"[... 2125 more characters truncat"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"export const getSystemStats = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n  const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n  const agents = cfg?.agents as Record<string, unknown> | undefined;\n  const defaults = agents?.defaults as Record<string, unknown> | undefined;\n  const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n  const crons = Array.isArray(cfg?.cron) ? cfg.cron as unknown[] : [];\n  const activeCrons = crons.filter((c: unknown) => (c as Record<string, unknown>).enabled !== false).length;\n\n  // Count workspace files\n  let workspaceFiles = 0;\n  try {\n    workspaceFiles = readdirSync(WORKSPACE).length;\n  } catch { /* ignore */ }\n\n  // Read real system stats via shell commands\n  let cpuLoad = \"0\";\n  let diskUsed = \"—\";\n  let diskFree = \"—\";\n  let diskTotal = \"—\";\n  let diskPercent = 0;\n  let memoryUsed = \"—\";\n  let memoryTotal = \"—\";\n  let memoryPercent = 0;\n  let uptime = \"—\";\n  let gatewayStatus = \"unknown\";\n  let gatewayUptime = \"—\";\n  let wdDiskUsed = \"—\";\n  let wdDiskTotal = \"—\";\n  let wdDiskPercent = 0;\n  let wdDiskMount = \"—\";\n\n  try {\n    const { execSync } = await import(\"node:child_process\");\n\n    // CPU load (1-min average)\n    try {\n      cpuLoad = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim();\n    } catch { /* ignore */ }\n\n    // Disk usage (internal)\n    try {\n      const df = execSync(\"df -h / | tail -1 | awk '{print $2, $3, $4, $5}'\", { encoding: \"utf-8\" }).trim().split(\" \");\n      if (df.length >= 4) {\n        diskTotal = df[0];\n        diskUsed = df[1];\n        diskFree = df[2];\n        diskPercent = parseInt(df[3].replace(\"%\", \"\")) || 0;\n      }\n    } catch { /* ignore */ }\n\n    // WD MyCloud disk usage\n    try {\n      // Find the WD mount point dynamically\n      const mounts = execSync(\"df -h | grep -iE 'wd|mycloud|public' | awk '{print $2, $3, $4, $6}'\", { encoding: \"utf-8\" }).trim();\n      if (mounts) {\n        const parts = mounts.split(\" \");\n        if (parts.length >= 4) {\n          wdDiskTotal = parts[0];\n          wdDiskUsed = parts[1];","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779961083596}}
