{"type":"message","id":"75a2a571","parentId":"e442a8c8","timestamp":"2026-05-28T09:47:34.729Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create the shared utilities and types file:"},{"type":"toolCall","id":"621535ee-5f6e-4e70-8be3-15aa822e0b13","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/types.ts","content":"// src/lib/server-data/types.ts\n// Shared types and constants for server data functions\n\nexport const WORKSPACE = process.env.OPENCLAW_WORKSPACE || \"/Users/spacemonkey/.openclaw/workspace\";\nexport const OPENCLAW_DIR = process.env.OPENCLAW_DIR || \"/Users/spacemonkey/.openclaw\";\n\n// ── Task Types ────────────────────────────────────────────────────────────────\n\nexport interface Task {\n  id: string;\n  title: string;\n  assignee: string;\n  status: \"backlog\" | \"in_progress\" | \"awaiting_review\" | \"done\";\n  priority: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  ts: string;\n  note?: string;\n  lastUpdated?: string;\n  startedAt?: string;\n  completedAt?: string;\n  progress?: number;\n  tags?: string[];\n  acknowledged?: boolean;\n  escalationLevel?: number;\n  history?: TaskHistoryEntry[];\n  errorId?: string;\n  jobId?: string;\n  summary?: string;\n}\n\nexport interface TaskHistoryEntry {\n  ts: string;\n  action: \"created\" | \"dispatched\" | \"started\" | \"progress\" | \"stalled\" | \"escalated\" | \"completed\" | \"reassigned\";\n  actor?: string;\n  details?: string;\n}\n\n// ── Queue Types ───────────────────────────────────────────────────────────────\n\nexport interface QueueItem {\n  id: string;\n  taskId: string;\n  title: string;\n  assignee: string;\n  dispatchedAt: string;\n  status: \"pending\" | \"executing\" | \"completed\" | \"failed\";\n}\n\n// ── Cron Types ────────────────────────────────────────────────────────────────\n\nexport interface CronJob {\n  id: string;\n  name: string;\n  schedule: string;\n  enabled: boolean;\n  status: string;\n  lastError: string;\n  lastErrorReason: string;\n  consecutiveErrors: number;\n  lastRun: string;\n  nextRun: string;\n  message: string;\n}\n\n// ── System Stats Types ────────────────────────────────────────────────────────\n\nexport interface SystemStats {\n  hostname: string;\n  uptime: string;\n  gatewayUptime: string;\n  diskUsed: string;\n  diskFree: string;\n  diskTotal: string;\n  diskPercent: number;\n  wdDiskUsed: string;\n  wdDiskTotal: string;\n  wdDiskPercent: number;\n  wdDiskMount: string;\n  memoryUsed: string;\n  memoryTotal: string;\n  memoryPercent: number;\n  cpuLoad: string;\n  openclawVersion: string;\n  model: string;\n  gatewayStatus: string;\n  activeCrons: number;\n  totalCrons: number;\n  workspaceFiles: number;\n  lastBackup: string;\n}\n\n// ── Agent Status Types ────────────────────────────────────────────────────────\n\nexport interface AgentStatus {\n  id: string;\n  name: string;\n  role: string;\n  emoji: string;\n  status: \"active\" | \"standby\" | \"error\";\n  model: string;\n  lastActive: string;\n  tasksActive: number;\n  currentAction?: string;\n}\n\n// ── Memory Types ──────────────────────────────────────────────────────────────\n\nexport interface MemoryEntry {\n  date: string;\n  title: string;\n  body: string;\n  path: string;\n}\n\n// ── Doc Types ─────────────────────────────────────────────────────────────────\n\nexport interface Doc {\n  id: string;\n  title: string;\n  type: string;\n  body: string;\n  updatedAt: string;\n}\n\n// ── Project Types ─────────────────────────────────────────────────────────────\n\nexport interface Project {\n  id: string;\n  title: string;\n  description: string;\n  status: string;\n  accent: string;\n  updatedAt: string;\n}\n\n// ── Incident Types ────────────────────────────────────────────────────────────\n\nexport interface Incident {\n  id: string;\n  title: string;\n  description: string;\n  severity: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  status: string;\n  assignee: string;\n  createdAt: string;\n  updatedAt: string;\n}\n\nexport interface CreateIncidentInput {\n  title: string;\n  description: string;\n  severity: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  assignee: string;\n}\n\n// ── Activity Types ────────────────────────────────────────────────────────────\n\nexport interface ActivityEvent {\n  id: string;\n  ts: string;\n  message: string;\n  type: string;\n  actor?: string;\n}\n\n// ── OpenClaw Status Types ─────────────────────────────────────────────────────\n\nexport interface OpenClawStatus {\n  gateway: string;\n  version: string;\n  model: string;\n  ctx: string;\n  sessions: number;\n  heartbeat: string;\n  channel: string;\n  memoryPlugin: string;\n  tasksActive: number;\n  dashboard: string;\n}\n\n// ── Quick Action Result ───────────────────────────────────────────────────────\n\nexport interface ActionResult {\n  ok: boolean;\n  message: string;\n  size?: string;\n}\n\nexport interface SystemHealth {\n  cpu: string;\n  disk: string;\n  memory: string;\n  gateway: string;\n}\n\nexport interface AwaitingReviewResult {\n  count: number;\n}\n\nexport interface CronToggleResult {\n  ok: boolean;\n  enabled: boolean;\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/types.ts\", \"content\": \"// src/lib/server-data/types.ts\\n// Shared types and constants for server data functions\\n\\nexport const WORKSPACE = process.env.OPENCLAW_WORKSPACE || \\\"/Users/spacemonkey/.openclaw/workspace\\\";\\nexport const OPENCLAW_DIR = process.env.OPENCLAW_DIR || \\\"/Users/spacemonkey/.openclaw\\\";\\n\\n// ── Task Types ────────────────────────────────────────────────────────────────\\n\\nexport interface Task {\\n  id: string;\\n  title: string;\\n  assignee: string;\\n  status: \\\"backlog\\\" | \\\"in_progress\\\" | \\\"awaiting_review\\\" | \\\"done\\\";\\n  priority: \\\"P1\\\" | \\\"P2\\\" | \\\"P3\\\" | \\\"P4\\\";\\n  ts: string;\\n  note?: strin