Jobs = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \\\"openclaw.json\\\"));\\n  if (!cfg || !Array.isArray(cfg.cron)) return [];\\n  return (cfg.cron as Record<string, unknown>[]).map((job, i) => {\\n    const j = job as Record<string, unknown>;\\n    return {\\n      id: String(j.id || `cron-${i}`),\\n      name: String(j.name || j.schedule || `Job ${i + 1}`),\\n      schedule: String(j.schedule || \\\"\\\"),\\n      nextRun: j.enabled !== false ? \\\"active\\\" : \\\"disabled\\\",\\n      enabled: j.enabled !== false,\\n      description: String((j.payload as Record<string, unknown>)?.message || (j.payload as Record<string, unknown>)?.text || \\\"\\\").slice(0, 120),\\n    } as CronJob;\\n  });\\n});\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":590,"output":351,"cacheRead":117888,"cacheWrite":0,"totalTokens":118829,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779962299325,"responseId":"gen-1779962299-bcspG3sXT8HQtVQ4AJe2"}}
