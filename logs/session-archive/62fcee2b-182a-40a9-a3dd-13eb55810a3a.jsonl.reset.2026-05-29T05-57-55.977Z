{"type":"message","id":"31ca0d7a","parentId":"736c6977","timestamp":"2026-05-28T10:02:36.097Z","message":{"role":"toolResult","toolCallId":"890e77b3-a734-4b32-be06-d73fb6b1f943","toolName":"exec","content":[{"type":"text","text":"export interface AgentStatus {\n  id: string;\n  name: string;\n  role: string;\n  emoji: string;\n  status: \"active\" | \"standby\" | \"error\";\n  model: string;\n  lastActive: string;\n  tasksActive: number;\n  currentAction?: string;\n}\n\nexport const getAgentStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n  const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n  const agents = cfg?.agents as Record<string, unknown> | undefined;\n  const defaults = agents?.defaults as Record<string, unknown> | undefined;\n  const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n  const currentModel = String(modelConfig?.primary || \"unknown\");\n\n  // Read crew from workspace files\n  const identityContent = readFileOrNull(join(WORKSPACE, \"IDENTITY.md\")) || \"\";\n  const soulContent = readFileOrNull(join(WORKSPACE, \"SOUL.md\")) || \"\";\n\n  // Count ALL non-done tasks per assignee (in_progress + backlog = assigned work)\n  const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  const activeTasks = tasks.filter((t) => t.status === \"in_progress\");\n\n  const countFor = (id: string) => activeTasks.filter((t) => t.assignee === id).length;\n\n  // Determine agent status: active if they have in_progress tasks OR if they're Always ON\n  const isAlwaysOn = (id: string) => id === \"monkey\" || id === \"lifesupport\";\n\n  // Helper: get the first in-progress task title for an agent\n  const currentTaskFor = (id: string) => {\n    const t = activeTasks.find(t => t.assignee === id);\n    return t ? t.title : undefined;\n  };\n\n  return [\n    {\n      id: \"monkey\",\n      name: \"Space Monkey\",\n      role: \"Mission Director\",\n      emoji: \"🐒\",\n      status: \"active\" as const,\n      model: currentModel,\n      lastActive: \"now\",\n      tasksActive: countFor(\"monkey\"),\n      currentAction: currentTaskFor(\"monkey\") || \"Monitoring station\",\n    },\n    {\n      id: \"lifesupport\",\n      name: \"Life Support Officer\",\n      role: \"Infrastructure Controller\",\n      emoji: \"🥷🏽\",\n      status: \"active\" as const,\n      model: currentModel,\n      lastActive: \"5m ago\",\n      tasksActive: countFor(\"lifesupport\"),\n      currentAction: currentTaskFor(\"lifesupport\") || \"Monitoring systems\",\n    },\n    {\n      id: \"engineer\",\n      name: \"Systems Engineer\",\n      role: \"Coder / Builder\",\n      emoji: \"🔧\",\n      status: countFor(\"engineer\") > 0 ? \"active\" as const : \"standby\" as const,\n      model: currentModel,\n      lastActive: countFor(\"engineer\") > 0 ? \"now\" : \"1h ago\",\n      tasksActive: countFor(\"engineer\"),\n      currentAction: currentTaskFor(\"engineer\") || \"Standing by\",\n    },\n    {\n      id: \"archivist\",\n      name: \"Station Archivist\",\n      role: \"Memory & Knowledge\",\n      emoji: \"📚\",\n      status: countFor(\"archivist\") > 0 ? \"active\" as const : \"standby\" as const,\n      model: currentModel,\n      lastActive: countFor(\"archivist\") > 0 ? \"now\" : \"30m ago\",\n      tasksActive: countFor(\"archivist\"),\n      currentAction: currentTaskFor(\"archivist\") || \"Indexing memory sectors\",\n    },\n  ] as AgentStatus[];\n  } catch (e) {\n    console.error(\"[getAgentStatus] ERROR:\", e);\n    throw e;\n  }\n});\n\n===DIVIDER===\n\nexport const restartMissionControl = createServerFn({ method: \"POST\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    // Kill existing dev server on port 3001\n    try {\n      execSync(\"lsof -ti :3001 | xargs kill -9 2>/dev/null || true\", { encoding: \"utf-8\", timeout: 5000 });\n    } catch { /* ignore */ }\n    // Start dev server in background\n    const projectDir = join(WORKSPACE, \"mission-control-dashboard\");\n    execSync(`cd ${projectDir} && nohup npx vite dev --port 3001 > /tmp/mc-dev.log 2>&1 &`, { encoding: \"utf-8\", timeout: 5000 });\n    // Wait a moment and verify it started\n    await new Promise((r) => setTimeout(r, 3000));\n    try {\n      const pid = execSync(\"lsof -ti :3001\", { encoding: \"utf-8\" }).trim();\n      if (pid) {\n        return { ok: true, message: `Dev server restarted (PID ${pid})` };\n      }\n    } catch { /* ignore */ }\n    return { ok: false, message: \"Dev server may not have started — check /tmp/mc-dev.log\" };\n  } catch (err) {\n    return { ok: false, message: String(err) };\n  }\n});\n\n===DIVIDER===\n\nexport const getAwaitingReviewCount = createServerFn({ method: \"GET\" }).handler(async () => {\n  const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  const count = tasks.filter((t) => t.status === \"awaiting_review\").length;\n  return { count };\n});\n\n===DIVIDER===\n\nexport interface OpenClawStatus {\n  gateway: string;\n  version: string;\n  dashboard: string;\n  channel: string;\n  sessions: number;\n  model: string;\n  ctx: string;\n  uptime: string;\n  heartbeat: string;\n  tasksActive: number;\n  tasksQueued: number;\n  memoryPlugin: string;\n}\n\nexport const getOpenClawStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n  const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n  const models = cfg?.agents as Record<string, unknown> | undefined;\n  const defaults = models?.defaults as Record<string, unknown> | undefined;\n  const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n  const channels = cfg?.channels as Record<string, unknown> | undefined;\n  const channelNames = channels ? Object.keys(channels).filter((k) => (channels[k] as Record<string, unknown>)?.enabled) : [];\n\n  const meta = cfg?.meta as Record<string, unknown> | undefined;\n  const skills = cfg?.skills as Record<string, unknown> | undefined;\n  const enabledSkills = skills ? Object.entries(skills).filter(([, v]) => (v as Record<string, unknown>)?.enabled).length : 0;\n\n  return {\n    gateway: \"running\",\n    version: String(meta?.lastTouchedVersion || \"unknown\"),\n    dashboard: \"http://127.0.0.1:18789/\",\n    channel: channelNames.join(\", \") || \"none\",\n    sessions: 4,\n    model: String(modelConfig?.primary || \"unknown\"),\n    ctx: \"1M\",\n    uptime: \"running\",\n    heartbeat: \"30m\",\n    tasksActive: 0,\n    tasksQueued: 0,\n    memoryPlugin: enabledSkills > 0 ? \"enabled\" : \"not checked\",\n  } as OpenClawStatus;\n  } catch (e) {\n    console.error(\"[getOpenClawStatus] ERROR:\", e);\n    throw e;\n  }\n});\n\n// -- OpenClaw Cron Management --------------------------------------------------\n\nexport interface OpenClawCronJob {\n  id: string;\n  name: string;\n  schedule: string;\n  enabled: boolean;\n  status: string;\n  lastRun: string;\n  nextRun: string;\n  message: string;\n  lastError?: string;\n  lastErrorReason?: string;\n  consecutiveErrors?: number;\n}\n\nexport const getOpenClawCrons = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const { execSync } = await import(\"node:child_process\");\n    const output = execSync(\"/opt/homebrew/bin/openclaw cron list --all --json\", { encoding: \"utf-8\", timeout: 10000 });\n    const data = JSON.parse(output);\n    const jobs = (data.jobs || []) as Record<string, unknown>[];\n    return jobs.map((j) => {\n      const state = (j.state || {}) as Record<string, unknown>;\n      const schedule = (j.schedule || {}) as Record<string, unknown>;\n      const payload = (j.payload || {}) as Record<string, unknown>;\n      return {\n        id: String(j.id || \"\"),\n        name: String(j.name || \"Unknown\"),\n        schedule: String(schedule.expr || \"\"),\n        enabled: j.enabled !== false,\n        status: String(state.lastRunStatus || \"never\"),\n        lastRun: state.lastRunAtMs ? new Date(Number(state.lastRunAtMs)).toISOString() : \"—\",\n        nextRun: state.nextRunAtMs ? new Date(Number(state.nextRunAtMs)).toISOString() : \"—\",\n        message: String(payload.message || \"\").slice(0, 150),\n      } as OpenClawCronJob;\n    });\n  } catch (err) {\n    console.error(\"[getOpenClawCrons] Error:\", err);\n    return [];\n  }\n});"}],"details":{"persistedDetailsTruncated":true,"originalDetailsBytesAtLeast":8320,"originalDetailKeys":["status","exitCode","durationMs","aggregated","cwd"],"status":"completed","cwd":"/Users/spacemonkey/.openclaw/workspace","exitCode":0},"isError":false,"timestamp":1779962556095}}
{"type":"message","id":"87048851","parentId":"31ca0d7a","timestamp":"2026-05-28T10:03:17.698Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me create all remaining modules and the barrel in one go:"},{"type":"toolCall","id":"dae2c729-a1fb-4350-87b5-94545b986c68","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/agent-status.ts","content":"// src/lib/server-data/agent-status.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { join } from \"node:path\";\nimport { WORKSPACE, OPENCLAW_DIR, type AgentStatus, type Task } from \"./types\";\nimport { readJsonOrNull, readFileOrNull } from \"./helpers\";\n\nexport const getAgentStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const agents = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = agents?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const currentModel = String(modelConfig?.primary || \"unknown\");\n\n    const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n    const activeTasks = tasks.filter((t) => t.status === \"in_progress\");\n    const countFor = (id: string) => activeTasks.filter((t) => t.assignee === id).length;\n    const currentTaskFor = (id: string) => {\n      const t = activeTasks.find(t => t.assignee === id);\n      return t ? t.title : undefined;\n    };\n\n    return [\n      {\n        id: \"monkey\", name: \"Space Monkey\", role: \"Mission Director\", emoji: \"🐒\",\n        status: \"active\" as const, model: currentModel, lastActive: \"now\",\n        tasksActive: countFor(\"monkey\"),\n        currentAction: currentTaskFor(\"monkey\") || \"Monitoring station\",\n      },\n      {\n        id: \"lifesupport\", name: \"Life Support Officer\", role: \"Infrastructure Controller\", emoji: \"🥷🏽\",\n        status: \"active\" as const, model: currentModel, lastActive: \"5m ago\",\n        tasksActive: countFor(\"lifesupport\"),\n        currentAction: currentTaskFor(\"lifesupport\") || \"Monitoring systems\",\n      },\n      {\n        id: \"engineer\", name: \"Systems Engineer\", role: \"Coder / Builder\", emoji: \"🔧\",\n        status: countFor(\"engineer\") > 0 ? \"active\" as const : \"standby\" as const,\n        model: currentModel, lastActive: countFor(\"engineer\") > 0 ? \"now\" : \"1h ago\",\n        tasksActive: countFor(\"engineer\"),\n        currentAction: currentTaskFor(\"engineer\") || \"Standing by\",\n      },\n      {\n        id: \"archivist\", name: \"Station Archivist\", role: \"Memory & Knowledge\", emoji: \"📚\",\n        status: countFor(\"archivist\") > 0 ? \"active\" as const : \"standby\" as const,\n        model: currentModel, lastActive: countFor(\"archivist\") > 0 ? \"now\" : \"30m ago\",\n        tasksActive: countFor(\"archivist\"),\n        currentAction: currentTaskFor(\"archivist\") || \"Indexing memory sectors\",\n      },\n    ] as AgentStatus[];\n  } catch (e) {\n    console.error(\"[getAgentStatus] ERROR:\", e);\n    throw e;\n  }\n});\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/agent-status.ts\", \"content\": \"// src/lib/server-data/agent-status.ts\\n\\nimport { createServerFn } from \\\"@tanstack/react-start\\\";\\nimport { join } from \\\"node:path\\\";\\nimport { WORKSPACE, OPENCLAW_DIR, type AgentStatus, type Task } from \\\"./types\\\";\\nimport { readJsonOrNull, readFileOrNull } from \\\"./helpers\\\";\\n\\nexport const getAgentStatus = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  try {\\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \\\"openclaw.json\\\"));\\n    const agents = cfg?.agents as Record<string, unknown> | undefined;\\n    const defaults = agents?.defaults as Record<string, unknown> | undefined;\\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\\n    const currentModel = String(modelConfig?.primary || \\\"unknown\\\");\\n\\n    const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \\\"data\\\", \\\"tasks.json\\\")) || [];\\n    const activeTasks = tasks.filter((t) => t.status === \\\"in_progress\\\");\\n    const countFor = (id: string) => activeTasks.filter((t) => t.assignee === id).length;\\n    const currentTaskFor = (id: string) => {\\n      const t = activeTasks.find(t => t.assignee === id);\\n      return t ? t.title : undefined;\\n    };\\n\\n    return [\\n      {\\n        id: \\\"monkey\\\", name: \\\"Space Monkey\\\", role: \\\"Mission Director\\\", emoji: \\\"🐒\\\",\\n        status: \\\"active\\\" as const, model: currentModel, lastActive: \\\"now\\\",\\n        tasksActive: countFor(\\\"monkey\\\"),\\n        currentAction: currentTaskFor(\\\"monkey\\\") || \\\"Monitoring station\\\",\\n      },\\n      {\\n        id: \\\"lifesupport\\\", name: \\\"Life Support Officer\\\", role: \\\"Infrastructure Controller\\\", emoji: \\\"🥷🏽\\\",\\n        status: \\\"active\\\" as const, model: currentModel, lastActive: \\\"5m ago\\\",\\n        tasksActive: countFor(\\\"lifesupport\\\"),\\n        currentAction: currentTaskFor(\\\"lifesupport\\\") || \\\"Monitoring systems\\\",\\n      },\\n      {\\n        id: \\\"engineer\\\", name: \\\"Systems Engineer\\\", role: \\\"Coder / Builder\\\", emoji: \\\"🔧\\\",\\n        status: countFor(\\\"engineer\\\") > 0 ? \\\"active\\\" as const : \\\"standby\\\" as const,\\n        model: currentModel, lastActive: countFor(\\\"engineer\\\") > 0 ? \\\"now\\\" : \\\"1h ago\\\",\\n        tasksActive: countFor(\\\"engineer\\\"),\\n        currentAction: currentTaskFor(\\\"engineer\\\") || \\\"Standing by\\\",\\n      },\\n      {\\n        id: \\\"archivist\\\", name: \\\"Station Archivist\\\", role: \\\"Memory & Knowledge\\\", emoji: \\\"📚\\\",\\n        status: countFor(\\\"archivist\\\") > 0 ? \\\"active\\\" as const : \\\"standby\\\" as const,\\n        model: currentModel, lastActive: countFor(\\\"archivist\\\") > 0 ? \\\"now\\\" : \\\"30m ago\\\",\\n        tasksActive: countFor(\\\"archivist\\\"),\\n        currentAction: currentTaskFor(\\\"archivist\\\") || \\\"Indexing memory sectors\\\",\\n      },\\n    ] as AgentStatus[];\\n  } catch (e) {\\n    console.error(\\\"[getAgentStatus] ERROR:\\\", e);\\n    throw e;\\n  }\\n});\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":2331,"output":759,"cacheRead":126976,"cacheWrite":0,"totalTokens":130066,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779962556100,"responseId":"gen-1779962556-5QHQRRjwjSNe4maV5fAT"}}
