{"type":"message","id":"4e17ed3d","parentId":"6ce72a02","timestamp":"2026-05-28T11:42:20.945Z","message":{"role":"toolResult","toolCallId":"e6a0e9df-0e0e-4442-876f-17787d92c1a2","toolName":"exec","content":[{"type":"text","text":"[... 572 more characters truncate"}],"details":{"status":"completed","exitCode":0,"durationMs":11,"aggregated":"}\n}\n\nfunction formatBytes(bytes: number): string {\n  if (bytes === 0) return \"0 B\";\n  const k = 1024;\n  const sizes = [\"B\", \"KB\", \"MB\", \"GB\", \"TB\"];\n  const i = Math.floor(Math.log(bytes) / Math.log(k));\n  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + \" \" + sizes[i];\n}\n\nfunction extractTitle(md: string): string {\n  const h1 = md.match(/^#\\s+(.+)/m);\n  if (h1) return h1[1].replace(/<!--.*?>/g, \"\").trim();\n  const h2 = md.match(/^##\\s+(.+)/m);\n  if (h2) return h2[1].replace(/<!--.*?>/g, \"\").trim();\n  return \"Untitled\";\n}\n\n---\n    1037 src/lib/server-data.ts","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779961818119}}
