{"type":"message","id":"c75a65be","parentId":"bb5c7c91","timestamp":"2026-05-28T11:42:20.944Z","message":{"role":"toolResult","toolCallId":"e8ae268b-bc46-4eb8-9802-95a1851d4f1d","toolName":"exec","content":[{"type":"text","text":"[... 4656 more characters truncat"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"wdDiskUsed = parts[1];\n          wdDiskMount = parts[3];\n          // Calculate percentage from used/total\n          const usedNum = parseSize(parts[1]);\n          const totalNum = parseSize(parts[0]);\n          if (totalNum > 0) {\n            wdDiskPercent = Math.round((usedNum / totalNum) * 100);\n          }\n        }\n      }\n    } catch { /* ignore */ }\n\n    // Memory (macOS vm_stat)\n    try {\n      const vmStat = execSync(\"vm_stat\", { encoding: \"utf-8\" });\n      const pageSize = 4096; // default macOS page size\n      const parse = (key: string) => {\n        const m = vmStat.match(new RegExp(`${key}:\\\\s+(\\\\d+)`));\n        return m ? parseInt(m[1]) : 0;\n      };\n      const active = parse(\"Pages active\");\n      const wired = parse(\"Pages wired down\");\n      const speculative = parse(\"Pages speculative\");\n      const free = parse(\"Pages free\");\n      const totalMem = execSync(\"sysctl -n hw.memsize\", { encoding: \"utf-8\" }).trim();\n      const totalBytes = parseInt(totalMem) || 0;\n      const usedBytes = (active + wired + speculative) * pageSize;\n      if (totalBytes > 0) {\n        memoryPercent = Math.round((usedBytes / totalBytes) * 100);\n        memoryUsed = formatBytes(usedBytes);\n        memoryTotal = formatBytes(totalBytes);\n      }\n    } catch { /* ignore */ }\n\n    // Uptime\n    try {\n      const uptimeSeconds = execSync(\"sysctl -n kern.boottime | awk '{print $4}' | tr -d ','\", { encoding: \"utf-8\" }).trim();\n      const bootTime = parseInt(uptimeSeconds) * 1000;\n      const upMs = Date.now() - bootTime;\n      const days = Math.floor(upMs / 86400000);\n      const hours = Math.floor((upMs % 86400000) / 3600000);\n      const mins = Math.floor((upMs % 3600000) / 60000);\n      uptime = days > 0 ? `${days}d ${hours}h ${mins}m` : `${hours}h ${mins}m`;\n    } catch { /* ignore */ }\n\n    // Gateway status + uptime\n    try {\n      const gw = execSync(\"openclaw gateway status 2>/dev/null\", { encoding: \"utf-8\" }).trim();\n      gatewayStatus = gw.toLowerCase().includes(\"running\") ? \"running\" : gw.toLowerCase().includes(\"stopped\") ? \"stopped\" : \"unknown\";\n      // Try to get gateway process start time\n      try {\n        const gwPid = execSync(\"pgrep -f 'openclaw' | head -1\", { encoding: \"utf-8\" }).trim();\n        if (gwPid) {\n          const gwStart = execSync(\"ps -o lstart= -p \" + gwPid, { encoding: \"utf-8\" }).trim();\n          if (gwStart) {\n            const gwMs = Date.now() - new Date(gwStart).getTime();\n            const gwH = Math.floor(gwMs / 3600000);\n            const gwM = Math.floor((gwMs % 3600000) / 60000);\n            gatewayUptime = `${gwH}h ${gwM}m`;\n          }\n        }\n      } catch { /* ignore */ }\n    } catch {\n      gatewayStatus = \"unknown\";\n    }\n  } catch { /* ignore all */ }\n\n  return {\n    hostname: \"spacemonkey\",\n    uptime,\n    gatewayUptime,\n    diskUsed,\n    diskFree,\n    diskTotal,\n    diskPercent,\n    wdDiskUsed,\n    wdDiskTotal,\n    wdDiskPercent,\n    wdDiskMount,\n    memoryUsed,\n    memoryTotal,\n    memoryPercent,\n    cpuLoad,\n    openclawVersion: \"2026.5.7\",\n    model: String(modelConfig?.primary || \"unknown\"),\n    gatewayStatus,\n    activeCrons,\n    totalCrons: crons.length,\n    workspaceFiles,\n    lastBackup: \"—\",\n  } as SystemStats;\n  } catch (e) {\n    console.error(\"[getSystemStats] ERROR:\", e);\n    throw e;\n  }\n});\n\nfunction parseSize(s: string): number {\n  const match = s.match(/^([\\d.]+)\\s*([KMGT]?B?)$/i);\n  if (!match) return 0;\n  const num = parseFloat(match[1]);\n  const unit = (match[2] || \"B\").toUpperCase();\n  const mult = unit.startsWith(\"K\") ? 1024 : unit.startsWith(\"M\") ? 1024**2 : unit.startsWith(\"G\") ? 1024**3 : unit.startsWith(\"T\") ? 1024**4 : 1;\n  return num * mult;\n}\n\n// ── Agent Status ──────────────────────────────────────────────────────────────\n\nexport interface AgentStatus {\n  id: string;\n  name: string;\n  role: string;\n  emoji: string;\n  status: \"active\" | \"standby\" | \"error\";\n  model: string;\n  lastActive: string;\n  tasksActive: number;\n  currentAction?: string;\n}\n\nexport const getAgentStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n  const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n  const agents = cfg?.agents as Record<string, unknown> | undefined;\n  const defaults = agents?.defaults as Record<string, unknown> | undefined;\n  const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n  const currentModel = String(modelConfig?.primary || \"unknown\");\n\n  // Read crew from workspace files\n  const identityContent = readFileOrNull(join(WORKSPACE, \"IDENTITY.md\")) || \"\";\n  const soulContent = readFileOrNull(join(WORKSPACE, \"SOUL.md\")) || \"\";","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779961098616}}
{"type":"message","id":"1bc6c607","parentId":"c75a65be","timestamp":"2026-05-28T11:42:20.944Z","message":{"role":"toolResult","toolCallId":"78764a51-98c0-4bcb-b6fa-6423b81d016f","toolName":"exec","content":[{"type":"text","text":"[... 3396 more characters truncat"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"export const getAgentStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n  const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n  const agents = cfg?.agents as Record<string, unknown> | undefined;\n  const defaults = agents?.defaults as Record<string, unknown> | undefined;\n  const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n  const currentModel = String(modelConfig?.primary || \"unknown\");\n\n  // Read crew from workspace files\n  const identityContent = readFileOrNull(join(WORKSPACE, \"IDENTITY.md\")) || \"\";\n  const soulContent = readFileOrNull(join(WORKSPACE, \"SOUL.md\")) || \"\";\n\n  // Count ALL non-done tasks per assignee (in_progress + backlog = assigned work)\n  const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  const activeTasks = tasks.filter((t) => t.status === \"in_progress\");\n\n  const countFor = (id: string) => activeTasks.filter((t) => t.assignee === id).length;\n\n  // Determine agent status: active if they have in_progress tasks OR if they're Always ON\n  const isAlwaysOn = (id: string) => id === \"monkey\" || id === \"lifesupport\";\n\n  // Helper: get the first in-progress task title for an agent\n  const currentTaskFor = (id: string) => {\n    const t = activeTasks.find(t => t.assignee === id);\n    return t ? t.title : undefined;\n  };\n\n  return [\n    {\n      id: \"monkey\",\n      name: \"Space Monkey\",\n      role: \"Mission Director\",\n      emoji: \"🐒\",\n      status: \"active\" as const,\n      model: currentModel,\n      lastActive: \"now\",\n      tasksActive: countFor(\"monkey\"),\n      currentAction: currentTaskFor(\"monkey\") || \"Monitoring station\",\n    },\n    {\n      id: \"lifesupport\",\n      name: \"Life Support Officer\",\n      role: \"Infrastructure Controller\",\n      emoji: \"🥷🏽\",\n      status: \"active\" as const,\n      model: currentModel,\n      lastActive: \"5m ago\",\n      tasksActive: countFor(\"lifesupport\"),\n      currentAction: currentTaskFor(\"lifesupport\") || \"Monitoring systems\",\n    },\n    {\n      id: \"engineer\",\n      name: \"Systems Engineer\",\n      role: \"Coder / Builder\",\n      emoji: \"🔧\",\n      status: countFor(\"engineer\") > 0 ? \"active\" as const : \"standby\" as const,\n      model: currentModel,\n      lastActive: countFor(\"engineer\") > 0 ? \"now\" : \"1h ago\",\n      tasksActive: countFor(\"engineer\"),\n      currentAction: currentTaskFor(\"engineer\") || \"Standing by\",\n    },\n    {\n      id: \"archivist\",\n      name: \"Station Archivist\",\n      role: \"Memory & Knowledge\",\n      emoji: \"📚\",\n      status: countFor(\"archivist\") > 0 ? \"active\" as const : \"standby\" as const,\n      model: currentModel,\n      lastActive: countFor(\"archivist\") > 0 ? \"now\" : \"30m ago\",\n      tasksActive: countFor(\"archivist\"),\n      currentAction: currentTaskFor(\"archivist\") || \"Indexing memory sectors\",\n    },\n  ] as AgentStatus[];\n  } catch (e) {\n    console.error(\"[getAgentStatus] ERROR:\", e);\n    throw e;\n  }\n});\n\n// ── Extended Quick Actions ───────────────────────────────────────────────────\n\nexport const restartGateway = createServerFn({ method: \"POST\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    execSync(\"openclaw gateway restart\", { timeout: 15000, encoding: \"utf-8\" });\n    return { ok: true, message: \"Gateway restarted\" };\n  } catch (err) {\n    return { ok: false, message: String(err) };\n  }\n});","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isEr