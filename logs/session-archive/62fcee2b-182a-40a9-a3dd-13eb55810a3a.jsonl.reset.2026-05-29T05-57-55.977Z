{"type":"message","id":"0e09e4b7","parentId":"e5534a5d","timestamp":"2026-05-28T11:42:20.945Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me write all the sub-modules and a clean index file:"},{"type":"toolCall","id":"f29a17b9-def8-4a55-85d5-a51632e5e6ca","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/helpers.ts","content":"// src/lib/server-data/helpers.ts\n// Shared utility functions\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { WORKSPACE } from \"./types\";\n\nexport function readFileOrNull(path: string): string | null {\n  try {\n    if (!existsSync(path)) return null;\n    return readFileSync(path, \"utf-8\");\n  } catch {\n    return null;\n  }\n}\n\nexport function readJsonOrNull<T>(path: string): T | null {\n  const raw = readFileOrNull(path);\n  if (!raw) return null;\n  try {\n    return JSON.parse(raw) as T;\n  } catch {\n    return null;\n  }\n}\n\nexport function formatBytes(bytes: number): string {\n  if (bytes === 0) return \"0 B\";\n  const k = 1024;\n  const sizes = [\"B\", \"KB\", \"MB\", \"GB\", \"TB\"];\n  const i = Math.floor(Math.log(bytes) / Math.log(k));\n  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + \" \" + sizes[i];\n}\n\nexport function extractTitle(md: string): string {\n  const h1 = md.match(/^#\\s+(.+)/m);\n  if (h1) return h1[1].replace(/<!--.*?>/g, \"\").trim();\n  const h2 = md.match(/^##\\s+(.+)/m);\n  if (h2) return h2[1].replace(/<!--.*?>/g, \"\").trim();\n  return \"Untitled\";\n}\n\nexport function parseSize(s: string): number {\n  const match = s.match(/^([\\d.]+)\\s*([KMGT]?B?)$/i);\n  if (!match) return 0;\n  const num = parseFloat(match[1]);\n  const unit = (match[2] || \"B\").toUpperCase();\n  const mult = unit.startsWith(\"K\") ? 1024 : unit.startsWith(\"M\") ? 1024 ** 2 : unit.startsWith(\"G\") ? 1024 ** 3 : unit.startsWith(\"T\") ? 1024 ** 4 : 1;\n  return num * mult;\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/helpers.ts\", \"content\": \"// src/lib/server-data/helpers.ts\\n// Shared utility functions\\n\\nimport { readFileSync, existsSync } from \\\"node:fs\\\";\\nimport { WORKSPACE } from \\\"./types\\\";\\n\\nexport function readFileOrNull(path: string): string | null {\\n  try {\\n    if (!existsSync(path)) return null;\\n    return readFileSync(path, \\\"utf-8\\\");\\n  } catch {\\n    return null;\\n  }\\n}\\n\\nexport function readJsonOrNull<T>(path: string): T | null {\\n  const raw = readFileOrNull(path);\\n  if (!raw) return null;\\n  try {\\n    return JSON.parse(raw) as T;\\n  } catch {\\n    return null;\\n  }\\n}\\n\\nexport function formatBytes(bytes: number): string {\\n  if (bytes === 0) return \\\"0 B\\\";\\n  const k = 1024;\\n  const sizes = [\\\"B\\\", \\\"KB\\\", \\\"MB\\\", \\\"GB\\\", \\\"TB\\\"];\\n  const i = Math.floor(Math.log(bytes) / Math.log(k));\\n  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + \\\" \\\" + sizes[i];\\n}\\n\\nexport function extractTitle(md: string): string {\\n  const h1 = md.match(/^#\\\\s+(.+)/m);\\n  if (h1) return h1[1].replace(/<!--.*?>/g, \\\"\\\").trim();\\n  const h2 = md.match(/^##\\\\s+(.+)/m);\\n  if (h2) return h2[1].replace(/<!--.*?>/g, \\\"\\\").trim();\\n  return \\\"Untitled\\\";\\n}\\n\\nexport function parseSize(s: string): number {\\n  const match = s.match(/^([\\\\d.]+)\\\\s*([KMGT]?B?)$/i);\\n  if (!match) return 0;\\n  const num = parseFloat(match[1]);\\n  const unit = (match[2] || \\\"B\\\").toUpperCase();\\n  const mult = unit.startsWith(\\\"K\\\") ? 1024 : unit.startsWith(\\\"M\\\") ? 1024 ** 2 : unit.startsWith(\\\"G\\\") ? 1024 ** 3 : unit.startsWith(\\\"T\\\") ? 1024 ** 4 : 1;\\n  return num * mult;\\n}\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":446,"output":514,"cacheRead":101376,"cacheWrite":0,"totalTokens":102336,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779961684180,"responseId":"gen-1779961684-he6AQCHR9rNRSxstujTM"}}
