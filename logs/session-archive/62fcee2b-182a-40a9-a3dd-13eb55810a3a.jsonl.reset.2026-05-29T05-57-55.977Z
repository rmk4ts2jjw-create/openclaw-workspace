{"type":"message","id":"3ea5e64c","parentId":"9f63a9ad","timestamp":"2026-05-28T09:46:27.972Z","message":{"role":"toolResult","toolCallId":"149501ef-e55a-4c68-8c93-dc87f0a28b49","toolName":"exec","content":[{"type":"text","text":"// src/components/TaskFlowSignals.tsx\n// Animated task flow packets between rooms\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport type { TaskFlowPacket } from \"@/lib/station-state\";\n\ninterface TaskFlowSignalsProps {\n  packets: TaskFlowPacket[];\n}\n\nexport function TaskFlowSignals({ packets }: TaskFlowSignalsProps) {\n  if (packets.length === 0) return null;\n\n  return (\n    <div className=\"rounded-xl border border-border bg-card/30 p-4\">\n      <div className=\"font-mono text-[10px] tracking-[0.2em] text-muted-foreground mb-3\">TASK FLOW</div>\n      <div className=\"flex items-center gap-4 overflow-x-auto\">\n        <AnimatePresence>\n          {packets.map(packet => (\n            <motion.div\n              key={packet.id}\n              initial={{ opacity: 0, scale: 0.5 }}\n              animate={{ opacity: 1, scale: 1 }}\n              exit={{ opacity: 0, scale: 0.5, x: 50 }}\n              className=\"flex items-center gap-2 shrink-0\"\n            >\n              <span className=\"font-mono text-[9px] text-muted-foreground\">{packet.from}</span>\n              <motion.div\n                className=\"w-8 h-1 rounded-full bg-gradient-to-r from-violet to-cyan\"\n                animate={{ scaleX: [0.5, 1, 0.5] }}\n                transition={{ duration: 1, repeat: Infinity }}\n              />\n              <span className=\"font-mono text-[9px] text-muted-foreground\">{packet.to}</span>\n              <span className=\"font-mono text-[8px] text-violet\">{packet.progress}%</span>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>\n    </div>\n  );\n}"}],"details":{"status":"completed","exitCode":0,"durationMs":10,"aggregated":"// src/components/TaskFlowSignals.tsx\n// Animated task flow packets between rooms\n\nimport { motion, AnimatePresence } from \"framer-motion\";\nimport type { TaskFlowPacket } from \"@/lib/station-state\";\n\ninterface TaskFlowSignalsProps {\n  packets: TaskFlowPacket[];\n}\n\nexport function TaskFlowSignals({ packets }: TaskFlowSignalsProps) {\n  if (packets.length === 0) return null;\n\n  return (\n    <div className=\"rounded-xl border border-border bg-card/30 p-4\">\n      <div className=\"font-mono text-[10px] tracking-[0.2em] text-muted-foreground mb-3\">TASK FLOW</div>\n      <div className=\"flex items-center gap-4 overflow-x-auto\">\n        <AnimatePresence>\n          {packets.map(packet => (\n            <motion.div\n              key={packet.id}\n              initial={{ opacity: 0, scale: 0.5 }}\n              animate={{ opacity: 1, scale: 1 }}\n              exit={{ opacity: 0, scale: 0.5, x: 50 }}\n              className=\"flex items-center gap-2 shrink-0\"\n            >\n              <span className=\"font-mono text-[9px] text-muted-foreground\">{packet.from}</span>\n              <motion.div\n                className=\"w-8 h-1 rounded-full bg-gradient-to-r from-violet to-cyan\"\n                animate={{ scaleX: [0.5, 1, 0.5] }}\n                transition={{ duration: 1, repeat: Infinity }}\n              />\n              <span className=\"font-mono text-[9px] text-muted-foreground\">{packet.to}</span>\n              <span className=\"font-mono text-[8px] text-violet\">{packet.progress}%</span>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>\n    </div>\n  );\n}","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1779961587971}}
