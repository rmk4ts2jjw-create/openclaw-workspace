{"type":"message","id":"7dcfd398","parentId":"4af11c3a","timestamp":"2026-05-28T10:09:29.665Z","message":{"role":"assistant","content":[{"type":"text","text":"I'm missing the `activity.ts` module! The activity feed code is still in the main server-data.ts. Let me extract it:"},{"type":"toolCall","id":"38b6feb3-c3ff-4030-9d68-43956a49d497","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/activity.ts","content":"// src/lib/server-data/activity.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { readFileSync, existsSync, readdirSync, statSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { WORKSPACE, type ActivityEvent, type Task } from \"./types\";\nimport { readJsonOrNull, extractTitle } from \"./helpers\";\n\nexport const getActivityFeed = createServerFn({ method: \"GET\" }).handler(async () => {\n  const limit = 30;\n  const events: ActivityEvent[] = [];\n\n  // 1. In-progress and recently completed tasks\n  const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  for (const t of tasks.filter((t) => t.status === \"in_progress\").slice(0, 5)) {\n    events.push({ id: `task-active-${t.id}`, ts: t.startedAt || t.ts, message: `Working: ${t.title}`, type: \"task\", actor: t.assignee });\n  }\n  for (const t of tasks.filter((t) => t.status === \"done\" && t.completedAt).slice(-5).reverse()) {\n    events.push({ id: `task-done-${t.id}`, ts: t.completedAt!, message: `Completed: ${t.title}`, type: \"task\", actor: t.assignee });\n  }\n\n  // 2. Open incidents\n  const incidents = readJsonOrNull<Record<string, unknown>[]>(join(WORKSPACE, \"data\", \"incidents.json\")) || [];\n  for (const inc of incidents.filter((i) => i.status !== \"RESOLVED\").slice(0, 3)) {\n    events.push({ id: `inc-${inc.id}`, ts: String(inc.updatedAt || inc.createdAt || new Date().toISOString()), message: `Incident: ${inc.title || inc.id}`, type: \"incident\", actor: String(inc.assignee || \"system\") });\n  }\n\n  // 3. Cron errors\n  const cronErrors = readJsonOrNull<Record<string, unknown>[]>(join(WORKSPACE, \"data\", \"cron-errors.json\")) || [];\n  for (const ce of cronErrors.filter((e) => e.status !== \"completed\").slice(0, 3)) {\n    events.push({ id: `cron-err-${ce.id}`, ts: String(ce.createdAt || new Date().toISOString()), message: `Cron error: ${ce.jobName || ce.jobId} (${ce.consecutiveErrors}x)`, type: \"cron\", actor: \"system\" });\n  }\n\n  // 4. Recent daily logs\n  const memDir = join(WORKSPACE, \"memory\");\n  if (existsSync(memDir)) {\n    const memFiles = readdirSync(memDir).filter((f) => /^\\d{4}-\\d{2}-\\d{2}\\.md$/.test(f)).sort().reverse().slice(0, 3);\n    for (const file of memFiles) {\n      const stat = statSync(join(memDir, file));\n      events.push({ id: `mem-${file}`, ts: stat.mtime.toISOString(), message: `Log: ${extractTitle(readFileSync(join(memDir, file), \"utf-8\").slice(0, 80))}`, type: \"memory\", actor: \"Space Monkey\" });\n    }\n  }\n\n  events.sort((a, b) => new Date(b.ts).getTime() - new Date(a.ts).getTime());\n  return events.slice(0, limit) as ActivityEvent[];\n});\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/activity.ts\", \"content\": \"// src/lib/server-data/activity.ts\\n\\nimport { createServerFn } from \\\"@tanstack/react-start\\\";\\nimport { readFileSync, existsSync, readdirSync, statSync } from \\\"node:fs\\\";\\nimport { join } from \\\"node:path\\\";\\nimport { WORKSPACE, type ActivityEvent, type Task } from \\\"./types\\\";\\nimport { readJsonOrNull, extractTitle } from \\\"./helpers\\\";\\n\\nexport const getActivityFeed = createServerFn({ method: \\\"GET\\\" }).handler(async () => {\\n  const limit = 30;\\n  const events: ActivityEvent[] = [];\\n\\n  // 1. In-progress and recently completed tasks\\n  const tasks = readJsonOrNull<Task[]>(join(WORKSPACE, \\\"data\\\", \\\"tasks.json\\\")) || [];\\n  for (const t of tasks.filter((t) => t.status === \\\"in_progress\\\").slice(0, 5)) {\\n    events.push({ id: `task-active-${t.id}`, ts: t.startedAt || t.ts, message: `Working: ${t.title}`, type: \\\"task\\\", actor: t.assignee });\\n  }\\n  for (const t of tasks.filter((t) => t.status === \\\"done\\\" && t.completedAt).slice(-5).reverse()) {\\n    events.push({ id: `task-done-${t.id}`, ts: t.completedAt!, message: `Completed: ${t.title}`, type: \\\"task\\\", actor: t.assignee });\\n  }\\n\\n  // 2. Open incidents\\n  const incidents = readJsonOrNull<Record<string, unknown>[]>(join(WORKSPACE, \\\"data\\\", \\\"incidents.json\\\")) || [];\\n  for (const inc of incidents.filter((i) => i.status !== \\\"RESOLVED\\\").slice(0, 3)) {\\n    events.push({ id: `inc-${inc.id}`, ts: String(inc.updatedAt || inc.createdAt || new Date().toISOString()), message: `Incident: ${inc.title || inc.id}`, type: \\\"incident\\\", actor: String(inc.assignee || \\\"system\\\") });\\n  }\\n\\n  // 3. Cron errors\\n  const cronErrors = readJsonOrNull<Record<string, unknown>[]>(join(WORKSPACE, \\\"data\\\", \\\"cron-errors.json\\\")) || [];\\n  for (const ce of cronErrors.filter((e) => e.status !== \\\"completed\\\").slice(0, 3)) {\\n    events.push({ id: `cron-err-${ce.id}`, ts: String(ce.createdAt || new Date().toISOString()), message: `Cron error: ${ce.jobName || ce.jobId} (${ce.consecutiveErrors}x)`, type: \\\"cron\\\", actor: \\\"system\\\" });\\n  }\\n\\n  // 4. Recent daily logs\\n  const memDir = join(WORKSPACE, \\\"memory\\\");\\n  if (existsSync(memDir)) {\\n    const memFiles = readdirSync(memDir).filter((f) => /^\\\\d{4}-\\\\d{2}-\\\\d{2}\\\\.md$/.test(f)).sort().reverse().slice(0, 3);\\n    for (const file of memFiles) {\\n      const stat = statSync(join(memDir, file));\\n      events.push({ id: `mem-${file}`, ts: stat.mtime.toISOString(), message: `Log: ${extractTitle(readFileSync(join(memDir, file), \\\"utf-8\\\").slice(0, 80))}`, type: \\\"memory\\\", actor: \\\"Space Monkey\\\" });\\n    }\\n  }\\n\\n  events.sort((a, b) => new Date(b.ts).getTime() - new Date(a.ts).getTime());\\n  return events.slice(0, limit) as ActivityEvent[];\\n});\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":645,"output":832,"cacheRead":134912,"cacheWrite":0,"totalTokens":136389,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779962927463,"responseId":"gen-1779962927-hYlO55D81mOcZIu7hQ8c"}}
