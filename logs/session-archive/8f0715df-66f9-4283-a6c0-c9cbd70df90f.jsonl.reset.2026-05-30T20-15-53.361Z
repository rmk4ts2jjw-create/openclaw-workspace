{"type":"message","id":"ca14aa88","parentId":"3ba82e94","timestamp":"2026-05-29T14:49:14.275Z","message":{"role":"toolResult","toolCallId":"ecb0af15-e3bd-45fb-97d7-b96516f03861","toolName":"exec","content":[{"type":"text","text":"#!/bin/bash\n# Start Mission Control dev server with build info injected via env vars\ncd \"$(dirname \"$0\")/..\"\n\nHASH=$(git rev-parse --short HEAD 2>/dev/null || echo \"dev\")\nTIME=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")\n\necho \"[mc] Starting with build $HASH at $TIME\"\nexec env VITE_BUILD_HASH=\"$HASH\" VITE_BUILD_TIME=\"$TIME\" bun run dev --host --port 3000"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"#!/bin/bash\n# Start Mission Control dev server with build info injected via env vars\ncd \"$(dirname \"$0\")/..\"\n\nHASH=$(git rev-parse --short HEAD 2>/dev/null || echo \"dev\")\nTIME=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")\n\necho \"[mc] Starting with build $HASH at $TIME\"\nexec env VITE_BUILD_HASH=\"$HASH\" VITE_BUILD_TIME=\"$TIME\" bun run dev --host --port 3000","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780066154275}}
