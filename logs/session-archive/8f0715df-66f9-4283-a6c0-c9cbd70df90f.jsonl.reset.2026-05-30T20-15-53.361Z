turn \"sprite-hacking\";\nsrc/components/Spacestation.tsx:238:        if (crew.id === \"lifesupport\") return \"sprite-monitoring\";\nsrc/components/Spacestation.tsx:239:        return \"sprite-working\";\nsrc/components/Spacestation.tsx:240:      case \"collaborating\": return \"sprite-working\";\nsrc/components/Spacestation.tsx:241:      case \"idle\": return \"sprite-idle\";\nsrc/components/Spacestation.tsx:242:      case \"away\": return \"sprite-away\";\nsrc/components/Spacestation.tsx:293:          src={isMoving ? crew.sprites.walking : status === \"working\" || status === \"collaborating\" ? crew.sprites.working : crew.sprites.idle}\nsrc/components/Spacestation.tsx:433:      {/* Agent sprite */}\nsrc/components/AgentTravel.tsx:12:  sprite: string;\nsrc/components/AgentTravel.tsx:121:      {/* Traveling agent sprites (HTML layer for pixelated rendering) */}\nsrc/components/AgentTravel.tsx:157:                  src={collab.sprite}\nsrc/lib/crew.ts:33:  sprites: Sprites;\nsrc/lib/crew.ts:53:    sprites: { idle: monkeyIdle, working: monkeyWorking, walking: monkeyWalking },\nsrc/lib/crew.ts:68:    sprites: { idle: lifesupportIdle, working: lifesupportWorking, walking: lifesupportWalking },\nsrc/lib/crew.ts:83:    sprites: { idle: engineerIdle, working: engineerWorking, walking: engineerWalking },\nsrc/lib/crew.ts:98:    sprites: { idle: archivistIdle, working: archivistWorking, walking: archivistWalking },","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780058992324}}
