{"type":"message","id":"bb99e99a","parentId":"73f47872","timestamp":"2026-05-29T12:52:48.068Z","message":{"role":"toolResult","toolCallId":"ac8f8c68-fbba-4d2f-bc48-ea7a8645e8cb","toolName":"exec","content":[{"type":"text","text":"import { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader, Pill } from \"@/components/PageHeader\";\nimport { getAgentStatus, getSystemStats, type AgentStatus, type SystemStats } from \"@/lib/server-data\";\nimport { CREW, MISSION_STATEMENT } from \"@/lib/crew\";\n\nexport const Route = createFileRoute(\"/team\")({\n  head: () => ({ meta: [{ title: \"Team — Mission Control\" }] }),\n  loader: async () => {\n    const [agents, stats] = await Promise.all([getAgentStatus(), getSystemStats()]);\n    return { agents, stats };\n  },\n  component: TeamPage,\n});\n\nconst statusVariant: Record<string, \"online\" | \"warning\" | \"default\"> = {\n  active: \"online\",\n  standby: \"warning\",\n  error: \"default\",\n};\n\nconst statusDot: Record<string, string> = {\n  active: \"online\",\n  standby: \"warning\",\n  error: \"error\",\n};\n\nfunction TeamPage() {\n  const { agents, stats } = Route.useLoaderData() as { agents: AgentStatus[]; stats: SystemStats };\n\n  return (\n    <>\n      <PageHeader icon=\"👥\" title=\"Team\" meta={`${agents.filter((a) => a.status === \"active\").length} active · ${agents.length} total`}>\n        {MISSION_STATEMENT}\n      </PageHeader>\n\n      {/* System Stats Bar */}\n      <div className=\"mb-6 rounded-xl border border-border bg-card/40 p-4\">\n        <div className=\"font-mono text-[10px] tracking-[0.25em] text-muted-foreground mb-3\">SYSTEM STATUS</div>\n        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n          <Stat label=\"MODEL\" value={stats.model.split(\"/\").pop() || stats.model} />\n          <Stat label=\"CRONS\" value={`${stats.activeCrons}/${stats.totalCrons} active`} />\n          <Stat label=\"GATEWAY\" value={stats.gatewayStatus} accent=\"online\" />\n          <Stat label=\"WORKSPACE\" value={`${stats.workspaceFiles} files`} />\n        </div>\n      </div>\n\n      {/* Agent Cards */}\n      <div className=\"grid gap-4 md:grid-cols-2\">\n        {agents.map((agent) => {\n          const crew = CREW.find((c) => c.id === agent.id);\n          return (\n            <div\n              key={agent.id}\n              className=\"rounded-xl border border-border bg-card/60 p-5\"\n            >\n              <div className=\"flex items-start gap-4\">\n                {crew && (\n                  <img\n                    src={crew.avatar}\n                    alt={agent.name}\n                    className=\"h-14 w-14 rounded-lg border border-border object-cover pixelated\"\n                  />\n                )}\n                <div className=\"flex-1 min-w-0\">\n                  <div className=\"flex items-center gap-2 flex-wrap\">\n                    <h3 className=\"font-bold text-lg\">{agent.emoji} {agent.name}</h3>\n                    <Pill variant={statusVariant[agent.status]}>{agent.status}</Pill>\n                  </div>\n                  <div className=\"font-mono text-xs text-muted-foreground mt-0.5\">{agent.role}</div>\n                  <div className=\"mt-3 grid grid-cols-2 gap-2 text-xs\">\n                    <div>\n                      <span className=\"text-muted-foreground\">model: </span>\n                      <span className=\"font-mono\">{agent.model.split(\"/\").pop()}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-muted-foreground\">last active: </span>\n                      <span className=\"font-mono\">{agent.lastActive}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-muted-foreground\">active tasks: </span>"}],"details":{"status":"completed","exitCode":0,"durationMs":26,"aggregated":"import { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader, Pill } from \"@/components/PageHeader\";\nimport { getAgentStatus, getSystemStats, type AgentStatus, type SystemStats } from \"@/lib/server-data\";\nimport { CREW, MISSION_STATEMENT } from \"@/lib/crew\";\n\nexport const Route = createFileRoute(\"/team\")({\n  head: () => ({ meta: [{ title: \"Team — Mission Control\" }] }),\n  loader: async () => {\n    const [agents, stats] = await Promise.all([getAgentStatus(), getSystemStats()]);\n    return { agents, stats };\n  },\n  component: TeamPage,\n});\n\nconst statusVariant: Record<string, \"online\" | \"warning\" | \"default\"> = {\n  active: \"online\",\n  standby: \"warning\",\n  error: \"default\",\n};\n\nconst statusDot: Record<string, string> = {\n  active: \"online\",\n  standby: \"warning\",\n  error: \"error\",\n};\n\nfunction TeamPage() {\n  const { agents, stats } = Route.useLoaderData() as { agents: AgentStatus[]; stats: SystemStats };\n\n  return (\n    <>\n      <PageHeader icon=\"👥\" title=\"Team\" meta={`${agents.filter((a) => a.status === \"active\").length} active · ${agents.length} total`}>\n        {MISSION_STATEMENT}\n      </PageHeader>\n\n      {/* System Stats Bar */}\n      <div className=\"mb-6 rounded-xl border border-border bg-card/40 p-4\">\n        <div className=\"font-mono text-[10px] tracking-[0.25em] text-muted-foreground mb-3\">SYSTEM STATUS</div>\n        <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4\">\n          <Stat label=\"MODEL\" value={stats.model.split(\"/\").pop() || stats.model} />\n          <Stat label=\"CRONS\" value={`${stats.activeCrons}/${stats.totalCrons} active`} />\n          <Stat label=\"GATEWAY\" value={stats.gatewayStatus} accent=\"online\" />\n          <Stat label=\"WORKSPACE\" value={`${stats.workspaceFiles} files`} />\n        </div>\n      </div>\n\n      {/* Agent Cards */}\n      <div className=\"grid gap-4 md:grid-cols-2\">\n        {agents.map((agent) => {\n          const crew = CREW.find((c) => c.id === agent.id);\n          return (\n            <div\n              key={agent.id}\n              className=\"rounded-xl border border-border bg-card/60 p-5\"\n            >\n              <div className=\"flex items-start gap-4\">\n                {crew && (\n                  <img\n                    src={crew.avatar}\n                    alt={agent.name}\n                    className=\"h-14 w-14 rounded-lg border border-border object-cover pixelated\"\n                  />\n                )}\n                <div className=\"flex-1 min-w-0\">\n                  <div className=\"flex items-center gap-2 flex-wrap\">\n                    <h3 className=\"font-bold text-lg\">{agent.emoji} {agent.name}</h3>\n                    <Pill variant={statusVariant[agent.status]}>{agent.status}</Pill>\n                  </div>\n                  <div className=\"font-mono text-xs text-muted-foreground mt-0.5\">{agent.role}</div>\n                  <div className=\"mt-3 grid grid-cols-2 gap-2 text-xs\">\n                    <div>\n                      <span className=\"text-muted-foreground\">model: </span>\n                      <span className=\"font-mono\">{agent.model.split(\"/\").pop()}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-muted-foreground\">last active: </span>\n                      <span className=\"font-mono\">{agent.lastActive}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-muted-foreground\">active tasks: </span>","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780059168068}}
