{"type":"message","id":"75fbb6aa","parentId":"0df6f5ab","timestamp":"2026-05-29T20:30:21.055Z","message":{"role":"assistant","content":[{"type":"text","text":"Good. Now let me check the system-stats and openclaw-status server functions to understand what they return:"},{"type":"toolCall","id":"6c668276-f6fb-4b8f-a02a-8f7599cba943","name":"exec","arguments":{"command":"cat ~/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/system.ts","timeout":5},"partialArgs":"{\"command\": \"cat ~/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/system.ts\", \"timeout\": 5}"},{"type":"toolCall","id":"9c4f1517-8b98-4674-a229-3036eab6001d","name":"exec","arguments":{"command":"cat ~/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/openclaw-status.ts","timeout":5},"partialArgs":"{\"command\": \"cat ~/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/openclaw-status.ts\", \"timeout\": 5}"},{"type":"toolCall","id":"1a1cc72c-ec22-4e75-98d3-8f0ca8d92eef","name":"exec","arguments":{"command":"cat ~/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/types.ts","timeout":5},"partialArgs":"{\"command\": \"cat ~/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/types.ts\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":77195,"output":137,"cacheRead":4736,"cacheWrite":0,"reasoningTokens":0,"totalTokens":82068,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780086588824,"responseId":"gen-1780086589-RizyUN1DW69ThkrYRPE6"}}
{"type":"message","id":"eaf60bfe","parentId":"75fbb6aa","timestamp":"2026-05-29T20:30:21.129Z","message":{"role":"toolResult","toolCallId":"6c668276-f6fb-4b8f-a02a-8f7599cba943","toolName":"exec","content":[{"type":"text","text":"// src/lib/server-data/system.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { readFileSync, readdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { WORKSPACE, OPENCLAW_DIR, type SystemStats, type SystemHealth, type ActionResult } from \"./types\";\nimport { readJsonOrNull, formatBytes, parseSize } from \"./helpers\";\n\nexport const getSystemStats = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const agents = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = agents?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const crons = Array.isArray(cfg?.cron) ? cfg.cron as unknown[] : [];\n    const activeCrons = crons.filter((c: unknown) => (c as Record<string, unknown>).enabled !== false).length;\n\n    let workspaceFiles = 0;\n    try { workspaceFiles = readdirSync(WORKSPACE).length; } catch { /* ignore */ }\n\n    let cpuLoad = \"0\";\n    let diskUsed = \"—\"; let diskFree = \"—\"; let diskTotal = \"—\"; let diskPercent = 0;\n    let memoryUsed = \"—\"; let memoryTotal = \"—\"; let memoryPercent = 0;\n    let uptime = \"—\"; let gatewayStatus = \"unknown\"; let gatewayUptime = \"—\";\n    let wdDiskUsed = \"—\"; let wdDiskTotal = \"—\"; let wdDiskPercent = 0; let wdDiskMount = \"—\";\n\n    try {\n      const { execSync } = await import(\"node:child_process\");\n\n      try { cpuLoad = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim(); } catch { /* */ }\n\n      try {\n        const df = execSync(\"df -h / | tail -1 | awk '{print $2, $3, $4, $5}'\", { encoding: \"utf-8\" }).trim().split(\" \");\n        if (df.length >= 4) { diskTotal = df[0]; diskUsed = df[1]; diskFree = df[2]; diskPercent = parseInt(df[3].replace(\"%\", \"\")) || 0; }\n      } catch { /* */ }\n\n      try {\n        const mounts = execSync(\"df -h | grep -iE 'wd|mycloud|public' | awk '{print $2, $3, $4, $6}'\", { encoding: \"utf-8\" }).trim();\n        if (mounts) {\n          const parts = mounts.split(\" \");\n          if (parts.length >= 4) {\n            wdDiskTotal = parts[0]; wdDiskUsed = parts[1]; wdDiskMount = parts[3];\n            const usedNum = parseSize(parts[1]); const totalNum = parseSize(parts[0]);\n            if (totalNum > 0) wdDiskPercent = Math.round((usedNum / totalNum) * 100);\n          }\n        }\n      } catch { /* */ }\n\n      try {\n        const vmStat = execSync(\"vm_stat\", { encoding: \"utf-8\" });\n        const pageSize = 4096;\n        const parse = (key: string) => { const m = vmStat.match(new RegExp(`${key}:\\\\s+(\\\\d+)`)); return m ? parseInt(m[1]) : 0; };\n        const usedBytes = (parse(\"Pages active\") + parse(\"Pages wired down\") + parse(\"Pages speculative\")) * pageSize;\n        const totalBytes = parseInt(execSync(\"sysctl -n hw.memsize\", { encoding: \"utf-8\" }).trim()) || 0;\n        if (totalBytes > 0) {\n          memoryPercent = Math.round((usedBytes / totalBytes) * 100);\n          memoryUsed = formatBytes(usedBytes); memoryTotal = formatBytes(totalBytes);\n        }\n      } catch { /* */ }\n\n      try {\n        const upSec = execSync(\"sysctl -n kern.boottime | awk '{print $4}' | tr -d ','\", { encoding: \"utf-8\" }).trim();\n        const upMs = Date.now() - parseInt(upSec) * 1000;\n        const d = Math.floor(upMs / 86400000); const h = Math.floor((upMs % 86400000) / 3600000); const m = Math.floor((upMs % 3600000) / 60000);\n        uptime = d > 0 ? `${d}d ${h}h ${m}m` : `${h}h ${m}m`;\n      } catch { /* */ }\n\n      try {\n        const gw = execSync(\"openclaw gateway status 2>/dev/null\", { encoding: \"utf-8\" }).trim();\n        gatewayStatus = gw.toLowerCase().includes(\"running\") ? \"running\" : gw.toLowerCase().includes(\"stopped\") ? \"stopped\" : \"unknown\";\n        try {\n          const gwPid = execSync(\"pgrep -f 'openclaw' | head -1\", { encoding: \"utf-8\" }).trim();\n          if (gwPid) {\n            const gwStart = execSync(\"ps -o lstart= -p \" + gwPid, { encoding: \"utf-8\" }).trim();\n            if (gwStart) { const gwH = Math.floor((Date.now() - new Date(gwStart).getTime()) / 3600000); const gwM = Math.floor(((Date.now() - new Date(gwStart).getTime()) % 3600000) / 60000); gatewayUptime = `${gwH}h ${gwM}m`; }\n          }\n        } catch { /* */ }\n      } catch { gatewayStatus = \"unknown\"; }\n\n    } catch { /* ignore all */ }\n\n    return {\n      hostname: \"spacemonkey\", uptime, gatewayUptime,\n      diskUsed, diskFree, diskTotal, diskPercent,\n      wdDiskUsed, wdDiskTotal, wdDiskPercent, wdDiskMount,\n      memoryUsed, memoryTotal, memoryPercent, cpuLoad,\n      openclawVersion: String(cfg?.version || \"unknown\"),\n      model: String(modelConfig?.primary || \"unknown\"),\n      gatewayStatus, activeCrons, totalCrons: crons.length, workspaceFiles, lastBackup: \"—\",\n    } as SystemStats;\n  } catch (e) { console.error(\"[getSystemStats] ERROR:\", e); throw e; }\n});\n\nexport const getSystemHealth = createServerFn({ method: \"GET\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    const cpu = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim();\n    const mem = execSync(\"vm_stat | head -5\", { encoding: \"utf-8\" }).trim();\n    const disk = execSync(\"df -h / | tail -1 | awk '{print $3, $4, $5}'\", { encoding: \"utf-8\" }).trim();\n    const gateway = execSync(\"openclaw gateway status 2>/dev/null | head -1 || echo 'unknown'\", { encoding: \"utf-8\" }).trim();\n    return { cpu, mem, disk, gateway, timestamp: new Date().toISOString() };\n  } catch { return { cpu: \"—\", mem: \"—\", disk: \"—\", gateway: \"unknown\", timestamp: new Date().toISOString() }; }\n});"}],"details":{"status":"completed","exitCode":0,"durationMs":17,"aggregated":"// src/lib/server-data/system.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { readFileSync, readdirSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport { WORKSPACE, OPENCLAW_DIR, type SystemStats, type SystemHealth, type ActionResult } from \"./types\";\nimport { readJsonOrNull, formatBytes, parseSize } from \"./helpers\";\n\nexport const getSystemStats = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const agents = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = agents?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const crons = Array.isArray(cfg?.cron) ? cfg.cron as unknown[] : [];\n    const activeCrons = crons.filter((c: unknown) => (c as Record<string, unknown>).enabled !== false).length;\n\n    let workspaceFiles = 0;\n    try { workspaceFiles = readdirSync(WORKSPACE).length; } catch { /* ignore */ }\n\n    let cpuLoad = \"0\";\n    let diskUsed = \"—\"; let diskFree = \"—\"; let diskTotal = \"—\"; let diskPercent = 0;\n    let memoryUsed = \"—\"; let memoryTotal = \"—\"; let memoryPercent = 0;\n    let uptime = \"—\"; let gatewayStatus = \"unknown\"; let gatewayUptime = \"—\";\n    let wdDiskUsed = \"—\"; let wdDiskTotal = \"—\"; let wdDiskPercent = 0; let wdDiskMount = \"—\";\n\n    try {\n      const { execSync } = await import(\"node:child_process\");\n\n      try { cpuLoad = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim(); } catch { /* */ }\n\n      try {\n        const df = execSync(\"df -h / | tail -1 | awk '{print $2, $3, $4, $5}'\", { encoding: \"utf-8\" }).trim().split(\" \");\n        if (df.length >= 4) { diskTotal = df[0]; diskUsed = df[1]; diskFree = df[2]; diskPercent = parseInt(df[3].replace(\"%\", \"\")) || 0; }\n      } catch { /* */ }\n\n      try {\n        const mounts = execSync(\"df -h | grep -iE 'wd|mycloud|public' | awk '{print $2, $3, $4, $6}'\", { encoding: \"utf-8\" }).trim();\n        if (mounts) {\n          const parts = mounts.split(\" \");\n          if (parts.length >= 4) {\n            wdDiskTotal = parts[0]; wdDiskUsed = parts[1]; wdDiskMount = parts[3];\n            const usedNum = parseSize(parts[1]); const totalNum = parseSize(parts[0]);\n            if (totalNum > 0) wdDiskPercent = Math.round((usedNum / totalNum) * 100);\n          }\n        }\n      } catch { /* */ }\n\n      try {\n        const vmStat = execSync(\"vm_stat\", { encoding: \"utf-8\" });\n        const pageSize = 4096;\n        const parse = (key: string) => { const m = vmStat.match(new RegExp(`${key}:\\\\s+(\\\\d+)`)); return m ? parseInt(m[1]) : 0; };\n        const usedBytes = (parse(\"Pages active\") + parse(\"Pages wired down\") + parse(\"Pages speculative\")) * pageSize;\n        const totalBytes = parseInt(execSync(\"sysctl -n hw.memsize\", { encoding: \"utf-8\" }).trim()) || 0;\n        if (totalBytes > 0) {\n          memoryPercent = Math.round((usedBytes / totalBytes) * 100);\n          memoryUsed = formatBytes(usedBytes); memoryTotal = formatBytes(totalBytes);\n        }\n      } catch { /* */ }\n\n      try {\n        const upSec = execSync(\"sysctl -n kern.boottime | awk '{print $4}' | tr -d ','\", { encoding: \"utf-8\" }).trim();\n        const upMs = Date.now() - parseInt(upSec) * 1000;\n        const d = Math.floor(upMs / 86400000); const h = Math.floor((upMs % 86400000) / 3600000); const m = Math.floor((upMs % 3600000) / 60000);\n        uptime = d > 0 ? `${d}d ${h}h ${m}m` : `${h}h ${m}m`;\n      } catch { /* */ }\n\n      try {\n        const gw = execSync(\"openclaw gateway status 2>/dev/null\", { encoding: \"utf-8\" }).trim();\n        gatewayStatus = gw.toLowerCase().includes(\"running\") ? \"running\" : gw.toLowerCase().includes(\"stopped\") ? \"stopped\" : \"unknown\";\n        try {\n          const gwPid = execSync(\"pgrep -f 'openclaw' | head -1\", { encoding: \"utf-8\" }).trim();\n          if (gwPid) {\n            const gwStart = execSync(\"ps -o lstart= -p \" + gwPid, { encoding: \"utf-8\" }).trim();\n            if (gwStart) { const gwH = Math.floor((Date.now() - new Date(gwStart).getTime()) / 3600000); const gwM = Math.floor(((Date.now() - new Date(gwStart).getTime()) % 3600000) / 60000); gatewayUptime = `${gwH}h ${gwM}m`; }\n          }\n        } catch { /* */ }\n      } catch { gatewayStatus = \"unknown\"; }\n\n    } catch { /* ignore all */ }\n\n    return {\n      hostname: \"spacemonkey\", uptime, gatewayUptime,\n      diskUsed, diskFree, diskTotal, diskPercent,\n      wdDiskUsed, wdDiskTotal, wdDiskPercent, wdDiskMount,\n      memoryUsed, memoryTotal, memoryPercent, cpuLoad,\n      openclawVersion: String(cfg?.version || \"unknown\"),\n      model: String(modelConfig?.primary || \"unknown\"),\n      gatewayStatus, activeCrons, totalCrons: crons.length, workspaceFiles, lastBackup: \"—\",\n    } as SystemStats;\n  } catch (e) { console.error(\"[getSystemStats] ERROR:\", e); throw e; }\n});\n\nexport const getSystemHealth = createServerFn({ method: \"GET\" }).handler(async () => {\n  const { execSync } = await import(\"node:child_process\");\n  try {\n    const cpu = execSync(\"sysctl -n vm.loadavg | awk '{print $2}'\", { encoding: \"utf-8\" }).trim();\n    const mem = execSync(\"vm_stat | head -5\", { encoding: \"utf-8\" }).trim();\n    const disk = execSync(\"df -h / | tail -1 | awk '{print $3, $4, $5}'\", { encoding: \"utf-8\" }).trim();\n    const gateway = execSync(\"openclaw gateway status 2>/dev/null | head -1 || echo 'unknown'\", { encoding: \"utf-8\" }).trim();\n    return { cpu, mem, disk, gateway, timestamp: new Date().toISOString() };\n  } catch { return { cpu: \"—\", mem: \"—\", disk: \"—\", gateway: \"unknown\", timestamp: new Date().toISOString() }; }\n});","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780086621128}}
{"type":"message","id":"c35ab9c3","parentId":"eaf60bfe","timestamp":"2026-05-29T20:30:21.131Z","message":{"role":"toolResult","toolCallId":"9c4f1517-8b98-4674-a229-3036eab6001d","toolName":"exec","content":[{"type":"text","text":"// src/lib/server-data/openclaw-status.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { join } from \"node:path\";\nimport { OPENCLAW_DIR, WORKSPACE, type OpenClawStatus, type OpenClawCronJob, type Task } from \"./types\";\nimport { readJsonOrNull } from \"./helpers\";\n\nexport const getOpenClawStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const models = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = models?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const channels = cfg?.channels as Record<string, unknown> | undefined;\n    const channelNames = channels ? Object.keys(channels).filter((k) => (channels[k] as Record<string, unknown>)?.enabled) : [];\n    const meta = cfg?.meta as Record<string, unknown> | undefined;\n    const skills = cfg?.skills as Record<string, unknown> | undefined;\n    const enabledSkills = skills ? Object.entries(skills).filter(([, v]) => (v as Record<string, unknown>)?.enabled).length : 0;\n\n    return {\n      gateway: \"running\",\n      version: String(meta?.lastTouchedVersion || \"unknown\"),\n      dashboard: \"http://127.0.0.1:18789/\",\n      channel: channelNames.join(\", \") || \"none\",\n      sessions: 4,\n      model: String(modelConfig?.primary || \"unknown\"),\n      ctx: \"1M\",\n      uptime: \"running\",\n      heartbeat: \"30m\",\n      tasksActive: 0,\n      tasksQueued: 0,\n      memoryPlugin: enabledSkills > 0 ? \"enabled\" : \"not checked\",\n    } as OpenClawStatus;\n  } catch (e) { console.error(\"[getOpenClawStatus] ERROR:\", e); throw e; }\n});\n\nexport const getOpenClawCrons = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const { execSync } = await import(\"node:child_process\");\n    const output = execSync(\"/opt/homebrew/bin/openclaw cron list --all --json\", { encoding: \"utf-8\", timeout: 10000 });\n    const data = JSON.parse(output);\n    const jobs = (data.jobs || []) as Record<string, unknown>[];\n    return jobs.map((j) => {\n      const state = (j.state || {}) as Record<string, unknown>;\n      const schedule = (j.schedule || {}) as Record<string, unknown>;\n      const payload = (j.payload || {}) as Record<string, unknown>;\n      return {\n        id: String(j.id || \"\"),\n        name: String(j.name || \"Unknown\"),\n        schedule: String(schedule.expr || \"\"),\n        enabled: j.enabled !== false,\n        status: String(state.lastRunStatus || \"never\"),\n        lastRun: state.lastRunAtMs ? new Date(Number(state.lastRunAtMs)).toISOString() : \"—\",\n        nextRun: state.nextRunAtMs ? new Date(Number(state.nextRunAtMs)).toISOString() : \"—\",\n        message: String(payload.message || \"\").slice(0, 150),\n      } as OpenClawCronJob;\n    });\n  } catch (err) { console.error(\"[getOpenClawCrons] Error:\", err); return []; }\n});\n\nexport const getAwaitingReviewCount = createServerFn({ method: \"GET\" }).handler(async () => {\n  const taskData = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  const count = taskData.filter((t) => t.status === \"awaiting_review\").length;\n  return { count };\n});"}],"details":{"status":"completed","exitCode":0,"durationMs":16,"aggregated":"// src/lib/server-data/openclaw-status.ts\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { join } from \"node:path\";\nimport { OPENCLAW_DIR, WORKSPACE, type OpenClawStatus, type OpenClawCronJob, type Task } from \"./types\";\nimport { readJsonOrNull } from \"./helpers\";\n\nexport const getOpenClawStatus = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const cfg = readJsonOrNull<Record<string, unknown>>(join(OPENCLAW_DIR, \"openclaw.json\"));\n    const models = cfg?.agents as Record<string, unknown> | undefined;\n    const defaults = models?.defaults as Record<string, unknown> | undefined;\n    const modelConfig = defaults?.model as Record<string, unknown> | undefined;\n    const channels = cfg?.channels as Record<string, unknown> | undefined;\n    const channelNames = channels ? Object.keys(channels).filter((k) => (channels[k] as Record<string, unknown>)?.enabled) : [];\n    const meta = cfg?.meta as Record<string, unknown> | undefined;\n    const skills = cfg?.skills as Record<string, unknown> | undefined;\n    const enabledSkills = skills ? Object.entries(skills).filter(([, v]) => (v as Record<string, unknown>)?.enabled).length : 0;\n\n    return {\n      gateway: \"running\",\n      version: String(meta?.lastTouchedVersion || \"unknown\"),\n      dashboard: \"http://127.0.0.1:18789/\",\n      channel: channelNames.join(\", \") || \"none\",\n      sessions: 4,\n      model: String(modelConfig?.primary || \"unknown\"),\n      ctx: \"1M\",\n      uptime: \"running\",\n      heartbeat: \"30m\",\n      tasksActive: 0,\n      tasksQueued: 0,\n      memoryPlugin: enabledSkills > 0 ? \"enabled\" : \"not checked\",\n    } as OpenClawStatus;\n  } catch (e) { console.error(\"[getOpenClawStatus] ERROR:\", e); throw e; }\n});\n\nexport const getOpenClawCrons = createServerFn({ method: \"GET\" }).handler(async () => {\n  try {\n    const { execSync } = await import(\"node:child_process\");\n    const output = execSync(\"/opt/homebrew/bin/openclaw cron list --all --json\", { encoding: \"utf-8\", timeout: 10000 });\n    const data = JSON.parse(output);\n    const jobs = (data.jobs || []) as Record<string, unknown>[];\n    return jobs.map((j) => {\n      const state = (j.state || {}) as Record<string, unknown>;\n      const schedule = (j.schedule || {}) as Record<string, unknown>;\n      const payload = (j.payload || {}) as Record<string, unknown>;\n      return {\n        id: String(j.id || \"\"),\n        name: String(j.name || \"Unknown\"),\n        schedule: String(schedule.expr || \"\"),\n        enabled: j.enabled !== false,\n        status: String(state.lastRunStatus || \"never\"),\n        lastRun: state.lastRunAtMs ? new Date(Number(state.lastRunAtMs)).toISOString() : \"—\",\n        nextRun: state.nextRunAtMs ? new Date(Number(state.nextRunAtMs)).toISOString() : \"—\",\n        message: String(payload.message || \"\").slice(0, 150),\n      } as OpenClawCronJob;\n    });\n  } catch (err) { console.error(\"[getOpenClawCrons] Error:\", err); return []; }\n});\n\nexport const getAwaitingReviewCount = createServerFn({ method: \"GET\" }).handler(async () => {\n  const taskData = readJsonOrNull<Task[]>(join(WORKSPACE, \"data\", \"tasks.json\")) || [];\n  const count = taskData.filter((t) => t.status === \"awaiting_review\").length;\n  return { count };\n});","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780086621130}}
{"type":"message","id":"72719cb4","parentId":"c35ab9c3","timestamp":"2026-05-29T20:30:21.131Z","message":{"role":"toolResult","toolCallId":"1a1cc72c-ec22-4e75-98d3-8f0ca8d92eef","toolName":"exec","content":[{"type":"text","text":"// src/lib/server-data/types.ts\n// Shared types and constants for server data functions\n\nexport const WORKSPACE = process.env.OPENCLAW_WORKSPACE || \"/Users/spacemonkey/.openclaw/workspace\";\nexport const OPENCLAW_DIR = process.env.OPENCLAW_DIR || \"/Users/spacemonkey/.openclaw\";\n\n// ── Task Types ────────────────────────────────────────────────────────────────\n\nexport interface Task {\n  id: string;\n  title: string;\n  assignee: string;\n  status: \"backlog\" | \"in_progress\" | \"awaiting_review\" | \"done\";\n  priority: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  ts: string;\n  note?: string;\n  lastUpdated?: string;\n  startedAt?: string;\n  completedAt?: string;\n  progress?: number;\n  tags?: string[];\n  acknowledged?: boolean;\n  escalationLevel?: number;\n  history?: TaskHistoryEntry[];\n  errorId?: string;\n  jobId?: string;\n  summary?: string;\n}\n\nexport interface TaskHistoryEntry {\n  ts: string;\n  action: \"created\" | \"dispatched\" | \"started\" | \"progress\" | \"stalled\" | \"escalated\" | \"completed\" | \"reassigned\";\n  actor?: string;\n  details?: string;\n}\n\n// ── Queue Types ───────────────────────────────────────────────────────────────\n\nexport interface QueueItem {\n  id: string;\n  taskId: string;\n  title: string;\n  assignee: string;\n  dispatchedAt: string;\n  status: \"pending\" | \"executing\" | \"completed\" | \"failed\";\n}\n\n// ── Cron Types ────────────────────────────────────────────────────────────────\n\nexport interface CronJob {\n  id: string;\n  name: string;\n  schedule: string;\n  nextRun: string;\n  enabled: boolean;\n  description: string;\n}\n\nexport interface OpenClawCronJob {\n  id: string;\n  name: string;\n  schedule: string;\n  enabled: boolean;\n  status: string;\n  lastRun: string;\n  nextRun: string;\n  message: string;\n  lastError?: string;\n  lastErrorReason?: string;\n  consecutiveErrors?: number;\n}\n\n// ── System Stats Types ────────────────────────────────────────────────────────\n\nexport interface SystemStats {\n  hostname: string;\n  uptime: string;\n  gatewayUptime: string;\n  diskUsed: string;\n  diskFree: string;\n  diskTotal: string;\n  diskPercent: number;\n  wdDiskUsed: string;\n  wdDiskTotal: string;\n  wdDiskPercent: number;\n  wdDiskMount: string;\n  memoryUsed: string;\n  memoryTotal: string;\n  memoryPercent: number;\n  cpuLoad: string;\n  openclawVersion: string;\n  model: string;\n  gatewayStatus: string;\n  activeCrons: number;\n  totalCrons: number;\n  workspaceFiles: number;\n  lastBackup: string;\n}\n\n// ── Agent Status Types ────────────────────────────────────────────────────────\n\nexport interface AgentStatus {\n  id: string;\n  name: string;\n  role: string;\n  emoji: string;\n  status: \"active\" | \"standby\" | \"error\";\n  model: string;\n  lastActive: string;\n  tasksActive: number;\n  currentAction?: string;\n}\n\n// ── Memory Types ──────────────────────────────────────────────────────────────\n\nexport interface MemoryEntry {\n  date: string;\n  words: number;\n  title: string;\n  body: string;\n}\n\n// ── Doc Types ─────────────────────────────────────────────────────────────────\n\nexport interface Doc {\n  id: string;\n  title: string;\n  date: string;\n  type: string;\n  author: string;\n  body: string;\n}\n\n// ── Project Types ─────────────────────────────────────────────────────────────\n\nexport interface Project {\n  id: string;\n  name: string;\n  description: string;\n  status: string;\n  accent: string;\n  updatedAt?: string;\n  progress?: number;\n  tasks?: number;\n  lastActivity?: string;\n  lead?: string;\n}\n\n// ── Incident Types ────────────────────────────────────────────────────────────\n\nexport interface IncidentEvent {\n  ts: string;\n  message: string;\n  actor?: string;\n}\n\nexport interface IncidentAction {\n  label: string;\n  description: string;\n  status: \"available\" | \"completed\" | \"skipped\" | \"in_progress\";\n  completedAt?: string;\n  completedBy?: string;\n}\n\nexport interface Incident {\n  id: string;\n  title: string;\n  severity: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  status: \"TRIAGE\" | \"MITIGATING\" | \"RESOLVED\";\n  owner: string;\n  acknowledged?: boolean;\n  escalated?: boolean;\n  opened: string;\n  resolved?: string;\n  lastActivity?: string;\n  summary: string;\n  tags: string[];\n  timeline: IncidentEvent[];\n  actions: IncidentAction[];\n}\n\nexport interface CreateIncidentInput {\n  title: string;\n  severity: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  owner: string;\n  summary: string;\n  tags: string[];\n  source: string;\n}\n\n// ── Activity Types ────────────────────────────────────────────────────────────\n\nexport interface ActivityEvent {\n  id: string;\n  ts: string;\n  message: string;\n  type: \"task\" | \"cron\" | \"system\" | \"memory\" | \"project\" | \"incident\";\n  actor?: string;\n}\n\n// ── Search Types ──────────────────────────────────────────────────────────────\n\nexport interface SearchResult {\n  id: string;\n  title: string;\n  snippet: string;\n  type: \"task\" | \"doc\" | \"memory\" | \"project\" | \"incident\" | \"cron\";\n  url: string;\n  date?: string;\n}\n\n// ── OpenClaw Status Types ─────────────────────────────────────────────────────\n\nexport interface OpenClawStatus {\n  gateway: string;\n  version: string;\n  dashboard: string;\n  channel: string;\n  sessions: number;\n  model: string;\n  ctx: string;\n  uptime: string;\n  heartbeat: string;\n  tasksActive: number;\n  tasksQueued: number;\n  memoryPlugin: string;\n}\n\n// ── Quick Action Result ───────────────────────────────────────────────────────\n\nexport interface ActionResult {\n  ok: boolean;\n  message: string;\n  size?: string;\n}\n\nexport interface SystemHealth {\n  cpu: string;\n  disk: string;\n  