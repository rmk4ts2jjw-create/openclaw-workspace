{"type":"message","id":"7051ebc4","parentId":"0ef3114a","timestamp":"2026-05-29T14:47:30.758Z","message":{"role":"toolResult","toolCallId":"ce2a1fa4-d270-458b-9126-277e7256b196","toolName":"read","content":[{"type":"text","text":"        <AppSidebar />\n        <main className=\"flex-1 min-w-0\">\n          <div className=\"mx-auto max-w-[1650px] px-6 py-8 md:px-10 md:py-10\">\n            <Outlet />\n          </div>\n          {/* Build version footer */}\n          <div className=\"mx-auto max-w-[1650px] px-6 pb-4 md:px-10\">\n            <div className=\"border-t border-border/30 pt-3 flex items-center justify-between\">\n              <span className=\"font-mono text-[8px] text-muted-foreground/40 tracking-wider\">\n                BUILD {BUILD_HASH}\n              </span>\n              <span className=\"font-mono text-[8px] text-muted-foreground/40 tracking-wider\">\n                {getBuildLabel()}\n              </span>\n            </div>\n\n[7 more lines in file. Use offset=145 to continue.]"}],"isError":false,"timestamp":1780066050758}}
