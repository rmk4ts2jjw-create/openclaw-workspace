tedAt ? new Date(t.startedAt) : null);\n+  const minutesSinceActivity = lastActivityTime ? Math.floor((now.getTime() - lastActivityTime.getTime()) / 60000) : 0;\n+  const isStalled = isInProgress && minutesSinceActivity >= STALE_WARNING_MINUTES;\n+  const stallDuration = isStalled ? minutesSinceActivity : 0;\n+\n+  // Progress bar color: grey (no activity), green (working), amber (stalled)\n+  const progressColor = isDone\n+    ? \"bg-[oklch(0.88_0.18_145)]\"\n+    : isStalled\n+    ? \"bg-amber\"\n+    : \"bg-gradient-to-r from-violet/60 to-violet\";\n+\n+  // Current step display\n+  const currentStep = t.currentStep || (isInProgress ? \"Working...\" : undefined);\n+\n   return (\n     <div\n       draggable"}],"details":{"status":"completed","exitCode":0,"durationMs":20,"aggregated":"diff --git a/src/routes/tasks.tsx b/src/routes/tasks.tsx\nindex b36cccb..9fd42fc 100644\n--- a/src/routes/tasks.tsx\n+++ b/src/routes/tasks.tsx\n@@ -34,8 +34,12 @@ async function dispatchTaskToQueue(task: { taskId: string; title: string; assign\n }\n import { Plus, X, User, FileText, ChevronDown, Send, Pencil, Trash2, Clock, User as UserIcon, CheckCircle } from \"lucide-react\";\n \n-// ── Auto-move configuration ────────────────────────────────────────────────\n-const AUTO_COMPLETE_DELAY_MS = 5 * 60 * 1000; // 5 minutes\n+// ── Progress and Stall Detection Configuration ────────────────────────────\n+const PROGRESS_UPDATE_INTERVAL_MS = 5 * 60 * 1000; // 5 minutes\n+const STALE_WARNING_MINUTES = 30;\n+const STALE_RETURN_MINUTES = 120; // 2 hours\n+const INITIAL_PROGRESS = 5;\n+const PROGRESS_PER_UPDATE = 10; // % per update\n import { loadState, saveState } from \"@/lib/persist\";\n \n export const Route = createFileRoute(\"/tasks\")({\n@@ -513,11 +517,13 @@ function TaskCard({\n   onDragStart,\n   dragging,\n   onClick,\n+  onUpdate,\n }: {\n   t: Task;\n   onDragStart: (id: string) => void;\n   dragging: boolean;\n   onClick: () => void;\n+  onUpdate: (updated: Task) => void;\n }) {\n   const a = getCrew(t.assignee);\n   const isInProgress = t.status === \"in_progress\";\n@@ -530,9 +536,26 @@ function TaskCard({\n     ? getTimeAgo(t.lastUpdated)\n     : t.ts;\n \n-  // Progress percentage (simulated based on time in progress)\n+  // Calculate real progress (not fake animation)\n   const progressPct = t.progress ?? (isDone ? 100 : isInProgress ? calculateProgress(t) : 0);\n \n+  // Detect stall: no activity for STALE_WARNING_MINUTES\n+  const now = new Date();\n+  const lastActivityTime = t.lastActivity ? new Date(t.lastActivity) : (t.startedAt ? new Date(t.startedAt) : null);\n+  const minutesSinceActivity = lastActivityTime ? Math.floor((now.getTime() - lastActivityTime.getTime()) / 60000) : 0;\n+  const isStalled = isInProgress && minutesSinceActivity >= STALE_WARNING_MINUTES;\n+  const stallDuration = isStalled ? minutesSinceActivity : 0;\n+\n+  // Progress bar color: grey (no activity), green (working), amber (stalled)\n+  const progressColor = isDone\n+    ? \"bg-[oklch(0.88_0.18_145)]\"\n+    : isStalled\n+    ? \"bg-amber\"\n+    : \"bg-gradient-to-r from-violet/60 to-violet\";\n+\n+  // Current step display\n+  const currentStep = t.currentStep || (isInProgress ? \"Working...\" : undefined);\n+\n   return (\n     <div\n       draggable","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780329224025}}
