{"type":"message","id":"badfe3e8","parentId":"1fb7aebf","timestamp":"2026-06-01T16:07:00.633Z","message":{"role":"toolResult","toolCallId":"167e2712-0eae-4e68-9878-e3e2f1fb1aae","toolName":"exec","content":[{"type":"text","text":"const stallDuration = isStalled ? minutesSinceActivity : 0;\n\n  // Progress bar color: grey/no bar (no activity), green (working), amber (stalled)\n  const progressColor = isDone\n    ? \"bg-[oklch(0.88_0.18_145)]\"\n    : isStalled\n    ? \"bg-amber\"\n    : hasRealActivity\n    ? \"bg-[oklch(0.88_0.18_145)]\"\n    : \"bg-muted-foreground/30\";\n\n  // Current step display — only show real agent data, never fake\n  const hasRealActivity = !!(t.currentStep && t.lastActivity);\n  const currentStep = isInProgress\n    ? (hasRealActivity ? t.currentStep : \"Waiting for agent...\")\n    : undefined;\n\n  return (\n    <div\n      draggable\n      onDragStart={(e) => {\n        e.dataTransfer.effectAllowed = \"move\";\n        e.dataTransfer.setData(\"text/plain\", t.id);\n--\n      }`}\n    >\n      {/* Progress bar (in-progress only) */}\n      {isInProgress && (\n        <div className=\"mb-2 space-y-1\">\n          <div className=\"h-1 w-full rounded-full bg-muted/30 overflow-hidden\">\n            {progressPct === 0 ? (\n              <div className=\"h-full w-2 rounded-full bg-muted-foreground/40 animate-pulse\" />\n            ) : (\n              <div\n                className={`h-full rounded-full transition-all duration-1000 ${progressColor}`}\n                style={{ width: `${progressPct}%` }}\n              />\n            )}\n          </div>\n          {/* Step label */}\n          <div className={`font-mono text-[8px] tracking-wider ${\n            hasRealActivity ? \"text-[oklch(0.82_0.12_295)]\" : \"text-muted-foreground/50\"\n          }`}>\n            {currentStep}\n          </div>\n        </div>\n      )}"}],"details":{"status":"completed","exitCode":0,"durationMs":16,"aggregated":"const stallDuration = isStalled ? minutesSinceActivity : 0;\n\n  // Progress bar color: grey/no bar (no activity), green (working), amber (stalled)\n  const progressColor = isDone\n    ? \"bg-[oklch(0.88_0.18_145)]\"\n    : isStalled\n    ? \"bg-amber\"\n    : hasRealActivity\n    ? \"bg-[oklch(0.88_0.18_145)]\"\n    : \"bg-muted-foreground/30\";\n\n  // Current step display — only show real agent data, never fake\n  const hasRealActivity = !!(t.currentStep && t.lastActivity);\n  const currentStep = isInProgress\n    ? (hasRealActivity ? t.currentStep : \"Waiting for agent...\")\n    : undefined;\n\n  return (\n    <div\n      draggable\n      onDragStart={(e) => {\n        e.dataTransfer.effectAllowed = \"move\";\n        e.dataTransfer.setData(\"text/plain\", t.id);\n--\n      }`}\n    >\n      {/* Progress bar (in-progress only) */}\n      {isInProgress && (\n        <div className=\"mb-2 space-y-1\">\n          <div className=\"h-1 w-full rounded-full bg-muted/30 overflow-hidden\">\n            {progressPct === 0 ? (\n              <div className=\"h-full w-2 rounded-full bg-muted-foreground/40 animate-pulse\" />\n            ) : (\n              <div\n                className={`h-full rounded-full transition-all duration-1000 ${progressColor}`}\n                style={{ width: `${progressPct}%` }}\n              />\n            )}\n          </div>\n          {/* Step label */}\n          <div className={`font-mono text-[8px] tracking-wider ${\n            hasRealActivity ? \"text-[oklch(0.82_0.12_295)]\" : \"text-muted-foreground/50\"\n          }`}>\n            {currentStep}\n          </div>\n        </div>\n      )}","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780330020632}}
