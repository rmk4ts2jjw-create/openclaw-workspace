{"type":"message","id":"f44990d2","parentId":"b4b2a558","timestamp":"2026-06-01T16:02:42.448Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me make all three code changes. First, the `calculateProgress` function and the progress bar display:"},{"type":"toolCall","id":"3a8ed6a4-fe89-4590-80b2-0c8a195be4e4","name":"edit","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/tasks.tsx","edits":[{"oldText":"function calculateProgress(t: Task): number {\n  if (!t.startedAt) return 10;\n  const elapsed = Date.now() - new Date(t.startedAt).getTime();\n  // Estimate: tasks progress ~10% per minute, cap at 95% until done\n  const estimated = Math.min(95, Math.floor(elapsed / 60000) * 10);\n  return Math.max(5, estimated);\n}","newText":"function calculateProgress(t: Task): number {\n  // Use explicit progress value if set by agent\n  if (t.progress !== undefined) return Math.min(100, Math.max(0, t.progress));\n  // If we have real activity data, derive progress from step completion\n  if (t.currentStep && t.lastActivity) {\n    // Agent is actively reporting — show 50-90% based on recency\n    const minsSinceActivity = Math.floor((Date.now() - new Date(t.lastActivity).getTime()) / 60000);\n    if (minsSinceActivity < 5) return 75;   // active now\n    if (minsSinceActivity < 30) return 60;  // recent activity\n    return 50;                               // stale\n  }\n  // No real data yet — return 0 so UI shows \"Waiting for agent...\"\n  return 0;\n}"}]},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/tasks.tsx\", \"edits\": [{\"oldText\": \"function calculateProgress(t: Task): number {\\n  if (!t.startedAt) return 10;\\n  const elapsed = Date.now() - new Date(t.startedAt).getTime();\\n  // Estimate: tasks progress ~10% per minute, cap at 95% until done\\n  const estimated = Math.min(95, Math.floor(elapsed / 60000) * 10);\\n  return Math.max(5, estimated);\\n}\", \"newText\": \"function calculateProgress(t: Task): number {\\n  // Use explicit progress value if set by agent\\n  if (t.progress !== undefined) return Math.min(100, Math.max(0, t.progress));\\n  // If we have real activity data, derive progress from step completion\\n  if (t.currentStep && t.lastActivity) {\\n    // Agent is actively reporting — show 50-90% based on recency\\n    const minsSinceActivity = Math.floor((Date.now() - new Date(t.lastActivity).getTime()) / 60000);\\n    if (minsSinceActivity < 5) return 75;   // active now\\n    if (minsSinceActivity < 30) return 60;  // recent activity\\n    return 50;                               // stale\\n  }\\n  // No real data yet — return 0 so UI shows \\\"Waiting for agent...\\\"\\n  return 0;\\n}\"}]}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":254,"output":389,"cacheRead":80640,"cacheWrite":0,"reasoningTokens":0,"totalTokens":81283,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780329734863,"responseId":"gen-1780329735-6DAS6e0ueRKUcC8S1VQy"}}
