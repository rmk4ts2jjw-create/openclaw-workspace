{"type":"message","id":"895738a8","parentId":"d0389bc3","timestamp":"2026-06-01T16:06:42.811Z","message":{"role":"toolResult","toolCallId":"56e06b5d-f070-4751-a9f6-7e76bd1d3fd6","toolName":"exec","content":[{"type":"text","text":"function calculateProgress(t: Task): number {\n  // Use explicit progress value if set by agent\n  if (t.progress !== undefined) return Math.min(100, Math.max(0, t.progress));\n  // If we have real activity data, derive progress from step completion\n  if (t.currentStep && t.lastActivity) {\n    // Agent is actively reporting — show 50-90% based on recency\n    const minsSinceActivity = Math.floor((Date.now() - new Date(t.lastActivity).getTime()) / 60000);\n    if (minsSinceActivity < 5) return 75;   // active now\n    if (minsSinceActivity < 30) return 60;  // recent activity\n    return 50;                               // stale\n  }\n  // No real data yet — return 0 so UI shows \"Waiting for agent...\"\n  return 0;\n}\n\n// ── Main Tasks Page ──────────────────────────────────────────────────────────"}],"details":{"status":"completed","exitCode":0,"durationMs":19,"aggregated":"function calculateProgress(t: Task): number {\n  // Use explicit progress value if set by agent\n  if (t.progress !== undefined) return Math.min(100, Math.max(0, t.progress));\n  // If we have real activity data, derive progress from step completion\n  if (t.currentStep && t.lastActivity) {\n    // Agent is actively reporting — show 50-90% based on recency\n    const minsSinceActivity = Math.floor((Date.now() - new Date(t.lastActivity).getTime()) / 60000);\n    if (minsSinceActivity < 5) return 75;   // active now\n    if (minsSinceActivity < 30) return 60;  // recent activity\n    return 50;                               // stale\n  }\n  // No real data yet — return 0 so UI shows \"Waiting for agent...\"\n  return 0;\n}\n\n// ── Main Tasks Page ──────────────────────────────────────────────────────────","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780330002811}}
