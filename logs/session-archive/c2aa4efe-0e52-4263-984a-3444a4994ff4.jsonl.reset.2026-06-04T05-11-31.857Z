{"type":"message","id":"2b83d093","parentId":"978b1af9","timestamp":"2026-06-03T22:23:08.223Z","message":{"role":"assistant","content":[{"type":"text","text":"Now implement the incident type mapping. I'll add an incident type classifier to the runbooks module and integrate it with incident creation:"},{"type":"toolCall","id":"4fabcbc9-3f18-4c00-a069-06764eb7ed4d","name":"edit","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/runbooks.ts","edits":[{"oldText":"/** Get all runbooks matching a severity level */\nexport function getRunbooksBySeverity(severity: RunbookSeverity): Runbook[] {\n  return RUNBOOKS.filter((r) => r.severity === severity);\n}","newText":"/** Get all runbooks matching a severity level */\nexport function getRunbooksBySeverity(severity: RunbookSeverity): Runbook[] {\n  return RUNBOOKS.filter((r) => r.severity === severity);\n}\n\n// ── Incident Type Classification ─────────────────────────────────────────────\n\ninterface TypePattern {\n  type: IncidentType;\n  severity: RunbookSeverity;\n  keywords: string[];\n}\n\nconst TYPE_PATTERNS: TypePattern[] = [\n  { type: \"cron-failure\", severity: \"P2\", keywords: [\"cron\", \"job\", \"scheduled\", \"timeout\", \"cron job\", \"dispatching\"] },\n  { type: \"rate-limit\", severity: \"P2\", keywords: [\"429\", \"rate limit\", \"too many request\", \"throttl\", \"quota\", \"free-models-per\"] },\n  { type: \"service-down\", severity: \"P1\", keywords: [\"down\", \"offline\", \"not responding\", \"connection refused\", \"unreachable\", \"crashed\"] },\n  { type: \"dependency-break\", severity: \"P2\", keywords: [\"import\", \"module\", \"dependency\", \"resolve\", \"npm\", \"package\", \"version\"] },\n  { type: \"vite-cache\", severity: \"P3\", keywords: [\"vite\", \"cache\", \"optimize dep\", \"504\", \"outdated optimize\", \"corrupt\"] },\n  { type: \"disk-space\", severity: \"P2\", keywords: [\"disk\", \"space\", \"storage\", \"full\", \"no space\", \"out of space\", \"df\"] },\n  { type: \"network\", severity: \"P2\", keywords: [\"network\", \"dns\", \"resolve\", \"timeout\", \"connection\", \"socket\", \"tls\", \"ssl\"] },\n];\n\n/** Auto-detect incident type from error message and/or title. Returns best match with confidence. */\nexport function classifyIncident(title: string, error?: string): { type: IncidentType; severity: RunbookSeverity; confidence: number } {\n  const text = `${title} ${_error || \"\"}`.toLowerCase();\n  let best: { type: IncidentType; severity: RunbookSeverity; score: number } | null = null;\n\n  for (const pattern of TYPE_PATTERNS) {\n    let score = 0;\n    for (const kw of pattern.keywords) {\n      if (text.includes(kw)) score += 1;\n    }\n    if (score > 0 && (!best || score > best.score)) {\n      best = { type: pattern.type, severity: pattern.severity, score };\n    }\n  }\n\n  if (best) {\n    // Normalize confidence: 1 keyword = 0.5, 2+ = 0.8, 3+ = 1.0\n    const confidence = best.score >= 3 ? 1.0 : best.score >= 2 ? 0.8 : 0.5;\n    return { type: best.type, severity: best.severity, confidence };\n  }\n\n  return { type: \"unknown\", severity: \"P3\", confidence: 0 };\n}\n\n/** Auto-suggest a runbook based on incident title and error */\nexport function suggestRunbook(title: string, error?: string): { runbook: Runbook | undefined; confidence: number } {\n  const { type, confidence } = classifyIncident(title, error);\n  if (type === \"unknown\" || confidence === 0) return { runbook: undefined, confidence: 0 };\n  const runbook = getRunbookForIncident(type);\n  return { runbook, confidence };\n}"}]},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/runbooks.ts\", \"edits\": [{\"oldText\": \"/** Get all runbooks matching a severity level */\\nexport function getRunbooksBySeverity(severity: RunbookSeverity): Runbook[] {\\n  return RUNBOOKS.filter((r) => r.severity === severity);\\n}\", \"newText\": \"/** Get all runbooks matching a severity level */\\nexport function getRunbooksBySeverity(severity: RunbookSeverity): Runbook[] {\\n  return RUNBOOKS.filter((r) => r.severity === severity);\\n}\\n\\n// ── Incident Type Classification ─────────────────────────────────────────────\\n\\ninterface TypePattern {\\n  type: IncidentType;\\n  severity: RunbookSeverity;\\n  keywords: string[];\\n}\\n\\nconst TYPE_PATTERNS: TypePattern[] = [\\n  { type: \\\"cron-failure\\\", severity: \\\"P2\\\", keywords: [\\\"cron\\\", \\\"job\\\", \\\"scheduled\\\", \\\"timeout\\\", \\\"cron job\\\", \\\"dispatching\\\"] },\\n  { type: \\\"rate-limit\\\", severity: \\\"P2\\\", keywords: [\\\"429\\\", \\\"rate limit\\\", \\\"too many request\\\", \\\"throttl\\\", \\\"quota\\\", \\\"free-models-per\\\"] },\\n  { type: \\\"service-down\\\", severity: \\\"P1\\\", keywords: [\\\"down\\\", \\\"offline\\\", \\\"not responding\\\", \\\"connection refused\\\", \\\"unreachable\\\", \\\"crashed\\\"] },\\n  { type: \\\"dependency-break\\\", severity: \\\"P2\\\", keywords: [\\\"import\\\", \\\"module\\\", \\\"dependency\\\", \\\"resolve\\\", \\\"npm\\\", \\\"package\\\", \\\"version\\\"] },\\n  { type: \\\"vite-cache\\\", severity: \\\"P3\\\", keywords: [\\\"vite\\\", \\\"cache\\\", \\\"optimize dep\\\", \\\"504\\\", \\\"outdated optimize\\\", \\\"corrupt\\\"] },\\n  { type: \\\"disk-space\\\", severity: \\\"P2\\\", keywords: [\\\"disk\\\", \\\"space\\\", \\\"storage\\\", \\\"full\\\", \\\"no space\\\", \\\"out of space\\\", \\\"df\\\"] },\\n  { type: \\\"network\\\", severity: \\\"P2\\\", keywords: [\\\"network\\\", \\\"dns\\\", \\\"resolve\\\", \\\"timeout\\\", \\\"connection\\\", \\\"socket\\\", \\\"tls\\\", \\\"ssl\\\"] },\\n];\\n\\n/** Auto-detect incident type from error message and/or title. Returns best match with confidence. */\\nexport function classifyIncident(title: string, error?: string): { type: IncidentType; severity: RunbookSeverity; confidence: number } {\\n  const text = `${title} ${_error || \\\"\\\"}`.toLowerCase();\\n  let best: { type: IncidentType; severity: RunbookSeverity; score: number } | null = null;\\n\\n  for (const pattern of TYPE_PATTERNS) {\\n    let score = 0;\\n    for (const kw of pattern.keywords) {\\n      if (text.includes(kw)) score += 1;\\n    }\\n    if (score > 0 && (!best || score > best.score)) {\\n      best = { type: pattern.type, severity: pattern.severity, score };\\n    }\\n  }\\n\\n  if (best) {\\n    // Normalize confidence: 1 keyword = 0.5, 2+ = 0.8, 3+ = 1.0\\n    const confidence = best.score >= 3 ? 1.0 : best.score >= 2 ? 0.8 : 0.5;\\n    return { type: best.type, severity: best.severity, confidence };\\n  }\\n\\n  return { type: \\\"unknown\\\", severity: \\\"P3\\\", confidence: 0 };\\n}\\n\\n/** Auto-suggest a runbook based on incident title and error */\\nexport function suggestRunbook(title: string, error?: string): { runbook: Runbook | undefined; confidence: number } {\\n  const { type, confidence } = classifyIncident(title, error);\\n  if (type === \\\"unknown\\\" || confidence === 0) return { runbook: undefined, confidence: 0 };\\n  const runbook = getRunbookForIncident(type);\\n  return { runbook, confidence };\\n}\"}]}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":719,"output":970,"cacheRead":124160,"cacheWrite":0,"reasoningTokens":0,"totalTokens":125849,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780514148357,"responseId":"gen-1780514149-rQEcmNMkdpfy46aWDwVj"}}
