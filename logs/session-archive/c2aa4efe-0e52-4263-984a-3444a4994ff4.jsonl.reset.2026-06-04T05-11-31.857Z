ink_info = f\\\"→ {len(linked)} task(s)\\\" if linked else \\\"→ ⚠️ NO LINKED TASK\\\"\\n        print(f\\\"  {inc['id']} [{inc.get('severity','?')}] {link_info} — {inc['title'][:45]}\\\")\\nPYEOF\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":301,"output":543,"cacheRead":162560,"cacheWrite":0,"reasoningTokens":0,"totalTokens":163404,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780535544415,"responseId":"gen-1780535545-0v5ZmTqejvsUugG4wDKY"}}
