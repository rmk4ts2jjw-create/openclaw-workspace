{"type":"message","id":"2284c3bf","parentId":"431f9b0e","timestamp":"2026-06-03T21:28:02.247Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"d567b24e-5d8d-49f3-878c-c6587108110a","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/timeline-data.ts","content":"// src/lib/server-data/timeline-data.ts\n// Unified event model — all station events feed into a single timeline\n\nimport { readFileSync, existsSync } from \"node:fs\";\nimport { join } from \"node:path\";\nimport type { Task } from \"./types\";\nimport type { Incident } from \"./types\";\n\nconst WORKSPACE = process.env.OPENCLAW_WORKSPACE || \"/Users/spacemonkey/.openclaw/workspace\";\n\nexport type TimelineEventType =\n  | \"task_created\"\n  | \"task_started\"\n  | \"task_completed\"\n  | \"task_stalled\"\n  | \"incident_created\"\n  | \"incident_status_change\"\n  | \"incident_resolved\"\n  | \"cron_success\"\n  | \"cron_failure\"\n  | \"system_health\";\n\nexport interface TimelineEvent {\n  id: string;\n  ts: string;\n  type: TimelineEventType;\n  source: string; // \"task\", \"incident\", \"cron\", \"system\"\n  severity: \"info\" | \"warning\" | \"critical\";\n  title: string;\n  description: string;\n  actor?: string;\n  entityId?: string; // task ID, incident ID, etc.\n  entityUrl?: string; // link to the related entity\n  metadata?: Record<string, string>;\n}\n\n// ── Collect events from all sources ──────────────────────────────────────────\n\nfunction readTasks(): Task[] {\n  const p = join(WORKSPACE, \"data\", \"tasks.json\");\n  if (!existsSync(p)) return [];\n  try { return JSON.parse(readFileSync(p, \"utf-8\")); } catch { return []; }\n}\n\nfunction readIncidents(): Incident[] {\n  const p = join(WORKSPACE, \"data\", \"incidents.json\");\n  if (!existsSync(p)) return [];\n  try { return JSON.parse(readFileSync(p, \"utf-8\")); } catch { return []; }\n}\n\nfunction readCrons(): any[] {\n  // Read from the OpenClaw cron data file\n  const p = join(WORKSPACE, \"data\", \"crons.json\");\n  if (!existsSync(p)) return [];\n  try { return JSON.parse(readFileSync(p, \"utf-8\")); } catch { return []; }\n}\n\n/** Extract timeline events from task history */\nfunction eventsFromTasks(tasks: Task[]): TimelineEvent[] {\n  const events: TimelineEvent[] = [];\n\n  for (const task of tasks) {\n    const history = task.history || [];\n\n    for (const entry of history) {\n      const ts = entry.ts;\n      const actor = entry.actor || \"system\";\n      const details = entry.details || \"\";\n\n      switch (entry.action) {\n        case \"created\":\n          events.push({\n            id: `evt-${task.id}-created`,\n            ts,\n            type: \"task_created\",\n            source: \"task\",\n            severity: \"info\",\n            title: `Task created: ${task.title}`,\n            description: details,\n            actor,\n            entityId: task.id,\n            entityUrl: \"/tasks\",\n          });\n          break;\n\n        case \"started\":\n          events.push({\n            id: `evt-${task.id}-started`,\n            ts,\n            type: \"task_started\",\n            source: \"task\",\n            severity: \"info\",\n            title: `Task started: ${task.title}`,\n            description: details,\n            actor,\n            entityId: task.id,\n            entityUrl: \"/tasks\",\n          });\n          break;\n\n        case \"completed\":\n          events.push({\n            id: `evt-${task.id}-completed`,\n            ts,\n            type: \"task_completed\",\n            source: \"task\",\n            severity: \"info\",\n            title: `Task completed: ${task.title}`,\n            description: details,\n            actor,\n            entityId: task.id,\n            entityUrl: \"/tasks\",\n          });\n          break;\n\n        case \"stalled\":\n          events.push({\n            id: `evt-${task.id}-stalled`,\n            ts,\n            type: \"task_stalled\",\n            source: \"task\",\n            severity: \"warning\",\n            title: `Task stalled: ${task.title}`,\n            description: details,\n            actor,\n            entityId: task.id,\n            entityUrl: \"/tasks\",\n          });\n          break;\n\n        case \"reassigned\":\n          // Only include triage-related reassignments\n          if (details.toLowerCase().includes(\"triage\")) {\n            events.push({\n              id: `evt-${task.id}-triage-${ts}`,\n              ts,\n              type: \"task_stalled\",\n              source: \"task\",\n              severity: \"warning\",\n              title: `Task moved to triage: ${task.title}`,\n              description: details,\n              actor,\n              entityId: task.id,\n              entityUrl: \"/tasks\",\n            });\n          }\n          break;\n      }\n    }\n  }\n\n  return events;\n}\n\n/** Extract timeline events from incident data */\nfunction eventsFromIncidents(incidents: Incident[]): TimelineEvent[] {\n  const events: TimelineEvent[] = [];\n\n  for (const inc of incidents) {\n    // Incident creation\n    events.push({\n      id: `evt-${inc.id}-created`,\n      ts: inc.opened,\n      type: \"incident_created\",\n      source: \"incident\",\n      severity: inc.severity === \"P1\" ? \"critical\" : inc.severity === \"P2\" ? \"warning\" : \"info\",\n      title: `Incident opened: ${inc.title}`,\n      description: inc.summary,\n      actor: \"system\",\n      entityId: inc.id,\n      entityUrl: \"/incidents\",\n      metadata: { severity: inc.severity },\n    });\n\n    // Timeline events\n    for (const tl of inc.timeline || []) {\n      events.push({\n        id: `evt-${inc.id}-tl-${tl.ts}`,\n        ts: tl.ts,\n        type: \"incident_status_change\",\n        source: \"incident\",\n        severity: \"info\",\n        title: `${inc.id}: ${tl.message}`,\n        description: tl.message,\n        actor: tl.actor || \"system\",\n        entityId: inc.id,\n        entityUrl: \"/incidents\",\n      });\n    }\n\n    // Resolution\n    if (inc.resolved) {\n      events.push({\n        id: `evt-${inc.id}-resolved`,\n        ts: inc.resolved,\n        type: \"incident_resolved\",\n        source: \"incident\",\n        severity: \"info\",\n        title: `Incident resolved: ${inc.title}`,\n        description: `${inc.id} resolved`,\n        actor: \"system\",\n        entityId: inc.id,\n        entityUrl: \"/incidents\",\n      });\n    }\n  }\n\n  return events;\n}\n\n/** Extract timeline events from cron data */\nfunction eventsFromCrons(crons: any[]): TimelineEvent[] {\n  const events: TimelineEvent[] = [];\n\n  for (const cron of crons) {\n    if (cron.lastError) {\n      events.push({\n        id: `evt-cron-${cron.id}-error`,\n        ts: cron.lastRun || new Date().toISOString(),\n        type: \"cron_failure\",\n        source: \"cron\",\n        severity: cron.consecutiveErrors >= 3 ? \"critical\" : \"warning\",\n        title: `Cron failed: ${cron.name}`,\n        description: cron.lastError || \"Unknown error\",\n        actor: \"system\",\n        entityId: cron.id,\n        entityUrl: \"/scheduler\",\n        metadata: {\n          consecutiveErrors: String(cron.consecutiveErrors || 1),\n          schedule: cron.schedule || \"\",\n        },\n      });\n    }\n\n    // Successful runs (only if we have a lastRun timestamp and no recent error)\n    if (cron.lastRun && !cron.lastError) {\n      events.push({\n        id: `evt-cron-${cron.id}-ok`,\n        ts: cron.lastRun,\n        type: \"cron_success\",\n        source: \"cron\",\n        severity: \"info\",\n        title: `Cron ran: ${cron.name}`,\n        description: `Scheduled: ${cron.schedule || \"unknown\"}`,\n        actor: \"system\",\n        entityId: cron.id,\n        entityUrl: \"/scheduler\",\n      });\n    }\n  }\n\n  return events;\n}\n\n// ── Public API ────────────────────────────────────────────────────────────────\n\n/** Get all timeline events, sorted newest first */\nexport function getTimelineEvents(filter?: {\n  source?: \"task\" | \"incident\" | \"cron\" | \"system\";\n  type?: TimelineEventType;\n  severity?: \"info\" | \"warning\" | \"critical\";\n  limit?: number;\n}): TimelineEvent[] {\n  const tasks = readTasks();\n  const incidents = readIncidents();\n  const crons = readCrons();\n\n  let events: TimelineEvent[] = [\n    ...eventsFromTasks(tasks),\n    ...eventsFromIncidents(incidents),\n    ...eventsFromCrons(crons),\n  ];\n\n  // Sort newest first\n  events.sort((a, b) => new Date(b.ts).getTime() - new Date(a.ts).getTime());\n\n  // Apply filters\n  if (filter?.source) events = events.filter((e) => e.source === filter.source);\n  if (filter?.type) events = events.filter((e) => e.type === filter.type);\n  if (filter?.severity) events = events.filter((e) => e.severity === filter.severity);\n  if (filter?.limit) events = events.slice(0, filter.limit);\n\n  return events;\n}\n\n/** Get timeline events for a specific incident (for the Incident detail drawer) */\nexport function getIncidentTimeline(incidentId: string): TimelineEvent[] {\n  const incidents = readIncidents();\n  const inc = incidents.find((i) => i.id === incidentId);\n  if (!inc) return [];\n\n  const events = eventsFromIncidents([inc]);\n  events.sort((a, b) => new Date(a.ts).getTime() - new Date(b.ts).getTime());\n  return events;\n}\n\n/** Get recent events (last N) for dashboard summary */\nexport function getRecentEvents(limit: number = 10): TimelineEvent[] {\n  return getTimelineEvents({ limit });\n}\n\n/** Summary counts for dashboard */\nexport function getTimelineSummary(): {\n  total: number;\n  critical: number;\n  warnings: number;\n  bySource: Record<string, number>;\n} {\n  const events = getTimelineEvents();\n  const bySource: Record<string, number> = { task: 0, incident: 0, cron: 0, system: 0 };\n  let critical = 0;\n  let warnings = 0;\n\n  for (const e of events) {\n    bySource[e.source] = (bySource[e.source] || 0) + 1;\n    if (e.severity === \"critical\") critical++;\n    if (e.severity === \"warning\") warnings++;\n  }\n\n  return { total: events.length, critical, warnings, bySource };\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/timeline-data.ts\", \"content\": \"// src/lib/server-data/timeline-data.ts\\n// Unified event model — all station events feed into a single timeline\\n\\nimport { readFileSync, existsSync } from \\\"node:fs\\\";\\nimport { join } from \\\"node:path\\\";\\nimport type { Task } from \\\"./types\\\";\\nimport type { Incident } from \\\"./types\\\";\\n\\nconst WORKSPACE = process.env.OPENCLAW_WORKSPACE || \\\"/Users/spacemonkey/.openclaw/workspace\\\";\\n\\nexport type TimelineEventType =\\n  | \\\"task_created\\\"\\n  | \\\"task_started\\\"\\n  | \\\"task_completed\\\"\\n  | \\\"task_stalled\\\"\\n  | \\\"incident_created\\\"\\n  | \\\"incident_status_change\\\"\\n  | \\\"incident_resolved\\\"\\n  | \\\"cron_success\\\"\\n  | \\\"cron_failure\\\"\\n  | \\\"system_health\\\";\\n\\nexport interface TimelineEvent {\\n  id: string;\\n  ts: string;\\n  type: TimelineEventType;\\n  source: string; // \\\"task\\\", \\\"incident\\\", \\\"cron\\\", \\\"system\\\"\\n  severity: \\\"info\\\" | \\\"warning\\\" | \\\"critical\\\";\\n  title: string;\\n  description: string;\\n  actor?: string;\\n  entityId?: string; // task ID, incident ID, etc.\\n  entityUrl?: string; // link to the related entity\\n  metadata?: Record<string, string>;\\n}\\n\\n// ── Collect events from all sources ──────────────────────────────────────────\\n\\nfunction readTasks(): Task[] {\\n  const p = join(WORKSPACE, \\\"data\\\", \\\"tasks.json\\\");\\n  if (!existsSync(p)) return [];\\n  try { return JSON.parse(readFileSync(p, \\\"utf-8\\\")); } catch { return []; }\\n}\\n\\nfunction readIncidents(): Incident[] {\\n  const p = join(WORKSPACE, \\\"data\\\", \\\"incidents.json\\\");\\n  if (!existsSync(p)) return [];\\n  try { return JSON.parse(readFileSync(p, \\\"utf-8\\\")); } catch { return []; }\\n}\\n\\nfunction readCrons(): any[] {\\n  // Read from the OpenClaw cron data file\\n  const p = join(WORKSPACE, \\\"data\\\", \\\"crons.json\\\");\\n  if (!existsSync(p)) return [];\\n  try { return JSON.parse(readFileSync(p, \\\"utf-8\\\")); } catch { return []; }\\n}\\n\\n/** Extract timeline events from task history */\\nfunction eventsFromTasks(tasks: Task[]): TimelineEvent[] {\\n  const events: TimelineEvent[] = [];\\n\\n  for (const task of tasks) {\\n    const history = task.history || [];\\n\\n    for (const entry of history) {\\n      const ts = entry.ts;\\n      const actor = entry.actor || \\\"system\\\";\\n      const details = entry.details || \\\"\\\";\\n\\n      switch (entry.action) {\\n        case \\\"created\\\":\\n          events.push({\\n            id: `evt-${task.id}-created`,\\n            ts,\\n            type: \\\"task_created\\\",\\n            source: \\\"task\\\",\\n            severity: \\\"info\\\",\\n            title: `Task created: ${task.title}`,\\n            description: details,\\n            actor,\\n            entityId: task.id,\\n            entityUrl: \\\"/tasks\\\",\\n          });\\n          break;\\n\\n        case \\\"started\\\":\\n          events.push({\\n            id: `evt-${task.id}-started`,\\n            ts,\\n            type: \\\"task_started\\\",\\n            source: \\\"task\\\",\\n            severity: \\\"info\\\",\\n            title: `Task started: ${task.title}`,\\n            description: details,\\n            actor,\\n            entityId: task.id,\\n            entityUrl: \\\"/tasks\\\",\\n          });\\n          break;\\n\\n        case \\\"completed\\\":\\n          events.push({\\n            id: `evt-${task.id}-completed`,\\n            ts,\\n            type: \\\"task_completed\\\",\\n            source: \\\"task\\\",\\n            severity: \\\"info\\\",\\n            title: `Task completed: ${task.title}`,\\n            description: details,\\n            actor,\\n            entityId: task.id,\\n            entityUrl: \\\"/tasks\\\",\\n          });\\n          break;\\n\\n        case \\\"stalled\\\":\\n          events.push({\\n            id: `evt-${task.id}-stalled`,\\n            ts,\\n            type: \\\"task_stalled\\\",\\n            source: \\\"task\\\",\\n            severity: \\\"warning\\\",\\n            title: `Task stalled: ${task.title}`,\\n            description: details,\\n            actor,\\n            entityId: task.id,\\n            entityUrl: \\\"/tasks\\\",\\n          });\\n          break;\\n\\n        case \\\"reassigned\\\":\\n          // Only include triage-related reassignments\\n          if (details.toLowerCase().includes(\\\"triage\\\")) {\\n            events.push({\\n              id: `evt-${task.id}-triage-${ts}`,\\n              ts,\\n              type: \\\"task_stalled\\\",\\n              source: \\\"task\\\",\\n              severity: \\\"warning\\\",\\n              title: `Task moved to triage: ${task.title}`,\\n              description: details,\\n              actor,\\n              entityId: task.id,\\n              entityUrl: \\\"/tasks\\\",\\n            });\\n          }\\n          break;\\n      }\\n    }\\n  }\\n\\n  return events;\\n}\\n\\n/** Extract timeline events from incident data */\\nfunction eventsFromIncidents(incidents: Incident[]): TimelineEvent[] {\\n  const events: TimelineEvent[] = [];\\n\\n  for (const inc of incidents) {\\n    // Incident creation\\n    events.push({\\n      id: `evt-${inc.id}-created`,\\n      ts: inc.opened,\\n      type: \\\"incident_created\\\",\\n      source: \\\"incident\\\",\\n      severity: inc.severity === \\\"P1\\\" ? \\\"critical\\\" : inc.severity === \\\"P2\\\" ? \\\"warning\\\" : \\\"info\\\",\\n      title: `Incident opened: ${inc.title}`,\\n      description: inc.summary,\\n      actor: \\\"system\\\",\\n      entityId: inc.id,\\n      entityUrl: \\\"/incidents\\\",\\n      metadata: { severity: inc.severity },\\n    });\\n\\n    // Timeline events\\n    for (const tl of inc.timeline || []) {\\n      events.push({\\n        id: `evt-${inc.id}-tl-${tl.ts}`,\\n        ts: tl.ts,\\n        type: \\\"incident_status_change\\\",\\n        source: \\\"incident\\\",\\n        severity: \\\"info\\\",\\n        title: `${inc.id}: ${tl.message}`,\\n        description: tl.message,\\n        actor: tl.actor || \\\"system\\\",\\n        entityId: inc.id,\\n        entityUrl: \\\"/incidents\\\",\\n      });\\n    }\\n\\n    // Resolution\\n    if (inc.resolved) {\\n      events.push({\\n        id: `evt-${inc.id}-resolved`,\\n        ts: inc.resolved,\\n        type: \\\"incident_resolved\\\",\\n        source: \\\"incident\\\",\\n        severity: \\\"info\\\",\\n        title: `Incident resolved: ${inc.title}`,\\n        description: `${inc.id} resolved`,\\n        actor: \\\"system\\\",\\n        entityId: inc.id,\\n        entityUrl: \\\"/incidents\\\",\\n      });\\n    }\\n  }\\n\\n  return events;\\n}\\n\\n/** Extract timeline events from cron data */\\nfunction eventsFromCrons(crons: any[]): TimelineEvent[] {\\n  const events: TimelineEvent[] = [];\\n\\n  for (const cron of crons) {\\n    if (cron.lastError) {\\n      events.push({\\n        id: `evt-cron-${cron.id}-error`,\\n        ts: cron.lastRun || new Date().toISOString(),\\n        type: \\\"cron_failure\\\",\\n        source: \\\"cron\\\",\\n        severity: cron.consecutiveErrors >= 3 ? \\\"critical\\\" : \\\"warning\\\",\\n        title: `Cron failed: ${cron.name}`,\\n        description: cron.lastError || \\\"Unknown error\\\",\\n        actor: \\\"system\\\",\\n        entityId: cron.id,\\n        entityUrl: \\\"/scheduler\\\",\\n        metadata: {\\n          consecutiveErrors: String(cron.consecutiveErrors || 1),\\n          schedule: cron.schedule || \\\"\\\",\\n        },\\n      });\\n    }\\n\\n    // Successful runs (only if we have a lastRun timestamp and no recent error)\\n    if (cron.lastRun && !cron.lastError) {\\n      events.push({\\n        id: `evt-cron-${cron.id}-ok`,\\n        ts: cron.lastRun,\\n        type: \\\"cron_success\\\",\\n        source: \\\"cron\\\",\\n        severity: \\\"info\\\",\\n        title: `Cron ran: ${cron.name}`,\\n        description: `Scheduled: ${cron.schedule || \\\"unknown\\\"}`,\\n        actor: \\\"system\\\",\\n        entityId: cron.id,\\n        entityUrl: \\\"/scheduler\\\",\\n      });\\n    }\\n  }\\n\\n  return events;\\n}\\n\\n// ── Public API ────────────────────────────────────────────────────────────────\\n\\n/** Get all timeline events, sorted newest first */\\nexport function getTimelineEvents(filter?: {\\n  source?: \\\"task\\\" | \\\"incident\\\" | \\\"cron\\\" | \\\"system\\\";\\n  type?: TimelineEventType;\\n  severity?: \\\"info\\\" | \\\"warning\\\" | \\\"critical\\\";\\n  limit?: number;\\n}): TimelineEvent[] {\\n  const tasks = readTasks();\\n  const incidents = readIncidents();\\n  const crons = readCrons();\\n\\n  let events: TimelineEvent[] = [\\n    ...eventsFromTasks(tasks),\\n    ...eventsFromIncidents(incidents),\\n    ...eventsFromCrons(crons),\\n  ];\\n\\n  // Sort newest first\\n  events.sort((a, b) => new Date(b.ts).getTime() - new Date(a.ts).getTime());\\n\\n  // Apply filters\\n  if (filter?.source) events = events.filter((e) => e.source === filter.source);\\n  if (filter?.type) events = events.filter((e) => e.type === filter.type);\\n  if (filter?.severity) events = events.filter((e) => e.severity === filter.severity);\\n  if (filter?.limit) events = events.slice(0, filter.limit);\\n\\n  return events;\\n}\\n\\n/** Get timeline events for a specific incident (for the Incident detail drawer) */\\nexport function getIncidentTimeline(incidentId: string): TimelineEvent[] {\\n  const incidents = readIncidents();\\n  const inc = incidents.find((i) => i.id === incidentId);\\n  if (!inc) return [];\\n\\n  const events = eventsFromIncidents([inc]);\\n  events.sort((a, b) => new Date(a.ts).getTime() - new Date(b.ts).getTime());\\n  return events;\\n}\\n\\n/** Get recent events (last N) for dashboard summary */\\nexport function getRecentEvents(limit: number = 10): TimelineEvent[] {\\n  return getTimelineEvents({ limit });\\n}\\n\\n/** Summary counts for dashboard */\\nexport function getTimelineSummary(): {\\n  total: number;\\n  critical: number;\\n  warnings: number;\\n  bySource: Record<string, number>;\\n} {\\n  const events = getTimelineEvents();\\n  const bySource: Record<string, number> = { task: 0, incident: 0, cron: 0, system: 0 };\\n  let critical = 0;\\n  let warnings = 0;\\n\\n  for (const e of events) {\\n    bySource[e.source] = (bySource[e.source] || 0) + 1;\\n    if (e.severity === \\\"critical\\\") critical++;\\n    if (e.severity === \\\"warning\\\") warnings++;\\n  }\\n\\n  return { total: events.length, critical, warnings, bySource };\\n}\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":327,"output":2304,"cacheRead":155264,"cacheWrite":0,"reasoningTokens":0,"totalTokens":157895,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780522017728,"responseId":"gen-1780522017-YVnXC18SCcRcITpGkrVY"}}
