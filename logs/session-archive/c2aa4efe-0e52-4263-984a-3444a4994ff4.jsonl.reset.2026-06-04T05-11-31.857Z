{"type":"message","id":"ab83b1d0","parentId":"9792529d","timestamp":"2026-06-03T22:23:08.223Z","message":{"role":"assistant","content":[{"type":"text","text":"I need to add the Runbook section before the Linked Tasks section. Let me find where linked tasks starts and add the runbook panel above it:"},{"type":"toolCall","id":"3e3b88d8-b716-4f66-aa1b-09e113d1f4d4","name":"edit","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/components/IncidentDetailsDrawer.tsx","edits":[{"oldText":"        {/* Linked Tasks / Operational Work — derived from Task.linkedIncidentId */}","newText":"        {/* Runbook — matched by incident type/title */}\n        {(() => {\n          // Match runbook by incident tags, title, or type field\n          const incidentType = (incident as any).type || \"\";\n          const runbook = getRunbookForIncident(incidentType) || getRunbookForIncident(incident.title);\n          if (!runbook) return null;\n          return (\n            <div className=\"mt-6 mb-6\">\n              <h3 className=\"font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground/70 flex items-center gap-1.5\">\n                <ListChecks className=\"h-3.5 w-3.5\" />\n                Response Runbook\n              </h3>\n              <p className=\"mt-1 text-xs text-muted-foreground/60\">\n                {runbook.steps.length} steps · est. {runbook.totalEstimatedMinutes} min · {runbook.severity} severity\n              </p>\n              <div className=\"mt-3 space-y-2\">\n                {runbook.steps.map((step, idx) => (\n                  <div key={step.order} className=\"rounded-lg border border-border/60 bg-card/20 p-3\">\n                    <div className=\"flex items-start gap-2\">\n                      <span className=\"font-mono text-[10px] text-violet bg-violet/10 rounded px-1.5 py-0.5 shrink-0 mt-0.5\">\n                        {step.order}\n                      </span>\n                      <div className=\"min-w-0 flex-1\">\n                        <div className=\"flex items-center justify-between gap-2\">\n                          <span className=\"text-sm font-medium\">{step.title}</span>\n                          <span className=\"font-mono text-[10px] text-muted-foreground shrink-0\">{step.estimatedMinutes}m · {step.owner}</span>\n                        </div>\n                        <p className=\"mt-1 text-xs text-muted-foreground/70\">{step.description}</p>\n                        <div className=\"mt-1.5 flex items-center gap-1\">\n                          <CheckCircle2 className=\"h-3 w-3 text-[oklch(0.88_0.18_145)]/50\" />\n                          <span className=\"text-[10px] text-muted-foreground/50\">{step.successCriteria}</span>\n                        </div>\n                        {step.escalationTrigger && (\n                          <div className=\"mt-1 flex items-center gap-1\">\n                            <AlertTriangle className=\"h-3 w-3 text-amber-500/50\" />\n                            <span className=\"text-[10px] text-amber-500/70\">Escalate: {step.escalationTrigger}</span>\n                          </div>\n                        )}\n                      </div>\n                    </div>\n                  </div>\n                ))}\n              </div>\n              <p className=\"mt-2 text-[10px] text-muted-foreground/40 italic\">Escalation: {runbook.escalationPath}</p>\n            </div>\n          );\n        })()}\n\n        {/* Linked Tasks / Operational Work — derived from Task.linkedIncidentId */}"}]},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/components/IncidentDetailsDrawer.tsx\", \"edits\": [{\"oldText\": \"        {/* Linked Tasks / Operational Work — derived from Task.linkedIncidentId */}\", \"newText\": \"        {/* Runbook — matched by incident type/title */}\\n        {(() => {\\n          // Match runbook by incident tags, title, or type field