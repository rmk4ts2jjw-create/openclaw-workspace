{"type":"message","id":"c2dbceb3","parentId":"852175d1","timestamp":"2026-06-03T22:23:08.223Z","message":{"role":"assistant","content":[{"type":"text","text":"Now let me design and implement the runbook data model. I'll create a TypeScript type definition and a JSON data file with initial runbooks:"},{"type":"toolCall","id":"d2c5b178-488b-4b5f-9128-d2ebbd60bd16","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/runbooks.ts","content":"// src/lib/server-data/runbooks.ts\n// Structured data model for incident response runbooks\n\nexport type IncidentType =\n  | \"cron-failure\"\n  | \"rate-limit\"\n  | \"service-down\"\n  | \"dependency-break\"\n  | \"vite-cache\"\n  | \"disk-space\"\n  | \"network\"\n  | \"unknown\";\n\nexport type RunbookSeverity = \"P1\" | \"P2\" | \"P3\" | \"P4\";\n\nexport interface RunbookStep {\n  order: number;\n  title: string;\n  description: string;\n  estimatedMinutes: number;\n  owner: string; // role: \"monkey\" | \"lifesupport\" | \"engineer\" | \"archivist\" | \"andre\"\n  successCriteria: string;\n  escalationTrigger?: string; // if this step fails, escalate\n}\n\nexport interface Runbook {\n  id: string;\n  incidentType: IncidentType;\n  label: string;\n  severity: RunbookSeverity;\n  steps: RunbookStep[];\n  totalEstimatedMinutes: number;\n  requiredRoles: string[];\n  escalationPath: string; // who to contact if runbook steps are insufficient\n  lastUpdated: string;\n  version: number;\n}\n\n// Default runbooks — these are advisory. Incident response is always context-dependent.\nexport const RUNBOOKS: Runbook[] = [\n  {\n    id: \"rb-cron-failure\",\n    incidentType: \"cron-failure\",\n    label: \"Cron Job Failure\",\n    severity: \"P2\",\n    totalEstimatedMinutes: 15,\n    requiredRoles: [\"monkey\", \"lifesupport\"],\n    escalationPath: \"If cron fails 3+ consecutive times, escalate to Andre for manual review.\",\n    lastUpdated: \"2026-06-03T00:00:00Z\",\n    version: 1,\n    steps: [\n      {\n        order: 1,\n        title: \"Identify failing cron job\",\n        description: \"Check the Scheduler page or /api/crons endpoint to identify which cron job failed. Note the error message and consecutive failure count.\",\n        estimatedMinutes: 2,\n        owner: \"monkey\",\n        successCriteria: \"Failing cron job identified with error message\",\n        escalationTrigger: \"Cannot identify which cron job failed\",\n      },\n      {\n        order: 2,\n        title: \"Check recent logs\",\n        description: \"Review the cron job's recent execution history for patterns. Check if this is a first-time failure or recurring.\",\n        estimatedMinutes: 3,\n        owner: \"monkey\",\n        successCriteria: \"Failure pattern identified (one-time vs recurring)\",\n        escalationTrigger: \"Error is cryptic or has no known fix pattern\",\n      },\n      {\n        order: 3,\n        title: \"Apply standard fix\",\n        description: \"For timeouts: check if the job duration exceeds limits. For rate limits: check model/API availability. For script errors: check the underlying script.\",\n        estimatedMinutes: 8,\n        owner: \"lifesupport\",\n        successCriteria: \"Fix applied and verified\",\n        escalationTrigger: \"Standard fix does not work after one attempt\",\n      },\n      {\n        order: 4,\n        title: \"Verify recovery\",\n        description: \"Run the cron job manually if possible, or wait for the next scheduled run. Confirm it succeeds.\",\n        estimatedMinutes: 2,\n        owner: \"monkey\",\n        successCriteria: \"Cron job runs successfully on next execution\",\n      },\n    ],\n  },\n  {\n    id: \"rb-rate-limit\",\n    incidentType: \"rate-limit\",\n    label: \"Rate Limit Exhaustion (429)\",\n    severity: \"P2\",\n    totalEstimatedMinutes: 10,\n    requiredRoles: [\"monkey\"],\n    escalationPath: \"If rate limits persist after switching models, escalate to Andre to add OpenRouter credits.\",\n    lastUpdated: \"2026-06-03T00:00:00Z\",\n    version: 1,\n    steps: [\n      {\n        order: 1,\n        title: \"Confirm rate limit\",\n        description: \"Check error feed for 429 errors. Note which model(s) are affected and the error rate.\",\n        estimatedMinutes: 1,\n        owner: \"monkey\",\n        successCriteria: \"Rate limit confirmed — model(s) identified\",\n      },\n      {\n        order: 2,\n        title: \"Switch to fallback model\",\n        description: \"If primary model is rate-limited, activate fallback model for affected operations.\",\n        estimatedMinutes: 3,\n        owner: \"monkey\",\n        successCriteria: \"Fallback model serving requests\",\n        escalationTrigger: \"All fallback models also rate-limited\",\n      },\n      {\n        order: 3,\n        title: \"Pause non-critical crons\",\n        description: \"Disable cron jobs that use the affected model tier until rate limit resets. Prioritize critical infrastructure checks.\",\n        estimatedMinutes: 3,\n        owner: \"monkey\",\n        successCriteria: \"Non-critical crons paused, critical crons on fallback\",\n      },\n      {\n        order: 4,\n        title: \"Monitor recovery\",\n        description: \"Wait for rate limit window to reset (typically 1 minute or 24 hours depending on tier). Gradually restore paused jobs.\",\n        estimatedMinutes: 3,\n        owner: \"monkey\",\n        successCriteria: \"All cron jobs restored and running normally\",\n      },\n    ],\n  },\n  {\n    id: \"rb-vite-cache\",\n    incidentType: \"vite-cache\",\n    label: \"Vite Cache Corruption\",\n    severity: \"P3\",\n    totalEstimatedMinutes: 5,\n    requiredRoles: [\"lifesupport\"],\n    escalationPath: \"If clearing cache doesn't fix the issue, may be a dependency problem. Escalate to Andre.\",\n    lastUpdated: \"2026-06-03T00:00:00Z\",\n    version: 1,\n    steps: [\n      {\n        order: 1,\n        title: \"Verify corruption\",\n        description: \"Check if Mission Control returns 504 (Outdated Optimize Dep) or similar Vite cache errors on port 3000.\",\n        estimatedMinutes: 1,\n        owner: \"lifesupport\",\n        successCriteria: \"Vite cache error confirmed\",\n      },\n      {\n        order: 2,\n        title: \"Clear Vite cache\",\n        description: \"Run `rm -rf node_modules/.vite .vite` in the mission-control-dashboard directory, then restart Vite with `bun run dev --host --port 3000`.\",\n        estimatedMinutes: 3,\n        owner: \"lifesupport\",\n        successCriteria: \"Vite restarted, cache cleared\",\n      },\n      {\n        order: 3,\n        title: \"Verify fix\",\n        description: \"Confirm Mission Control loads on port 3000 and returns HTTP 200.\",\n        estimatedMinutes: 1,\n        owner: \"lifesupport\",\n        successCriteria: \"App loads cleanly, no cache errors\",\n      },\n    ],\n  },\n  {\n    id: \"rb-service-down\",\n    incidentType: \"service-down\",\n    label: \"Service Down\",\n    severity: \"P1\",\n    totalEstimatedMinutes: 20,\n    requiredRoles: [\"lifesupport\", \"monkey\"],\n    escalationPath: \"If critical service (gateway, MC dashboard) cannot be restored in 30 min, Andre is awake.\",\n    lastUpdated: \"2026-06-03T00:00:00Z\",\n    version: 1,\n    steps: [\n      {\n        order: 1,\n        title: \"Identify affected service\",\n        description: \"Determine which service is down: OpenClaw gateway, Mission Control dashboard, or external dependency.\",\n        estimatedMinutes: 2,\n        owner: \"lifesupport\",\n        successCriteria: \"Affected service identified\",\n        escalationTrigger: \"Cannot determine which service is affected\",\n      },\n      {\n        order: 2,\n        title: \"Check process status\",\n        description: \"Use `openclaw status` for gateway, `curl localhost:3000` for MC, `ps aux | grep vite` for dev server.\",\n        estimatedMinutes: 3,\n        owner: \"lifesupport\",\n        successCriteria: \"Process status determined (running, crashed, or zombie)\",\n      },\n      {\n        order: 3,\n        title: \"Restart service\",\n        description: \"Gateway: `openclaw gateway restart`. MC: kill stale Vite process and relaunch. Document what killed it.\",\n        estimatedMinutes: 5,\n        owner: \"lifesupport\",\n        successCriteria: \"Service restarted and responding\",\n        escalationTrigger: \"Service fails to restart or crashes immediately\",\n      },\n      {\n        order: 4,\n        title: \"Root cause check\",\n        description: \"Check if OOM, disk full, or dependency change caused the crash. Update health-log.md.\",\n        estimatedMinutes: 7,\n        owner: \"monkey\",\n        successCriteria: \"Root cause identified or marked as intermittent\",\n      },\n      {\n        order: 5,\n        title: \"Verify stability\",\n        description: \"Monitor the service for 5 minutes to confirm it stays up. Verify dependent services are also functional.\",\n        estimatedMinutes: 3,\n        owner: \"lifesupport\",\n        successCriteria: \"Service stable for 5+ minutes\",\n      },\n    ],\n  },\n  {\n    id: \"rb-disk-space\",\n    incidentType: \"disk-space\",\n    label: \"Disk Space Low\",\n    severity: \"P2\",\n    totalEstimatedMinutes: 15,\n    requiredRoles: [\"lifesupport\", \"monkey\"],\n    escalationPath: \"If disk is critically full (>95%) and cleanup doesn't free enough space, escalate to Andre.\",\n    lastUpdated: \"2026-06-03T00:00:00Z\",\n    version: 1,\n    steps: [\n      {\n        order: 1,\n        title: \"Check disk usage\",\n        description: \"Run `df -h` to check disk usage. Identify which partition is full.\",\n        estimatedMinutes: 1,\n        owner: \"lifesupport\",\n        successCriteria: \"Disk usage confirmed, partition identified\",\n      },\n      {\n        order: 2,\n        title: \"Find large files/directories\",\n        description: \"Run `du -sh /* 2>/dev/null | sort -rh | head -20` to find space hogs.\",\n        estimatedMinutes: 3,\n        owner: \"lifesupport\",\n        successCriteria: \"Largest consumers identified\",\n      },\n      {\n        order: 3,\n        title: \"Safe cleanup\",\n        description: \"Clear stale logs, node_modules in deleted projects, old backups, Vite cache. Never delete without Andre: workspace files, .openclaw config.\",\n        estimatedMinutes: 10,\n        owner: \"monkey\",\n        successCriteria: \"Disk usage below 85%\",\n        escalationTrigger: \"Cannot free enough space with safe cleanup alone\",\n      },\n      {\n        order: 4,\n        title: \"Verify and log\",\n        description: \"Confirm disk is healthy. Update health-log.md with what was cleaned.\",\n        estimatedMinutes: 1,\n        owner: \"monkey\",\n        successCriteria: \"Disk healthy, cleanup logged\",\n      },\n    ],\n  },\n];\n\n/** Look up the best matching runbook for an incident type */\nexport function getRunbookForIncident(incidentType: string): Runbook | undefined {\n  // Direct match\n  const direct = RUNBOOKS.find((r) => r.incidentType === incidentType);\n  if (direct) return direct;\n\n  // Fuzzy match by label\n  const lower = incidentType.toLowerCase();\n  const fuzzy = RUNBOOKS.find(\n    (r) =>\n      lower.includes(r.incidentType) ||\n      r.incidentType.includes(lower) ||\n      lower.includes(r.label.toLowerCase())\n  );\n  if (fuzzy) return fuzzy;\n\n  return undefined;\n}\n\n/** Get all runbooks matching a severity level */\nexport function getRunbooksBySeverity(severity: RunbookSeverity): Runbook[] {\n  return RUNBOOKS.filter((r) => r.severity === severity);\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/runbooks.ts\", \"content\": \"// src/lib/server-data/runbooks.ts\\n// Structured data model for incident response runbooks\\n\\nexport type IncidentType =\\n  | \\\"cron-failure\\\"\\n  | \\\"rate-limit\\\"\\n  | \\\"service-down\\\"\\n  | \\\"dependency-break\\\"\\n  | \\\"vite-cache\\\"\\n  | \\\"disk-space\\\"\\n  | \\\"network\\\"\\n  | \\\"unknown\\\";\\n\\nexport type RunbookSeverity = \\\"P1\\\" | \\\"P2\\\" | \\\"P3\\\" | \\\"P4\\\";\\n\\nexport interface RunbookStep {\\n  order: number;\\n  title: string;\\n  description: string;\\n  estimatedMinutes: number;\\n  owner: string; // role: \\\"monkey\\\" | \\\"lifesupport\\\" | \\\"engineer\\\" | \\\"archivist\\\" | \\\"andre\\\"\\n  successCriteria: string;\\n  escalationTrigger?: string; // if this step fails, escalate\\n}\\n\\nexport interface Runbook {\\n  id: string;\\n  incidentType: IncidentType;\\n  label: string;\\n  severity: RunbookSeverity;\\n  steps: RunbookStep[];\\n  totalEstimatedMinutes: number;\\n  requiredRoles: string[];\\n  escalationPath: string; // who to contact if runbook steps are insufficient\\n  lastUpdated: string;\\n  version: number;\\n}\\n\\n// Default runbooks — these are advisory. Incident response is always context-dependent.\\nexport const RUNBOOKS: Runbook[] = [\\n  {\\n    id: \\\"rb-cron-failure\\\",\\n    incidentType: \\\"cron-failure\\\",\\n    label: \\\"Cron Job Failure\\\",\\n    severity: \\\"P2\\\",\\n    totalEstimatedMinutes: 15,\\n    requiredRoles: [\\\"monkey\\\", \\\"lifesupport\\\"],\\n    escalationPath: \\\"If cron fails 3+ consecutive times, escalate to Andre for manual review.\\\",\\n    lastUpdated: \\\"2026-06-03T00:00:00Z\\\",\\n    version: 1,\\n    steps: [\\n      {\\n        order: 1,\\n        title: \\\"Identify failing cron job\\\",\\n        description: \\\"Check the Scheduler page or /api/crons endpoint to identify which cron job failed. Note the error message and consecutive failure count.\\\",\\n        estimatedMinutes: 2,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Failing cron job identified with error message\\\",\\n        escalationTrigger: \\\"Cannot identify which cron job failed\\\",\\n      },\\n      {\\n        order: 2,\\n        title: \\\"Check recent logs\\\",\\n        description: \\\"Review the cron job's recent execution history for patterns. Check if this is a first-time failure or recurring.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Failure pattern identified (one-time vs recurring)\\\",\\n        escalationTrigger: \\\"Error is cryptic or has no known fix pattern\\\",\\n      },\\n      {\\n        order: 3,\\n        title: \\\"Apply standard fix\\\",\\n        description: \\\"For timeouts: check if the job duration exceeds limits. For rate limits: check model/API availability. For script errors: check the underlying script.\\\",\\n        estimatedMinutes: 8,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Fix applied and verified\\\",\\n        escalationTrigger: \\\"Standard fix does not work after one attempt\\\",\\n      },\\n      {\\n        order: 4,\\n        title: \\\"Verify recovery\\\",\\n        description: \\\"Run the cron job manually if possible, or wait for the next scheduled run. Confirm it succeeds.\\\",\\n        estimatedMinutes: 2,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Cron job runs successfully on next execution\\\",\\n      },\\n    ],\\n  },\\n  {\\n    id: \\\"rb-rate-limit\\\",\\n    incidentType: \\\"rate-limit\\\",\\n    label: \\\"Rate Limit Exhaustion (429)\\\",\\n    severity: \\\"P2\\\",\\n    totalEstimatedMinutes: 10,\\n    requiredRoles: [\\\"monkey\\\"],\\n    escalationPath: \\\"If rate limits persist after switching models, escalate to Andre to add OpenRouter credits.\\\",\\n    lastUpdated: \\\"2026-06-03T00:00:00Z\\\",\\n    version: 1,\\n    steps: [\\n      {\\n        order: 1,\\n        title: \\\"Confirm rate limit\\\",\\n        description: \\\"Check error feed for 429 errors. Note which model(s) are affected and the error rate.\\\",\\n        estimatedMinutes: 1,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Rate limit confirmed — model(s) identified\\\",\\n      },\\n      {\\n        order: 2,\\n        title: \\\"Switch to fallback model\\\",\\n        description: \\\"If primary model is rate-limited, activate fallback model for affected operations.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Fallback model serving requests\\\",\\n        escalationTrigger: \\\"All fallback models also rate-limited\\\",\\n      },\\n      {\\n        order: 3,\\n        title: \\\"Pause non-critical crons\\\",\\n        description: \\\"Disable cron jobs that use the affected model tier until rate limit resets. Prioritize critical infrastructure checks.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Non-critical crons paused, critical crons on fallback\\\",\\n      },\\n      {\\n        order: 4,\\n        title: \\\"Monitor recovery\\\",\\n        description: \\\"Wait for rate limit window to reset (typically 1 minute or 24 hours depending on tier). Gradually restore paused jobs.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"All cron jobs restored and running normally\\\",\\n      },\\n    ],\\n  },\\n  {\\n    id: \\\"rb-vite-cache\\\",\\n    incidentType: \\\"vite-cache\\\",\\n    label: \\\"Vite Cache Corruption\\\",\\n    severity: \\\"P3\\\",\\n    totalEstimatedMinutes: 5,\\n    requiredRoles: [\\\"lifesupport\\\"],\\n    escalationPath: \\\"If clearing cache doesn't fix the issue, may be a dependency problem. Escalate to Andre.\\\",\\n    lastUpdated: \\\"2026-06-03T00:00:00Z\\\",\\n    version: 1,\\n    steps: [\\n      {\\n        order: 1,\\n        title: \\\"Verify corruption\\\",\\n        description: \\\"Check if Mission Control returns 504 (Outdated Optimize Dep) or similar Vite cache errors on port 3000.\\\",\\n        estimatedMinutes: 1,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Vite cache error confirmed\\\",\\n      },\\n      {\\n        order: 2,\\n        title: \\\"Clear Vite cache\\\",\\n        description: \\\"Run `rm -rf node_modules/.vite .vite` in the mission-control-dashboard directory, then restart Vite with `bun run dev --host --port 3000`.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Vite restarted, cache cleared\\\",\\n      },\\n      {\\n        order: 3,\\n        title: \\\"Verify fix\\\",\\n        description: \\\"Confirm Mission Control loads on port 3000 and returns HTTP 200.\\\",\\n        estimatedMinutes: 1,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"App loads cleanly, no cache errors\\\",\\n      },\\n    ],\\n  },\\n  {\\n    id: \\\"rb-service-down\\\",\\n    incidentType: \\\"service-down\\\",\\n    label: \\\"Service Down\\\",\\n    severity: \\\"P1\\\",\\n    totalEstimatedMinutes: 20,\\n    requiredRoles: [\\\"lifesupport\\\", \\\"monkey\\\"],\\n    escalationPath: \\\"If critical service (gateway, MC dashboard) cannot be restored in 30 min, Andre is awake.\\\",\\n    lastUpdated: \\\"2026-06-03T00:00:00Z\\\",\\n    version: 1,\\n    steps: [\\n      {\\n        order: 1,\\n        title: \\\"Identify affected service\\\",\\n        description: \\\"Determine which service is down: OpenClaw gateway, Mission Control dashboard, or external dependency.\\\",\\n        estimatedMinutes: 2,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Affected service identified\\\",\\n        escalationTrigger: \\\"Cannot determine which service is affected\\\",\\n      },\\n      {\\n        order: 2,\\n        title: \\\"Check process status\\\",\\n        description: \\\"Use `openclaw status` for gateway, `curl localhost:3000` for MC, `ps aux | grep vite` for dev server.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Process status determined (running, crashed, or zombie)\\\",\\n      },\\n      {\\n        order: 3,\\n        title: \\\"Restart service\\\",\\n        description: \\\"Gateway: `openclaw gateway restart`. MC: kill stale Vite process and relaunch. Document what killed it.\\\",\\n        estimatedMinutes: 5,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Service restarted and responding\\\",\\n        escalationTrigger: \\\"Service fails to restart or crashes immediately\\\",\\n      },\\n      {\\n        order: 4,\\n        title: \\\"Root cause check\\\",\\n        description: \\\"Check if OOM, disk full, or dependency change caused the crash. Update health-log.md.\\\",\\n        estimatedMinutes: 7,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Root cause identified or marked as intermittent\\\",\\n      },\\n      {\\n        order: 5,\\n        title: \\\"Verify stability\\\",\\n        description: \\\"Monitor the service for 5 minutes to confirm it stays up. Verify dependent services are also functional.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Service stable for 5+ minutes\\\",\\n      },\\n    ],\\n  },\\n  {\\n    id: \\\"rb-disk-space\\\",\\n    incidentType: \\\"disk-space\\\",\\n    label: \\\"Disk Space Low\\\",\\n    severity: \\\"P2\\\",\\n    totalEstimatedMinutes: 15,\\n    requiredRoles: [\\\"lifesupport\\\", \\\"monkey\\\"],\\n    escalationPath: \\\"If disk is critically full (>95%) and cleanup doesn't free enough space, escalate to Andre.\\\",\\n    lastUpdated: \\\"2026-06-03T00:00:00Z\\\",\\n    version: 1,\\n    steps: [\\n      {\\n        order: 1,\\n        title: \\\"Check disk usage\\\",\\n        description: \\\"Run `df -h` to check disk usage. Identify which partition is full.\\\",\\n        estimatedMinutes: 1,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Disk usage confirmed, partition identified\\\",\\n      },\\n      {\\n        order: 2,\\n        title: \\\"Find large files/directories\\\",\\n        description: \\\"Run `du -sh /* 2>/dev/null | sort -rh | head -20` to find space hogs.\\\",\\n        estimatedMinutes: 3,\\n        owner: \\\"lifesupport\\\",\\n        successCriteria: \\\"Largest consumers identified\\\",\\n      },\\n      {\\n        order: 3,\\n        title: \\\"Safe cleanup\\\",\\n        description: \\\"Clear stale logs, node_modules in deleted projects, old backups, Vite cache. Never delete without Andre: workspace files, .openclaw config.\\\",\\n        estimatedMinutes: 10,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Disk usage below 85%\\\",\\n        escalationTrigger: \\\"Cannot free enough space with safe cleanup alone\\\",\\n      },\\n      {\\n        order: 4,\\n        title: \\\"Verify and log\\\",\\n        description: \\\"Confirm disk is healthy. Update health-log.md with what was cleaned.\\\",\\n        estimatedMinutes: 1,\\n        owner: \\\"monkey\\\",\\n        successCriteria: \\\"Disk healthy, cleanup logged\\\",\\n      },\\n    ],\\n  },\\n];\\n\\n/** Look up the best matching runbook for an incident type */\\nexport function getRunbookForIncident(incidentType: string): Runbook | undefined {\\n  // Direct match\\n  const direct = RUNBOOKS.find((r) => r.incidentType === incidentType);\\n  if (direct) return direct;\\n\\n  // Fuzzy match by label\\n  const lower = incidentType.toLowerCase();\\n  const fuzzy = RUNBOOKS.find(\\n    (r) =>\\n      lower.includes(r.incidentType) ||\\n      r.incidentType.includes(lower) ||\\n      lower.includes(r.label.toLowerCase())\\n  );\\n  if (fuzzy) return fuzzy;\\n\\n  return undefined;\\n}\\n\\n/** Get all runbooks matching a severity level */\\nexport function getRunbooksBySeverity(severity: RunbookSeverity): Runbook[] {\\n  return RUNBOOKS.filter((r) => r.severity === severity);\\n}\\n\"}"}],"api":"openai-