{"type":"message","id":"25cd524d","parentId":"b773ff08","timestamp":"2026-06-03T19:29:18.474Z","message":{"role":"assistant","content":[{"type":"text","text":"I'll implement auto-remediation as a module that the heartbeat can call. It checks for known failure patterns and applies fixes:"},{"type":"toolCall","id":"2ebe4371-b84d-46c6-87cb-81481d550686","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/auto-remediation.ts","content":"// src/lib/server-data/auto-remediation.ts\n// Predefined remediation actions for common failure patterns\n\nexport interface RemediationRule {\n  id: string;\n  label: string;\n  description: string;\n  /** Check if this rule applies to the given error/title */\n  matches: (title: string, error: string) => boolean;\n  /** Execute the remediation. Returns a summary of what was done. */\n  execute: () => Promise<RemediationResult>;\n  /** Whether this rule requires Andre's approval before executing */\n  requiresApproval: boolean;\n}\n\nexport interface RemediationResult {\n  ruleId: string;\n  success: boolean;\n  action: string;\n  detail: string;\n}\n\n// ── Rules ────────────────────────────────────────────────────────────────────\n\nconst RULES: RemediationRule[] = [\n  {\n    id: \"vite-cache-corruption\",\n    label: \"Vite Cache Corruption\",\n    description: \"Clear Vite cache and restart dev server when 504/optimize-dep errors detected\",\n    matches: (title, error) => {\n      const text = `${title} ${error}`.toLowerCase();\n      return (\n        (text.includes(\"vite\") || text.includes(\"504\") || text.includes(\"outdated optimize\")) &&\n        (text.includes(\"cache\") || text.includes(\"corrupt\") || text.includes(\"dep\"))\n      );\n    },\n    requiresApproval: false,\n    execute: async (): Promise<RemediationResult> => {\n      const { execSync } = await import(\"child_process\");\n      try {\n        const mcDir = \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard\";\n        // Clear Vite cache\n        execSync(`cd ${mcDir} && rm -rf node_modules/.vite .vite`, { timeout: 10000 });\n        // Kill existing Vite process\n        try {\n          execSync(\"pkill -f 'vite dev' 2>/dev/null || true\", { timeout: 5000 });\n        } catch { /* ignore if no process */ }\n        // Restart Vite\n        execSync(`cd ${mcDir} && nohup bun run dev --host --port 3000 > /tmp/mc-dev.log 2>&1 &`, {\n          timeout: 5000,\n          detached: true,\n        });\n        // Wait and verify\n        await new Promise((r) => setTimeout(r, 3000));\n        const http = await import(\"http\");\n        const ok = await new Promise<boolean>((resolve) => {\n          const req = http.get(\"http://localhost:3000/\", (res) => {\n            resolve(res.statusCode === 200);\n          });\n          req.on(\"error\", () => resolve(false));\n          req.setTimeout(3000, () => { req.destroy(); resolve(false); });\n        });\n        return {\n          ruleId: \"vite-cache-corruption\",\n          success: ok,\n          action: \"Cleared Vite cache and restarted dev server\",\n          detail: ok ? \"MC dashboard responding 200 on port 3000\" : \"MC dashboard not responding after restart\",\n        };\n      } catch (err) {\n        return {\n          ruleId: \"vite-cache-corruption\",\n          success: false,\n          action: \"Attempted Vite cache clear + restart\",\n          detail: `Error: ${String(err)}`,\n        };\n      }\n    },\n  },\n  {\n    id: \"cron-timeout-retry\",\n    label: \"Cron Timeout Retry\",\n    description: \"Disable and re-enable a cron job that's timing out repeatedly\",\n    matches: (title, error) => {\n      const text = `${title} ${error}`.toLowerCase();\n      return text.includes(\"cron\") && (text.includes(\"timeout\") || text.includes(\"timed out\"));\n    },\n    requiresApproval: true, // Changing cron state needs approval\n    execute: async (): Promise<RemediationResult> => {\n      return {\n        ruleId: \"cron-timeout-retry\",\n        success: false,\n        action: \"Requires Andre approval to disable/re-enable cron\",\n        detail: \"Auto-remediation for cron timeouts requires human approval. Flagged for triage.\",\n      };\n    },\n  },\n  {\n    id: \"rate-limit-backoff\",\n    label: \"Rate Limit Backoff\",\n    description: \"Pause non-critical cron jobs when rate limits are detected\",\n    matches: (title, error) => {\n      const text = `${title} ${error}`.toLowerCase();\n      return text.includes(\"429\") || text.includes(\"rate limit\");\n    },\n    requiresApproval: true, // Pausing crons needs approval\n    execute: async (): Promise<RemediationResult> => {\n      return {\n        ruleId: \"rate-limit-backoff\",\n        success: false,\n        action: \"Requires Andre approval to pause cron jobs\",\n        detail: \"Rate limit remediation requires human approval. Flagged for triage.\",\n      };\n    },\n  },\n  {\n    id: \"disk-space-cleanup\",\n    label: \"Disk Space Cleanup\",\n    description: \"Clear temporary files and caches when disk space is low\",\n    matches: (title, error) => {\n      const text = `${title} ${error}`.toLowerCase();\n      return (\n        (text.includes(\"disk\") || text.includes(\"space\") || text.includes(\"storage\")) &&\n        (text.includes(\"full\") || text.includes(\"low\") || text.includes(\"no space\"))\n      );\n    },\n    requiresApproval: false,\n    execute: async (): Promise<RemediationResult> => {\n      const { execSync } = await import(\"child_process\");\n      try {\n        // Safe cleanup targets\n        const cleanupCmds = [\n          \"rm -rf /tmp/mc-dev.log /tmp/vite-*.log 2>/dev/null || true\",\n          \"cd /Users/spacemonkey/.openclaw/workspace/mission-control-dashboard && rm -rf node_modules/.vite .vite 2>/dev/null || true\",\n        ];\n        for (const cmd of cleanupCmds) {\n          execSync(cmd, { timeout: 10000 });\n        }\n        // Check disk after\n        const df = execSync(\"df -h / | tail -1\", { timeout: 5000 }).toString().trim();\n        return {\n          ruleId: \"disk-space-cleanup\",\n          success: true,\n          action: \"Cleared temp files and Vite cache\",\n          detail: `Disk status: ${df}`,\n        };\n      } catch (err) {\n        return {\n          ruleId: \"disk-space-cleanup\",\n          success: false,\n          action: \"Attempted disk cleanup\",\n          detail: `Error: ${String(err)}`,\n        };\n      }\n    },\n  },\n];\n\n// ── Public API ───────────────────────────────────────────────────────────────\n\n/** Find all remediation rules that match a given error/title */\nexport function findMatchingRules(title: string, error: string): RemediationRule[] {\n  return RULES.filter((r) => r.matches(title, error));\n}\n\n/** Execute a remediation rule by ID */\nexport function executeRule(ruleId: string): Promise<RemediationResult> {\n  const rule = RULES.find((r) => r.id === ruleId);\n  if (!rule) {\n    return Promise.resolve({\n      ruleId,\n      success: false,\n      action: \"Rule not found\",\n      detail: `No remediation rule with ID: ${ruleId}`,\n    });\n  }\n  return rule.execute();\n}\n\n/** Get all available rules (for display in UI) */\nexport function getAllRules(): RemediationRule[] {\n  return [...RULES];\n}\n\n/** Run auto-remediation check — returns results for all matching rules */\nexport async function runAutoRemediation(title: string, error: string): Promise<{\n  matched: number;\n  executed: number;\n  results: RemediationResult[];\n}> {\n  const matching = findMatchingRules(title, error);\n  const results: RemediationResult[] = [];\n  let executed = 0;\n\n  for (const rule of matching) {\n    if (rule.requiresApproval) {\n      results.push({\n        ruleId: rule.id,\n        success: false,\n        action: rule.label,\n        detail: \"Requires Andre approval — flagged for triage\",\n      });\n    } else {\n      const result = await rule.execute();\n      results.push(result);\n      executed++;\n    }\n  }\n\n  return { matched: matching.length, executed, results };\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/lib/server-data/auto-remediation.ts\", \"content\": \"// src/lib/server-data/auto-remediation.ts\\n// Predefined remediation actions for common failure patterns\\n\\nexport interface RemediationRule {\\n  id: string;\\n  label: string;\\n  description: string;\\n  /** Check if this rule applies to the given error/title */\\n  matches: (title: string, error: string) => boolean;\\n  /** Execute the remediation. Returns a summary of what was done. */\\n  execute: () => Promise<RemediationResult>;\\n  /** Whether this rule requires Andre's approval before executing */\\n  requiresApproval: boolean;\\n}\\n\\nexport interface RemediationResult {\\n  ruleId: string;\\n  success: boolean;\\n  action: string;\\n  detail: string;\\n}\\n\\n// ── Rules ────────────────────────────────────────────────────────────────────\\n\\nconst RULES: RemediationRule[] = [\\n  {\\n    id: \\\"vite-cache-corruption\\\",\\n    label: \\\"Vite Cache Corruption\\\",\\n    description: \\\"Clear Vite cache and restart dev server when 504/optimize-dep errors detected\\\",\\n    matches: (title, error) => {\\n      const text = `${title} ${error}`.toLowerCase();\\n      return (\\n        (text.includes(\\\"vite\\\") || text.includes(\\\"504\\\") || text.includes(\\\"outdated optimize\\\")) &&\\n        (text.includes(\\\"cache\\\") || text.includes(\\\"corrupt\\\") || text.includes(\\\"dep\\\"))\\n      );\\n    },\\n    requiresApproval: false,\\n    execute: async (): Promise<RemediationResult> => {\\n      const { execSync } = await import(\\\"child_process\\\");\\n      try {\\n        const mcDir = \\\"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard\\\";\\n        // Clear Vite cache\\n        execSync(`cd ${mcDir} && rm -rf node_modules/.vite .vite`, { timeout: 10000 });\\n        // Kill existing Vite process\\n        try {\\n          execSync(\\\"pkill -f 'vite dev' 2>/dev/null || true\\\", { timeout: 5000 });\\n        } catch { /* ignore if no process */ }\\n        // Restart Vite\\n        execSync(`cd ${mcDir} && nohup bun run dev --host --port 3000 > /tmp/mc-dev.log 2>&1 &`, {\\n          timeout: 5000,\\n          detached: true,\\n        });\\n        // Wait and verify\\n        await new Promise((r) => setTimeout(r, 3000));\\n        const http = await import(\\\"http\\\");\\n        const ok = await new Promise<boolean>((resolve) => {\\n          const req = http.get(\\\"http://localhost:3000/\\\", (res) => {\\n            resolve(res.statusCode === 200);\\n          });\\n          req.on(\\\"error\\\", () => resolve(false));\\n          req.setTimeout(3000, () => { req.destroy(); resolve(false); });\\n        });\\n        return {\\n          ruleId: \\\"vite-cache-corruption\\\",\\n          success: ok,\\n          action: \\\"Cleared Vite cache and restarted dev server\\\",\\n          detail: ok ? \\\"MC dashboard responding 200 on port 3000\\\" : \\\"MC dashboard not responding after restart\\\",\\n        };\\n      } catch (err) {\\n        return {\\n          ruleId: \\\"vite-cache-corruption\\\",\\n          success: false,\\n          action: \\\"Attempted Vite cache clear + restart\\\",\\n          detail: `Error: ${String(err)}`,\\n        };\\n      }\\n    },\\n  },\\n  {\\n    id: \\\"cron-timeout-retry\\\",\\n    label: \\\"Cron Timeout Retry\\\",\\n    description: \\\"Disable and re-enable a cron job that's timing out repeatedly\\\",\\n    matches: (title, error) => {\\n      const text = `${title} ${error}`.toLowerCase();\\n      return text.includes(\\\"cron\\\") && (text.includes(\\\"timeout\\\") || text.includes(\\\"timed out\\\"));\\n    },\\n    requiresApproval: true, // Changing cron state needs approval\\n    execute: async (): Promise<RemediationResult> => {\\n      return {\\n        ruleId: \\\"cron-timeout-retry\\\",\\n        success: false,\\n        action: \\\"Requires Andre approval to disable/re-enable cron\\\",\\n        detail: \\\"Auto-remediation for cron timeouts requires human approval. Flagged for triage.\\\",\\n      };\\n    },\\n  },\\n  {\\n    id: \\\"rate-limit-backoff\\\",\\n    label: \\\"Rate Limit Backoff\\\",\\n    description: \\\"Pause non-critical cron jobs when rate limits are detected\\\",\\n    matches: (title, error) => {\\n      const text = `${title} ${error}`.toLowerCase();\\n      return text.includes(\\\"429\\\") || text.includes(\\\"rate limit\\\");\\n    },\\n    requiresApproval: true, // Pausing crons needs approval\\n    execute: async (): Promise<RemediationResult> => {\\n      return {\\n        ruleId: \\\"rate-limit-backoff\\\",\\n        success: false,\\n        action: \\\"Requires Andre approval to pause cron jobs\\\",\\n        detail: \\\"Rate limit remediation requires human approval. Flagged for triage.\\\",\\n      };\\n    },\\n  },\\n  {\\n    id: \\\"disk-space-cleanup\\\",\\n    label: \\\"Disk Space Cleanup\\\",\\n    description: \\\"Clear temporary files and caches when disk space is low\\\",\\n    matches: (title, error) => {\\n      const text = `${title} ${error}`.toLowerCase();\\n      return (\\n        (text.includes(\\\"disk\\\") || text.includes(\\\"space\\\") || text.includes(\\\"storage\\\")) &&\\n        (text.includes(\\\"full\\\") || text.includes(\\\"low\\\") || text.includes(\\\"no space\\\"))\\n      );\\n    },\\n    requiresApproval: false,\\n    execute: async (): Promise<RemediationResult> => {\\n      const { execSync } = await import(\\\"child_process\\\");\\n      try {\\n        // Safe cleanup targets\\n        const cleanupCmds = [\\n          \\\"rm -rf /tmp/mc-dev.log /tmp/vite-*.log 2>/dev/null || true\\\",\\n          \\\"cd /Users/spacemonkey/.openclaw/workspace/mission-control-dashboard && rm -rf node_modules/.vite .vite 2>/dev/null || true\\\",\\n        ];\\n        for (const cmd of cleanupCmds) {\\n          execSync(cmd, { timeout: 10000 });\\n        }\\n        // Check disk after\\n        const df = execSync(\\\"df -h / | tail -1\\\", { timeout: 5000 }).toString().trim();\\n        return {\\n          ruleId: \\\"disk-space-cleanup\\\",\\n          success: true,\\n          action: \\\"Cleared temp files and Vite cache\\\",\\n          detail: `Disk status: ${df}`,\\n        };\\n      } catch (err) {\\n        return {\\n          ruleId: \\\"disk-space-cleanup\\\",\\n          success: false,\\n          action: \\\"Attempted disk cleanup\\\",\\n          detail: `Error: ${String(err)}`,\\n        };\\n      }\\n    },\\n  },\\n];\\n\\n// ── Public API ───────────────────────────────────────────────────────────────\\n\\n/** Find all remediation rules that match a given error/title */\\nexport function findMatchingRules(title: string, error: string): RemediationRule[] {\\n  return RULES.filter((r) => r.matches(title, error));\\n}\\n\\n/** Execute a remediation rule by ID */\\nexport function executeRule(ruleId: string): Promise<RemediationResult> {\\n  const rule = RULES.find((r) => r.id === ruleId);\\n  if (!rule) {\\n    return Promise.resolve({\\n      ruleId,\\n      success: false,\\n      action: \\\"Rule not found\\\",\\n      detail: `No remediation rule with ID: ${ruleId}`,\\n    });\\n  }\\n  return rule.execute();\\n}\\n\\n/** Get all available rules (for display in UI) */\\nexport function getAllRules(): RemediationRule[] {\\n  return [...RULES];\\n}\\n\\n/** Run auto-remediation check — returns results for all matching rules */\\nexport async function runAutoRemediation(title: string, error: string): Promise<{\\n  matched: number;\\n  executed: number;\\n  results: RemediationResult[];\\n}> {\\n  const matching = findMatchingRules(title, error);\\n  const results: RemediationResult[] = [];\\n  let executed = 0;\\n\\n  for (const rule of matching) {\\n    if (rule.requiresApproval) {\\n      results.push({\\n        ruleId: rule.id,\\n        success: false,\\n        action: rule.label,\\n        detail: \\\"Requires Andre approval — flagged for triage\\\",\\n      });\\n    } else {\\n      const result = await rule.execute();\\n      results.push(result);\\n      executed++;\\n    }\\n  }\\n\\n  return { matched: matching.length, executed, results };\\n}\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":354,"output":1880,"cacheRead":139904,"cacheWrite":0,"reasoningTokens":0,"totalTokens":142138,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780514909885,"responseId":"gen-1780514910-jXMiRfE71oyyrgDYOnCY"}}
