{"type":"message","id":"e02ae407","parentId":"7553f2d9","timestamp":"2026-06-03T22:23:08.224Z","message":{"role":"toolResult","toolCallId":"b517576a-3903-4ac6-8714-51b5b2be4b49","toolName":"exec","content":[{"type":"text","text":"319 /Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/scheduler.tsx\n===\nimport { useState } from \"react\";\nimport { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader, Pill } from \"@/components/PageHeader\";\nimport { useCronData } from \"@/components/scheduler/useCronData\";\nimport type { CronError } from \"@/components/scheduler/useCronData\";\nimport { CronJobCard } from \"@/components/scheduler/CronJobCard\";\nimport { Power, Clock, AlertTriangle, CheckCircle, Loader2, Play, SkipForward, CheckCircle2, RotateCcw } from \"lucide-react\";\n\nexport const Route = createFileRoute(\"/scheduler\")({\n  head: () => ({ meta: [{ title: \"Scheduler — Mission Control\" }] }),\n  component: SchedulerPage,\n});\n\n// ── Main Page ────────────────────────────────────────────────────────────────\n\ntype Tab = \"jobs\" | \"errors\";\n\nfunction SchedulerPage() {\n  const [activeTab, setActiveTab] = useState<Tab>(\"jobs\");\n  const {\n    jobs,\n    errors,\n    loading,\n    toggling,\n    result,\n    handleToggle,\n    updateErrorStatus,\n  } = useCronData();\n\n  const enabledCount = jobs.filter((j) => j.enabled).length;\n  const errorCount = errors.filter((e) => e.status === \"new\" || e.status === \"in_progress\").length;\n  const unresolvedErrors = errors.filter((e) => e.status === \"new\" || e.status === \"in_progress\").length;\n\n  if (loading) {\n    return (\n      <div className=\"flex items-center justify-center py-20\">\n        <Loader2 className=\"h-6 w-6 animate-spin text-muted-foreground\" />\n      </div>\n    );\n  }\n\n  return (\n    <>\n      <PageHeader icon=\"📅\" title=\"Scheduler\" meta={`${jobs.length} jobs · ${enabledCount} active · ${errorCount} errors`}>\n        All scheduled automation for the station. Toggle jobs on or off.\n      </PageHeader>\n\n      {/* Tabs */}\n      <div className=\"flex items-center gap-1 mb-6 border-b border-border\">\n        <button\n          onClick={() => setActiveTab(\"jobs\")}\n          className={`px-4 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px ${\n            activeTab === \"jobs\"\n              ? \"border-violet text-foreground\"\n              : \"border-transparent text-muted-foreground hover:text-foreground\"\n          }`}\n        >\n          Cron Jobs\n          <span className=\"ml-2 rounded-full bg-muted px-1.5 py-0.5 text-[10px]\">{jobs.length}</span>\n        </button>"}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"319 /Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/scheduler.tsx\n===\nimport { useState } from \"react\";\nimport { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader, Pill } from \"@/components/PageHeader\";\nimport { useCronData } from \"@/components/scheduler/useCronData\";\nimport type { CronError } from \"@/components/scheduler/useCronData\";\nimport { CronJobCard } from \"@/components/scheduler/CronJobCard\";\nimport { Power, Clock, AlertTriangle, CheckCircle, Loader2, Play, SkipForward, CheckCircle2, RotateCcw } from \"lucide-react\";\n\nexport const Route = createFileRoute(\"/scheduler\")({\n  head: () => ({ meta: [{ title: \"Scheduler — Mission Control\" }] }),\n  component: SchedulerPage,\n});\n\n// ── Main Page ────────────────────────────────────────────────────────────────\n\ntype Tab = \"jobs\" | \"errors\";\n\nfunction SchedulerPage() {\n  const [activeTab, setActiveTab] = useState<Tab>(\"jobs\");\n  const {\n    jobs,\n    errors,\n    loading,\n    toggling,\n    result,\n    handleToggle,\n    updateErrorStatus,\n  } = useCronData();\n\n  const enabledCount = jobs.filter((j) => j.enabled).length;\n  const errorCount = errors.filter((e) => e.status === \"new\" || e.status === \"in_progress\").length;\n  const unresolvedErrors = errors.filter((e) => e.status === \"new\" || e.status === \"in_progress\").length;\n\n  if (loading) {\n    return (\n      <div className=\"flex items-center justify-center py-20\">\n        <Loader2 className=\"h-6 w-6 animate-spin text-muted-foreground\" />\n      </div>\n    );\n  }\n\n  return (\n    <>\n      <PageHeader icon=\"📅\" title=\"Scheduler\" meta={`${jobs.length} jobs · ${enabledCount} active · ${errorCount} errors`}>\n        All scheduled automation for the station. Toggle jobs on or off.\n      </PageHeader>\n\n      {/* Tabs */}\n      <div className=\"flex items-center gap-1 mb-6 border-b border-border\">\n        <button\n          onClick={() => setActiveTab(\"jobs\")}\n          className={`px-4 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px ${\n            activeTab === \"jobs\"\n              ? \"border-violet text-foreground\"\n              : \"border-transparent text-muted-foreground hover:text-foreground\"\n          }`}\n        >\n          Cron Jobs\n          <span className=\"ml-2 rounded-full bg-muted px-1.5 py-0.5 text-[10px]\">{jobs.length}</span>\n        </button>","cwd":"/Users/spacemonkey/.openclaw/workspace"},"isError":false,"timestamp":1780523010367}}
