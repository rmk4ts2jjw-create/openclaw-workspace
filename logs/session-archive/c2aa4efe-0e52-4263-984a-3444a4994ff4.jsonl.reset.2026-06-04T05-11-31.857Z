',\n            'details': 'Reset from in_progress to backlog — task flipped by work-dispatcher.sh before it was disabled. No agent spawned. currentStep still \"Agent starting…\" at 5%.'\n        })\n        print(\"\\n→ Reset to backlog (last ghost dispatch from work-dispatcher)\")\n        break\n\nwith open(tasks_file, 'w') as f:\n    json.dump(tasks, f, indent=2)\nPYEOF","timeout":5},"partialArgs":"{\"command\": \"python3 << 'PYEOF'\\nimport json\\nfrom datetime import datetime, timezone\\n\\ntasks_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/tasks.json\\\"\\nwith open(tasks_file) as f:\\n    tasks = json.load(f)\\n\\nnow = datetime.now(timezone.utc)\\n\\nfor t in tasks:\\n    if t['id'] == 'task-fd625713':\\n        # Check staleness\\n        la = t.get('lastActivity', '')\\n        if la:\\n            try:\\n                ts = datetime.fromisoformat(la.replace('Z','+00:00'))\\n                age_min = (now - ts).total_seconds() / 60\\n                print(f\\\"lastActivity: {la} ({age_min:.0f} min ago)\\\")\\n            except:\\n                print(f\\\"lastActivity: {la} (unparseable)\\\")\\n        else:\\n            print(\\\"lastActivity: None\\\")\\n        \\n        print(f\\\"currentStep: {t.get('currentStep')}\\\")\\n        print(f\\\"progress: {t.get('progress', 0)}%\\\")\\n        print(f\\\"dispatchCount: {t.get('dispatchCount', 0)}\\\")\\n        print(f\\\"wasStalled: {t.get('wasStalled')}\\\")\\n        print(f\\\"Note tail: ...{t.get('note', '')[-120:] if t.get('note') else '(none)'}\\\")\\n        \\n        # Reset — no agent working on it\\n        t['status'] = 'backlog'\\n        t['stalledAt'] = now.isoformat()\\n        t['dispatchCount'] = t.get('dispatchCount', 0) + 1\\n        t['lastActivity'] = now.isoformat()\\n        if 'history' not in t:\\n            t['history'] = []\\n        t['history'].append({\\n            'ts': now.isoformat(),\\n            'action': 'stalled',\\n            'actor': 'heartbeat',