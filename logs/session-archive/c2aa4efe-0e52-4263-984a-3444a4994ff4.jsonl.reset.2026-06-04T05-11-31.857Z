{"type":"message","id":"695716fe","parentId":"732ae8cb","timestamp":"2026-06-03T19:26:14.045Z","message":{"role":"assistant","content":[{"type":"text","text":"Now create the Asset View route page:"},{"type":"toolCall","id":"7a02a4f5-5047-4a24-91aa-d94ce7afc44f","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/assets.tsx","content":"// src/routes/assets.tsx\n// Asset View — dedicated page showing all assets and their health status\nimport { useState, useMemo } from \"react\";\nimport { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader } from \"@/components/PageHeader\";\nimport {\n  getAssets,\n  getAssetSummary,\n  type Asset,\n  type AssetType,\n  type AssetHealth,\n} from \"@/lib/server-data/assets\";\nimport {\n  Activity,\n  Bot,\n  Clock,\n  Cpu,\n  HardDrive,\n  Heart,\n  HeartCrack,\n  HelpCircle,\n  Server,\n  Shield,\n  Wrench,\n  Zap,\n} from \"lucide-react\";\n\nexport const Route = createFileRoute(\"/assets\")({\n  head: () => ({ meta: [{ title: \"Assets — Mission Control\" }] }),\n  loader: async () => {\n    const assets = getAssets();\n    const summary = getAssetSummary();\n    return { assets, summary };\n  },\n  component: AssetsPage,\n});\n\nconst TYPE_CONFIG: Record<AssetType, { label: string; icon: typeof Activity; color: string }> = {\n  service: { label: \"Services\", icon: Server, color: \"text-violet\" },\n  agent: { label: \"Agents\", icon: Bot, color: \"text-cyan\" },\n  cron: { label: \"Cron Jobs\", icon: Clock, color: \"text-amber-400\" },\n  infra: { label: \"Infrastructure\", icon: Cpu, color: \"text-emerald-400\" },\n};\n\nconst HEALTH_CONFIG: Record<AssetHealth, { label: string; icon: typeof Heart; color: string; bg: string; dot: string }> = {\n  healthy: { label: \"Healthy\", icon: Heart, color: \"text-[oklch(0.88_0.18_145)]\", bg: \"bg-[oklch(0.88_0.18_145)]/10\", dot: \"bg-[oklch(0.88_0.18_145)]\" },\n  degraded: { label: \"Degraded\", icon: Zap, color: \"text-amber-400\", bg: \"bg-amber-400/10\", dot: \"bg-amber-400\" },\n  down: { label: \"Down\", icon: HeartCrack, color: \"text-red-400\", bg: \"bg-red-400/10\", dot: \"bg-red-400\" },\n  unknown: { label: \"Unknown\", icon: HelpCircle, color: \"text-muted-foreground\", bg: \"bg-muted/10\", dot: \"bg-muted-foreground\" },\n};\n\nfunction AssetCard({ asset }: { asset: Asset }) {\n  const health = HEALTH_CONFIG[asset.status];\n  const type = TYPE_CONFIG[asset.type];\n  const HealthIcon = health.icon;\n  const TypeIcon = type.icon;\n\n  return (\n    <div className={`rounded-lg border border-border/60 bg-card/30 p-4 ${health.bg}`}>\n      <div className=\"flex items-start justify-between gap-3\">\n        <div className=\"flex items-center gap-2 min-w-0\">\n          <TypeIcon className={`h-4 w-4 ${type.color} shrink-0`} />\n          <div className=\"min-w-0\">\n            <span className=\"text-sm font-medium block truncate\">{asset.name}</span>\n            <span className=\"text-[10px] font-mono text-muted-foreground\">{asset.id}</span>\n          </div>\n        </div>\n        <div className={`flex items-center gap-1.5 shrink-0 ${health.color}`}>\n          <span className={`h-1.5 w-1.5 rounded-full ${health.dot}`} />\n          <HealthIcon className=\"h-3.5 w-3.5\" />\n          <span className=\"font-mono text-[10px]\">{health.label}</span>\n        </div>\n      </div>\n\n      <div className=\"mt-3 flex items-center gap-3 text-[10px] text-muted-foreground/70\">\n        <span className=\"flex items-center gap-1\">\n          <Shield className=\"h-3 w-3\" />\n          {asset.owner}\n        </span>\n        {asset.consecutiveFailures > 0 && (\n          <span className=\"text-amber-400\">\n            {asset.consecutiveFailures} consecutive failure{asset.consecutiveFailures > 1 ? \"s\" : \"\"}\n          </span>\n        )}\n        {asset.dependencies.length > 0 && (\n          <span className=\"flex items-center gap-1\">\n            <Wrench className=\"h-3 w-3\" />\n            {asset.dependencies.length} dep{asset.dependencies.length > 1 ? \"s\" : \"\"}\n          </span>\n        )}\n      </div>\n\n      {Object.keys(asset.metadata).length > 0 && (\n        <div className=\"mt-2 flex flex-wrap gap-1\">\n          {Object.entries(asset.metadata).map(([k, v]) => (\n            <span key={k} className=\"text-[9px] font-mono text-muted-foreground/50 bg-muted/20 rounded px-1.5 py-0.5\">\n              {k}: {v}\n            </span>\n          ))}\n        </div>\n      )}\n    </div>\n  );\n}\n\nfunction AssetsPage() {\n  const { assets, summary } = Route.useLoaderData() as {\n    assets: Asset[];\n    summary: ReturnType<typeof getAssetSummary>;\n  };\n  const [filterType, setFilterType] = useState<AssetType | \"all\">(\"all\");\n  const [filterHealth, setFilterHealth] = useState<AssetHealth | \"all\">(\"all\");\n\n  const filtered = useMemo(() => {\n    let result = assets;\n    if (filterType !== \"all\") result = result.filter((a) => a.type === filterType);\n    if (filterHealth !== \"all\") result = result.filter((a) => a.status === filterHealth);\n    // Sort: worst health first, then by type\n    const healthOrder: Record<AssetHealth, number> = { down: 0, degraded: 1, unknown: 2, healthy: 3 };\n    result.sort((a, b) => healthOrder[a.status] - healthOrder[b.status]);\n    return result;\n  }, [assets, filterType, filterHealth]);\n\n  return (\n    <div className=\"space-y-6\">\n      <PageHeader\n        title=\"Assets\"\n        subtitle={`${summary.total} tracked · ${summary.byHealth.healthy} healthy · ${summary.byHealth.degraded} degraded · ${summary.byHealth.down} down`}\n        icon={<HardDrive className=\"h-5 w-5 text-violet\" />}\n      />\n\n      {/* Summary badges */}\n      <div className=\"flex flex-wrap gap-2\">\n        {(Object.keys(TYPE_CONFIG) as AssetType[]).map((type) => {\n          const cfg = TYPE_CONFIG[type];\n          const Icon = cfg.icon;\n          const count = summary.byType[type];\n          return (\n            <button\n              key={type}\n              onClick={() => setFilterType(filterType === type ? \"all\" : type)}\n              className={`flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs transition-colors ${\n                filterType === type\n                  ? \"border-violet/50 bg-violet/10 text-violet\"\n                  : \"border-border/60 bg-card/20 text-muted-foreground hover:border-border\"\n              }`}\n            >\n              <Icon className=\"h-3.5 w-3.5\" />\n              {cfg.label}\n              <span className=\"font-mono text-[10px] opacity-70\">{count}</span>\n            </button>\n          );\n        })}\n        <div className=\"w-px bg-border/40 mx-1\" />\n        {(Object.keys(HEALTH_CONFIG) as AssetHealth[]).map((h) => {\n          const cfg = HEALTH_CONFIG[h];\n          const count = summary.byHealth[h];\n          if (count === 0) return null;\n          return (\n            <button\n              key={h}\n              onClick={() => setFilterHealth(filterHealth === h ? \"all\" : h)}\n              className={`flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs transition-colors ${\n                filterHealth === h\n                  ? \"border-violet/50 bg-violet/10\"\n                  : \"border-border/60 bg-card/20 text-muted-foreground hover:border-border\"\n              } ${cfg.color}`}\n            >\n              <span className={`h-1.5 w-1.5 rounded-full ${cfg.dot}`} />\n              {cfg.label}\n              <span className=\"font-mono text-[10px] opacity-70\">{count}</span>\n            </button>\n          );\n        })}\n      </div>\n\n      {/* Asset grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3\">\n        {filtered.map((asset) => (\n          <AssetCard key={asset.id} asset={asset} />\n        ))}\n      </div>\n\n      {filtered.length === 0 && (\n        <div className=\"text-center py-12 text-muted-foreground/50 text-sm\">\n          No assets match the current filter\n        </div>\n      )}\n    </div>\n  );\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/assets.tsx\", \"content\": \"// src/routes/assets.tsx\\n// Asset View — dedicated page showing all assets and their health status\\nimport { useState, useMemo } from \\\"react\\\";\\nimport { createFileRoute } from \\\"@tanstack/react-router\\\";\\nimport { PageHeader } from \\\"@/components/PageHeader\\\";\\nimport {\\n  getAssets,\\n  getAssetSummary,\\n  type Asset,\\n  type AssetType,\\n  type AssetHealth,\\n} from \\\"@/lib/server-data/assets\\\";\\nimport {\\n  Activity,\\n  Bot,\\n  Clock,\\n  Cpu,\\n  HardDrive,\\n  Heart,\\n  HeartCrack,\\n  HelpCircle,\\n  Server,\\n  Shield,\\n  Wrench,\\n  Zap,\\n} from \\\"lucide-react\\\";\\n\\nexport const Route = createFileRoute(\\\"/assets\\\")({\\n  head: () => ({ meta: [{ title: \\\"Assets — Mission Control\\\" }] }),\\n  loader: async () => {\\n    const assets = getAssets();\\n    const summary = getAssetSummary();\\n    return { assets, summary };\\n  },\\n  component: AssetsPage,\\n});\\n\\nconst TYPE_CONFIG: Record<AssetType, { label: string; icon: typeof Activity; color: string }> = {\\n  service: { label: \\\"Services\\\", icon: Server, color: \\\"text-violet\\\" },\\n  agent: { label: \\\"Agents\\\", icon: Bot, color: \\\"text-cyan\\\" },\\n  cron: { label: \\\"Cron Jobs\\\", icon: Clock, color: \\\"text-amber-400\\\" },\\n  infra: { label: \\\"Infrastructure\\\", icon: Cpu, color: \\\"text-emerald-400\\\" },\\n};\\n\\nconst HEALTH_CONFIG: Record<AssetHealth, { label: string; icon: typeof Heart; color: string; bg: string; dot: string }> = {\\n  healthy: { label: \\\"Healthy\\\", icon: Heart, color: \\\"text-[oklch(0.88_0.18_145)]\\\", bg: \\\"bg-[oklch(0.88_0.18_145)]/10\\\", dot: \\\"bg-[oklch(0.88_0.18_145)]\\\" },\\n  degraded: { label: \\\"Degraded\\\", icon: Zap, color: \\\"text-amber-400\\\", bg: \\\"bg-amber-400/10\\\", dot: \\\"bg-amber-400\\\" },\\n  down: { label: \\\"Down\\\", icon: HeartCrack, color: \\\"text-red-400\\\", bg: \\\"bg-red-400/10\\\", dot: \\\"bg-red-400\\\" },\\n  unknown: { label: \\\"Unknown\\\", icon: HelpCircle, color: \\\"text-muted-foreground\\\", bg: \\\"bg-muted/10\\\", dot: \\\"bg-muted-foreground\\\" },\\n};\\n\\nfunction AssetCard({ asset }: { asset: Asset }) {\\n  const health = HEALTH_CONFIG[asset.status];\\n  const type = TYPE_CONFIG[asset.type];\\n  const HealthIcon = health.icon;\\n  const TypeIcon = type.icon;\\n\\n  return (\\n    <div className={`rounded-lg border border-border/60 bg-card/30 p-4 ${health.bg}`}>\\n      <div className=\\\"flex items-start justify-between gap-3\\\">\\n        <div className=\\\"flex items-center gap-2 min-w-0\\\">\\n          <TypeIcon className={`h-4 w-4 ${type.color} shrink-0`} />\\n          <div className=\\\"min-w-0\\\">\\n            <span className=\\\"text-sm font-medium block truncate\\\">{asset.name}</span>\\n            <span className=\\\"text-[10px] font-mono text-muted-foreground\\\">{asset.id}</span>\\n          </div>\\n        </div>\\n        <div className={`flex items-center gap-1.5 shrink-0 ${health.color}`}>\\n          <span className={`h-1.5 w-1.5 rounded-full ${health.dot}`} />\\n          <HealthIcon className=\\\"h-3.5 w-3.5\\\" />\\n          <span className=\\\"font-mono text-[10px]\\\">{health.label}</span>\\n        </div>\\n      </div>\\n\\n      <div className=\\\"mt-3 flex items-center gap-3 text-[10px] text-muted-foreground/70\\\">\\n        <span className=\\\"flex items-center gap-1\\\">\\n          <Shield className=\\\"h-3 w-3\\\" />\\n          {asset.owner}\\n        </span>\\n        {asset.consecutiveFailures > 0 && (\\n          <span className=\\\"text-amber-400\\\">\\n            {asset.consecutiveFailures} consecutive failure{asset.consecutiveFailures > 1 ? \\\"s\\\" : \\\"\\\"}\\n          </span>\\n        )}\\n        {asset.dependencies.length > 0 && (\\n          <span className=\\\"flex items-center gap-1\\\">\\n            <Wrench className=\\\"h-3 w-3\\\" />\\n            {asset.dependencies.length} dep{asset.dependencies.length > 1 ? \\\"s\\\" : \\\"\\\"}\\n          </span>\\n        )}\\n      </div>\\n\\n      {Object.keys(asset.metadata).length > 0 && (\\n        <div className=\\\"mt-2 flex flex-wrap gap-1\\\">\\n          {Object.entries(asset.metadata).map(([k, v]) => (\\n            <span key={k} className=\\\"text-[9px] font-mono text-muted-foreground/50 bg-muted/20 rounded px-1.5 py-0.5\\\">\\n              {k}: {v}\\n            </span>\\n          ))}\\n        </div>\\n      )}\\n    </div>\\n  );\\n}\\n\\nfunction AssetsPage() {\\n  const { assets, summary } = Route.useLoaderData() as {\\n    assets: Asset[];\\n    summary: ReturnType<typeof getAssetSummary>;\\n  };\\n  const [filterType, setFilterType] = useState<AssetType | \\\"all\\\">(\\\"all\\\");\\n  const [filterHealth, setFilterHealth] = useState<AssetHealth | \\\"all\\\">(\\\"all\\\");\\n\\n  const filtered = useMemo(() => {\\n    let result = assets;\\n    if (filterType !== \\\"all\\\") result = result.filter((a) => a.type === filterType);\\n    if (filterHealth !== \\\"all\\\") result = result.filter((a) => a.status === filterHealth);\\n    // Sort: worst health first, then by type\\n    const healthOrder: Record<AssetHealth, number> = { down: 0, degraded: 1, unknown: 2, healthy: 3 };\\n    result.sort((a, b) => healthOrder[a.status] - healthOrder[b.status]);\\n    return result;\\n  }, [assets, filterType, filterHealth]);\\n\\n  return (\\n    <div className=\\\"space-y-6\\\">\\n      <PageHeader\\n        title=\\\"Assets\\\"\\n        subtitle={`${summary.total} tracked · ${summary.byHealth.healthy} healthy · ${summary.byHealth.degraded} degraded · ${summary.byHealth.down} down`}\\n        icon={<HardDrive className=\\\"h-5 w-5 text-violet\\\" />}\\n      />\\n\\n      {/* Summary badges */}\\n      <div className=\\\"flex flex-wrap gap-2\\\">\\n        {(Object.keys(TYPE_CONFIG) as AssetType[]).map((type) => {\\n          const cfg = TYPE_CONFIG[type];\\n          const Icon = cfg.icon;\\n          const count = summary.byType[type];\\n          return (\\n            <button\\n              key={type}\\n              onClick={() => setFilterType(filterType === type ? \\\"all\\\" : type)}\\n              className={`flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs transition-colors ${\\n                filterType === type\\n                  ? \\\"border-violet/50 bg-violet/10 text-violet\\\"\\n                  : \\\"border-border/60 bg-card/20 text-muted-foreground hover:border-border\\\"\\n              }`}\\n            >\\n              <Icon className=\\\"h-3.5 w-3.5\\\" />\\n              {cfg.label}\\n              <span className=\\\"font-mono text-[10px] opacity-70\\\">{count}</span>\\n            </button>\\n          );\\n        })}\\n        <div className=\\\"w-px bg-border/40 mx-1\\\" />\\n        {(Object.keys(HEALTH_CONFIG) as AssetHealth[]).map((h) => {\\n          const cfg = HEALTH_CONFIG[h];\\n          const count = summary.byHealth[h];\\n          if (count === 0) return null;\\n          return (\\n            <button\\n              key={h}\\n              onClick={() => setFilterHealth(filterHealth === h ? \\\"all\\\" : h)}\\n              className={`flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-xs transition-colors ${\\n                filterHealth === h\\n                  ? \\\"border-violet/50 bg-violet/10\\\"\\n                  : \\\"border-border/60 bg-card/20 text-muted-foreground hover:border-border\\\"\\n              } ${cfg.color}`}\\n            >\\n              <span className={`h-1.5 w-1.5 rounded-full ${cfg.dot}`} />\\n              {cfg.label}\\n              <span className=\\\"font-mono text-[10px] opacity-70\\\">{count}</span>\\n            </button>\\n          );\\n        })}\\n      </div>\\n\\n      {/* Asset grid */}\\n      <div className=\\\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3\\\">\\n        {filtered.map((asset) => (\\n          <AssetCard key={asset.id} asset={asset} />\\n        ))}\\n      </div>\\n\\n      {filtered.length === 0 && (\\n        <div className=\\\"text-center py-12 text-muted-foreground/50 text-sm\\\">\\n          No assets match the current filter\\n        </div>\\n      )}\\n    </div>\\n  );\\n}\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":1476,"output":2103,"cacheRead":132992,"cacheWrite":0,"reasoningTokens":0,"totalTokens":136571,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780514667576,"responseId":"gen-1780514667-68z91jnXMcrSD8ZPoI4S"}}
