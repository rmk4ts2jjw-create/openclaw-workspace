solved.append(f\"  RESOLVE {inc['id']}: linked task {done_linked[0]['id']} is done\")\n    elif len(linked) == 0:\n        # No linked tasks — check age\n        try:\n            opened = datetime.fromisoformat(inc['opened'].replace('Z', '+00:00'))\n            age_days = (now - opened).days\n        except:\n            age_days = 999\n        \n        if age_days >= close_old_days:\n            closed.append(f\"  CLOSE {inc['id']}: no linked task, {age_days}d old — {inc['title'][:50]}\")\n        else:\n            skipped.append(f\"  SKIP {inc['id']}: no linked task but only {age_days}d old\")\n    else:\n        statuses = [t.get('status','?') for t in linked]\n        skipped.append(f\"  SKIP {inc['id']}: linked tasks status: {statuses}\")\n\nprint(f\"\\nResolved ({len(resolved)}):\")\nfor r in resolved:\n    print(r)\n\nprint(f\"\\nClosed ({len(closed)}):\")\nfor c in closed:\n    print(c)\n\nprint(f\"\\nSkipped ({len(skipped)}):\")\nfor s in skipped:\n    print(s)\n\n# Count what remains\nremaining = len(skipped)\nprint(f\"\\n=== After cleanup: {len(resolved)} resolved, {len(closed)} closed, {remaining} remain open ===\")\nPYEOF","timeout":5},"partialArgs":"{\"command\": \"python3 << 'PYEOF'\\nimport json\\nfrom datetime import datetime, timezone\\n\\nincidents_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/incidents.json\\\"\\ntasks_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/tasks.json\\\"\\n\\nwith open(incidents_file) as f:\\n    incidents = json.load(f)\\nwith open(tasks_file) as f:\\n    tasks = json.load(f)\\n\\nnow = datetime.now(timezone.utc)\\nclose_old_days = 5\\n\\n# Build a map of all tasks (including archived) with linkedIncidentId\\nall_linked_tasks = [t for t in tasks if t.get('linkedIncidentId')]\\nprint(f\\\"Tasks with linkedIncidentId in active tasks: {len(all_linked_tasks)}\\\")\\n\\n# Also check archive\\nimport os\\narchive_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/tasks-archive.json\\\"\\narchived_linked = []\\nif os.path.exists(archive_file):\\n    with open(archive_file) as f:\\n        archive = json.load(f)\\n    archived_linked = [t for t in archive if t.get('linkedIncidentId')]\\n    print(f\\\"Tasks with linkedIncidentId in archive: {len(archived_linked)}\\\")\\n\\n# Combine all tasks\\nall_tasks = tasks + archive\\nlinked_task_map = {t['linkedIncidentId']: t for t in all_tasks if t.get('linkedIncidentId')}\\n\\nprint(f\\\"\\\\n=== Dry Run: Auto-Resolve ===\\\")\\nresolved = []\\nclosed = []\\nskipped = []\\n\\nfor inc in incidents:\\n    if inc['status'] == 'RESOLVED':\\n        continue\\n    \\n    # Check if any task links to this incident\\n    linked = [t for t in all_tasks if t.get('linkedIncidentId') == inc['id']]\\n    done_linked = [t for t in linked if t.get('status') == 'done']\\n    \\n    if done_linked:\\n        resolved.append(f\\\"  RESOLVE {inc['id']}: linked task {done_linked[0]['id']} is done\\\")\\n    elif len(linked) == 0:\\n        # No linked tasks — check age\\n        try:\\n            opened = datetime.fromisoformat(inc['opened'].replace('Z', '+00:00'))\\n            age_days = (now - opened).days\\n        except:\\n            age_days = 999\\n        \\n        if age_days >= close_old_days:\\n            closed.append(f\\\"  CLOSE {inc['id']}: no linked task, {age_days}d old — {inc['title'][:50]}\\\")\\n        else:\\n            skipped.append(f\\\"  SKIP {inc['id']}: no linked task but only {age_days}d old\\\")\\n    else:\\n        statuses = [t.get('status','?') for t in linked]\\n        skipped.append(f\\\"  SKIP {inc['id']}: linked tasks status: {statuses}\\\")\\n\\nprint(f\\\"\\\\nResolved ({len(resolved)}):\\\")\\nfor r in resolved:\\n    print(r)\\n\\nprint(f\\\"\\\\nClosed ({len(closed)}):\\\")\\nfor c in closed:\\n    print(c)\\n\\nprint(f\\\"\\\\nSkipped ({len(skipped)}):\\\")\\nfor s in skipped:\\n    print(s)\\n\\n# Count what remains\\nremaining = len(skipped)\\nprint(f\\\"\\\\n=== After cleanup: {len(resolved)} resolved, {len(closed)} closed, {remaining} remain open ===\\\")\\nPYEOF\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":268,"output":773,"cacheRead":87424,"cacheWrite":0,"reasoningTokens":0,"totalTokens":88465,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780528611353,"responseId":"gen-1780528611-0jk2QuJYnDsoBWR0ut1l"}}
