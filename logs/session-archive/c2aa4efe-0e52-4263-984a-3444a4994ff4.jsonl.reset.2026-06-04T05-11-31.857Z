.get('wasStalled'))]\\n\\nprotected.sort(key=lambda t: t.get('stalledAt') or '')\\n\\nprint(f\\\"PROTECTED/STALLED TASKS: {len(protected)}\\\\n\\\")\\nfor i, t in enumerate(protected, 1):\\n    dc = t.get('dispatchCount', 0)\\n    sa = t.get('stalledAt', '')\\n    ws = 'wasStalled' if t.get('wasStalled') else ''\\n    age = ''\\n    if sa:\\n        try:\\n            ts = datetime.fromisoformat(sa.replace('Z', '+00:00'))\\n            h = (now - ts).total_seconds() / 3600\\n            age = f\\\"{h:.0f}h ago\\\"\\n        except:\\n            age = \\\"?\\\"\\n    flags = []\\n    if dc >= 3: flags.append(f\\\"dc={dc}\\\")\\n    if sa: flags.append(f\\\"stalled {age}\\\")\\n    if ws: flags.append(ws)\\n    \\n    print(f\\\"{i:2}. [{t.get('priority','?')}] {t['id']}\\\")\\n    print(f\\\"    {t['title'][:70]}\\\")\\n    print(f\\\"    assignee={t.get('assignee','?')}  {'  '.join(flags)}\\\")\\n    print()\\nPYEOF\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":273,"output":413,"cacheRead":65792,"cacheWrite":0,"reasoningTokens":0,"totalTokens":66478,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780507099422,"responseId":"gen-1780507099-n7FnjVWYRcyRrz4NMepE"}}
