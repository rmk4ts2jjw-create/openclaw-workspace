{"type":"message","id":"c2c0a0ac","parentId":"5eb5138e","timestamp":"2026-06-03T22:23:08.224Z","message":{"role":"assistant","content":[{"type":"text","text":"Now create the Timeline route page:"},{"type":"toolCall","id":"9367dd55-7f48-4e07-babf-39e921c359f3","name":"write","arguments":{"path":"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/timeline.tsx","content":"// src/routes/timeline.tsx\n// Timeline — Unified Event Model showing all station events\nimport { useState, useMemo } from \"react\";\nimport { createFileRoute } from \"@tanstack/react-router\";\nimport { PageHeader } from \"@/components/PageHeader\";\nimport {\n  getTimelineEvents,\n  getTimelineSummary,\n  type TimelineEvent,\n  type TimelineEventType,\n} from \"@/lib/server-data/timeline-data\";\nimport {\n  AlertTriangle,\n  ArrowRight,\n  Bot,\n  CheckCircle2,\n  Clock,\n  FileText,\n  OctagonX,\n  Play,\n  RotateCcw,\n  Server,\n  Shield,\n  XCircle,\n  Zap,\n} from \"lucide-react\";\n\nexport const Route = createFileRoute(\"/timeline\")({\n  head: () => ({ meta: [{ title: \"Timeline — Mission Control\" }] }),\n  loader: async () => {\n    const events = getTimelineEvents();\n    const summary = getTimelineSummary();\n    return { events, summary };\n  },\n  component: TimelinePage,\n});\n\nconst TYPE_CONFIG: Record<string, { icon: typeof Zap; color: string; bg: string }> = {\n  task_created: { icon: FileText, color: \"text-cyan\", bg: \"bg-cyan/10\" },\n  task_started: { icon: Play, color: \"text-violet\", bg: \"bg-violet/10\" },\n  task_completed: { icon: CheckCircle2, color: \"text-[oklch(0.88_0.18_145)]\", bg: \"bg-[oklch(0.88_0.18_145)]/10\" },\n  task_stalled: { icon: RotateCcw, color: \"text-amber-400\", bg: \"bg-amber-400/10\" },\n  incident_created: { icon: AlertTriangle, color: \"text-red-400\", bg: \"bg-red-400/10\" },\n  incident_status_change: { icon: Shield, color: \"text-amber-400\", bg: \"bg-amber-400/10\" },\n  incident_resolved: { icon: CheckCircle2, color: \"text-[oklch(0.88_0.18_145)]\", bg: \"bg-[oklch(0.88_0.18_145)]/10\" },\n  cron_success: { icon: CheckCircle2, color: \"text-[oklch(0.88_0.18_145)]\", bg: \"bg-[oklch(0.88_0.18_145)]/10\" },\n  cron_failure: { icon: XCircle, color: \"text-red-400\", bg: \"bg-red-400/10\" },\n  system_health: { icon: Server, color: \"text-cyan\", bg: \"bg-cyan/10\" },\n};\n\nconst SOURCE_FILTERS = [\n  { key: \"all\", label: \"All Events\" },\n  { key: \"task\", label: \"Tasks\" },\n  { key: \"incident\", label: \"Incidents\" },\n  { key: \"cron\", label: \"Crons\" },\n] as const;\n\nfunction EventCard({ event }: { event: TimelineEvent }) {\n  const cfg = TYPE_CONFIG[event.type] || TYPE_CONFIG[\"task_created\"];\n  const Icon = cfg.icon;\n  const time = new Date(event.ts);\n  const timeStr = time.toLocaleTimeString(\"en-GB\", { hour: \"2-digit\", minute: \"2-digit\" });\n  const dateStr = time.toLocaleDateString(\"en-GB\", { day: \"numeric\", month: \"short\" });\n\n  return (\n    <div className={`flex items-start gap-3 rounded-lg border border-border/40 bg-card/20 p-3 ${event.severity === \"critical\" ? \"border-red-400/30\" : event.severity === \"warning\" ? \"border-amber-400/20\" : \"\"}`}>\n      <div className={`rounded-md p-1.5 ${cfg.bg} shrink-0 mt-0.5`}>\n        <Icon className={`h-3.5 w-3.5 ${cfg.color}`} />\n      </div>\n      <div className=\"min-w-0 flex-1\">\n        <div className=\"flex items-start justify-between gap-2\">\n          <span className=\"text-sm font-medium leading-tight\">{event.title}</span>\n          <span className=\"text-[10px] font-mono text-muted-foreground/50 shrink-0\">{dateStr} {timeStr}</span>\n        </div>\n        {event.description && event.description !== event.title && (\n          <p className=\"mt-0.5 text-xs text-muted-foreground/70 leading-snug\">{event.description}</p>\n        )}\n        <div className=\"mt-1 flex items-center gap-2 text-[10px] text-muted-foreground/50\">\n          {event.actor && <span>{event.actor}</span>}\n          {event.entityId && event.entityUrl && (\n            <a href={event.entityUrl} className=\"flex items-center gap-0.5 hover:text-violet transition-colors\">\n              <ArrowRight className=\"h-2.5 w-2.5\" />\n              {event.entityId}\n            </a>\n          )}\n          {event.metadata?.severity && (\n            <span className=\"font-mono\">{event.metadata.severity}</span>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n\nfunction TimelinePage() {\n  const { events, summary } = Route.useLoaderData() as {\n    events: TimelineEvent[];\n    summary: ReturnType<typeof getTimelineSummary>;\n  };\n  const [sourceFilter, setSourceFilter] = useState<string>(\"all\");\n\n  const filtered = useMemo(() => {\n    if (sourceFilter === \"all\") return events;\n    return events.filter((e) => e.source === sourceFilter);\n  }, [events, sourceFilter]);\n\n  // Group by date\n  const grouped = useMemo(() => {\n    const groups: Record<string, TimelineEvent[]> = {};\n    for (const e of filtered) {\n      const date = new Date(e.ts).toLocaleDateString(\"en-GB\", { day: \"numeric\", month: \"short\", year: \"numeric\" });\n      if (!groups[date]) groups[date] = [];\n      groups[date].push(e);\n    }\n    return groups;\n  }, [filtered]);\n\n  return (\n    <div className=\"space-y-6\">\n      <PageHeader\n        title=\"Timeline\"\n        subtitle={`${summary.total} events · ${summary.critical} critical · ${summary.warnings} warnings`}\n        icon={<Clock className=\"h-5 w-5 text-violet\" />}\n      />\n\n      {/* Source filters */}\n      <div className=\"flex flex-wrap gap-2\">\n        {SOURCE_FILTERS.map((f) => (\n          <button\n            key={f.key}\n            onClick={() => setSourceFilter(f.key)}\n            className={`rounded-lg border px-3 py-1.5 text-xs transition-colors ${\n              sourceFilter === f.key\n                ? \"border-violet/50 bg-violet/10 text-violet\"\n                : \"border-border/60 bg-card/20 text-muted-foreground hover:border-border\"\n            }`}\n          >\n            {f.label}\n            <span className=\"ml-1.5 font-mono text-[10px] opacity-70\">\n              {f.key === \"all\" ? summary.total : summary.bySource[f.key] || 0}\n            </span>\n          </button>\n        ))}\n      </div>\n\n      {/* Timeline */}\n      <div className=\"space-y-6\">\n        {Object.entries(grouped).map(([date, dateEvents]) => (\n          <div key={date}>\n            <div className=\"sticky top-0 z-10 bg-background/80 backdrop-blur-sm py-2 mb-3\">\n              <h3 className=\"font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground/70\">{date}</h3>\n            </div>\n            <div className=\"space-y-2 ml-2 border-l border-border/30 pl-4\">\n              {dateEvents.map((event) => (\n                <EventCard key={event.id} event={event} />\n              ))}\n            </div>\n          </div>\n        ))}\n      </div>\n\n      {filtered.length === 0 && (\n        <div className=\"text-center py-12 text-muted-foreground/50 text-sm\">\n          No events match the current filter\n        </div>\n      )}\n    </div>\n  );\n}\n"},"partialArgs":"{\"path\": \"/Users/spacemonkey/.openclaw/workspace/mission-control-dashboard/src/routes/timeline.tsx\", \"content\": \"// src/routes/timeline.tsx\\n// Timeline — Unified Event Model showing all station events\\nimport { useState, useMemo } from \\\"react\\\";\\nimport { createFileRoute } from \\\"@tanstack/react-router\\\";\\nimport { PageHeader } from \\\"@/components/PageHeader\\\";\\nimport {\\n  getTimelineEvents,\\n  getTimelineSummary,\\n  type TimelineEvent,\\n  type TimelineEventType,\\n} from \\\"@/lib/server-data/timeline-data\\\";\\nimport {\\n  AlertTriangle,\\n  ArrowRight,\\n  Bot,\\n  CheckCircle2,\\n  Clock,\\n  FileText,\\n  OctagonX,\\n  Play,\\n  RotateCcw,\\n  Server,\\n  Shield,\\n  XCircle,\\n  Zap,\\n} from \\\"lucide-react\\\";\\n\\nexport const Route = createFileRoute(\\\"/timeline\\\")({\\n  head: () => ({ meta: [{ title: \\\"Timeline — Mission Control\\\" }] }),\\n  loader: async () => {\\n    const events = getTimelineEvents();\\n    const summary = getTimelineSummary();\\n    return { events, summary };\\n  },\\n  component: TimelinePage,\\n});\\n\\nconst TYPE_CONFIG: Record<string, { icon: typeof Zap; color: string; bg: string }> = {\\n  task_created: { icon: FileText, color: \\\"text-cyan\\\", bg: \\\"bg-cyan/10\\\" },\\n  task_started: { icon: Play, color: \\\"text-violet\\\", bg: \\\"bg-violet/10\\\" },\\n  task_completed: { icon: CheckCircle2, color: \\\"text-[oklch(0.88_0.18_145)]\\\", bg: \\\"bg-[oklch(0.88_0.18_145)]/10\\\" },\\n  task_stalled: { icon: RotateCcw, color: \\\"text-amber-400\\\", bg: \\\"bg-amber-400/10\\\" },\\n  incident_created: { icon: AlertTriangle, color: \\\"text-red-400\\\", bg: \\\"bg-red-400/10\\\" },\\n  incident_status_change: { icon: Shield, color: \\\"text-amber-400\\\", bg: \\\"bg-amber-400/10\\\" },\\n  incident_resolved: { icon: CheckCircle2, color: \\\"text-[oklch(0.88_0.18_145)]\\\", bg: \\\"bg-[oklch(0.88_0.18_145)]/10\\\" },\\n  cron_success: { icon: CheckCircle2, color: \\\"text-[oklch(0.88_0.18_145)]\\\", bg: \\\"bg-[oklch(0.88_0.18_145)]/10\\\" },\\n  cron_failure: { icon: XCircle, color: \\\"text-red-400\\\", bg: \\\"bg-red-400/10\\\" },\\n  system_health: { icon: Server, color: \\\"text-cyan\\\", bg: \\\"bg-cyan/10\\\" },\\n};\\n\\nconst SOURCE_FILTERS = [\\n  { key: \\\"all\\\", label: \\\"All Events\\\" },\\n  { key: \\\"task\\\", label: \\\"Tasks\\\" },\\n  { key: \\\"incident\\\", label: \\\"Incidents\\\" },\\n  { key: \\\"cron\\\", label: \\\"Crons\\\" },\\n] as const;\\n\\nfunction EventCard({ event }: { event: TimelineEvent }) {\\n  const cfg = TYPE_CONFIG[event.type] || TYPE_CONFIG[\\\"task_created\\\"];\\n  const Icon = cfg.icon;\\n  const time = new Date(event.ts);\\n  const timeStr = time.toLocaleTimeString(\\\"en-GB\\\", { hour: \\\"2-digit\\\", minute: \\\"2-digit\\\" });\\n  const dateStr = time.toLocaleDateString(\\\"en-GB\\\", { day: \\\"numeric\\\", month: \\\"short\\\" });\\n\\n  return (\\n    <div className={`flex items-start gap-3 rounded-lg border border-border/40 bg-card/20 p-3 ${event.severity === \\\"critical\\\" ? \\\"border-red-400/30\\\" : event.severity === \\\"warning\\\" ? \\\"border-amber-400/20\\\" : \\\"\\\"}`}>\\n      <div className={`rounded-md p-1.5 ${cfg.bg} shrink-0 mt-0.5`}>\\n        <Icon className={`h-3.5 w-3.5 ${cfg.color}`} />\\n      </div>\\n      <div className=\\\"min-w-0 flex-1\\\">\\n        <div className=\\\"flex items-start justify-between gap-2\\\">\\n          <span className=\\\"text-sm font-medium leading-tight\\\">{event.title}</span>\\n          <span className=\\\"text-[10px] font-mono text-muted-foreground/50 shrink-0\\\">{dateStr} {timeStr}</span>\\n        </div>\\n        {event.description && event.description !== event.title && (\\n          <p className=\\\"mt-0.5 text-xs text-muted-foreground/70 leading-snug\\\">{event.description}</p>\\n        )}\\n        <div className=\\\"mt-1 flex items-center gap-2 text-[10px] text-muted-foreground/50\\\">\\n          {event.actor && <span>{event.actor}</span>}\\n          {event.entityId && event.entityUrl && (\\n            <a href={event.entityUrl} className=\\\"flex items-center gap-0.5 hover:text-violet transition-colors\\\">\\n              <ArrowRight className=\\\"h-2.5 w-2.5\\\" />\\n              {event.entityId}\\n            </a>\\n          )}\\n          {event.metadata?.severity && (\\n            <span className=\\\"font-mono\\\">{event.metadata.severity}</span>\\n          )}\\n        </div>\\n      </div>\\n    </div>\\n  );\\n}\\n\\nfunction TimelinePage() {\\n  const { events, summary } = Route.useLoaderData() as {\\n    events: TimelineEvent[];\\n    summary: ReturnType<typeof getTimelineSummary>;\\n  };\\n  const [sourceFilter, setSourceFilter] = useState<string>(\\\"all\\\");\\n\\n  const filtered = useMemo(() => {\\n    if (sourceFilter === \\\"all\\\") return events;\\n    return events.filter((e) => e.source === sourceFilter);\\n  }, [events, sourceFilter]);\\n\\n  // Group by date\\n  const grouped = useMemo(() => {\\n    const groups: Record<string, TimelineEvent[]> = {};\\n    for (const e of filtered) {\\n      const date = new Date(e.ts).toLocaleDateString(\\\"en-GB\\\", { day: \\\"numeric\\\", month: \\\"short\\\", year: \\\"numeric\\\" });\\n      if (!groups[date]) groups[date] = [];\\n      groups[date].push(e);\\n    }\\n    return groups;\\n  }, [filtered]);\\n\\n  return (\\n    <div className=\\\"space-y-6\\\">\\n      <PageHeader\\n        title=\\\"Timeline\\\"\\n        subtitle={`${summary.total} events · ${summary.critical} critical · ${summary.warnings} warnings`}\\n        icon={<Clock className=\\\"h-5 w-5 text-violet\\\" />}\\n      />\\n\\n      {/* Source filters */}\\n      <div className=\\\"flex flex-wrap gap-2\\\">\\n        {SOURCE_FILTERS.map((f) => (\\n          <button\\n            key={f.key}\\n            onClick={() => setSourceFilter(f.key)}\\n            className={`rounded-lg border px-3 py-1.5 text-xs transition-colors ${\\n              sourceFilter === f.key\\n                ? \\\"border-violet/50 bg-violet/10 text-violet\\\"\\n                : \\\"border-border/60 bg-card/20 text-muted-foreground hover:border-border\\\"\\n            }`}\\n          >\\n            {f.label}\\n            <span className=\\\"ml-1.5 font-mono text-[10px] opacity-70\\\">\\n              {f.key === \\\"all\\\" ? summary.total : summary.bySource[f.key] || 0}\\n            </span>\\n          </button>\\n        ))}\\n      </div>\\n\\n      {/* Timeline */}\\n      <div className=\\\"space-y-6\\\">\\n        {Object.entries(grouped).map(([date, dateEvents]) => (\\n          <div key={date}>\\n            <div className=\\\"sticky top-0 z-10 bg-background/80 backdrop-blur-sm py-2 mb-3\\\">\\n              <h3 className=\\\"font-mono text-[11px] uppercase tracking-[0.18em] text-muted-foreground/70\\\">{date}</h3>\\n            </div>\\n            <div className=\\\"space-y-2 ml-2 border-l border-border/30 pl-4\\\">\\n              {dateEvents.map((event) => (\\n                <EventCard key={event.id} event={event} />\\n              ))}\\n            </div>\\n          </div>\\n        ))}\\n      </div>\\n\\n      {filtered.length === 0 && (\\n        <div className=\\\"text-center py-12 text-muted-foreground/50 text-sm\\\">\\n          No events match the current filter\\n        </div>\\n      )}\\n    </div>\\n  );\\n}\\n\"}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":2422,"output":1946,"cacheRead":155520,"cacheWrite":0,"reasoningTokens":0,"totalTokens":159888,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780522082279,"responseId":"gen-1780522082-nhIOoMgTfFaUSK9RZYxy"}}
