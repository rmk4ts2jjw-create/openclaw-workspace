{"type":"message","id":"e19368a5","parentId":"3be9c361","timestamp":"2026-06-03T23:18:04.680Z","message":{"role":"assistant","content":[{"type":"text","text":"The 2 MITIGATING incidents are old (999 days — likely bad timestamps) with stale timeline entries. They're abandoned. Let me execute the full cleanup now:"},{"type":"toolCall","id":"38aab4a8-9d25-49e8-82d2-909910cdb8fa","name":"exec","arguments":{"command":"python3 << 'PYEOF'\nimport json\nfrom datetime import datetime, timezone\nimport os\n\nincidents_file = \"/Users/spacemonkey/.openclaw/workspace/data/incidents.json\"\ntasks_file = \"/Users/spacemonkey/.openclaw/workspace/data/tasks.json\"\narchive_file = \"/Users/spacemonkey/.openclaw/workspace/data/tasks-archive.json\"\n\nwith open(incidents_file) as f:\n    incidents = json.load(f)\nwith open(tasks_file) as f:\n    tasks = json.load(f)\n\nall_tasks = tasks[:]\nif os.path.exists(archive_file):\n    with open(archive_file) as f:\n        all_tasks.extend(json.load(f))\n\nnow = datetime.now(timezone.utc)\nclose_old_days = 5\n\nresolved_count = 0\nclosed_count = 0\n\nfor inc in incidents:\n    if inc['status'] == 'RESOLVED':\n        continue\n    \n    # Find linked tasks\n    linked = [t for t in all_tasks if t.get('linkedIncidentId') == inc['id']]\n    done_linked = [t for t in linked if t.get('status') == 'done']\n    \n    if done_linked:\n        # Case 1: linked task is done → resolve\n        inc['status'] = 'RESOLVED'\n        inc['resolvedAt'] = now.isoformat()\n        timeline = inc.get('timeline', [])\n        timeline.append({\n            'ts': now.isoformat(),\n            'message': f\"Incident auto-resolved: linked task \\\"{done_linked[0].get('title', done_linked[0]['id'])}\\\" completed\",\n            'actor': 'system'\n        })\n        inc['timeline'] = timeline\n        inc['lastActivity'] = now.isoformat()\n        resolved_count += 1\n        print(f\"✅ RESOLVED {inc['id']}: {inc['title'][:50]}\")\n    elif len(linked) == 0:\n        # Case 2: no linked tasks — check age\n        try:\n            opened = datetime.fromisoformat(inc['opened'].replace('Z', '+00:00'))\n            age_days = (now - opened).days\n        except:\n            age_days = 999  # bad timestamp = old\n        \n        if age_days >= close_old_days:\n            inc['status'] = 'RESOLVED'\n            inc['resolvedAt'] = now.isoformat()\n            timeline = inc.get('timeline', [])\n            timeline.append({\n                'ts': now.isoformat(),\n                'message': f\"Incident auto-closed: no linked task, {age_days} days old\",\n                'actor': 'system'\n            })\n            inc['timeline'] = timeline\n            inc['lastActivity'] = now.isoformat()\n            closed_count += 1\n            print(f\"🗑️ CLOSED {inc['id']}: {inc['title'][:50]} ({age_days}d old)\")\n\nwith open(incidents_file, 'w') as f:\n    json.dump(incidents, f, indent=2)\n\n# Count remaining\nremaining = [i for i in incidents if i['status'] != 'RESOLVED']\nstatus_counts = {}\nfor i in remaining:\n    status_counts[i['status']] = status_counts.get(i['status'], 0) + 1\n\nprint(f\"\\n=== Cleanup Complete ===\")\nprint(f\"  Resolved (linked task done): {resolved_count}\")\nprint(f\"  Closed (old, no linked task): {closed_count}\")\nprint(f\"  Remaining open: {len(remaining)}\")\nfor s, c in sorted(status_counts.items()):\n    print(f\"    {s}: {c}\")\nfor i in remaining:\n    print(f\"    {i['id']}: {i['title'][:50]} ({i['status']})\")\nPYEOF","timeout":5},"partialArgs":"{\"command\": \"python3 << 'PYEOF'\\nimport json\\nfrom datetime import datetime, timezone\\nimport os\\n\\nincidents_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/incidents.json\\\"\\ntasks_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/tasks.json\\\"\\narchive_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/tasks-archive.json\\\"\\n\\nwith open(incidents_file) as f:\\n    incidents = json.load(f)\\nwith open(tasks_file) as f:\\n    tasks = json.load(f)\\n\\nall_tasks = tasks[:]\\nif os.path.exists(archive_file):\\n    with open(archive_file) as f:\\n        all_tasks.extend(json.load(f))\\n\\nnow = datetime.now(timezone.utc)\\nclose_old_days = 5\\n\\nresolved_count = 0\\nclosed_count = 0\\n\\nfor inc in incidents:\\n    if inc['status'] == 'RESOLVED':\\n        continue\\n    \\n    # Find linked tasks\\n    linked = [t for t in all_tasks if t.get('linkedIncidentId') == inc['id']]\\n    done_linked = [t for t in linked if t.get('status') == 'done']\\n    \\n    if done_linked:\\n        # Case 1: linked task is done → resolve\\n        inc['status'] = 'RESOLVED'\\n        inc['resolvedAt'] = now.isoformat()\\n        timeline = inc.get('timeline', [])\\n        timeline.append({\\n            'ts': now.isoformat(),\\n            'message': f\\\"Incident auto-resolved: linked task \\\\\\\"{done_linked[0].get('title', done_linked[0]['id'])}\\\\\\\" completed\\\",\\n            'actor': 'system'\\n        })\\n        inc['timeline'] = timeline\\n        inc['lastActivity'] = now.isoformat()\\n        resolved_count += 1\\n        print(f\\\"✅ RESOLVED {inc['id']}: {inc['title'][:50]}\\\")\\n    elif len(linked) == 0:\\n        # Case 2: no linked tasks — check age\\n        try:\\n            opened = datetime.fromisoformat(inc['opened'].replace('Z', '+00:00'))\\n            age_days = (now - opened).days\\n        except:\\n            age_days = 999  # bad timestamp = old\\n        \\n        if age_days >= close_old_days:\\n            inc['status'] = 'RESOLVED'\\n            inc['resolvedAt'] = now.isoformat()\\n            timeline = inc.get('timeline', [])\\n            timeline.append({\\n                'ts': now.isoformat(),\\n                'message': f\\\"Incident auto-closed: no linked task, {age_days} days old\\\",\\n                'actor': 'system'\\n            })\\n            inc['timeline'] = timeline\\n            inc['lastActivity'] = now.isoformat()\\n            closed_count += 1\\n            print(f\\\"🗑️ CLOSED {inc['id']}: {inc['title'][:50]} ({age_days}d old)\\\")\\n\\nwith open(incidents_file, 'w') as f:\\n    json.dump(incidents, f, indent=2)\\n\\n# Count remaining\\nremaining = [i for i in incidents if i['status'] != 'RESOLVED']\\nstatus_counts = {}\\nfor i in remaining:\\n    status_counts[i['status']] = status_counts.get(i['status'], 0) + 1\\n\\nprint(f\\\"\\\\n=== Cleanup Complete ===\\\")\\nprint(f\\\"  Resolved (linked task done): {resolved_count}\\\")\\nprint(f\\\"  Closed (old, no linked task): {closed_count}\\\")\\nprint(f\\\"  Remaining open: {len(remaining)}\\\")\\nfor s, c in sorted(status_counts.items()):\\n    print(f\\\"    {s}: {c}\\\")\\nfor i in remaining:\\n    print(f\\\"    {i['id']}: {i['title'][:50]} ({i['status']})\\\")\\nPYEOF\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":615,"output":869,"cacheRead":89728,"cacheWrite":0,"reasoningTokens":0,"totalTokens":91212,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780528656517,"responseId":"gen-1780528656-r3DCfbrqgL8iG8qZEm0r"}}
