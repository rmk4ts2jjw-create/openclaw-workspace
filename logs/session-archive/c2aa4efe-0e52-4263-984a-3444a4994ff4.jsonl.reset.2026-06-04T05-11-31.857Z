{"type":"message","id":"58ff9d86","parentId":"adccef0a","timestamp":"2026-06-03T22:23:08.224Z","message":{"role":"assistant","content":[{"type":"text","text":"\n\nLet me run through the heartbeat checks."},{"type":"toolCall","id":"2fff23e4-0234-4dd9-9616-226f3fb0a52c","name":"exec","arguments":{"command":"curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/","timeout":5},"partialArgs":"{\"command\": \"curl -s -o /dev/null -w \\\"%{http_code}\\\" http://localhost:3000/\", \"timeout\": 5}"},{"type":"toolCall","id":"ab1cb896-5393-446b-bb0b-aafcb7f9dd61","name":"exec","arguments":{"command":"python3 << 'PYEOF'\nimport json\nfrom datetime import datetime, timezone\n\ntasks_file = \"/Users/spacemonkey/.openclaw/workspace/data/tasks.json\"\nwith open(tasks_file) as f:\n    tasks = json.load(f)\n\nnow = datetime.now(timezone.utc)\nfrom collections import Counter\nstatus_counts = Counter(t['status'] for t in tasks)\n\nprint(\"=== Task Status ===\")\nfor s, c in sorted(status_counts.items()):\n    print(f\"  {s}: {c}\")\n\n# Check for stale in_progress\nin_progress = [t for t in tasks if t.get('status') == 'in_progress']\nif in_progress:\n    print(f\"\\n⚠️ In Progress:\")\n    for t in in_progress:\n        la = t.get('lastActivity', '')\n        age = ''\n        if la and la != 'just now':\n            try:\n                ts = datetime.fromisoformat(la.replace('Z','+00:00'))\n                age = f\" ({(now - ts).total_seconds()/60:.0f}min ago)\"\n            except:\n                age = ' (unparseable)'\n        print(f\"  {t['id']}: {t['title'][:50]}{age}\")\n        print(f\"    step: {t.get('currentStep','?')} | progress: {t.get('progress',0)}%\")\nelse:\n    print(f\"\\n✅ No in_progress tasks\")\n\n# Check for ghost dispatches\nfor t in tasks:\n    note = t.get('note', '')\n    if 'auto-dispatched' in note and t.get('status') in ('in_progress', 'backlog') and not t.get('lastActivity'):\n        print(f\"\\n🚨 GHOST: {t['id']} — {t['title'][:50]}\")\n\n# Night Shift check — is it 01:00-07:00 BST?\nhour_bst = (now.hour + 1) % 24  # UTC+1 for BST\nif 1 <= hour_bst < 7:\n    print(f\"\\n🌙 Night Shift window (BST hour: {hour_bst})\")\n    dispatchable = [t for t in tasks if t.get('status') == 'backlog' \n                    and not t.get('stalledAt') \n                    and t.get('dispatchCount', 0) < 3 \n                    and not t.get('wasStalled')\n                    and t.get('priority') in ('P2', 'P3')]\n    print(f\"   Dispatchable: {len(dispatchable)}\")\nelse:\n    print(f\"\\n☀️ Daytime (BST hour: {hour_bst}) — Night Shift inactive\")\nPYEOF","timeout":5},"partialArgs":"{\"command\": \"python3 << 'PYEOF'\\nimport json\\nfrom datetime import datetime, timezone\\n\\ntasks_file = \\\"/Users/spacemonkey/.openclaw/workspace/data/tasks.json\\\"\\nwith open(tasks_file) as f:\\n    tasks = json.load(f)\\n\\nnow = datetime.now(timezone.utc)\\nfrom collections import Counter\\nstatus_counts = Counter(t['status'] for t in tasks)\\n\\nprint(\\\"=== Task Status ===\\\")\\nfor s, c in sorted(status_counts.items()):\\n    print(f\\\"  {s}: {c}\\\")\\n\\n# Check for stale in_progress\\nin_progress = [t for t in tasks if t.get('status') == 'in_progress']\\nif in_progress:\\n    print(f\\\"\\\\n⚠️ In Progress:\\\")\\n    for t in in_progress:\\n        la = t.get('lastActivity', '')\\n        age = ''\\n        if la and la != 'just now':\\n            try:\\n                ts = datetime.fromisoformat(la.replace('Z','+00:00'))\\n                age = f\\\" ({(now - ts).total_seconds()/60:.0f}min ago)\\\"\\n            except:\\n                age = ' (unparseable)'\\n        print(f\\\"  {t['id']}: {t['title'][:50]}{age}\\\")\\n        print(f\\\"    step: {t.get('currentStep','?')} | progress: {t.get('progress',0)}%\\\")\\nelse:\\n    print(f\\\"\\\\n✅ No in_progress tasks\\\")\\n\\n# Check for ghost dispatches\\nfor t in tasks:\\n    note = t.get('note', '')\\n    if 'auto-dispatched' in note and t.get('status') in ('in_progress', 'backlog') and not t.get('lastActivity'):\\n        print(f\\\"\\\\n🚨 GHOST: {t['id']} — {t['title'][:50]}\\\")\\n\\n# Night Shift check — is it 01:00-07:00 BST?\\nhour_bst = (now.hour + 1) % 24  # UTC+1 for BST\\nif 1 <= hour_bst < 7:\\n    print(f\\\"\\\\n🌙 Night Shift window (BST hour: {hour_bst})\\\")\\n    dispatchable = [t for t in tasks if t.get('status') == 'backlog' \\n                    and not t.get('stalledAt') \\n                    and t.get('dispatchCount', 0) < 3 \\n                    and not t.get('wasStalled')\\n                    and t.get('priority') in ('P2', 'P3')]\\n    print(f\\\"   Dispatchable: {len(dispatchable)}\\\")\\nelse:\\n    print(f\\\"\\\\n☀️ Daytime (BST hour: {hour_bst}) — Night Shift inactive\\\")\\nPYEOF\", \"timeout\": 5}"}],"api":"openai-completions","provider":"openrouter","model":"openrouter/owl-alpha","usage":{"input":138953,"output":652,"cacheRead":10240,"cacheWrite":0,"reasoningTokens":0,"totalTokens":149845,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1780517544356,"responseId":"gen-1780517544-AHgALf20aD3yO33DuHJD"}}
