{"type":"message","id":"ef6633f6","parentId":"e5ec88b7","timestamp":"2026-05-21T20:00:25.280Z","message":{"role":"toolResult","toolCallId":"81e97f44-8c33-4ca4-a566-a1cf8b8647f9","toolName":"read","content":[{"type":"text","text":"// src/lib/server-data.ts\n// Server-side data functions using TanStack Start createServerFn.\n// These run ONLY on the server and can safely access the filesystem.\n\nimport { createServerFn } from \"@tanstack/react-start\";\nimport { readFileSync, existsSync, readdirSync, statSync } from \"node:fs\";\nimport { join } from \"node:path\";\n\nconst WORKSPACE = process.env.OPENCLAW_WORKSPACE || \"/Users/spacemonkey/.openclaw/workspace\";\nconst OPENCLAW_DIR = process.env.OPENCLAW_DIR || \"/Users/spacemonkey/.openclaw\";\n\nfunction readFileOrNull(path: string): string | null {\n  try {\n    if (!existsSync(path)) return null;\n    return readFileSync(path, \"utf-8\");\n  } catch {\n    return null;\n  }\n}\n\nfunction readJsonOrNull<T>(path: string): T | null {\n  const raw = readFileOrNull(path);\n  if (!raw) return null;\n  try {\n    return JSON.parse(raw) as T;\n  } catch {\n    return null;\n  }\n}\n\nfunction formatBytes(bytes: number): string {\n  if (bytes === 0) return \"0 B\";\n  const k = 1024;\n  const sizes = [\"B\", \"KB\", \"MB\", \"GB\", \"TB\"];\n  const i = Math.floor(Math.log(bytes) / Math.log(k));\n  return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + \" \" + sizes[i];\n}\n\nfunction extractTitle(md: string): string {\n  const h1 = md.match(/^#\\s+(.+)/m);\n  if (h1) return h1[1].replace(/<!--.*?>/g, \"\").trim();\n  const h2 = md.match(/^##\\s+(.+)/m);\n  if (h2) return h2[1].replace(/<!--.*?>/g, \"\").trim();\n  return \"Untitled\";\n}\n\n// ── Tasks ──────────────────────────────────────────────────────────────────────\n\nexport interface Task {\n  id: string;\n  title: string;\n  assignee: string;\n  status: \"backlog\" | \"in_progress\" | \"awaiting_review\" | \"done\";\n  priority: \"P1\" | \"P2\" | \"P3\" | \"P4\";\n  ts: string;\n  note?: string;\n  lastUpdated?: string;\n  startedAt?: string;\n  completedAt?: string;\n  progress?: number;\n\n[956 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1779393625279}}
