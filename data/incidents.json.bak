  {
    "id": "INC-001",
    "title": "Cron job drift \u2014 daily heartbeat running 3 hours late",
    "severity": "P3",
    "status": "RESOLVED",
    "owner": "lifesupport",
    "opened": "2026-05-12 06:00",
    "summary": "The daily heartbeat cron job was scheduled for 03:00 but is consistently firing around 06:00. The gateway sleep/wake cycle is shifting the effective trigger time. This causes checks to run during active hours instead of quiet hours.",
    "tags": [
      "cron",
      "scheduling",
      "heartbeat",
      "drift"
    ],
    "timeline": [
      {
        "ts": "06:00",
        "message": "Daily heartbeat fired three hours late \u2014 gap analysis initiated",
        "actor": "lifesupport"
      },
      {
        "ts": "06:10",
        "message": "Root cause: gateway sleep shifts cron anchorMs forward on each resume",
        "actor": "engineer"
      },
      {
        "ts": "06:30",
        "message": "Proposed fix: switch to cron expr with tz instead of everyMs",
        "actor": "engineer"
      },
      {
        "ts": "2026-06-03T23:18:04.753797+00:00",
        "message": "Incident auto-closed: no linked task, 999 days old",
        "actor": "system"
      }
    ],
    "actions": [
      {
        "label": "Switch to cron expression",
        "description": "Replace everyMs schedule with cron '0 3 * * *' in Europe/London tz",
        "status": "in_progress",
        "completedAt": "2026-05-14 14:16:40",
        "completedBy": "Space Monkey"
      },
      {
        "label": "Add stagger tolerance",
        "description": "Set staggerMs to 60000 to prevent exact-time clustering",
        "status": "skipped",
        "completedAt": "2026-05-14 14:16:33",
        "completedBy": "Space Monkey"
      },
      {
        "label": "Monitor for 48h",
        "description": "Verify the fix holds over two sleep/wake cycles",
        "status": "skipped",
        "completedAt": "2026-05-14 13:57:08",
        "completedBy": "Space Monkey"
      }
    ],
    "acknowledged": true,
    "escalated": false,
    "lastActivity": "2026-06-03T23:18:04.753797+00:00",
    "resolvedAt": "2026-06-03T23:18:04.753797+00:00"
  }
